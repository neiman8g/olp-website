---
import { navigation } from '../data/navigation';
import { company } from '../data/company';
import Button from './Button.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-xl border-b border-steel-gray" id="main-header" data-pagefind-ignore>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-[80px]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0">
        <svg class="w-8 h-8 text-steel-blue" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <span class="font-display font-bold text-[28px] text-near-black tracking-tight">ONLINE <span class="text-steel-blue">POWER</span></span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        <!-- Products Dropdown -->
        <div class="relative" data-dropdown>
          <button
            class="px-2.5 py-2 text-[13px] font-display font-bold uppercase tracking-[0.08em] text-slate hover:text-near-black transition-colors flex items-center gap-1"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="dropdown-products"
            data-dropdown-trigger
          >
            Products
            <svg class="w-4 h-4 transition-transform" data-dropdown-chevron fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div
            class="absolute left-0 top-full pt-3 opacity-0 invisible transition-all duration-200"
            id="dropdown-products"
            role="menu"
            data-dropdown-menu
          >
            <div class="bg-deep-navy border border-navy-mid rounded-lg py-3 w-[440px] max-h-[76vh] overflow-y-auto shadow-2xl shadow-near-black/30">
              <div class="px-5 pb-2">
                <p class="font-display text-[10px] font-bold uppercase tracking-[0.18em] text-sky-blue">Products</p>
              </div>
              {navigation.products.map(item => (
                <a href={item.href} role="menuitem" tabindex="-1" class="block px-5 py-2.5 hover:bg-navy-mid transition-colors">
                  <span class="font-display font-semibold text-[15px] text-white">{item.name}</span>
                  <span class="block text-[12px] text-muted-blue mt-0.5">{item.description}</span>
                </a>
              ))}

              <!-- Divider + Services group -->
              <div class="border-t border-navy-mid mt-3 pt-3">
                <div class="px-5 pb-2">
                  <p class="font-display text-[10px] font-bold uppercase tracking-[0.18em] text-sky-blue">Services &amp; Solutions</p>
                </div>
                {navigation.services.map(item => (
                  <a href={item.href} role="menuitem" tabindex="-1" class="block px-5 py-2.5 hover:bg-navy-mid transition-colors">
                    <span class="font-display font-semibold text-[15px] text-white">{item.name}</span>
                    <span class="block text-[12px] text-muted-blue mt-0.5">{item.description}</span>
                  </a>
                ))}
              </div>

              <div class="border-t border-navy-mid mt-3 pt-3 px-5 pb-1">
                <a href="/products/" role="menuitem" tabindex="-1" class="font-display font-bold text-[13px] text-steel-blue hover:text-white transition-colors uppercase tracking-[0.08em]">All Products →</a>
              </div>
            </div>
          </div>
        </div>

        <a href="/training/" class="px-2.5 py-2 text-[13px] font-display font-bold uppercase tracking-[0.08em] text-slate hover:text-near-black transition-colors">Training</a>

        <!-- Company Dropdown -->
        <div class="relative" data-dropdown>
          <button
            class="px-2.5 py-2 text-[13px] font-display font-bold uppercase tracking-[0.08em] text-slate hover:text-near-black transition-colors flex items-center gap-1"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="dropdown-company"
            data-dropdown-trigger
          >
            Company
            <svg class="w-4 h-4 transition-transform" data-dropdown-chevron fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div
            class="absolute left-0 top-full pt-3 opacity-0 invisible transition-all duration-200"
            id="dropdown-company"
            role="menu"
            data-dropdown-menu
          >
            <div class="bg-deep-navy border border-navy-mid rounded-lg py-3 w-[260px] shadow-2xl shadow-near-black/30">
              {navigation.company.map(item => (
                <a href={item.href} role="menuitem" tabindex="-1" class="block px-5 py-2.5 hover:bg-navy-mid transition-colors font-display font-semibold text-[14px] text-white">{item.name}</a>
              ))}
            </div>
          </div>
        </div>

        <a href="/support/documents" class="px-2.5 py-2 text-[13px] font-display font-bold uppercase tracking-[0.08em] text-slate hover:text-near-black transition-colors">Documents</a>
        <a href="https://800pwrsrvc.com/" target="_blank" rel="noopener" class="px-2.5 py-2 text-[13px] font-display font-bold uppercase tracking-[0.08em] text-slate hover:text-near-black transition-colors inline-flex items-center gap-1">
          Power Services
          <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
        </a>
      </nav>

      <!-- CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <button onclick="window.openSearch()" data-search-trigger class="p-2 text-slate hover:text-steel-blue transition-colors" aria-label="Search products">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>
        <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="text-[14px] text-near-black hover:text-steel-blue transition-colors font-display font-bold whitespace-nowrap">{company.phone}</a>
        <Button href="/contact/" variant="outline" size="sm">Request a Quote</Button>
      </div>

      <!-- Mobile: Search + Menu -->
      <div class="lg:hidden flex items-center gap-1">
        <button onclick="window.openSearch()" data-search-trigger class="p-2 text-slate hover:text-steel-blue transition-colors" aria-label="Search products">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>
        <button class="p-2 text-slate hover:text-near-black" id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false">
          <svg class="w-6 h-6" id="menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path></svg>
          <svg class="w-6 h-6 hidden" id="menu-icon-close" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
    </div>
  </div>


</header>

<!-- Mobile Menu (outside header to avoid clipping) -->
<div class="hidden lg:hidden" id="mobile-menu" style="position:fixed;top:80px;left:0;right:0;bottom:0;z-index:9999;background:#F8F9FB;overflow-y:auto;">
  <div class="px-4 py-5 space-y-2.5">
    <!-- Products accordion — dark panel when open -->
    <div class="rounded-xl overflow-hidden border border-steel-gray bg-white has-[.is-open]:border-steel-blue has-[.is-open]:shadow-[0_14px_32px_-12px_rgba(37,103,194,0.3)] transition-all">
      <button class="mobile-accordion-btn group flex justify-between items-center w-full py-4 px-4 text-left font-display font-bold uppercase tracking-[0.08em] text-[13px] text-near-black aria-expanded:bg-deep-navy aria-expanded:text-white transition-colors" aria-controls="mobile-products" aria-expanded="false">
        <span class="flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-steel-blue/10 group-aria-expanded:bg-sky-blue/20 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-steel-blue group-aria-expanded:text-sky-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </span>
          Products
        </span>
        <svg class="w-5 h-5 text-slate group-aria-expanded:text-sky-blue group-aria-expanded:rotate-180 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="hidden mobile-accordion-content relative overflow-hidden" id="mobile-products">
        <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 24px 24px;"></div>
        <div class="absolute -top-20 -right-20 w-[260px] h-[260px] pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.35) 0%, rgba(37,103,194,0) 70%); filter: blur(8px);"></div>
        <div class="relative bg-deep-navy py-1">
          <p class="px-4 pt-3 pb-2 font-display text-[10px] font-bold uppercase tracking-[0.2em] text-sky-blue">Products</p>
          {navigation.products.map(item => (
            <a href={item.href} class="group flex items-start gap-3 px-4 py-3 hover:bg-navy-mid transition-colors border-t border-navy-mid/60">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-sky-blue/60 group-hover:bg-sky-blue flex-shrink-0"></span>
              <span class="flex-1 min-w-0">
                <span class="block font-display font-semibold text-[14px] text-white group-hover:text-sky-blue transition-colors">{item.name}</span>
                {item.description && <span class="block text-[12px] text-muted-blue mt-0.5 leading-snug">{item.description}</span>}
              </span>
              <svg class="w-3.5 h-3.5 text-muted-blue/50 group-hover:text-sky-blue transition-colors flex-shrink-0 mt-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
            </a>
          ))}
          <p class="px-4 pt-4 pb-2 mt-2 font-display text-[10px] font-bold uppercase tracking-[0.2em] text-sky-blue border-t border-navy-mid/60">Services &amp; Solutions</p>
          {navigation.services.map(item => (
            <a href={item.href} class="group flex items-start gap-3 px-4 py-3 hover:bg-navy-mid transition-colors border-t border-navy-mid/60">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-sky-blue/60 group-hover:bg-sky-blue flex-shrink-0"></span>
              <span class="flex-1 min-w-0">
                <span class="block font-display font-semibold text-[14px] text-white group-hover:text-sky-blue transition-colors">{item.name}</span>
                {item.description && <span class="block text-[12px] text-muted-blue mt-0.5 leading-snug">{item.description}</span>}
              </span>
              <svg class="w-3.5 h-3.5 text-muted-blue/50 group-hover:text-sky-blue transition-colors flex-shrink-0 mt-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
            </a>
          ))}
          <a href="/products/" class="flex items-center justify-between py-3 px-4 mt-1 border-t border-navy-mid/60 font-display font-bold text-[12px] uppercase tracking-[0.14em] text-sky-blue hover:text-white hover:bg-navy-mid transition-colors">
            <span>All Products</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Training (flat card) -->
    <a href="/training/" class="group flex items-center gap-3 py-4 px-4 rounded-xl bg-white border border-steel-gray hover:border-steel-blue hover:shadow-[0_8px_20px_-10px_rgba(37,103,194,0.3)] transition-all font-display font-bold uppercase tracking-[0.08em] text-[13px] text-near-black">
      <span class="w-8 h-8 rounded-lg bg-steel-blue/10 flex items-center justify-center group-hover:bg-steel-blue group-hover:text-white transition-colors">
        <svg class="w-4 h-4 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
      </span>
      <span class="flex-1 group-hover:text-steel-blue transition-colors">Training</span>
      <svg class="w-4 h-4 text-slate/40 group-hover:text-steel-blue group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
    </a>

    <!-- Company accordion -->
    <div class="rounded-xl overflow-hidden border border-steel-gray bg-white has-[.is-open]:border-steel-blue has-[.is-open]:shadow-[0_14px_32px_-12px_rgba(37,103,194,0.3)] transition-all">
      <button class="mobile-accordion-btn group flex justify-between items-center w-full py-4 px-4 text-left font-display font-bold uppercase tracking-[0.08em] text-[13px] text-near-black aria-expanded:bg-deep-navy aria-expanded:text-white transition-colors" aria-controls="mobile-company" aria-expanded="false">
        <span class="flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-steel-blue/10 group-aria-expanded:bg-sky-blue/20 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-steel-blue group-aria-expanded:text-sky-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </span>
          Company
        </span>
        <svg class="w-5 h-5 text-slate group-aria-expanded:text-sky-blue group-aria-expanded:rotate-180 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="hidden mobile-accordion-content relative overflow-hidden" id="mobile-company">
        <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 24px 24px;"></div>
        <div class="absolute -top-20 -right-20 w-[260px] h-[260px] pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.35) 0%, rgba(37,103,194,0) 70%); filter: blur(8px);"></div>
        <div class="relative bg-deep-navy py-1">
          {navigation.company.map(item => (
            <a href={item.href} class="group flex items-center gap-3 px-4 py-3 hover:bg-navy-mid transition-colors border-t border-navy-mid/60 first:border-t-0">
              <span class="w-1 h-1 rounded-full bg-sky-blue/60 group-hover:bg-sky-blue flex-shrink-0"></span>
              <span class="flex-1 font-display font-semibold text-[14px] text-white group-hover:text-sky-blue transition-colors">{item.name}</span>
              <svg class="w-3.5 h-3.5 text-muted-blue/50 group-hover:text-sky-blue transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Documents -->
    <a href="/support/documents" class="group flex items-center gap-3 py-4 px-4 rounded-xl bg-white border border-steel-gray hover:border-steel-blue hover:shadow-[0_8px_20px_-10px_rgba(37,103,194,0.3)] transition-all font-display font-bold uppercase tracking-[0.08em] text-[13px] text-near-black">
      <span class="w-8 h-8 rounded-lg bg-steel-blue/10 flex items-center justify-center group-hover:bg-steel-blue transition-colors">
        <svg class="w-4 h-4 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </span>
      <span class="flex-1 group-hover:text-steel-blue transition-colors">Documents</span>
      <svg class="w-4 h-4 text-slate/40 group-hover:text-steel-blue group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
    </a>

    <!-- Power Services (external) -->
    <a href="https://800pwrsrvc.com/" target="_blank" rel="noopener" class="group flex items-center gap-3 py-4 px-4 rounded-xl bg-white border border-steel-gray hover:border-steel-blue hover:shadow-[0_8px_20px_-10px_rgba(37,103,194,0.3)] transition-all font-display font-bold uppercase tracking-[0.08em] text-[13px] text-near-black">
      <span class="w-8 h-8 rounded-lg bg-steel-blue/10 flex items-center justify-center group-hover:bg-steel-blue transition-colors">
        <svg class="w-4 h-4 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
      </span>
      <span class="flex-1 group-hover:text-steel-blue transition-colors">Power Services</span>
      <svg class="w-3.5 h-3.5 text-slate/40 group-hover:text-steel-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
    </a>

    <!-- Primary CTA -->
    <a href="/contact/" class="flex items-center justify-center gap-2 py-4 px-4 rounded-xl bg-steel-blue text-white font-display font-bold uppercase tracking-[0.08em] text-[13px] hover:bg-steel-blue/90 transition-colors shadow-[0_8px_24px_-8px_rgba(37,103,194,0.5)] mt-4">
      Request a Quote
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
    </a>

    <!-- Contact strip -->
    <div class="pt-6 mt-4 border-t border-steel-gray space-y-4">
      <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="flex items-center gap-3 group">
        <span class="w-8 h-8 rounded-lg bg-steel-blue/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </span>
        <div>
          <p class="font-display text-[10px] font-bold uppercase tracking-[0.16em] text-slate">Call</p>
          <p class="font-display text-[17px] font-bold text-near-black group-hover:text-steel-blue transition-colors">{company.phone}</p>
        </div>
      </a>
      <a href={`mailto:${company.email}`} class="flex items-center gap-3 group">
        <span class="w-8 h-8 rounded-lg bg-steel-blue/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </span>
        <div>
          <p class="font-display text-[10px] font-bold uppercase tracking-[0.16em] text-slate">Email</p>
          <p class="text-[14px] text-near-black group-hover:text-steel-blue transition-colors">{company.email}</p>
        </div>
      </a>
    </div>
  </div>
</div>

<!-- Spacer for fixed header -->
<div class="h-[80px]"></div>

<script>
  // ===== MOBILE MENU =====
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    document.body.style.overflow = isOpen ? '' : 'hidden';
    menuBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Mobile accordion — only one open at a time
  const mobileAccordionBtns = document.querySelectorAll('.mobile-accordion-btn');
  mobileAccordionBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const icon = btn.querySelector('svg');
      const willOpen = content?.classList.contains('hidden');

      // Close any currently-open accordion first
      mobileAccordionBtns.forEach(other => {
        if (other === btn) return;
        const otherContent = other.nextElementSibling;
        const otherIcon = other.querySelector('svg');
        otherContent?.classList.add('hidden');
        otherIcon?.classList.remove('rotate-180');
        other.setAttribute('aria-expanded', 'false');
        other.classList.remove('is-open');
      });

      // Toggle the clicked one
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
      btn.setAttribute('aria-expanded', String(willOpen));
      btn.classList.toggle('is-open', willOpen);
    });
  });

  // Close mobile menu on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu && !mobileMenu.classList.contains('hidden')) {
      mobileMenu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      document.body.style.overflow = '';
      menuBtn?.setAttribute('aria-expanded', 'false');
      menuBtn?.focus();
    }
  });

  // ===== DESKTOP DROPDOWNS =====
  const dropdowns = document.querySelectorAll('[data-dropdown]');

  function closeAllDropdowns(except) {
    dropdowns.forEach(dd => {
      if (dd === except) return;
      const trigger = dd.querySelector('[data-dropdown-trigger]');
      const menu = dd.querySelector('[data-dropdown-menu]');
      const chevron = dd.querySelector('[data-dropdown-chevron]');
      if (menu) {
        menu.classList.add('opacity-0', 'invisible');
        menu.classList.remove('opacity-100', 'visible');
      }
      if (trigger) trigger.setAttribute('aria-expanded', 'false');
      if (chevron) chevron.classList.remove('rotate-180');
    });
  }

  function openDropdown(dd) {
    const trigger = dd.querySelector('[data-dropdown-trigger]');
    const menu = dd.querySelector('[data-dropdown-menu]');
    const chevron = dd.querySelector('[data-dropdown-chevron]');
    if (menu) {
      menu.classList.remove('opacity-0', 'invisible');
      menu.classList.add('opacity-100', 'visible');
    }
    if (trigger) trigger.setAttribute('aria-expanded', 'true');
    if (chevron) chevron.classList.add('rotate-180');
  }

  function isDropdownOpen(dd) {
    const trigger = dd.querySelector('[data-dropdown-trigger]');
    return trigger?.getAttribute('aria-expanded') === 'true';
  }

  let closeTimer = null;

  dropdowns.forEach(dd => {
    const trigger = dd.querySelector('[data-dropdown-trigger]');
    const menu = dd.querySelector('[data-dropdown-menu]');

    // Hover open (desktop)
    dd.addEventListener('mouseenter', () => {
      clearTimeout(closeTimer);
      closeAllDropdowns(dd);
      openDropdown(dd);
    });

    // Hover close with small delay (prevents flicker when moving to submenu)
    dd.addEventListener('mouseleave', () => {
      closeTimer = setTimeout(() => {
        closeAllDropdowns();
      }, 150);
    });

    // Click also works (for touch-screen laptops)
    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (isDropdownOpen(dd)) {
        closeAllDropdowns();
      } else {
        closeAllDropdowns();
        openDropdown(dd);
      }
    });

    // Keyboard navigation inside menu
    menu?.addEventListener('keydown', (e) => {
      const items = Array.from(menu.querySelectorAll('[role="menuitem"]'));
      const currentIndex = items.indexOf(document.activeElement);

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        const next = currentIndex < items.length - 1 ? currentIndex + 1 : 0;
        items[next]?.focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        const prev = currentIndex > 0 ? currentIndex - 1 : items.length - 1;
        items[prev]?.focus();
      } else if (e.key === 'Escape') {
        e.preventDefault();
        closeAllDropdowns();
        trigger?.focus();
      } else if (e.key === 'Tab') {
        closeAllDropdowns();
      }
    });

    // ArrowDown on trigger opens dropdown AND focuses first item
    trigger?.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (!isDropdownOpen(dd)) {
          closeAllDropdowns();
          openDropdown(dd);
        }
        const firstItem = menu?.querySelector('[role="menuitem"]');
        firstItem?.focus();
      }
    });

    // Click also focuses first item (keyboard users)
    trigger?.addEventListener('click', () => {
      if (isDropdownOpen(dd)) {
        const firstItem = menu?.querySelector('[role="menuitem"]');
        if (document.activeElement === trigger) firstItem?.focus();
      }
    });
  });

  // Click outside closes all
  document.addEventListener('click', () => {
    closeAllDropdowns();
  });

  // Prevent dropdown click from bubbling to document
  dropdowns.forEach(dd => {
    dd.addEventListener('click', (e) => e.stopPropagation());
  });
</script>
