---
import { company } from '../data/company';
import { social } from '../data/social';
import { navigation } from '../data/navigation';

const year = new Date().getFullYear();
---

<footer class="bg-obsidian border-t border-steel/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Products -->
      <div>
        <h3 class="font-mono text-xs uppercase tracking-widest text-voltage mb-5">Products</h3>
        <ul class="space-y-2.5">
          {navigation.products.map(item => (
            <li><a href={item.href} class="text-sm text-ash hover:text-pure transition-colors">{item.name}</a></li>
          ))}
          <li><a href="/products/" class="text-sm text-voltage hover:text-pure font-medium">All Products &rarr;</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="font-mono text-xs uppercase tracking-widest text-voltage mb-5">Support</h3>
        <ul class="space-y-2.5">
          {navigation.support.map(item => (
            <li><a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener' : undefined} class="text-sm text-ash hover:text-pure transition-colors">{item.name}</a></li>
          ))}
          <li><a href="/training/" class="text-sm text-ash hover:text-pure transition-colors">Product Training</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-mono text-xs uppercase tracking-widest text-voltage mb-5">Company</h3>
        <ul class="space-y-2.5">
          {navigation.company.map(item => (
            <li><a href={item.href} class="text-sm text-ash hover:text-pure transition-colors">{item.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-mono text-xs uppercase tracking-widest text-voltage mb-5">Contact</h3>
        <ul class="space-y-3">
          <li>
            <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="text-sm text-ash hover:text-voltage transition-colors font-mono">{company.phone}</a>
          </li>
          <li>
            <a href={`mailto:${company.email}`} class="text-sm text-ash hover:text-voltage transition-colors">{company.email}</a>
          </li>
        </ul>
        <!-- Social Links -->
        <div class="flex items-center gap-3 mt-6">
          <a href={social.instagram} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg border border-steel/50 flex items-center justify-center text-ash hover:text-voltage hover:border-voltage/50 transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg border border-steel/50 flex items-center justify-center text-ash hover:text-voltage hover:border-voltage/50 transition-colors" aria-label="LinkedIn">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
      <div class="flex flex-col items-center gap-3">
        <p class="font-mono text-sm text-ash tracking-wide">{company.tagline}</p>
        <div class="flex items-center gap-4">
          <p class="text-xs text-ash/60">&copy; {year} {company.legalName}</p>
          <a href="/privacy-policy/" class="text-xs text-ash/60 hover:text-ash transition-colors">Privacy</a>
          <a href="/terms/" class="text-xs text-ash/60 hover:text-ash transition-colors">Terms</a>
        </div>
      </div>
    </div>
  </div>
</footer>
