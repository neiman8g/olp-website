---
/**
 * CustomOEM.astro
 * SVG illustration showing a "Spec → Engineer → Build" journey for the
 * Custom OEM section. Three phases flow left to right: customer blueprint
 * spec, OLP engineering processing, and finished manufactured product.
 */
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 500 300"
  fill="none"
  role="img"
  aria-label="Custom OEM journey: your specification flows through OLP engineering into a manufactured power solution"
  class="custom-oem-illustration"
>
  <defs>
    <style>
      /* Fonts inherited from BaseLayout */

      .font-display { font-family: 'Barlow Condensed', sans-serif; }
      .font-mono { font-family: 'DM Sans', sans-serif; }

      /* ===== PHASE 1: BLUEPRINT DRAW-IN ===== */
      @keyframes drawLine {
        from { stroke-dashoffset: 200; }
        to   { stroke-dashoffset: 0; }
      }
      @keyframes drawLineShort {
        from { stroke-dashoffset: 80; }
        to   { stroke-dashoffset: 0; }
      }
      .blueprint-draw {
        stroke-dasharray: 200;
        stroke-dashoffset: 200;
        animation: drawLine 2s ease-out forwards;
      }
      .blueprint-draw-short {
        stroke-dasharray: 80;
        stroke-dashoffset: 80;
        animation: drawLineShort 1.5s 0.5s ease-out forwards;
      }
      .blueprint-draw-d2 {
        stroke-dasharray: 80;
        stroke-dashoffset: 80;
        animation: drawLineShort 1.5s 0.8s ease-out forwards;
      }
      .blueprint-draw-d3 {
        stroke-dasharray: 80;
        stroke-dashoffset: 80;
        animation: drawLineShort 1.5s 1.1s ease-out forwards;
      }

      /* ===== PHASE 2: SCAN LINE ===== */
      @keyframes scanSweep {
        0%   { transform: translateX(0); opacity: 0; }
        10%  { opacity: 1; }
        90%  { opacity: 1; }
        100% { transform: translateX(140px); opacity: 0; }
      }
      .scan-line {
        animation: scanSweep 3s ease-in-out infinite;
      }

      /* ===== FLOW DOTS: PHASE 1 → 2 ===== */
      @keyframes flowDot12 {
        0%   { offset-distance: 0%; opacity: 0; }
        5%   { opacity: 1; }
        95%  { opacity: 1; }
        100% { offset-distance: 100%; opacity: 0; }
      }
      .flow-dot-12 {
        offset-path: path('M 160 135 C 165 135, 168 135, 175 135');
        animation: flowDot12 4s linear infinite;
      }
      .flow-dot-12-b { animation-delay: 1.3s; }
      .flow-dot-12-c { animation-delay: 2.6s; }

      /* ===== FLOW DOTS: PHASE 2 → 3 ===== */
      @keyframes flowDot23 {
        0%   { offset-distance: 0%; opacity: 0; }
        5%   { opacity: 1; }
        95%  { opacity: 1; }
        100% { offset-distance: 100%; opacity: 0; }
      }
      .flow-dot-23 {
        offset-path: path('M 330 135 C 335 135, 338 135, 345 135');
        animation: flowDot23 4s linear infinite;
        animation-delay: 1s;
      }
      .flow-dot-23-b { animation-delay: 2.3s; }
      .flow-dot-23-c { animation-delay: 3.6s; }

      /* ===== PHASE 3: PRODUCT GLOW ===== */
      @keyframes productPulse {
        0%, 100% { opacity: 0.15; }
        50%      { opacity: 0.4; }
      }
      .product-glow {
        animation: productPulse 4s ease-in-out infinite;
        animation-delay: 2s;
      }

      /* ===== GREEN CHECKMARK POP ===== */
      @keyframes checkPop {
        0%, 60% { transform: scale(0); opacity: 0; }
        75%     { transform: scale(1.3); opacity: 1; }
        85%     { transform: scale(0.9); }
        100%    { transform: scale(1); opacity: 1; }
      }
      .check-pop {
        transform-origin: center;
        animation: checkPop 4s ease-out infinite;
        animation-delay: 1.5s;
      }

      /* ===== FLOW ARROW PULSE ===== */
      @keyframes arrowPulse {
        0%, 100% { opacity: 0.4; }
        50%      { opacity: 1; }
      }
      .arrow-pulse {
        animation: arrowPulse 2s ease-in-out infinite;
      }
      .arrow-pulse-delay {
        animation: arrowPulse 2s ease-in-out infinite;
        animation-delay: 1s;
      }

      /* ===== BLUEPRINT TEXT FADE IN ===== */
      @keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      .fade-in-1 { opacity: 0; animation: fadeIn 0.6s 1.2s ease-out forwards; }
      .fade-in-2 { opacity: 0; animation: fadeIn 0.6s 1.5s ease-out forwards; }
      .fade-in-3 { opacity: 0; animation: fadeIn 0.6s 1.8s ease-out forwards; }
      .fade-in-4 { opacity: 0; animation: fadeIn 0.6s 2.1s ease-out forwards; }
    </style>

    <!-- Blueprint grid pattern -->
    <pattern id="oem-grid" width="10" height="10" patternUnits="userSpaceOnUse">
      <path d="M 10 0 L 0 0 0 10" fill="none" stroke="#7EB3F5" stroke-width="0.15" opacity="0.2"/>
    </pattern>

    <!-- Scan line gradient -->
    <linearGradient id="oem-scan-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#2567C2" stop-opacity="0"/>
      <stop offset="50%" stop-color="#2567C2" stop-opacity="0.7"/>
      <stop offset="100%" stop-color="#2567C2" stop-opacity="0"/>
    </linearGradient>

    <!-- Product glow -->
    <radialGradient id="oem-product-glow" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0%" stop-color="#34D399" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="#34D399" stop-opacity="0"/>
    </radialGradient>

    <!-- Flow arrow gradients -->
    <linearGradient id="oem-flow-12" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#7EB3F5"/>
      <stop offset="100%" stop-color="#2567C2"/>
    </linearGradient>
    <linearGradient id="oem-flow-23" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#2567C2"/>
      <stop offset="100%" stop-color="#34D399"/>
    </linearGradient>
  </defs>

  <!-- ======================================================== -->
  <!-- PHASE 1 — YOUR SPEC (x: 20–160)                          -->
  <!-- ======================================================== -->
  <g id="oem-phase1">
    <!-- Blueprint background -->
    <rect x="25" y="35" width="130" height="180" rx="3" fill="#0F2A4A" stroke="#7EB3F5" stroke-width="0.5" opacity="0.6"/>
    <rect x="25" y="35" width="130" height="180" rx="3" fill="url(#oem-grid)"/>

    <!-- Equipment outline (cabinet/enclosure) — animated draw-in -->
    <rect x="52" y="62" width="76" height="110" rx="1" fill="none" stroke="#7EB3F5" stroke-width="1.2" class="blueprint-draw" stroke-dasharray="372" style="stroke-dashoffset: 372; animation: drawLine 2s ease-out forwards;"/>

    <!-- Dashed construction lines -->
    <line x1="52" y1="55" x2="128" y2="55" stroke="#7EB3F5" stroke-width="0.4" stroke-dasharray="3 2" opacity="0.4" class="fade-in-1"/>
    <line x1="45" y1="62" x2="45" y2="172" stroke="#7EB3F5" stroke-width="0.4" stroke-dasharray="3 2" opacity="0.4" class="fade-in-1"/>

    <!-- Width dimension line (top) -->
    <g class="blueprint-draw-short">
      <line x1="55" y1="55" x2="125" y2="55" stroke="#7EB3F5" stroke-width="0.6"/>
      <line x1="55" y1="53" x2="55" y2="57" stroke="#7EB3F5" stroke-width="0.6"/>
      <line x1="125" y1="53" x2="125" y2="57" stroke="#7EB3F5" stroke-width="0.6"/>
    </g>
    <!-- Arrow heads for width -->
    <polygon points="55,55 59,53.5 59,56.5" fill="#7EB3F5" class="fade-in-1"/>
    <polygon points="125,55 121,53.5 121,56.5" fill="#7EB3F5" class="fade-in-1"/>

    <!-- Height dimension line (left) -->
    <g class="blueprint-draw-d2">
      <line x1="45" y1="65" x2="45" y2="169" stroke="#7EB3F5" stroke-width="0.6"/>
      <line x1="43" y1="65" x2="47" y2="65" stroke="#7EB3F5" stroke-width="0.6"/>
      <line x1="43" y1="169" x2="47" y2="169" stroke="#7EB3F5" stroke-width="0.6"/>
    </g>
    <!-- Arrow heads for height -->
    <polygon points="45,65 43.5,69 46.5,69" fill="#7EB3F5" class="fade-in-1"/>
    <polygon points="45,169 43.5,165 46.5,165" fill="#7EB3F5" class="fade-in-1"/>

    <!-- Annotation callouts -->
    <text x="62" y="82" class="font-mono fade-in-2" fill="#7EB3F5" font-size="6.5" opacity="0.9">480V 3&#x3A6;</text>
    <text x="62" y="102" class="font-mono fade-in-3" fill="#7EB3F5" font-size="6.5" opacity="0.9">NEMA 3R</text>
    <text x="62" y="122" class="font-mono fade-in-4" fill="#7EB3F5" font-size="6.5" opacity="0.9">200kVA</text>

    <!-- Internal detail lines (shelves/components inside cabinet) -->
    <line x1="58" y1="92" x2="122" y2="92" stroke="#7EB3F5" stroke-width="0.4" stroke-dasharray="2 3" class="fade-in-2"/>
    <line x1="58" y1="112" x2="122" y2="112" stroke="#7EB3F5" stroke-width="0.4" stroke-dasharray="2 3" class="fade-in-3"/>
    <line x1="58" y1="140" x2="122" y2="140" stroke="#7EB3F5" stroke-width="0.4" stroke-dasharray="2 3" class="fade-in-4"/>

    <!-- Title block (bottom-right corner of blueprint) -->
    <rect x="95" y="180" width="55" height="28" fill="none" stroke="#7EB3F5" stroke-width="0.5" class="fade-in-4"/>
    <line x1="95" y1="190" x2="150" y2="190" stroke="#7EB3F5" stroke-width="0.3" class="fade-in-4"/>
    <text x="100" y="188" class="font-mono fade-in-4" fill="#7EB3F5" font-size="4.5" font-weight="700">CUSTOMER</text>
    <text x="100" y="201" class="font-mono fade-in-4" fill="#7EB3F5" font-size="5.5" font-weight="700">SPEC</text>

    <!-- Phase label -->
    <text x="90" y="240" text-anchor="middle" class="font-mono" fill="#B8D4F0" font-size="6" letter-spacing="0.5">01 YOUR SPEC</text>
  </g>


  <!-- ======================================================== -->
  <!-- FLOW ARROW: PHASE 1 → PHASE 2                            -->
  <!-- ======================================================== -->
  <g id="oem-flow-1-2">
    <!-- Arrow line -->
    <line x1="158" y1="135" x2="175" y2="135" stroke="url(#oem-flow-12)" stroke-width="1.5" class="arrow-pulse"/>
    <!-- Chevron -->
    <polygon points="173,131 179,135 173,139" fill="#2567C2" class="arrow-pulse" opacity="0.8"/>

    <!-- Animated flow dots -->
    <circle r="2.5" fill="#7EB3F5" class="flow-dot-12" opacity="0"/>
    <circle r="2" fill="#7EB3F5" class="flow-dot-12 flow-dot-12-b" opacity="0"/>
    <circle r="1.8" fill="#2567C2" class="flow-dot-12 flow-dot-12-c" opacity="0"/>
  </g>


  <!-- ======================================================== -->
  <!-- PHASE 2 — OLP ENGINEERING (x: 170–330)                    -->
  <!-- ======================================================== -->
  <g id="oem-phase2">
    <!-- Engineering box background -->
    <rect x="182" y="55" width="136" height="160" rx="4" fill="#2B5580" stroke="#2567C2" stroke-width="0.8" opacity="0.85"/>

    <!-- Inner processing area -->
    <rect x="192" y="72" width="116" height="120" rx="2" fill="#0F2A4A" stroke="#2567C2" stroke-width="0.4" opacity="0.5"/>

    <!-- OLP Logo/brain center -->
    <rect x="222" y="100" width="56" height="36" rx="3" fill="#2B5580" stroke="#2567C2" stroke-width="1"/>
    <text x="250" y="122" text-anchor="middle" class="font-display" fill="#2567C2" font-size="14" font-weight="700">OLP</text>

    <!-- ENGINEERING label -->
    <text x="250" y="67" text-anchor="middle" class="font-mono" fill="#2567C2" font-size="6" font-weight="700" letter-spacing="1.5">ENGINEERING</text>

    <!-- Sine wave symbol (top-left of processing area) -->
    <path d="M 198 85 Q 204 75 210 85 Q 216 95 222 85" fill="none" stroke="#2567C2" stroke-width="0.8" opacity="0.6"/>
    <text x="198" y="99" class="font-mono" fill="#B8D4F0" font-size="4">WAVEFORM</text>

    <!-- Circuit traces connecting input to center -->
    <path d="M 192 120 L 222 120" fill="none" stroke="#2567C2" stroke-width="0.5" stroke-dasharray="3 2" opacity="0.5"/>
    <path d="M 278 120 L 308 120" fill="none" stroke="#2567C2" stroke-width="0.5" stroke-dasharray="3 2" opacity="0.5"/>
    <path d="M 192 130 L 210 130 L 210 115 L 222 115" fill="none" stroke="#2567C2" stroke-width="0.4" opacity="0.35"/>
    <path d="M 278 115 L 290 115 L 290 130 L 308 130" fill="none" stroke="#2567C2" stroke-width="0.4" opacity="0.35"/>

    <!-- Small dots at circuit junctions -->
    <circle cx="210" cy="130" r="1.2" fill="#2567C2" opacity="0.5"/>
    <circle cx="210" cy="115" r="1.2" fill="#2567C2" opacity="0.5"/>
    <circle cx="290" cy="115" r="1.2" fill="#2567C2" opacity="0.5"/>
    <circle cx="290" cy="130" r="1.2" fill="#2567C2" opacity="0.5"/>

    <!-- ISO 9001 badge -->
    <rect x="270" y="78" width="34" height="14" rx="2" fill="none" stroke="#B8D4F0" stroke-width="0.5"/>
    <text x="287" y="87" text-anchor="middle" class="font-mono" fill="#B8D4F0" font-size="4.5" font-weight="700">ISO 9001</text>

    <!-- 48 Years Experience -->
    <text x="250" y="155" text-anchor="middle" class="font-mono" fill="#B8D4F0" font-size="4.5" opacity="0.7">48 YEARS EXPERIENCE</text>

    <!-- Additional trace decoration lines -->
    <line x1="200" y1="170" x2="300" y2="170" stroke="#2567C2" stroke-width="0.3" opacity="0.2"/>
    <line x1="200" y1="175" x2="300" y2="175" stroke="#2567C2" stroke-width="0.3" opacity="0.15"/>

    <!-- Scanning line (animated) -->
    <rect x="192" y="72" width="3" height="120" fill="url(#oem-scan-grad)" class="scan-line" opacity="0.6"/>

    <!-- Phase label -->
    <text x="250" y="240" text-anchor="middle" class="font-mono" fill="#B8D4F0" font-size="6" letter-spacing="0.5">02 WE ENGINEER</text>
  </g>


  <!-- ======================================================== -->
  <!-- FLOW ARROW: PHASE 2 → PHASE 3                            -->
  <!-- ======================================================== -->
  <g id="oem-flow-2-3">
    <!-- Arrow line -->
    <line x1="322" y1="135" x2="339" y2="135" stroke="url(#oem-flow-23)" stroke-width="1.5" class="arrow-pulse-delay"/>
    <!-- Chevron -->
    <polygon points="337,131 343,135 337,139" fill="#34D399" class="arrow-pulse-delay" opacity="0.8"/>

    <!-- Animated flow dots -->
    <circle r="2.5" fill="#2567C2" class="flow-dot-23" opacity="0"/>
    <circle r="2" fill="#34D399" class="flow-dot-23 flow-dot-23-b" opacity="0"/>
    <circle r="1.8" fill="#34D399" class="flow-dot-23 flow-dot-23-c" opacity="0"/>
  </g>


  <!-- ======================================================== -->
  <!-- PHASE 3 — MANUFACTURED PRODUCT (x: 340–480)              -->
  <!-- ======================================================== -->
  <g id="oem-phase3">
    <!-- Product glow (behind cabinet) -->
    <ellipse cx="410" cy="140" rx="65" ry="80" fill="url(#oem-product-glow)" class="product-glow"/>

    <!-- Isometric cabinet — top face -->
    <polygon points="370,65 420,45 470,65 420,85" fill="#2B5580" stroke="#34D399" stroke-width="0.6" opacity="0.9"/>

    <!-- Isometric cabinet — front face -->
    <polygon points="370,65 370,185 420,205 420,85" fill="#2B5580" stroke="#34D399" stroke-width="0.6"/>

    <!-- Isometric cabinet — right side face -->
    <polygon points="420,85 420,205 470,185 470,65" fill="#2B5580" stroke="#34D399" stroke-width="0.5" opacity="0.7"/>

    <!-- Front panel details -->
    <!-- Ventilation slots -->
    <line x1="380" y1="95" x2="410" y2="105" stroke="#34D399" stroke-width="0.4" opacity="0.4"/>
    <line x1="380" y1="100" x2="410" y2="110" stroke="#34D399" stroke-width="0.4" opacity="0.4"/>
    <line x1="380" y1="105" x2="410" y2="115" stroke="#34D399" stroke-width="0.4" opacity="0.4"/>
    <line x1="380" y1="110" x2="410" y2="120" stroke="#34D399" stroke-width="0.4" opacity="0.4"/>

    <!-- Status LED -->
    <circle cx="385" cy="130" r="3" fill="#34D399" opacity="0.9"/>
    <circle cx="385" cy="130" r="5" fill="#34D399" opacity="0.15" class="product-glow"/>

    <!-- OLP logo badge on front panel -->
    <rect x="378" y="145" width="30" height="12" rx="1" fill="none" stroke="#2567C2" stroke-width="0.5" transform="skewY(14)"/>
    <text x="383" y="167" class="font-display" fill="#2567C2" font-size="6" font-weight="600" transform="skewY(14)">OLP</text>

    <!-- Front panel border line -->
    <line x1="375" y1="90" x2="415" y2="100" stroke="#34D399" stroke-width="0.3" opacity="0.3"/>
    <line x1="375" y1="180" x2="415" y2="200" stroke="#34D399" stroke-width="0.3" opacity="0.3"/>

    <!-- CUSTOM BUILT label -->
    <text x="405" y="225" text-anchor="middle" class="font-mono" fill="#34D399" font-size="5" font-weight="700" letter-spacing="0.5">CUSTOM BUILT</text>

    <!-- Green checkmark (animated pop) -->
    <g class="check-pop" transform="translate(452, 52)">
      <circle cx="0" cy="0" r="10" fill="#0F2A4A" stroke="#34D399" stroke-width="1"/>
      <path d="M -5 0 L -1.5 4 L 5 -4" fill="none" stroke="#34D399" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </g>

    <!-- MADE IN LA badge -->
    <g transform="translate(440, 190)">
      <rect x="0" y="0" width="36" height="12" rx="2" fill="#0F2A4A" stroke="#34D399" stroke-width="0.5"/>
      <text x="18" y="9" text-anchor="middle" class="font-mono" fill="#34D399" font-size="4.5" font-weight="700">MADE IN LA</text>
    </g>

    <!-- Phase label -->
    <text x="410" y="240" text-anchor="middle" class="font-mono" fill="#B8D4F0" font-size="6" letter-spacing="0.5">03 WE BUILD</text>
  </g>


  <!-- ======================================================== -->
  <!-- BOTTOM CAPTION                                            -->
  <!-- ======================================================== -->
  <line x1="20" y1="262" x2="480" y2="262" stroke="#2B5580" stroke-width="0.5"/>
  <text x="250" y="278" text-anchor="middle" class="font-mono" fill="#2B5580" font-size="5.5" letter-spacing="1">
    // CUSTOM OEM &#xB7; BUILT TO YOUR SPEC &#xB7; ISO 9001
  </text>
</svg>
