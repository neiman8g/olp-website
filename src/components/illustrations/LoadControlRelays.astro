<svg viewBox="0 0 600 360" width="100%" xmlns="http://www.w3.org/2000/svg">
  <style>
    /* ── 10-second cycle: Normal 0-30%, Dimmed 30-50%, Emergency 50-90%, Reset 90-100% ── */
    @keyframes lcr-cycle {
      0%, 100% { opacity: 1; }
    }

    /* Light glow — full brightness warm */
    @keyframes lcr-glow-full {
      0%, 28%   { opacity: 0.9; r: 38; }
      32%, 48%  { opacity: 0.35; r: 22; }
      52%, 88%  { opacity: 0.95; r: 40; }
      92%, 100% { opacity: 0.9; r: 38; }
    }

    /* Light glow color shift — warm to cyan in emergency */
    @keyframes lcr-glow-color {
      0%, 28%   { fill: #FCD34D; }
      32%, 48%  { fill: #FCD34D; }
      52%, 88%  { fill: #2A7AE2; }
      92%, 100% { fill: #FCD34D; }
    }

    /* Fixture warm fill */
    @keyframes lcr-fixture-fill {
      0%, 28%   { fill: #FBBF24; opacity: 0.9; }
      32%, 48%  { fill: #FBBF24; opacity: 0.4; }
      52%, 88%  { fill: #2A7AE2; opacity: 1; }
      92%, 100% { fill: #FBBF24; opacity: 0.9; }
    }

    /* Normal LED */
    @keyframes lcr-led-normal {
      0%, 28%   { fill: #34D399; opacity: 1; }
      32%, 48%  { fill: #34D399; opacity: 1; }
      52%, 88%  { fill: #34D399; opacity: 0.15; }
      92%, 100% { fill: #34D399; opacity: 1; }
    }

    /* Emergency LED */
    @keyframes lcr-led-emerg {
      0%, 28%   { fill: #2A7AE2; opacity: 0.15; }
      32%, 48%  { fill: #2A7AE2; opacity: 0.15; }
      52%, 88%  { fill: #2A7AE2; opacity: 1; }
      92%, 100% { fill: #2A7AE2; opacity: 0.15; }
    }

    /* Test LED always dim amber */
    @keyframes lcr-led-test {
      0%, 100% { fill: #FBBF24; opacity: 0.15; }
    }

    /* Dimmer slider position */
    @keyframes lcr-slider {
      0%, 28%   { transform: translateX(0px); }
      32%, 48%  { transform: translateX(-20px); }
      52%, 88%  { transform: translateX(0px); }
      92%, 100% { transform: translateX(0px); }
    }

    /* Dimmer percentage text — 100% */
    @keyframes lcr-dim-100 {
      0%, 28%   { opacity: 1; }
      32%, 48%  { opacity: 0; }
      52%, 88%  { opacity: 1; }
      92%, 100% { opacity: 1; }
    }

    /* Dimmer percentage text — 50% */
    @keyframes lcr-dim-50 {
      0%, 28%   { opacity: 0; }
      32%, 48%  { opacity: 1; }
      52%, 88%  { opacity: 0; }
      92%, 100% { opacity: 0; }
    }

    /* Power fail flash */
    @keyframes lcr-powerfail {
      0%, 48%   { opacity: 0; }
      50%       { opacity: 1; }
      52%       { opacity: 0; }
      54%       { opacity: 1; }
      56%       { opacity: 0; }
      58%, 88%  { opacity: 1; }
      92%, 100% { opacity: 0; }
    }

    /* Override active text */
    @keyframes lcr-override {
      0%, 50%   { opacity: 0; }
      54%, 88%  { opacity: 1; }
      92%, 100% { opacity: 0; }
    }

    /* Signal flow dots */
    @keyframes lcr-flow {
      0%   { offset-distance: 0%;   opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { offset-distance: 100%; opacity: 0; }
    }

    /* Emergency bypass flow */
    @keyframes lcr-bypass-flow {
      0%, 48%   { opacity: 0; }
      52%       { offset-distance: 0%; opacity: 0; }
      58%       { opacity: 1; }
      85%       { opacity: 1; offset-distance: 100%; }
      88%, 100% { opacity: 0; }
    }

    /* Pulse for active elements */
    @keyframes lcr-pulse {
      0%, 100% { opacity: 0.5; }
      50%      { opacity: 1; }
    }

    /* Mode label: NORMAL */
    @keyframes lcr-mode-normal {
      0%, 28%   { opacity: 1; }
      32%, 88%  { opacity: 0; }
      92%, 100% { opacity: 1; }
    }

    /* Mode label: DIMMED */
    @keyframes lcr-mode-dimmed {
      0%, 28%   { opacity: 0; }
      32%, 48%  { opacity: 1; }
      52%, 100% { opacity: 0; }
    }

    /* Mode label: EMERGENCY */
    @keyframes lcr-mode-emerg {
      0%, 48%   { opacity: 0; }
      52%, 88%  { opacity: 1; }
      92%, 100% { opacity: 0; }
    }

    /* Light sequence stagger for fixture 2 */
    .lcr-glow-2 { animation-delay: 0.15s; }
    .lcr-glow-3 { animation-delay: 0.3s; }

    .lcr-dot {
      r: 2;
      fill: #2A7AE2;
      offset-rotate: 0deg;
      animation: lcr-flow 2s linear infinite;
    }
    .lcr-mono { font-family: 'DM Sans', sans-serif; }
    .lcr-sans { font-family: 'Barlow Condensed', sans-serif; }
  </style>

  <defs>
    <!-- Warm light glow -->
    <radialGradient id="lcr-warm-glow">
      <stop offset="0%" stop-color="#FCD34D" stop-opacity="0.7"/>
      <stop offset="40%" stop-color="#FCD34D" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="#FCD34D" stop-opacity="0"/>
    </radialGradient>
    <!-- Cyan emergency glow -->
    <radialGradient id="lcr-cyan-glow">
      <stop offset="0%" stop-color="#2A7AE2" stop-opacity="0.6"/>
      <stop offset="40%" stop-color="#2A7AE2" stop-opacity="0.2"/>
      <stop offset="100%" stop-color="#2A7AE2" stop-opacity="0"/>
    </radialGradient>
    <!-- Signal flow paths -->
    <path id="lcr-dimmer-to-lcr" d="M 115,205 L 200,205" fill="none"/>
    <path id="lcr-lcr-to-lights" d="M 400,175 L 450,175 L 450,60" fill="none"/>
    <path id="lcr-bypass-path" d="M 115,265 L 200,265 L 230,235" fill="none"/>
  </defs>

  <!-- ==================== BACKGROUND ==================== -->
  <rect width="600" height="360" fill="#0F2A4A" rx="0"/>

  <!-- ==================== CEILING SECTION ==================== -->
  <!-- Ceiling bar -->
  <rect x="100" y="22" width="400" height="8" rx="2" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
  <rect x="100" y="28" width="400" height="2" fill="#2B5580"/>

  <!-- Fixture 1 -->
  <g transform="translate(200, 30)">
    <!-- Mount rod -->
    <rect x="-1" y="0" width="2" height="12" fill="#2B5580"/>
    <!-- Fixture body -->
    <rect x="-20" y="12" width="40" height="8" rx="2" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
    <!-- Fixture lens -->
    <rect x="-16" y="18" width="32" height="3" rx="1" style="animation: lcr-fixture-fill 10s ease-in-out infinite;"/>
    <!-- Light glow circle -->
    <circle cx="0" cy="50" r="38" fill="url(#lcr-warm-glow)" style="animation: lcr-glow-full 10s ease-in-out infinite;">
      <animate attributeName="r" values="38;38;22;22;40;40;38" keyTimes="0;0.28;0.32;0.48;0.52;0.88;1" dur="10s" repeatCount="indefinite"/>
    </circle>
    <circle cx="0" cy="50" r="38" style="animation: lcr-glow-color 10s ease-in-out infinite; opacity: 0.5;">
      <animate attributeName="r" values="38;38;22;22;40;40;38" keyTimes="0;0.28;0.32;0.48;0.52;0.88;1" dur="10s" repeatCount="indefinite"/>
    </circle>
  </g>

  <!-- Fixture 2 -->
  <g transform="translate(300, 30)">
    <rect x="-1" y="0" width="2" height="12" fill="#2B5580"/>
    <rect x="-20" y="12" width="40" height="8" rx="2" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
    <rect x="-16" y="18" width="32" height="3" rx="1" style="animation: lcr-fixture-fill 10s ease-in-out infinite; animation-delay: 0.15s;"/>
    <circle cx="0" cy="50" r="38" fill="url(#lcr-warm-glow)" style="animation: lcr-glow-full 10s ease-in-out infinite; animation-delay: 0.15s;">
      <animate attributeName="r" values="38;38;22;22;40;40;38" keyTimes="0;0.28;0.32;0.48;0.52;0.88;1" dur="10s" begin="0.15s" repeatCount="indefinite"/>
    </circle>
    <circle cx="0" cy="50" r="38" style="animation: lcr-glow-color 10s ease-in-out infinite; animation-delay: 0.15s; opacity: 0.5;">
      <animate attributeName="r" values="38;38;22;22;40;40;38" keyTimes="0;0.28;0.32;0.48;0.52;0.88;1" dur="10s" begin="0.15s" repeatCount="indefinite"/>
    </circle>
  </g>

  <!-- Fixture 3 -->
  <g transform="translate(400, 30)">
    <rect x="-1" y="0" width="2" height="12" fill="#2B5580"/>
    <rect x="-20" y="12" width="40" height="8" rx="2" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
    <rect x="-16" y="18" width="32" height="3" rx="1" style="animation: lcr-fixture-fill 10s ease-in-out infinite; animation-delay: 0.3s;"/>
    <circle cx="0" cy="50" r="38" fill="url(#lcr-warm-glow)" style="animation: lcr-glow-full 10s ease-in-out infinite; animation-delay: 0.3s;">
      <animate attributeName="r" values="38;38;22;22;40;40;38" keyTimes="0;0.28;0.32;0.48;0.52;0.88;1" dur="10s" begin="0.3s" repeatCount="indefinite"/>
    </circle>
    <circle cx="0" cy="50" r="38" style="animation: lcr-glow-color 10s ease-in-out infinite; animation-delay: 0.3s; opacity: 0.5;">
      <animate attributeName="r" values="38;38;22;22;40;40;38" keyTimes="0;0.28;0.32;0.48;0.52;0.88;1" dur="10s" begin="0.3s" repeatCount="indefinite"/>
    </circle>
  </g>

  <!-- Light labels -->
  <text x="200" y="96" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="7" opacity="0.6">ZONE 1</text>
  <text x="300" y="96" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="7" opacity="0.6">ZONE 2</text>
  <text x="400" y="96" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="7" opacity="0.6">ZONE 3</text>

  <!-- Connection lines: LCR to lights -->
  <line x1="300" y1="100" x2="300" y2="148" stroke="#2B5580" stroke-width="1" stroke-dasharray="3 2"/>
  <line x1="200" y1="96" x2="200" y2="108" stroke="#2B5580" stroke-width="0.75" stroke-dasharray="3 2"/>
  <line x1="200" y1="108" x2="300" y2="108" stroke="#2B5580" stroke-width="0.75" stroke-dasharray="3 2"/>
  <line x1="400" y1="96" x2="400" y2="108" stroke="#2B5580" stroke-width="0.75" stroke-dasharray="3 2"/>
  <line x1="400" y1="108" x2="300" y2="108" stroke="#2B5580" stroke-width="0.75" stroke-dasharray="3 2"/>
  <!-- LOAD label -->
  <text x="310" y="130" class="lcr-mono" fill="#2A7AE2" font-size="7" opacity="0.7">LOAD</text>

  <!-- ==================== LCR MODULE (center) ==================== -->
  <g transform="translate(210, 148)">
    <!-- Module body -->
    <rect x="0" y="0" width="180" height="100" rx="4" fill="#2B5580" stroke="#2A7AE2" stroke-width="1.5" opacity="0.95"/>
    <!-- Inner border accent -->
    <rect x="3" y="3" width="174" height="94" rx="3" fill="none" stroke="#2B5580" stroke-width="0.5"/>

    <!-- Brand and model -->
    <text x="14" y="18" class="lcr-sans" fill="#FFFFFF" font-size="11" font-weight="700" letter-spacing="1">LCR-20</text>
    <text x="14" y="28" class="lcr-mono" fill="#2A7AE2" font-size="7" letter-spacing="2">OLP</text>

    <!-- Divider -->
    <line x1="80" y1="8" x2="80" y2="35" stroke="#2B5580" stroke-width="0.5"/>

    <!-- Status LEDs -->
    <g transform="translate(90, 10)">
      <!-- NORMAL LED -->
      <circle cx="0" cy="0" r="3" style="animation: lcr-led-normal 10s ease-in-out infinite;"/>
      <text x="8" y="3" class="lcr-mono" fill="#B8D4F0" font-size="6">NORMAL</text>

      <!-- EMERGENCY LED -->
      <circle cx="0" cy="12" r="3" style="animation: lcr-led-emerg 10s ease-in-out infinite;"/>
      <text x="8" y="15" class="lcr-mono" fill="#B8D4F0" font-size="6">EMERGENCY</text>

      <!-- TEST LED -->
      <circle cx="0" cy="24" r="3" style="animation: lcr-led-test 10s ease-in-out infinite;"/>
      <text x="8" y="27" class="lcr-mono" fill="#B8D4F0" font-size="6">TEST</text>
    </g>

    <!-- Terminal strip at bottom -->
    <rect x="10" y="68" width="160" height="24" rx="2" fill="#0F2A4A" stroke="#2B5580" stroke-width="0.5"/>

    <!-- Input terminals (left) -->
    <rect x="18" y="72" width="10" height="10" rx="1" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
    <circle cx="23" cy="77" r="2.5" fill="#0F2A4A" stroke="#2A7AE2" stroke-width="0.5"/>
    <text x="23" y="87" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="5">DIM</text>

    <rect x="38" y="72" width="10" height="10" rx="1" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
    <circle cx="43" cy="77" r="2.5" fill="#0F2A4A" stroke="#2A7AE2" stroke-width="0.5"/>
    <text x="43" y="87" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="5">LINE</text>

    <!-- Center terminal -->
    <rect x="68" y="72" width="10" height="10" rx="1" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
    <circle cx="73" cy="77" r="2.5" fill="#0F2A4A" stroke="#FBBF24" stroke-width="0.5"/>
    <text x="73" y="87" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="5">N</text>

    <!-- Output terminals (right) -->
    <rect x="98" y="72" width="10" height="10" rx="1" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
    <circle cx="103" cy="77" r="2.5" fill="#0F2A4A" stroke="#2A7AE2" stroke-width="0.5"/>
    <text x="103" y="87" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="5">LOAD</text>

    <rect x="122" y="72" width="10" height="10" rx="1" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
    <circle cx="127" cy="77" r="2.5" fill="#0F2A4A" stroke="#2A7AE2" stroke-width="0.5"/>
    <text x="127" y="87" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="5">AUX</text>

    <!-- Emergency input terminal -->
    <rect x="148" y="72" width="10" height="10" rx="1" fill="#2B5580" stroke="#2B5580" stroke-width="0.5"/>
    <circle cx="153" cy="77" r="2.5" fill="#0F2A4A" stroke="#FF3B3B" stroke-width="0.5"/>
    <text x="153" y="87" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="5">EMG</text>

    <!-- Mode display -->
    <text x="90" y="56" text-anchor="middle" class="lcr-sans" fill="#34D399" font-size="9" font-weight="600" style="animation: lcr-mode-normal 10s ease-in-out infinite;">NORMAL</text>
    <text x="90" y="56" text-anchor="middle" class="lcr-sans" fill="#FBBF24" font-size="9" font-weight="600" style="animation: lcr-mode-dimmed 10s ease-in-out infinite;">DIMMED</text>
    <text x="90" y="56" text-anchor="middle" class="lcr-sans" fill="#2A7AE2" font-size="9" font-weight="600" style="animation: lcr-mode-emerg 10s ease-in-out infinite;">EMERGENCY</text>
  </g>

  <!-- ==================== DIMMER CONTROL (left side) ==================== -->
  <g transform="translate(30, 160)">
    <text x="40" y="0" text-anchor="middle" class="lcr-sans" fill="#B8D4F0" font-size="8" font-weight="600" letter-spacing="1">DIMMER</text>

    <!-- Dimmer housing -->
    <rect x="10" y="6" width="60" height="70" rx="3" fill="#2B5580" stroke="#2B5580" stroke-width="1"/>

    <!-- Slider track -->
    <rect x="36" y="14" width="8" height="50" rx="4" fill="#0F2A4A" stroke="#2B5580" stroke-width="0.5"/>

    <!-- Slider fill (animated) -->
    <rect x="37" y="24" width="6" height="39" rx="3" fill="#2B5580">
      <animate attributeName="height" values="39;39;20;20;39;39;39" keyTimes="0;0.28;0.32;0.48;0.52;0.88;1" dur="10s" repeatCount="indefinite"/>
      <animate attributeName="y" values="24;24;43;43;24;24;24" keyTimes="0;0.28;0.32;0.48;0.52;0.88;1" dur="10s" repeatCount="indefinite"/>
    </rect>

    <!-- Slider knob -->
    <rect x="33" y="20" width="14" height="8" rx="2" fill="#2B5580" stroke="#2A7AE2" stroke-width="0.5">
      <animate attributeName="y" values="20;20;40;40;20;20;20" keyTimes="0;0.28;0.32;0.48;0.52;0.88;1" dur="10s" repeatCount="indefinite"/>
    </rect>

    <!-- Percentage display -->
    <text x="40" y="72" text-anchor="middle" class="lcr-mono" fill="#FFFFFF" font-size="9" font-weight="700" style="animation: lcr-dim-100 10s ease-in-out infinite;">100%</text>
    <text x="40" y="72" text-anchor="middle" class="lcr-mono" fill="#FBBF24" font-size="9" font-weight="700" style="animation: lcr-dim-50 10s ease-in-out infinite;">50%</text>

    <!-- DIM INPUT label -->
    <text x="40" y="86" text-anchor="middle" class="lcr-mono" fill="#2A7AE2" font-size="6" opacity="0.7">DIM INPUT</text>
  </g>

  <!-- ==================== INVERTER (bottom left) ==================== -->
  <g transform="translate(30, 268)">
    <rect x="8" y="0" width="64" height="30" rx="3" fill="#2B5580" stroke="#2B5580" stroke-width="1"/>
    <text x="40" y="14" text-anchor="middle" class="lcr-sans" fill="#FFFFFF" font-size="8" font-weight="600">INVERTER</text>
    <text x="40" y="24" text-anchor="middle" class="lcr-mono" fill="#FF3B3B" font-size="6" opacity="0.7">EMERG PWR</text>
  </g>

  <!-- ==================== WIRING / SIGNAL FLOW ==================== -->

  <!-- Dimmer to LCR line -->
  <line x1="100" y1="205" x2="210" y2="205" stroke="#2B5580" stroke-width="1.5"/>
  <!-- Animated signal dots: dimmer to LCR -->
  <circle r="2" fill="#2A7AE2" opacity="0.8">
    <animate attributeName="cx" values="100;210" dur="1.5s" repeatCount="indefinite"/>
    <animate attributeName="cy" values="205;205" dur="1.5s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="1.5s" repeatCount="indefinite"/>
  </circle>

  <!-- LCR to lights vertical line -->
  <line x1="300" y1="148" x2="300" y2="108" stroke="#2A7AE2" stroke-width="1" opacity="0.4" stroke-dasharray="3 2"/>

  <!-- Bypass line: Inverter to LCR emergency terminal -->
  <path d="M 94,280 L 140,280 L 363,248" fill="none" stroke="#FF3B3B" stroke-width="1" stroke-dasharray="4 3" opacity="0.5"/>
  <!-- Animated bypass signal (emergency only) -->
  <circle r="2" fill="#FF3B3B">
    <animate attributeName="cx" values="94;140;363" keyTimes="0;0.3;1" dur="2s" repeatCount="indefinite"/>
    <animate attributeName="cy" values="280;280;248" keyTimes="0;0.3;1" dur="2s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values="0;0;0;0;0;1;1;0" keyTimes="0;0.1;0.2;0.3;0.48;0.52;0.88;1" dur="10s" repeatCount="indefinite"/>
  </circle>

  <!-- LINE label on incoming power -->
  <text x="155" y="200" class="lcr-mono" fill="#B8D4F0" font-size="6" opacity="0.6">LINE</text>

  <!-- Arrow: dimmer output -->
  <polygon points="205,202 210,205 205,208" fill="#2A7AE2" opacity="0.5"/>
  <!-- Arrow: LCR to load -->
  <polygon points="297,112 300,108 303,112" fill="#2A7AE2" opacity="0.5"/>

  <!-- ==================== POWER FAIL INDICATOR ==================== -->
  <g style="animation: lcr-powerfail 10s ease-in-out infinite;" transform="translate(440, 145)">
    <rect x="0" y="0" width="90" height="22" rx="3" fill="#FF3B3B" opacity="0.15" stroke="#FF3B3B" stroke-width="1"/>
    <text x="45" y="14" text-anchor="middle" class="lcr-sans" fill="#FF3B3B" font-size="9" font-weight="700" letter-spacing="1">POWER FAIL</text>
    <!-- Flash burst -->
    <line x1="-6" y1="11" x2="-2" y2="6" stroke="#FF3B3B" stroke-width="1.5"/>
    <line x1="-2" y1="6" x2="-4" y2="11" stroke="#FF3B3B" stroke-width="1.5"/>
    <line x1="-4" y1="11" x2="0" y2="16" stroke="#FF3B3B" stroke-width="1.5"/>
  </g>

  <!-- ==================== OVERRIDE ACTIVE ==================== -->
  <g style="animation: lcr-override 10s ease-in-out infinite;" transform="translate(440, 178)">
    <rect x="0" y="0" width="120" height="20" rx="3" fill="#2A7AE2" opacity="0.08" stroke="#2A7AE2" stroke-width="0.75"/>
    <text x="60" y="13" text-anchor="middle" class="lcr-mono" fill="#2A7AE2" font-size="8" font-weight="700" letter-spacing="1">OVERRIDE ACTIVE</text>
  </g>

  <!-- ==================== SIGNAL FLOW DIAGRAM (bottom) ==================== -->
  <g transform="translate(120, 310)">
    <!-- Flow boxes -->
    <rect x="0" y="0" width="60" height="18" rx="2" fill="#2B5580" stroke="#2B5580" stroke-width="0.75"/>
    <text x="30" y="12" text-anchor="middle" class="lcr-mono" fill="#B8D4F0" font-size="7">DIMMER</text>

    <!-- Arrow -->
    <line x1="64" y1="9" x2="90" y2="9" stroke="#2B5580" stroke-width="1"/>
    <polygon points="88,6 93,9 88,12" fill="#2B5580"/>

    <rect x="96" y="0" width="60" height="18" rx="2" fill="#2B5580" stroke="#2A7AE2" stroke-width="0.75"/>
    <text x="126" y="12" text-anchor="middle" class="lcr-mono" fill="#2A7AE2" font-size="7">LCR-20</text>

    <!-- Arrow -->
    <line x1="160" y1="9" x2="186" y2="9" stroke="#2B5580" stroke-width="1"/>
