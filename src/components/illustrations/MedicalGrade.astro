---
/**
 * MedicalGrade.astro
 * Isometric hospital/ICU room SVG illustration showing medical equipment
 * protected by an OLP isolation transformer. Animated ECG waveform,
 * clean-power sine flow, and pulsing status LEDs convey calm, clinical
 * precision — "your critical equipment is safe."
 */
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 600 360"
  fill="none"
  role="img"
  aria-label="Medical grade power protection illustration showing an isometric hospital room with patient monitor, IV pump, and ventilator powered through an OLP isolation transformer"
  class="mg-illustration"
>
  <defs>
    <style>
      /* Fonts inherited from BaseLayout */

      .font-display { font-family: 'Barlow Condensed', sans-serif; }
      .font-mono    { font-family: 'DM Sans', monospace; }

      /* ── ECG heartbeat scroll (left to right) ── */
      @keyframes ecgScroll {
        0%   { transform: translateX(-160px); }
        100% { transform: translateX(0); }
      }

      /* ── Clean sine wave scroll (left to right, power flow) ── */
      @keyframes sineScroll {
        0%   { transform: translateX(-80px); }
        100% { transform: translateX(0); }
      }

      /* ── LED pulse (green) ── */
      @keyframes ledPulse {
        0%, 100% { opacity: 0.55; filter: drop-shadow(0 0 2px #34D399); }
        50%      { opacity: 1;    filter: drop-shadow(0 0 8px #34D399); }
      }

      /* ── Orange LED pulse (hospital outlet) ── */
      @keyframes ledOrange {
        0%, 100% { opacity: 0.6; filter: drop-shadow(0 0 2px #FF6B35); }
        50%      { opacity: 1;   filter: drop-shadow(0 0 6px #FF6B35); }
      }

      /* ── Ventilator oscillation ── */
      @keyframes ventOsc {
        0%, 100% { transform: translateY(0); }
        50%      { transform: translateY(-2px); }
      }

      /* ── Power-flow cyan dots ── */
      @keyframes dotFlow {
        0%   { offset-distance: 0%;   opacity: 0; }
        10%  { opacity: 1; }
        90%  { opacity: 1; }
        100% { offset-distance: 100%; opacity: 0; }
      }

      /* ── Dirty power jagged shimmer ── */
      @keyframes dirtyShimmer {
        0%, 100% { opacity: 0.5; }
        50%      { opacity: 0.9; }
      }

      /* ── Ambient glow on equipment ── */
      @keyframes ambientGlow {
        0%, 100% { opacity: 0.08; }
        50%      { opacity: 0.18; }
      }

      /* ── BPM digit subtle flicker ── */
      @keyframes bpmFlicker {
        0%, 90%, 100% { opacity: 1; }
        92%           { opacity: 0.7; }
      }

      /* ── Monitor scan line ── */
      @keyframes monitorScan {
        0%   { transform: translateY(0); }
        100% { transform: translateY(90px); }
      }

      /* ── Checkmark / badge pulse ── */
      @keyframes badgePulse {
        0%, 100% { opacity: 0.7; }
        50%      { opacity: 1; }
      }
    </style>

    <!-- Grid pattern for isometric floor -->
    <pattern id="mg-floorGrid" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse" patternTransform="skewY(-30) scale(1,0.6)">
      <line x1="0" y1="0" x2="0" y2="20" stroke="#1A3F6A" stroke-width="0.5" opacity="0.3"/>
      <line x1="0" y1="0" x2="20" y2="0" stroke="#1A3F6A" stroke-width="0.5" opacity="0.3"/>
    </pattern>

    <!-- Gradients -->
    <linearGradient id="mg-wallGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#1A3F6A"/>
      <stop offset="100%" stop-color="#1A3F6A"/>
    </linearGradient>

    <linearGradient id="mg-floorGrad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%"   stop-color="#1A3F6A"/>
      <stop offset="100%" stop-color="#0F2A4A"/>
    </linearGradient>

    <linearGradient id="mg-cyanGlow" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#2A7AE2" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="#2A7AE2" stop-opacity="0"/>
    </linearGradient>

    <!-- ECG clip region (monitor screen) -->
    <clipPath id="mg-ecgClip">
      <rect x="370" y="88" width="130" height="52"/>
    </clipPath>

    <!-- Clean sine clip region (power line) -->
    <clipPath id="mg-sineClip">
      <rect x="180" y="220" width="130" height="30"/>
    </clipPath>

    <!-- Dirty power clip -->
    <clipPath id="mg-dirtyClip">
      <rect x="40" y="220" width="100" height="30"/>
    </clipPath>
  </defs>

  <!-- ================================================================ -->
  <!-- BACKGROUND                                                       -->
  <!-- ================================================================ -->
  <rect width="600" height="360" fill="#0F2A4A" rx="8"/>

  <!-- ================================================================ -->
  <!-- ISOMETRIC ROOM                                                   -->
  <!-- ================================================================ -->

  <!-- Back wall (left portion) -->
  <polygon points="60,70 320,70 320,240 60,240" fill="url(#mg-wallGrad)" opacity="0.55"/>

  <!-- Side wall (right portion, angled) -->
  <polygon points="320,70 540,120 540,280 320,240" fill="#1A3F6A" opacity="0.45"/>

  <!-- Floor -->
  <polygon points="60,240 320,240 540,280 280,320" fill="url(#mg-floorGrad)" opacity="0.6"/>

  <!-- Wall-floor edge lines -->
  <line x1="60" y1="240" x2="320" y2="240" stroke="#1A3F6A" stroke-width="0.8" opacity="0.6"/>
  <line x1="320" y1="240" x2="540" y2="280" stroke="#1A3F6A" stroke-width="0.8" opacity="0.6"/>
  <line x1="320" y1="70" x2="320" y2="240" stroke="#1A3F6A" stroke-width="0.8" opacity="0.4"/>

  <!-- Subtle floor grid lines -->
  <g opacity="0.15">
    <line x1="120" y1="240" x2="340" y2="280" stroke="#1A3F6A" stroke-width="0.5"/>
    <line x1="180" y1="240" x2="400" y2="280" stroke="#1A3F6A" stroke-width="0.5"/>
    <line x1="240" y1="240" x2="460" y2="280" stroke="#1A3F6A" stroke-width="0.5"/>
    <line x1="60" y1="260" x2="420" y2="260" stroke="#1A3F6A" stroke-width="0.5"/>
    <line x1="120" y1="275" x2="480" y2="275" stroke="#1A3F6A" stroke-width="0.5"/>
  </g>

  <!-- ================================================================ -->
  <!-- MEDICAL CROSS (top-left on back wall)                            -->
  <!-- ================================================================ -->
  <g transform="translate(82, 86)">
    <rect x="5" y="0" width="6" height="16" rx="1" fill="#34D399" opacity="0.7"/>
    <rect x="0" y="5" width="16" height="6" rx="1" fill="#34D399" opacity="0.7"/>
  </g>

  <!-- ================================================================ -->
  <!-- POWER SYSTEM — LEFT / LOWER                                      -->
  <!-- ================================================================ -->

  <!-- ── Facility power entry (far left) ── -->
  <g transform="translate(40, 200)">
    <!-- Cable from wall -->
    <line x1="0" y1="35" x2="25" y2="35" stroke="#94AECF" stroke-width="2" opacity="0.4"/>
    <text x="0" y="18" class="font-mono" font-size="6" fill="#94AECF" opacity="0.5">FACILITY</text>
    <text x="0" y="25" class="font-mono" font-size="6" fill="#94AECF" opacity="0.5">POWER</text>
  </g>

  <!-- ── Dirty power waveform (jagged) entering transformer ── -->
  <g clip-path="url(#mg-dirtyClip)">
    <g style="animation: dirtyShimmer 2s ease-in-out infinite;">
      <path
        d="M40,235 L50,228 L54,240 L58,225 L62,238 L66,230 L72,242 L76,226 L80,237 L86,232 L90,240 L96,224 L100,238 L106,230 L112,242 L116,227 L122,236 L128,231 L132,240 L138,225 L142,237
           L148,228 L152,240 L156,225 L160,238 L164,230 L170,242 L174,226 L178,237 L184,232 L188,240 L194,224 L198,238 L204,230 L210,242 L214,227 L220,236"
        stroke="#FF6B35"
        stroke-width="1.5"
        fill="none"
        opacity="0.7"
        stroke-linecap="round"
      />
    </g>
  </g>

  <!-- ── ISOLATION TRANSFORMER UNIT ── -->
  <g id="mg-transformer" transform="translate(155, 180)">

    <!-- Ambient glow -->
    <rect x="-4" y="-4" width="88" height="78" rx="8" fill="#2A7AE2" opacity="0.05"
          style="animation: ambientGlow 4s ease-in-out infinite;"/>

    <!-- Isometric box: top face -->
    <polygon points="40,-10 80,8 40,26 0,8" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.6"/>

    <!-- Isometric box: left face -->
    <polygon points="0,8 40,26 40,66 0,48" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.6"/>

    <!-- Isometric box: right face -->
    <polygon points="80,8 40,26 40,66 80,48" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.6"/>

    <!-- OLP label on right face -->
    <text x="58" y="34" text-anchor="middle" class="font-display" font-size="10" font-weight="700" fill="#2A7AE2" opacity="0.9">OLP</text>

    <!-- ISO-CARE label on right face -->
    <text x="58" y="44" text-anchor="middle" class="font-mono" font-size="5" fill="#94AECF" letter-spacing="1">ISO-CARE</text>

    <!-- Status LED (green) on left face -->
    <circle cx="16" cy="32" r="3" fill="#34D399"
            style="animation: ledPulse 2.5s ease-in-out infinite;"/>
    <circle cx="16" cy="32" r="5.5" fill="none" stroke="#34D399" stroke-width="0.5" opacity="0.25"
            style="animation: ledPulse 2.5s ease-in-out infinite;"/>

    <!-- Ground symbol on left face -->
    <g transform="translate(10, 48)" opacity="0.5">
      <line x1="4" y1="0" x2="4" y2="6" stroke="#94AECF" stroke-width="1"/>
      <line x1="0" y1="6" x2="8" y2="6" stroke="#94AECF" stroke-width="1"/>
      <line x1="1.5" y1="9" x2="6.5" y2="9" stroke="#94AECF" stroke-width="0.8"/>
      <line x1="3" y1="11.5" x2="5" y2="11.5" stroke="#94AECF" stroke-width="0.6"/>
    </g>

    <!-- ±1% REGULATION badge on top face -->
    <rect x="6" y="-8" width="52" height="12" rx="2" fill="#1A3F6A" stroke="#2A7AE2" stroke-width="0.6" opacity="0.85"/>
    <text x="32" y="1" text-anchor="middle" class="font-mono" font-size="6" font-weight="700" fill="#2A7AE2" opacity="0.9">&plusmn;1% REG</text>

    <!-- Input arrow (dirty) -->
    <line x1="-20" y1="35" x2="0" y2="28" stroke="#FF6B35" stroke-width="1.2" opacity="0.5" stroke-dasharray="3 2"/>

    <!-- Output arrow (clean) -->
    <line x1="80" y1="28" x2="105" y2="28" stroke="#2A7AE2" stroke-width="1.2" opacity="0.6" stroke-dasharray="3 2"/>
  </g>

  <!-- ── Clean sine wave flowing out of transformer ── -->
  <g clip-path="url(#mg-sineClip)">
    <g style="animation: sineScroll 2s linear infinite;">
      <path
        d="M180,235 C190,225 200,225 210,235 C220,245 230,245 240,235 C250,225 260,225 270,235 C280,245 290,245 300,235 C310,225 320,225 330,235 C340,245 350,245 360,235"
        stroke="#2A7AE2"
        stroke-width="1.5"
        fill="none"
        opacity="0.7"
        stroke-linecap="round"
        filter="drop-shadow(0 0 3px rgba(0,229,255,0.3))"
      />
    </g>
  </g>

  <!-- ── Power-flow cyan dots (transformer to outlet) ── -->
  <circle r="2.5" fill="#2A7AE2"
          style="offset-path: path('M260,208 Q300,215 330,230 Q350,240 370,235'); animation: dotFlow 2s linear infinite;">
    <animate attributeName="opacity" values="0;1;1;0" dur="2s" repeatCount="indefinite"/>
  </circle>
  <circle r="2.5" fill="#2A7AE2"
          style="offset-path: path('M260,208 Q300,215 330,230 Q350,240 370,235'); animation: dotFlow 2s linear infinite; animation-delay: 0.66s;">
    <animate attributeName="opacity" values="0;1;1;0" dur="2s" begin="0.66s" repeatCount="indefinite"/>
  </circle>
  <circle r="2.5" fill="#2A7AE2"
          style="offset-path: path('M260,208 Q300,215 330,230 Q350,240 370,235'); animation: dotFlow 2s linear infinite; animation-delay: 1.33s;">
    <animate attributeName="opacity" values="0;1;1;0" dur="2s" begin="1.33s" repeatCount="indefinite"/>
  </circle>

  <!-- ── GROUND FAULT PROTECTED text ── -->
  <text x="155" y="272" class="font-mono" font-size="5.5" fill="#94AECF" opacity="0.5" letter-spacing="0.8">GROUND FAULT PROTECTED</text>

  <!-- ================================================================ -->
  <!-- HOSPITAL-GRADE WALL OUTLET PANEL                                 -->
  <!-- ================================================================ -->
  <g transform="translate(370, 200)">
    <!-- Panel body -->
    <rect x="0" y="0" width="40" height="50" rx="3" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.8"/>

    <!-- Outlet slots (two duplex) -->
    <rect x="10" y="8" width="8" height="3" rx="1" fill="#0F2A4A"/>
    <rect x="22" y="8" width="8" height="3" rx="1" fill="#0F2A4A"/>
    <circle cx="20" cy="16" r="2" fill="#0F2A4A"/>

    <rect x="10" y="26" width="8" height="3" rx="1" fill="#0F2A4A"/>
    <rect x="22" y="26" width="8" height="3" rx="1" fill="#0F2A4A"/>
    <circle cx="20" cy="34" r="2" fill="#0F2A4A"/>

    <!-- Hospital-grade orange dot -->
    <circle cx="20" cy="44" r="3" fill="#FF6B35"
            style="animation: ledOrange 3s ease-in-out infinite;"/>

    <!-- "H.G." label -->
    <text x="20" y="55" text-anchor="middle" class="font-mono" font-size="5" fill="#94AECF" opacity="0.5">H.G.</text>
  </g>

  <!-- Power cables from outlet to equipment -->
  <path d="M410,210 Q430,190 440,170 Q445,160 450,145" stroke="#1A3F6A" stroke-width="1.2" fill="none" opacity="0.5"/>
  <path d="M395,205 Q400,180 420,165 Q430,158 435,145" stroke="#1A3F6A" stroke-width="1.2" fill="none" opacity="0.5"/>
  <path d="M400,215 Q415,200 470,195 Q490,192 500,180" stroke="#1A3F6A" stroke-width="1.2" fill="none" opacity="0.5"/>

  <!-- ================================================================ -->
  <!-- MEDICAL EQUIPMENT — RIGHT SIDE                                   -->
  <!-- ================================================================ -->

  <!-- ── PATIENT MONITOR ── -->
  <g id="mg-monitor" transform="translate(355, 72)">

    <!-- Monitor ambient glow -->
    <rect x="-6" y="-6" width="162" height="110" rx="8" fill="#2A7AE2" opacity="0.04"
          style="animation: ambientGlow 5s ease-in-out infinite;"/>

    <!-- Monitor body -->
    <rect x="0" y="0" width="150" height="98" rx="5" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.8"/>

    <!-- Screen bezel -->
    <rect x="4" y="4" width="142" height="68" rx="3" fill="#0F2A4A"/>

    <!-- Screen scanline -->
    <rect x="4" y="4" width="142" height="2" rx="1" fill="#2A7AE2" opacity="0.06"
          style="animation: monitorScan 4s linear infinite;"/>

    <!-- ── ECG waveform ── -->
    <g clip-path="url(#mg-ecgClip)">
      <g style="animation: ecgScroll 2.4s linear infinite;">
        <!-- Heartbeat waveform pattern (repeating ~160px period) -->
        <path
          d="M370,112
             L390,112 L394,112 L398,110 L400,114 L402,112
             L410,112 L414,112 L416,98 L418,126 L420,105 L422,112
             L434,112 L438,110 L440,112
             L452,112 L456,112 L458,110 L460,114 L462,112
             L470,112 L474,112 L476,98 L478,126 L480,105 L482,112
             L494,112 L498,110 L500,112
             L512,112 L516,112 L518,110 L520,114 L522,112
             L530,112 L534,112 L536,98 L538,126 L540,105 L542,112
             L554,112 L558,110 L560,112
             L572,112 L576,112 L578,110 L580,114 L582,112
             L590,112 L594,112 L596,98 L598,126 L600,105 L602,112
             L614,112 L618,110 L620,112"
          stroke="#34D399"
          stroke-width="1.8"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
          filter="drop-shadow(0 0 3px rgba(52,211,153,0.5))"
        />
      </g>
    </g>

    <!-- ── Heart rate reading ── -->
    <g transform="translate(8, 46)">
      <text x="0" y="8" class="font-mono" font-size="5.5" fill="#94AECF" opacity="0.7">HR</text>
      <text x="0" y="20" class="font-mono" font-size="14" font-weight="700" fill="#34D399"
            style="animation: bpmFlicker 3s ease-in-out infinite;">72</text>
      <text x="32" y="20" class="font-mono" font-size="7" fill="#94AECF" opacity="0.6">BPM</text>
    </g>

    <!-- ── SpO2 reading ── -->
    <g transform="translate(80, 46)">
      <text x="0" y="8" class="font-mono" font-size="5.5" fill="#94AECF" opacity="0.7">SpO2</text>
      <text x="0" y="20" class="font-mono" font-size="14" font-weight="700" fill="#2A7AE2"
            style="animation: bpmFlicker 3s ease-in-out infinite; animation-delay: 1s;">99</text>
      <text x="28" y="20" class="font-mono" font-size="7" fill="#94AECF" opacity="0.6">%</text>
    </g>

    <!-- Monitor stand -->
    <line x1="75" y1="98" x2="75" y2="115" stroke="#1A3F6A" stroke-width="3"/>
    <rect x="60" y="113" width="30" height="4" rx="2" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.5"/>

    <!-- Small medical cross on monitor -->
    <g transform="translate(130, 78)" opacity="0.7">
      <rect x="2" y="0" width="3" height="8" rx="0.5" fill="#34D399"/>
      <rect x="0" y="2" width="7" height="3" rx="0.5" fill="#34D399"/>
    </g>
  </g>

  <!-- ── IV PUMP STAND ── -->
  <g id="mg-ivPump" transform="translate(460, 95)">
    <!-- Pole -->
    <line x1="12" y1="0" x2="12" y2="150" stroke="#1A3F6A" stroke-width="2"/>

    <!-- Top hook -->
    <path d="M8,-2 Q12,-8 16,-2" stroke="#94AECF" stroke-width="1.2" fill="none"/>

    <!-- IV bag (simple) -->
    <rect x="5" y="10" width="14" height="20" rx="3" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.6" opacity="0.8"/>
    <rect x="8" y="13" width="8" height="14" rx="2" fill="#0F2A4A" opacity="0.4"/>

    <!-- Pump box -->
    <rect x="2" y="40" width="20" height="24" rx="2" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.6"/>

    <!-- Pump LED -->
    <circle cx="12" cy="48" r="2" fill="#34D399" opacity="0.7"
            style="animation: ledPulse 3s ease-in-out infinite; animation-delay: 0.5s;"/>

    <!-- Drip rate label -->
    <text x="12" y="60" text-anchor="middle" class="font-mono" font-size="4" fill="#94AECF" opacity="0.5">mL/h</text>

    <!-- Tubing down -->
    <line x1="12" y1="30" x2="12" y2="40" stroke="#94AECF" stroke-width="0.6" opacity="0.3"/>

    <!-- Base -->
    <line x1="2" y1="150" x2="22" y2="150" stroke="#1A3F6A" stroke-width="2"/>
  </g>

  <!-- ── VENTILATOR UNIT ── -->
  <g id="mg-ventilator" transform="translate(500, 148)">
    <!-- Body -->
    <rect x="0" y="0" width="36" height="42" rx="3" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.8"/>

    <!-- Ambient glow -->
    <rect x="-3" y="-3" width="42" height="48" rx="5" fill="#2A7AE2" opacity="0.03"
          style="animation: ambientGlow 5s ease-in-out infinite; animation-delay: 1s;"/>

    <!-- Screen area -->
    <rect x="4" y="4" width="28" height="16" rx="2" fill="#0F2A4A"/>

    <!-- Oscillating bar indicator -->
    <g style="animation: ventOsc 1.5s ease-in-out infinite;">
      <rect x="8" y="8" width="20" height="2" rx="1" fill="#2A7AE2" opacity="0.6"/>
      <rect x="12" y="13" width="12" height="2" rx="1" fill="#2A7AE2" opacity="0.35"/>
    </g>

    <!-- Status LED -->
    <circle cx="10" cy="28" r="2" fill="#34D399" opacity="0.7"
            style="animation: ledPulse 2.5s ease-in-out infinite; animation-delay: 1.2s;"/>

    <!-- Label -->
    <text x="18" y="38" text-anchor="middle" class="font-mono" font-size="4" fill="#94AECF" opacity="0.4">VENT</text>

    <!-- Stand -->
    <line x1="18" y1="42" x2="18" y2="100" stroke="#1A3F6A" stroke-width="2"/>
    <line x1="6" y1="100" x2="30" y2="100" stroke="#1A3F6A" stroke-width="2"/>
  </g>

  <!-- ================================================================ -->
  <!-- COMPLIANCE BADGES                                                -->
  <!-- ================================================================ -->

  <!-- UL 60601-1 badge -->
  <g transform="translate(70, 300)" style="animation: badgePulse 4s ease-in-out infinite;">
    <rect x="0" y="0" width="70" height="16" rx="3" fill="#1A3F6A" stroke="#34D399" stroke-width="0.6"/>
    <text x="35" y="11" text-anchor="middle" class="font-mono" font-size="6.5" font-weight="700" fill="#34D399" letter-spacing="0.3">UL 60601-1</text>
  </g>

  <!-- Dirty → Clean power flow labels -->
  <g transform="translate(65, 220)">
    <text x="0" y="-5" class="font-mono" font-size="5.5" fill="#FF6B35" opacity="0.6" letter-spacing="0.5">DIRTY</text>
  </g>
  <g transform="translate(260, 215)">
    <text x="0" y="0" class="font-mono" font-size="5.5" fill="#2A7AE2" opacity="0.6" letter-spacing="0.5">CLEAN</text>
  </g>

  <!-- Arrow from dirty to transformer -->
  <line x1="140" y1="235" x2="155" y2="228" stroke="#FF6B35" stroke-width="0.8" opacity="0.4" marker-end="url(#mg-arrowOrange)"/>

  <!-- Arrow from transformer to outlet -->
  <line x1="260" y1="208" x2="370" y2="225" stroke="#2A7AE2" stroke-width="0.8" opacity="0.3"/>

  <!-- ================================================================ -->
  <!-- BOTTOM CAPTION                                                   -->
  <!-- ================================================================ -->
  <text x="300" y="348" text-anchor="middle" class="font-mono" font-size="9" fill="#1A3F6A" letter-spacing="1.5">
    // MEDICAL GRADE POWER &middot; UL 60601-1
  </text>

  <!-- ================================================================ -->
  <!-- TITLE AREA (top)                                                 -->
  <!-- ================================================================ -->
  <text x="300" y="25" text-anchor="middle" class="font-display" font-size="11" font-weight="600" fill="#FFFFFF" opacity="0.5" letter-spacing="2">MEDICAL GRADE PROTECTION</text>

  <!-- ================================================================ -->
  <!-- ARROW MARKERS                                                    -->
  <!-- ================================================================ -->
