<svg viewBox="0 0 560 340" width="100%" xmlns="http://www.w3.org/2000/svg">
  <style>
    @keyframes ev-normal {
      0%, 35%   { opacity: 1; }
      40%, 85%  { opacity: 0; }
      90%, 100% { opacity: 1; }
    }
    @keyframes ev-em {
      0%, 38%   { opacity: 0; }
      42%, 87%  { opacity: 1; }
      90%, 100% { opacity: 0; }
    }
    @keyframes ev-flash {
      0%, 38% { opacity: 0; }
      39%     { opacity: 1; }
      41%     { opacity: 0; }
      43%     { opacity: 0.7; }
      45%,100%{ opacity: 0; }
    }
    @keyframes ev-dot {
      0%   { offset-distance: 0%; opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { offset-distance: 100%; opacity: 0; }
    }
    .normal { animation: ev-normal 8s ease-in-out infinite; }
    .em     { animation: ev-em 8s ease-in-out infinite; }
    .flash  { animation: ev-flash 8s ease-in-out infinite; }
    .dot    { animation: ev-dot 2s linear infinite; }
  </style>

  <!-- Labels -->
  <text x="140" y="18" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#B8D4F0" letter-spacing="2">NORMAL — PASS THROUGH</text>
  <text x="420" y="18" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#2567C2" letter-spacing="2">EMERGENCY — BACKUP + REGEN</text>
  <line x1="280" y1="8" x2="280" y2="325" stroke="#3D6A9E" stroke-width="0.5" stroke-dasharray="6 4"/>

  <!-- ============================================ -->
  <!-- LEFT: NORMAL MODE — unit is pass-through     -->
  <!-- ============================================ -->

  <!-- Utility -->
  <g class="normal">
    <rect x="30" y="40" width="80" height="40" rx="3" fill="#1A3F6A" stroke="#34D399" stroke-width="1.5"/>
    <text x="70" y="58" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#FFFFFF">UTILITY</text>
    <text x="70" y="70" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#34D399">ONLINE</text>
  </g>

  <!-- Inverter (pass-through, dimmed) -->
  <rect x="70" y="130" width="140" height="50" rx="4" fill="#2B5580" stroke="#3D6A9E" stroke-width="1"/>
  <text x="140" y="152" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#FFFFFF">OLP INVERTER</text>
  <g class="normal">
    <text x="140" y="168" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">Pass-Through Mode</text>
  </g>

  <!-- Elevator -->
  <g class="normal">
    <rect x="170" y="40" width="90" height="40" rx="3" fill="#1A3F6A" stroke="#3D6A9E" stroke-width="1.5"/>
    <text x="215" y="58" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#FFFFFF">ELEVATOR</text>
    <text x="215" y="70" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#7EB3F5">3-Phase Motor</text>
  </g>

  <!-- Battery (idle/charging) -->
  <rect x="95" y="220" width="90" height="35" rx="3" fill="#2B5580" stroke="#3D6A9E" stroke-width="1"/>
  <rect x="103" y="228" width="10" height="18" rx="1" fill="#34D399" opacity="0.7"/>
  <rect x="117" y="228" width="10" height="18" rx="1" fill="#34D399" opacity="0.6"/>
  <rect x="131" y="228" width="10" height="18" rx="1" fill="#34D399" opacity="0.5"/>
  <rect x="145" y="228" width="10" height="18" rx="1" fill="#34D399" opacity="0.4"/>
  <rect x="159" y="228" width="10" height="18" rx="1" fill="#34D399" opacity="0.3"/>
  <text x="140" y="268" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">BATTERY (CHARGING)</text>

  <!-- Normal flows: straight pass-through -->
  <g class="normal">
    <!-- Utility → straight through inverter → Elevator -->
    <line x1="70" y1="80" x2="100" y2="130" stroke="#2567C2" stroke-width="2"/>
    <line x1="180" y1="130" x2="215" y2="80" stroke="#2567C2" stroke-width="2"/>
    <circle r="3.5" fill="#2567C2" class="dot" style="offset-path: path('M70,80 L140,155 L215,80');"/>
    <circle r="3.5" fill="#2567C2" class="dot" style="offset-path: path('M70,80 L140,155 L215,80'); animation-delay: 0.7s;"/>
    <circle r="3.5" fill="#2567C2" class="dot" style="offset-path: path('M70,80 L140,155 L215,80'); animation-delay: 1.4s;"/>

    <!-- Label: pass through -->
    <text x="140" y="110" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="9" fill="#2567C2" font-weight="600">PASS THROUGH →</text>

    <!-- Battery trickle charge line -->
    <line x1="140" y1="180" x2="140" y2="220" stroke="#3D6A9E" stroke-width="1" stroke-dasharray="3 3"/>
  </g>

  <!-- Normal bottom label -->
  <g class="normal">
    <rect x="25" y="295" width="230" height="24" rx="4" fill="#1A3F6A"/>
    <text x="140" y="311" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">Unit passes utility power straight through</text>
  </g>

  <!-- ============================================ -->
  <!-- RIGHT: EM MODE — backup + regen capture      -->
  <!-- ============================================ -->

  <!-- Utility FAILED -->
  <g class="em">
    <rect x="310" y="40" width="80" height="40" rx="3" fill="#1A3F6A" stroke="#FF3B3B" stroke-width="1.5" stroke-dasharray="4 3"/>
    <line x1="335" y1="50" x2="365" y2="70" stroke="#FF3B3B" stroke-width="1.5"/>
    <line x1="365" y1="50" x2="335" y2="70" stroke="#FF3B3B" stroke-width="1.5"/>
    <text x="350" y="92" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#FF3B3B" font-weight="700">UTILITY FAIL</text>
  </g>

  <!-- Inverter ACTIVE -->
  <g class="em">
    <rect x="350" y="130" width="140" height="50" rx="4" fill="#2B5580" stroke="#2567C2" stroke-width="2"/>
    <text x="420" y="152" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#FFFFFF">OLP INVERTER</text>
    <text x="420" y="168" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#2567C2" font-weight="700">BACKUP ACTIVE</text>
  </g>

  <!-- Elevator -->
  <g class="em">
    <rect x="450" y="40" width="90" height="40" rx="3" fill="#1A3F6A" stroke="#2567C2" stroke-width="1.5"/>
    <text x="495" y="58" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#FFFFFF">ELEVATOR</text>
    <text x="495" y="70" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#7EB3F5">3-Phase Motor</text>
  </g>

  <!-- Battery DISCHARGING -->
  <g class="em">
    <rect x="375" y="220" width="90" height="35" rx="3" fill="#2B5580" stroke="#2567C2" stroke-width="1.5"/>
    <rect x="383" y="228" width="10" height="18" rx="1" fill="#34D399" opacity="0.6"/>
    <rect x="397" y="228" width="10" height="18" rx="1" fill="#34D399" opacity="0.35"/>
    <rect x="411" y="228" width="10" height="18" rx="1" fill="#3D6A9E" opacity="0.3"/>
    <rect x="425" y="228" width="10" height="18" rx="1" fill="#3D6A9E" opacity="0.2"/>
    <rect x="439" y="228" width="10" height="18" rx="1" fill="#3D6A9E" opacity="0.15"/>
    <text x="420" y="268" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">BATTERY (DISCHARGING)</text>
  </g>

  <!-- EM flows -->
  <g class="em">
    <!-- Battery → Inverter (powering system) -->
    <line x1="420" y1="220" x2="420" y2="180" stroke="#2567C2" stroke-width="2"/>
    <circle r="3.5" fill="#2567C2" class="dot" style="offset-path: path('M420,220 L420,180');"/>

    <!-- Inverter → Elevator (power to motor) -->
    <line x1="460" y1="130" x2="495" y2="80" stroke="#2567C2" stroke-width="2"/>
    <circle r="3.5" fill="#2567C2" class="dot" style="offset-path: path('M460,130 L495,80');"/>
    <circle r="3.5" fill="#2567C2" class="dot" style="offset-path: path('M460,130 L495,80'); animation-delay: 0.7s;"/>

    <!-- REGEN: Elevator → Inverter → Battery (GREEN) -->
    <line x1="485" y1="80" x2="450" y2="130" stroke="#34D399" stroke-width="2" stroke-dasharray="6 3"/>
    <line x1="420" y1="180" x2="420" y2="220" stroke="#34D399" stroke-width="1.5" stroke-dasharray="6 3" opacity="0.6"/>
    <circle r="3" fill="#34D399" class="dot" style="offset-path: path('M485,80 L420,155 L420,220'); animation-delay: 0.5s;"/>
    <circle r="3" fill="#34D399" class="dot" style="offset-path: path('M485,80 L420,155 L420,220'); animation-delay: 1.3s;"/>

    <!-- Regen label -->
    <rect x="445" y="100" width="75" height="18" rx="3" fill="#0F2A4A"/>
    <text x="482" y="113" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="9" fill="#34D399" font-weight="700">REGEN ↩</text>

    <!-- Power label -->
    <text x="408" y="200" font-family="Barlow Condensed, sans-serif" font-size="8" fill="#2567C2" font-weight="600">POWER ↑</text>
  </g>

  <!-- EM bottom label -->
  <g class="em">
    <rect x="310" y="295" width="230" height="24" rx="4" fill="#1A3F6A"/>
    <text x="425" y="311" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">Battery powers elevator, regen recharges</text>
  </g>

  <!-- Flash on left utility when failing -->
  <g class="flash">
    <line x1="55" y1="50" x2="85" y2="70" stroke="#FF3B3B" stroke-width="2"/>
    <line x1="85" y1="50" x2="55" y2="70" stroke="#FF3B3B" stroke-width="2"/>
  </g>

  <!-- Caption -->
  <text x="280" y="335" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#3D6A9E">POWER WAVE ELEVATE · UL 924 · UL 1778</text>
</svg>
