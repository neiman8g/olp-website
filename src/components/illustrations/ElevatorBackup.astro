---
/**
 * ElevatorBackup.astro
 * Isometric building cutaway SVG illustration for elevator backup power.
 * Color scheme: obsidian bg, voltage-cyan accent, slate/steel fills.
 * Animations: cabin descent, power cut, backup engage, door open, text reveal.
 */
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 600 360"
  class="elevator-backup-illustration"
  role="img"
  aria-label="Elevator backup power system illustration showing safe evacuation during power outage"
>
  <defs>
    <!-- Fonts -->
    <style>
      /* Fonts inherited from BaseLayout */

      /* ---------- TIMING VARIABLES ---------- */
      :root {
        --cycle: 8s;
        --door-delay: 6.5s;
        --text-delay: 7.5s;
      }

      /* ---------- CABIN DESCENT ---------- */
      .cabin-group {
        animation: cabin-descend 8s ease-in-out infinite;
      }
      @keyframes cabin-descend {
        0%, 5%   { transform: translateY(0); }
        60%, 75% { transform: translateY(144px); }
        90%,100% { transform: translateY(0); }
      }

      /* ---------- DOOR OPEN / CLOSE ---------- */
      .door-left {
        animation: door-l 8s ease-in-out infinite;
      }
      .door-right {
        animation: door-r 8s ease-in-out infinite;
      }
      @keyframes door-l {
        0%, 62%  { transform: translateX(0); }
        72%, 78% { transform: translateX(-10px); }
        88%,100% { transform: translateX(0); }
      }
      @keyframes door-r {
        0%, 62%  { transform: translateX(0); }
        72%, 78% { transform: translateX(10px); }
        88%,100% { transform: translateX(0); }
      }

      /* ---------- CABIN INDICATOR LIGHT ---------- */
      .cabin-light {
        animation: blink-light 1.2s ease-in-out infinite;
      }
      @keyframes blink-light {
        0%, 100% { opacity: 1; }
        50%      { opacity: 0.4; }
      }

      /* ---------- UTILITY POWER CUT ---------- */
      .utility-line-live {
        animation: power-cut 8s step-end infinite;
      }
      @keyframes power-cut {
        0%, 15%  { stroke: #2567C2; }
        18%      { stroke: #FF3B3B; }
        22%,100% { stroke: #2B5580; }
      }

      .power-break-flash {
        animation: flash-break 8s ease-in-out infinite;
      }
      @keyframes flash-break {
        0%, 14%  { opacity: 0; }
        16%      { opacity: 1; }
        18%      { opacity: 0.8; }
        20%      { opacity: 0; }
        100%     { opacity: 0; }
      }

      /* ---------- INVERTER GLOW ---------- */
      .inverter-border {
        animation: inv-pulse 8s ease-in-out infinite;
      }
      @keyframes inv-pulse {
        0%, 20%  { stroke: #2B5580; opacity: 0.7; }
        25%      { stroke: #2567C2; opacity: 1; }
        30%, 70% { stroke: #2567C2; opacity: 1; }
        75%      { stroke: #2567C2; opacity: 1; }
        80%,100% { stroke: #2B5580; opacity: 0.7; }
      }

      /* ---------- BACKUP POWER DOTS ---------- */
      .power-dot {
        animation: dot-flow 2s linear infinite;
        opacity: 0;
      }
      .power-dots-group {
        animation: dots-visible 8s step-end infinite;
      }
      @keyframes dots-visible {
        0%, 24%  { opacity: 0; }
        25%,80%  { opacity: 1; }
        82%,100% { opacity: 0; }
      }
      @keyframes dot-flow {
        0%   { opacity: 0; transform: translateY(0); }
        10%  { opacity: 1; }
        90%  { opacity: 1; }
        100% { opacity: 0; transform: translateY(-130px); }
      }
      .power-dot:nth-child(2) { animation-delay: 0.5s; }
      .power-dot:nth-child(3) { animation-delay: 1.0s; }
      .power-dot:nth-child(4) { animation-delay: 1.5s; }

      /* ---------- SAFE EVACUATION TEXT ---------- */
      .safe-evac-text {
        animation: text-reveal 8s ease-in-out infinite;
      }
      @keyframes text-reveal {
        0%, 70%  { opacity: 0; }
        76%, 82% { opacity: 1; }
        90%,100% { opacity: 0; }
      }

      /* ---------- FLOOR INDICATOR ACTIVE DOT ---------- */
      .floor-dot-active {
        animation: dot-track 8s ease-in-out infinite;
      }
      @keyframes dot-track {
        0%, 5%   { cy: 104; }
        60%, 75% { cy: 248; }
        90%,100% { cy: 104; }
      }
    </style>

  </defs>

  <!-- ============================================================= -->
  <!--  BACKGROUND                                                    -->
  <!-- ============================================================= -->
  <rect width="600" height="360" fill="#0F2A4A" />

  <!-- ============================================================= -->
  <!--  BUILDING STRUCTURE (isometric-style cross-section)            -->
  <!-- ============================================================= -->
  <g>
    <!-- Outer shell -->
    <path
      d="M160,60 L400,60 L420,72 L420,300 L400,312 L160,312 L140,300 L140,72 Z"
      fill="#2B5580" stroke="#2B5580" stroke-width="1.5"
    />
    <!-- Top face (isometric) -->
    <path
      d="M160,60 L400,60 L420,72 L180,72 Z"
      fill="#2B5580" stroke="#2B5580" stroke-width="0.5"
    />
    <!-- Right face -->
    <path
      d="M400,60 L420,72 L420,300 L400,312 Z"
      fill="#0F2A4A" stroke="#2B5580" stroke-width="0.5"
    />
  </g>

  <!-- Floor lines -->
  <line x1="160" y1="108" x2="400" y2="108" stroke="#2B5580" stroke-width="0.8" />
  <line x1="160" y1="156" x2="400" y2="156" stroke="#2B5580" stroke-width="0.8" />
  <line x1="160" y1="204" x2="400" y2="204" stroke="#2B5580" stroke-width="0.8" />
  <line x1="160" y1="252" x2="400" y2="252" stroke="#2B5580" stroke-width="0.8" />

  <!-- Floor labels (left side) -->
  <text x="148" y="92" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="9" fill="#B8D4F0">5F</text>
  <text x="148" y="140" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="9" fill="#B8D4F0">4F</text>
  <text x="148" y="188" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="9" fill="#B8D4F0">3F</text>
  <text x="148" y="236" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="9" fill="#B8D4F0">2F</text>
  <text x="148" y="284" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="9" fill="#B8D4F0">1F</text>

  <!-- ============================================================= -->
  <!--  ELEVATOR SHAFT                                                -->
  <!-- ============================================================= -->
  <!-- Shaft background -->
  <rect x="254" y="68" width="52" height="244" fill="#0F2A4A" stroke="#2B5580" stroke-width="1" />

  <!-- Guide rails (thin vertical strokes) -->
  <line x1="260" y1="68" x2="260" y2="312" stroke="#2B5580" stroke-width="0.6" stroke-dasharray="4 3" />
  <line x1="300" y1="68" x2="300" y2="312" stroke="#2B5580" stroke-width="0.6" stroke-dasharray="4 3" />

  <!-- Floor indicator dots (right side of shaft) -->
  <circle cx="316" cy="88"  r="3" fill="none" stroke="#2B5580" stroke-width="1" />
  <circle cx="316" cy="136" r="3" fill="none" stroke="#2B5580" stroke-width="1" />
  <circle cx="316" cy="184" r="3" fill="none" stroke="#2B5580" stroke-width="1" />
  <circle cx="316" cy="232" r="3" fill="none" stroke="#2B5580" stroke-width="1" />
  <circle cx="316" cy="280" r="3" fill="none" stroke="#2B5580" stroke-width="1" />

  <!-- Active floor indicator (animated) -->
  <circle class="floor-dot-active" cx="316" cy="104" r="3" fill="#2567C2" />

  <!-- ============================================================= -->
  <!--  ELEVATOR CABIN (starts at 4F ~ y=104)                        -->
  <!-- ============================================================= -->
  <g class="cabin-group">
    <!-- Cabin body -->
    <rect x="262" y="104" width="36" height="40" rx="2" fill="#2B5580" stroke="#B8D4F0" stroke-width="1" />

    <!-- Door panels -->
    <rect class="door-left"  x="268" y="112" width="10" height="28" rx="1" fill="#2B5580" stroke="#2B5580" stroke-width="0.6" />
    <rect class="door-right" x="282" y="112" width="10" height="28" rx="1" fill="#2B5580" stroke="#2B5580" stroke-width="0.6" />

    <!-- Door gap line -->
    <line x1="280" y1="112" x2="280" y2="140" stroke="#0F2A4A" stroke-width="0.5" />

    <!-- Cabin roof indicator light -->
    <circle class="cabin-light" cx="280" cy="100" r="2.5" fill="#2567C2" />
  </g>

  <!-- ============================================================= -->
  <!--  UTILITY POWER LINE (enters from left at ground level)        -->
  <!-- ============================================================= -->
  <!-- Live segment (before break) -->
  <line class="utility-line-live" x1="20" y1="290" x2="110" y2="290" stroke="#2567C2" stroke-width="2" />

  <!-- Power break point (animated flash) -->
  <g class="power-break-flash">
    <!-- Zigzag break symbol -->
    <polyline
      points="110,286 116,294 122,282 128,298 134,286"
      fill="none" stroke="#FF3B3B" stroke-width="2" stroke-linecap="round"
    />
    <circle cx="122" cy="290" r="12" fill="none" stroke="#FF3B3B" stroke-width="0.8" opacity="0.4" />
  </g>

  <!-- Dead segment (after break) -->
  <line x1="134" y1="290" x2="160" y2="290" stroke="#2B5580" stroke-width="2" />

  <!-- Utility label -->
  <text x="40" y="282" font-family="'DM Sans', sans-serif" font-size="7" fill="#B8D4F0">UTILITY</text>

  <!-- ============================================================= -->
  <!--  INVERTER / BACKUP POWER UNIT (below shaft)                   -->
  <!-- ============================================================= -->
  <g transform="translate(246, 316)">
    <!-- Inverter box -->
    <rect class="inverter-border" x="0" y="0" width="68" height="30" rx="3" fill="#2B5580" stroke="#2B5580" stroke-width="1.5" />

    <!-- OLP label -->
    <text x="34" y="18" text-anchor="middle" font-family="'Barlow Condensed', sans-serif" font-weight="700" font-size="11" fill="#2567C2">OLP</text>

    <!-- Battery symbol (left of inverter) -->
    <g transform="translate(-30, 6)">
      <rect x="0" y="2" width="18" height="12" rx="2" fill="none" stroke="#B8D4F0" stroke-width="1" />
      <rect x="18" y="5" width="3" height="6" rx="1" fill="#B8D4F0" />
      <!-- Battery charge bars -->
      <rect x="3" y="5" width="3" height="6" rx="0.5" fill="#2567C2" />
      <rect x="8" y="5" width="3" height="6" rx="0.5" fill="#2567C2" />
      <rect x="13" y="5" width="3" height="6" rx="0.5" fill="#2567C2" opacity="0.4" />
    </g>

    <!-- 2HR RUNTIME badge -->
    <g transform="translate(74, 2)">
      <rect x="0" y="0" width="62" height="18" rx="9" fill="none" stroke="#2567C2" stroke-width="0.8" opacity="0.7" />
      <text x="31" y="12" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="7" fill="#2567C2">2HR RUNTIME</text>
    </g>
  </g>

  <!-- Backup power line from inverter up the shaft -->
  <line x1="280" y1="316" x2="280" y2="312" stroke="#2B5580" stroke-width="1.5" />

  <!-- ============================================================= -->
  <!--  BACKUP POWER FLOW DOTS (ascending the shaft)                 -->
  <!-- ============================================================= -->
  <g class="power-dots-group">
    <circle class="power-dot" cx="280" cy="310" r="2" fill="#2567C2" style="animation-delay: 0s" />
    <circle class="power-dot" cx="280" cy="310" r="2" fill="#2567C2" style="animation-delay: 0.5s" />
    <circle class="power-dot" cx="280" cy="310" r="2" fill="#2567C2" style="animation-delay: 1.0s" />
    <circle class="power-dot" cx="280" cy="310" r="2" fill="#2567C2" style="animation-delay: 1.5s" />
  </g>

  <!-- ============================================================= -->
  <!--  SAFE EVACUATION TEXT                                          -->
  <!-- ============================================================= -->
  <text
    class="safe-evac-text"
    x="380"
    y="290"
    font-family="'Barlow Condensed', sans-serif"
    font-weight="700"
    font-size="13"
    fill="#2567C2"
       opacity="0"
  >SAFE EVACUATION</text>

  <!-- ============================================================= -->
  <!--  BOTTOM CAPTION                                                -->
  <!-- ============================================================= -->
  <text
    x="300"
    y="354"
    text-anchor="middle"
    font-family="'DM Sans', sans-serif"
    font-size="9"
    fill="#2B5580"
  >// ELEVATOR BACKUP &middot; UL 924</text>
</svg>

<style>
  .elevator-backup-illustration {
    width: 100%;
    max-width: 600px;
    height: auto;
    display: block;
  }
</style>
