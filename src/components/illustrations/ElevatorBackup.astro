<svg viewBox="0 0 480 360" width="100%" xmlns="http://www.w3.org/2000/svg">
  <style>
    @keyframes ev-dot-down {
      0%   { offset-distance: 0%; opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { offset-distance: 100%; opacity: 0; }
    }
    @keyframes ev-dot-up {
      0%   { offset-distance: 100%; opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { offset-distance: 0%; opacity: 0; }
    }
    .dot-down { animation: ev-dot-down 2s linear infinite; }
    .dot-up   { animation: ev-dot-up 2s linear infinite; }
  </style>

  <!-- ====== UTILITY / GRID (top left) ====== -->
  <rect x="30" y="30" width="130" height="60" rx="4" fill="#1A3F6A" stroke="#3D6A9E" stroke-width="1.5"/>
  <text x="95" y="55" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="14" font-weight="700" fill="#FFFFFF" letter-spacing="1">UTILITY GRID</text>
  <text x="95" y="72" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">480V 3-Phase</text>

  <!-- ====== OLP INVERTER (center) ====== -->
  <rect x="140" y="145" width="200" height="70" rx="5" fill="#2B5580" stroke="#2567C2" stroke-width="2"/>
  <text x="240" y="172" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="16" font-weight="700" fill="#FFFFFF" letter-spacing="1">OLP INVERTER</text>
  <text x="240" y="195" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">UL 924 · UL 1778 · Bidirectional</text>

  <!-- ====== ELEVATOR MOTOR (top right) ====== -->
  <rect x="320" y="30" width="130" height="60" rx="4" fill="#1A3F6A" stroke="#3D6A9E" stroke-width="1.5"/>
  <circle cx="385" cy="55" r="16" fill="none" stroke="#7EB3F5" stroke-width="2"/>
  <text x="385" y="61" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="14" fill="#7EB3F5" font-weight="700">M</text>
  <text x="385" y="105" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="10" fill="#B8D4F0">ELEVATOR</text>

  <!-- ====== BATTERY (bottom center) ====== -->
  <rect x="170" y="275" width="140" height="50" rx="4" fill="#2B5580" stroke="#3D6A9E" stroke-width="1.5"/>
  <rect x="185" y="288" width="14" height="22" rx="2" fill="#34D399" opacity="0.7"/>
  <rect x="205" y="288" width="14" height="22" rx="2" fill="#34D399" opacity="0.55"/>
  <rect x="225" y="288" width="14" height="22" rx="2" fill="#34D399" opacity="0.4"/>
  <rect x="245" y="288" width="14" height="22" rx="2" fill="#34D399" opacity="0.25"/>
  <rect x="265" y="288" width="14" height="22" rx="2" fill="#3D6A9E" opacity="0.3"/>
  <text x="240" y="340" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="10" fill="#B8D4F0">BATTERY · 2HR RUNTIME</text>

  <!-- ============================================ -->
  <!-- POWER FLOW: Utility → Inverter (blue, down)  -->
  <!-- ============================================ -->
  <line x1="95" y1="90" x2="180" y2="145" stroke="#2567C2" stroke-width="2.5"/>
  <circle r="4" fill="#2567C2" class="dot-down" style="offset-path: path('M95,90 L180,145');"/>
  <circle r="4" fill="#2567C2" class="dot-down" style="offset-path: path('M95,90 L180,145'); animation-delay: 1s;"/>
  <!-- Arrow label -->
  <text x="110" y="118" font-family="Barlow Condensed, sans-serif" font-size="10" fill="#2567C2" font-weight="600" transform="rotate(-28 110 118)">POWER IN</text>

  <!-- ============================================ -->
  <!-- POWER FLOW: Inverter → Elevator (blue, up)   -->
  <!-- ============================================ -->
  <line x1="300" y1="145" x2="385" y2="90" stroke="#2567C2" stroke-width="2.5"/>
  <circle r="4" fill="#2567C2" class="dot-down" style="offset-path: path('M300,145 L385,90');"/>
  <circle r="4" fill="#2567C2" class="dot-down" style="offset-path: path('M300,145 L385,90'); animation-delay: 1s;"/>
  <!-- Arrow label -->
  <text x="355" y="132" font-family="Barlow Condensed, sans-serif" font-size="10" fill="#2567C2" font-weight="600" transform="rotate(28 355 132)">TO MOTOR</text>

  <!-- ============================================ -->
  <!-- REGEN FLOW: Elevator → Inverter (GREEN, back) -->
  <!-- ============================================ -->
  <line x1="370" y1="90" x2="310" y2="145" stroke="#34D399" stroke-width="2" stroke-dasharray="6 3"/>
  <circle r="3.5" fill="#34D399" class="dot-up" style="offset-path: path('M310,145 L370,90');"/>
  <circle r="3.5" fill="#34D399" class="dot-up" style="offset-path: path('M310,145 L370,90'); animation-delay: 0.9s;"/>
  <!-- Arrow label -->
  <rect x="340" y="112" width="70" height="16" rx="3" fill="#0F2A4A"/>
  <text x="375" y="124" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="9" fill="#34D399" font-weight="700" letter-spacing="0.5">REGEN ↩</text>

  <!-- ============================================ -->
  <!-- REGEN → UTILITY (GREEN, inverter to grid)    -->
  <!-- ============================================ -->
  <line x1="170" y1="155" x2="95" y2="90" stroke="#34D399" stroke-width="2" stroke-dasharray="6 3"/>
  <circle r="3.5" fill="#34D399" class="dot-up" style="offset-path: path('M95,90 L170,155');"/>
  <!-- Arrow label -->
  <rect x="70" y="118" width="85" height="16" rx="3" fill="#0F2A4A"/>
  <text x="112" y="130" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="9" fill="#34D399" font-weight="700" letter-spacing="0.5">→ BACK TO GRID</text>

  <!-- ============================================ -->
  <!-- Battery ↔ Inverter (bidirectional)           -->
  <!-- ============================================ -->
  <line x1="240" y1="215" x2="240" y2="275" stroke="#2567C2" stroke-width="2"/>
  <circle r="3" fill="#2567C2" class="dot-down" style="offset-path: path('M240,215 L240,275'); animation-delay: 0.5s;"/>
  <!-- Also receives regen in EM -->
  <line x1="250" y1="275" x2="250" y2="215" stroke="#34D399" stroke-width="1.5" stroke-dasharray="5 3" opacity="0.5"/>
  <text x="275" y="250" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">Charge /</text>
  <text x="275" y="261" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">Backup</text>

  <!-- ====== LEGEND ====== -->
  <g transform="translate(30, 280)">
    <line x1="0" y1="8" x2="20" y2="8" stroke="#2567C2" stroke-width="2.5"/>
    <text x="25" y="12" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">Power draw</text>

    <line x1="0" y1="28" x2="20" y2="28" stroke="#34D399" stroke-width="2" stroke-dasharray="5 3"/>
    <text x="25" y="32" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">Regen return</text>
  </g>

  <!-- Caption -->
  <text x="240" y="356" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#3D6A9E">POWER WAVE ELEVATE · BIDIRECTIONAL REGEN · UL 924</text>
</svg>
