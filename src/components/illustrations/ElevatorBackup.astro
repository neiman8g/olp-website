<svg viewBox="0 0 560 340" width="100%" xmlns="http://www.w3.org/2000/svg">
  <style>
    @keyframes ev-fail {
      0%, 35%   { opacity: 1; }
      40%, 85%  { opacity: 0; }
      90%, 100% { opacity: 1; }
    }
    @keyframes ev-em {
      0%, 38%   { opacity: 0; }
      42%, 87%  { opacity: 1; }
      90%, 100% { opacity: 0; }
    }
    @keyframes ev-dot {
      0%   { offset-distance: 0%; opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { offset-distance: 100%; opacity: 0; }
    }
    @keyframes ev-flash {
      0%, 38% { opacity: 0; }
      39%     { opacity: 1; }
      41%     { opacity: 0; }
      43%     { opacity: 0.7; }
      45%,100%{ opacity: 0; }
    }
    @keyframes ev-regen {
      0%   { offset-distance: 100%; opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { offset-distance: 0%; opacity: 0; }
    }
    .normal  { animation: ev-fail 8s ease-in-out infinite; }
    .em-on   { animation: ev-em 8s ease-in-out infinite; }
    .flash   { animation: ev-flash 8s ease-in-out infinite; }
    .dot     { animation: ev-dot 1.8s linear infinite; }
    .regen   { animation: ev-regen 1.8s linear infinite; }
  </style>

  <!-- ====== LABELS ====== -->
  <text x="140" y="18" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#B8D4F0" letter-spacing="2">NORMAL OPERATION</text>
  <text x="420" y="18" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#2567C2" letter-spacing="2">EMERGENCY MODE</text>
  <line x1="280" y1="8" x2="280" y2="332" stroke="#3D6A9E" stroke-width="0.5" stroke-dasharray="6 4"/>

  <!-- ============================================ -->
  <!-- LEFT: NORMAL — regen goes back to building   -->
  <!-- ============================================ -->

  <!-- Building -->
  <g class="normal">
    <rect x="25" y="35" width="55" height="50" rx="3" fill="#1A3F6A" stroke="#3D6A9E" stroke-width="1"/>
    <rect x="33" y="42" width="8" height="8" rx="1" fill="#FFD580" opacity="0.3"/>
    <rect x="45" y="42" width="8" height="8" rx="1" fill="#FFD580" opacity="0.3"/>
    <rect x="57" y="42" width="8" height="8" rx="1" fill="#FFD580" opacity="0.3"/>
    <rect x="33" y="54" width="8" height="8" rx="1" fill="#FFD580" opacity="0.3"/>
    <rect x="45" y="54" width="8" height="8" rx="1" fill="#FFD580" opacity="0.3"/>
    <rect x="57" y="54" width="8" height="8" rx="1" fill="#FFD580" opacity="0.3"/>
    <text x="52" y="98" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">BUILDING</text>
    <text x="52" y="108" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#34D399">GRID OK</text>
  </g>

  <!-- Inverter -->
  <rect x="90" y="140" width="120" height="50" rx="4" fill="#2B5580" stroke="#2567C2" stroke-width="1.5"/>
  <text x="150" y="160" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#FFFFFF" letter-spacing="1">OLP INVERTER</text>
  <text x="150" y="175" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#B8D4F0">UL 924 · UL 1778</text>

  <!-- Elevator motor -->
  <g class="normal">
    <rect x="200" y="35" width="55" height="50" rx="3" fill="#1A3F6A" stroke="#3D6A9E" stroke-width="1"/>
    <circle cx="227" cy="57" r="14" fill="none" stroke="#7EB3F5" stroke-width="1.5"/>
    <text x="227" y="62" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="10" fill="#7EB3F5" font-weight="700">M</text>
    <text x="227" y="98" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">ELEVATOR</text>
  </g>

  <!-- Battery -->
  <rect x="115" y="225" width="70" height="30" rx="3" fill="#2B5580" stroke="#3D6A9E" stroke-width="1"/>
  <rect x="122" y="232" width="10" height="16" rx="1" fill="#34D399" opacity="0.6"/>
  <rect x="136" y="232" width="10" height="16" rx="1" fill="#34D399" opacity="0.5"/>
  <rect x="150" y="232" width="10" height="16" rx="1" fill="#34D399" opacity="0.4"/>
  <rect x="164" y="232" width="10" height="16" rx="1" fill="#34D399" opacity="0.3"/>
  <text x="150" y="270" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">BATTERY</text>

  <!-- NORMAL FLOWS -->
  <g class="normal">
    <!-- Utility → Inverter -->
    <line x1="80" y1="60" x2="100" y2="160" stroke="#34D399" stroke-width="2"/>
    <!-- Inverter → Motor (power draw) -->
    <line x1="210" y1="160" x2="227" y2="85" stroke="#2567C2" stroke-width="2"/>
    <circle r="3" fill="#2567C2" class="dot" style="offset-path: path('M210,160 L227,85');"/>
    <circle r="3" fill="#2567C2" class="dot" style="offset-path: path('M210,160 L227,85'); animation-delay: 0.6s;"/>

    <!-- REGEN: Motor → Inverter → Building -->
    <path d="M227,85 L150,155 L52,85" fill="none" stroke="#FFD580" stroke-width="1.5" stroke-dasharray="5 3" opacity="0.5"/>
    <circle r="3" fill="#FFD580" class="regen" style="offset-path: path('M227,85 L150,155 L52,85');" opacity="0.9"/>
    <circle r="3" fill="#FFD580" class="regen" style="offset-path: path('M227,85 L150,155 L52,85'); animation-delay: 0.9s;" opacity="0.9"/>

    <!-- Label -->
    <text x="140" y="125" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="9" fill="#FFD580" font-weight="600" letter-spacing="0.5">REGEN → GRID</text>
  </g>

  <!-- Normal caption -->
  <g class="normal">
    <rect x="25" y="290" width="230" height="26" rx="4" fill="#1A3F6A"/>
    <text x="140" y="307" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">Regen power returned to building</text>
  </g>

  <!-- ============================================ -->
  <!-- RIGHT: EM — regen charges batteries          -->
  <!-- ============================================ -->

  <!-- Building FAILED -->
  <g class="em-on">
    <rect x="305" y="35" width="55" height="50" rx="3" fill="#1A3F6A" stroke="#FF3B3B" stroke-width="1" stroke-dasharray="4 3"/>
    <line x1="320" y1="48" x2="348" y2="72" stroke="#FF3B3B" stroke-width="1.5"/>
    <line x1="348" y1="48" x2="320" y2="72" stroke="#FF3B3B" stroke-width="1.5"/>
    <text x="332" y="98" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#FF3B3B" font-weight="700">UTILITY FAIL</text>
  </g>

  <!-- Inverter EM -->
  <g class="em-on">
    <rect x="370" y="140" width="120" height="50" rx="4" fill="#2B5580" stroke="#2567C2" stroke-width="2"/>
    <text x="430" y="160" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#FFFFFF" letter-spacing="1">OLP INVERTER</text>
    <text x="430" y="175" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#2567C2" font-weight="700">EM ACTIVE</text>
  </g>

  <!-- Elevator motor -->
  <g class="em-on">
    <rect x="480" y="35" width="55" height="50" rx="3" fill="#1A3F6A" stroke="#2567C2" stroke-width="1"/>
    <circle cx="507" cy="57" r="14" fill="none" stroke="#7EB3F5" stroke-width="1.5"/>
    <text x="507" y="62" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="10" fill="#7EB3F5" font-weight="700">M</text>
    <text x="507" y="98" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">ELEVATOR</text>
  </g>

  <!-- Battery (discharging + receiving regen) -->
  <g class="em-on">
    <rect x="395" y="225" width="70" height="30" rx="3" fill="#2B5580" stroke="#2567C2" stroke-width="1"/>
    <rect x="402" y="232" width="10" height="16" rx="1" fill="#34D399" opacity="0.6"/>
    <rect x="416" y="232" width="10" height="16" rx="1" fill="#34D399" opacity="0.4"/>
    <rect x="430" y="232" width="10" height="16" rx="1" fill="#34D399" opacity="0.2"/>
    <rect x="444" y="232" width="10" height="16" rx="1" fill="#3D6A9E" opacity="0.3"/>
    <text x="430" y="270" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="8" fill="#B8D4F0">BATTERY</text>
  </g>

  <!-- EM FLOWS -->
  <g class="em-on">
    <!-- Battery → Inverter -->
    <line x1="430" y1="225" x2="430" y2="190" stroke="#2567C2" stroke-width="2"/>
    <circle r="3" fill="#2567C2" class="dot" style="offset-path: path('M430,225 L430,190');"/>

    <!-- Inverter → Motor -->
    <line x1="490" y1="160" x2="507" y2="85" stroke="#2567C2" stroke-width="2"/>
    <circle r="3" fill="#2567C2" class="dot" style="offset-path: path('M490,160 L507,85');"/>
    <circle r="3" fill="#2567C2" class="dot" style="offset-path: path('M490,160 L507,85'); animation-delay: 0.6s;"/>

    <!-- REGEN: Motor → Inverter → BATTERY -->
    <path d="M507,85 L430,155 L430,225" fill="none" stroke="#FFD580" stroke-width="1.5" stroke-dasharray="5 3" opacity="0.5"/>
    <circle r="3" fill="#FFD580" class="regen" style="offset-path: path('M507,85 L430,155 L430,225');" opacity="0.9"/>

    <!-- Label -->
    <text x="470" y="125" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="9" fill="#FFD580" font-weight="600" letter-spacing="0.5">REGEN → BATT</text>
  </g>

  <!-- EM caption -->
  <g class="em-on">
    <rect x="310" y="290" width="230" height="26" rx="4" fill="#1A3F6A"/>
    <text x="425" y="307" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">Regen power charges batteries in EM</text>
  </g>

  <!-- Flash on left building when power fails -->
  <g class="flash">
    <line x1="45" y1="48" x2="60" y2="68" stroke="#FF3B3B" stroke-width="2"/>
    <line x1="60" y1="48" x2="45" y2="68" stroke="#FF3B3B" stroke-width="2"/>
  </g>

  <!-- Caption -->
  <text x="280" y="335" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#3D6A9E">ELEVATOR BACKUP · BIDIRECTIONAL REGEN · UL 924</text>
</svg>
