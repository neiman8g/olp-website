---
/**
 * Monitoring.astro
 * SVG illustration of a Global Monitoring System (GMS) dashboard displayed
 * on a laptop screen, showing floor-plan equipment status, battery health
 * gauge, and inverter system status with real-time data flow animations.
 */
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 600 360"
  fill="none"
  role="img"
  aria-label="Global Monitoring System dashboard on laptop showing floor plan, battery health gauge, and inverter status with real-time data flow"
  class="monitoring-illustration"
>
  <defs>
    <style>
      /* Fonts inherited from BaseLayout */

      .font-display { font-family: 'Barlow Condensed', sans-serif; }
      .font-mono { font-family: 'DM Sans', monospace; }

      /* ===== STAGGERED FADE-IN (simulates page load) ===== */
      @keyframes fadeIn {
        0% { opacity: 0; transform: translateY(4px); }
        100% { opacity: 1; transform: translateY(0); }
      }
      .fade-1 { animation: fadeIn 0.6s 0.1s both ease-out; }
      .fade-2 { animation: fadeIn 0.6s 0.3s both ease-out; }
      .fade-3 { animation: fadeIn 0.6s 0.5s both ease-out; }
      .fade-4 { animation: fadeIn 0.6s 0.7s both ease-out; }
      .fade-5 { animation: fadeIn 0.6s 0.9s both ease-out; }

      /* ===== EQUIPMENT DOT PULSES ===== */
      @keyframes pulseGreen {
        0%, 100% { r: 3; opacity: 1; }
        50% { r: 4.5; opacity: 0.7; }
      }
      @keyframes pulseAmber {
        0%, 100% { r: 3; opacity: 1; }
        50% { r: 5; opacity: 0.6; }
      }
      @keyframes pulseRed {
        0%, 100% { r: 3; opacity: 1; }
        50% { r: 4; opacity: 0.7; }
      }
      @keyframes blinkAmber {
        0%, 40%, 100% { opacity: 1; }
        50%, 90% { opacity: 0.3; }
      }

      .dot-green { animation: pulseGreen 3s ease-in-out infinite; }
      .dot-green-slow { animation: pulseGreen 4s 0.5s ease-in-out infinite; }
      .dot-green-mid { animation: pulseGreen 3.5s 1s ease-in-out infinite; }
      .dot-amber { animation: blinkAmber 1.4s ease-in-out infinite; }
      .dot-red { animation: pulseRed 2s ease-in-out infinite; }

      /* ===== BATTERY GAUGE NEEDLE ===== */
      @keyframes needleOscillate {
        0%, 100% { transform: rotate(-47deg); }
        33% { transform: rotate(-48.5deg); }
        66% { transform: rotate(-45.5deg); }
      }
      .gauge-needle {
        transform-origin: 320px 148px;
        animation: needleOscillate 4s ease-in-out infinite;
      }

      /* ===== DATA FLOW DOTS ===== */
      @keyframes flowUp1 {
        0% { opacity: 0; transform: translateY(0); }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { opacity: 0; transform: translateY(-60px); }
      }
      @keyframes flowUp2 {
        0% { opacity: 0; transform: translateY(0); }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { opacity: 0; transform: translateY(-55px); }
      }
      @keyframes flowUp3 {
        0% { opacity: 0; transform: translateY(0); }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { opacity: 0; transform: translateY(-58px); }
      }

      .data-dot-1 { animation: flowUp1 2s linear infinite; }
      .data-dot-2 { animation: flowUp2 2s 0.6s linear infinite; }
      .data-dot-3 { animation: flowUp3 2s 1.2s linear infinite; }
      .data-dot-4 { animation: flowUp1 2.2s 0.3s linear infinite; }
      .data-dot-5 { animation: flowUp2 1.8s 0.9s linear infinite; }
      .data-dot-6 { animation: flowUp3 2.4s 0.4s linear infinite; }
      .data-dot-7 { animation: flowUp1 2s 1.5s linear infinite; }
      .data-dot-8 { animation: flowUp2 2.1s 0.2s linear infinite; }
      .data-dot-9 { animation: flowUp3 1.9s 1s linear infinite; }

      /* ===== CONNECTION STATUS BLINK ===== */
      @keyframes connBlink {
        0%, 70%, 100% { opacity: 1; }
        75%, 95% { opacity: 0.4; }
      }
      .conn-dot { animation: connBlink 3s ease infinite; }

      /* ===== CLOCK COLON BLINK ===== */
      @keyframes colonBlink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0.3; }
      }
      .clock-colon { animation: colonBlink 1s step-end infinite; }
    </style>

    <!-- Battery gauge gradient arc -->
    <linearGradient id="gaugeGrad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#FF3B3B" />
      <stop offset="40%" stop-color="#FBBF24" />
      <stop offset="70%" stop-color="#34D399" />
      <stop offset="100%" stop-color="#34D399" />
    </linearGradient>
  </defs>

  <!-- ============================================================ -->
  <!-- BACKGROUND                                                    -->
  <!-- ============================================================ -->
  <rect width="600" height="360" fill="#0F2A4A" rx="4" />

  <!-- ============================================================ -->
  <!-- LAPTOP / MONITOR                                              -->
  <!-- ============================================================ -->
  <g class="fade-1">
    <!-- Screen bezel -->
    <rect x="55" y="18" width="490" height="238" rx="6" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="2" />
    <!-- Inner screen area -->
    <rect x="63" y="26" width="474" height="222" rx="3" fill="#0F2A4A" />
    <!-- Laptop base -->
    <path d="M30 256 L55 256 L55 258 Q55 262 59 262 L541 262 Q545 262 545 258 L545 256 L570 256 L560 272 Q558 276 554 276 L46 276 Q42 276 40 272 Z" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="1" />
    <!-- Hinge line -->
    <line x1="55" y1="256" x2="545" y2="256" stroke="#1A3F6A" stroke-width="1.5" />
    <!-- Webcam dot -->
    <circle cx="300" cy="22" r="1.5" fill="#1A3F6A" />
  </g>

  <!-- ============================================================ -->
  <!-- DASHBOARD TOP BAR                                             -->
  <!-- ============================================================ -->
  <g class="fade-2">
    <!-- Top bar background -->
    <rect x="63" y="26" width="474" height="22" rx="3" fill="#1A3F6A" />
    <line x1="63" y1="48" x2="537" y2="48" stroke="#1A3F6A" stroke-width="0.5" />

    <!-- GMS Logo -->
    <text x="74" y="41" class="font-display" font-size="11" font-weight="700" fill="#2A7AE2">GMS</text>

    <!-- ONLINE POWER branding -->
    <text x="104" y="41" class="font-display" font-size="8" font-weight="400" fill="#94AECF">ONLINE POWER</text>

    <!-- Live clock -->
    <text x="370" y="41" class="font-mono" font-size="8" fill="#FFFFFF">14</text>
    <text x="381" y="41" class="font-mono clock-colon" font-size="8" fill="#FFFFFF">:</text>
    <text x="385" y="41" class="font-mono" font-size="8" fill="#FFFFFF">32</text>
    <text x="396" y="41" class="font-mono clock-colon" font-size="8" fill="#FFFFFF">:</text>
    <text x="400" y="41" class="font-mono" font-size="8" fill="#94AECF">07</text>

    <!-- Connection status -->
    <circle cx="430" cy="38" r="2.5" fill="#34D399" class="conn-dot" />
    <text x="436" y="41" class="font-mono" font-size="7" fill="#34D399">CONNECTED</text>

    <!-- Protocol badges -->
    <rect x="488" y="32" width="28" height="12" rx="2" fill="none" stroke="#1A3F6A" stroke-width="0.5" />
    <text x="492" y="41" class="font-mono" font-size="5.5" fill="#94AECF">BACnet</text>

    <rect x="484" y="32" width="0" height="0" />

    <g transform="translate(0, 0)">
      <rect x="490" y="32" width="22" height="12" rx="2" fill="none" stroke="#1A3F6A" stroke-width="0.5" />
      <text x="493" y="41" class="font-mono" font-size="5.5" fill="#94AECF">BACn</text>
    </g>

    <!-- Redone protocol badges properly spaced -->
  </g>

  <!-- Protocol badges - clean placement -->
  <g class="fade-2">
    <rect x="480" y="32" width="16" height="11" rx="2" fill="#1A3F6A" fill-opacity="0.5" stroke="#1A3F6A" stroke-width="0.5" />
    <text x="481.5" y="40.5" class="font-mono" font-size="4.5" fill="#94AECF">BACn</text>

    <rect x="499" y="32" width="18" height="11" rx="2" fill="#1A3F6A" fill-opacity="0.5" stroke="#1A3F6A" stroke-width="0.5" />
    <text x="500.5" y="40.5" class="font-mono" font-size="4.5" fill="#94AECF">Modbs</text>

    <rect x="520" y="32" width="16" height="11" rx="2" fill="#1A3F6A" fill-opacity="0.5" stroke="#1A3F6A" stroke-width="0.5" />
    <text x="522" y="40.5" class="font-mono" font-size="4.5" fill="#94AECF">SNMP</text>
  </g>

  <!-- ============================================================ -->
  <!-- PANEL 1 — FLOOR PLAN (left)                                   -->
  <!-- ============================================================ -->
  <g class="fade-3" transform="translate(68, 52)">
    <!-- Panel background -->
    <rect width="155" height="190" rx="3" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.5" />
    <text x="8" y="14" class="font-mono" font-size="6.5" fill="#94AECF">FLOOR PLAN</text>
    <line x1="8" y1="18" x2="147" y2="18" stroke="#1A3F6A" stroke-width="0.5" />

    <!-- Building outline -->
    <rect x="10" y="24" width="135" height="155" rx="2" fill="none" stroke="#1A3F6A" stroke-width="0.75" />

    <!-- Room dividers -->
    <!-- Horizontal divider -->
    <line x1="10" y1="100" x2="145" y2="100" stroke="#1A3F6A" stroke-width="0.5" />
    <!-- Vertical dividers top row -->
    <line x1="60" y1="24" x2="60" y2="100" stroke="#1A3F6A" stroke-width="0.5" />
    <line x1="110" y1="24" x2="110" y2="100" stroke="#1A3F6A" stroke-width="0.5" />
    <!-- Vertical divider bottom row -->
    <line x1="80" y1="100" x2="80" y2="179" stroke="#1A3F6A" stroke-width="0.5" />

    <!-- Room labels -->
    <text x="22" y="34" class="font-mono" font-size="4.5" fill="#1A3F6A">RM-A1</text>
    <text x="72" y="34" class="font-mono" font-size="4.5" fill="#1A3F6A">RM-A2</text>
    <text x="118" y="34" class="font-mono" font-size="4.5" fill="#1A3F6A">RM-A3</text>
    <text x="22" y="110" class="font-mono" font-size="4.5" fill="#1A3F6A">RM-B1</text>
    <text x="100" y="110" class="font-mono" font-size="4.5" fill="#1A3F6A">RM-B2</text>

    <!-- Equipment dots — Room A1 (green healthy) -->
    <circle cx="25" cy="55" r="3" fill="#34D399" class="dot-green" />
    <circle cx="40" cy="70" r="3" fill="#34D399" class="dot-green-slow" />

    <!-- Equipment dots — Room A2 (green + amber warning) -->
    <circle cx="78" cy="60" r="3" fill="#34D399" class="dot-green-mid" />
    <circle cx="90" cy="78" r="3" fill="#FBBF24" class="dot-amber" />

    <!-- Equipment dots — Room A3 (green) -->
    <circle cx="125" cy="58" r="3" fill="#34D399" class="dot-green" />

    <!-- Equipment dots — Room B1 (red alert) -->
    <circle cx="35" cy="135" r="3" fill="#FF3B3B" class="dot-red" />
    <circle cx="55" cy="150" r="3" fill="#34D399" class="dot-green-slow" />

    <!-- Equipment dots — Room B2 (green) -->
    <circle cx="110" cy="140" r="3" fill="#34D399" class="dot-green-mid" />
    <circle cx="130" cy="155" r="3" fill="#34D399" class="dot-green" />

    <!-- Legend -->
    <circle cx="14" cy="186" r="2" fill="#34D399" />
    <text x="19" y="188" class="font-mono" font-size="4" fill="#94AECF">OK</text>
    <circle cx="36" cy="186" r="2" fill="#FBBF24" />
    <text x="41" y="188" class="font-mono" font-size="4" fill="#94AECF">WARN</text>
    <circle cx="64" cy="186" r="2" fill="#FF3B3B" />
    <text x="69" y="188" class="font-mono" font-size="4" fill="#94AECF">ALERT</text>
  </g>

  <!-- ============================================================ -->
  <!-- PANEL 2 — BATTERY HEALTH GAUGE (center)                      -->
  <!-- ============================================================ -->
  <g class="fade-4" transform="translate(230, 52)">
    <!-- Panel background -->
    <rect width="150" height="190" rx="3" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.5" />
    <text x="8" y="14" class="font-mono" font-size="6.5" fill="#94AECF">BATTERY HEALTH</text>
    <line x1="8" y1="18" x2="142" y2="18" stroke="#1A3F6A" stroke-width="0.5" />

    <!-- Gauge background arc -->
    <g transform="translate(75, 100)">
      <!-- Outer arc track -->
      <path d="M-50 10 A 55 55 0 0 1 50 10" fill="none" stroke="#1A3F6A" stroke-width="8" stroke-linecap="round" />

      <!-- Colored arc (gradient) -->
      <!-- Red zone (0-40%) -->
      <path d="M-50 10 A 55 55 0 0 1 -42 -25" fill="none" stroke="#FF3B3B" stroke-width="7" stroke-linecap="round" opacity="0.9" />
      <!-- Amber zone (40-70%) -->
      <path d="M-42 -25 A 55 55 0 0 1 -5 -54" fill="none" stroke="#FBBF24" stroke-width="7" stroke-linecap="round" opacity="0.9" />
      <!-- Green zone (70-100%) -->
      <path d="M-5 -54 A 55 55 0 0 1 50 10" fill="none" stroke="#34D399" stroke-width="7" stroke-linecap="round" opacity="0.9" />

      <!-- Gauge tick marks -->
      <line x1="-50" y1="10" x2="-44" y2="10" stroke="#94AECF" stroke-width="0.5" />
      <line x1="50" y1="10" x2="44" y2="10" stroke="#94AECF" stroke-width="0.5" />
      <line x1="0" y1="-55" x2="0" y2="-49" stroke="#94AECF" stroke-width="0.5" />

      <!-- Tick labels -->
      <text x="-56" y="14" class="font-mono" font-size="5" fill="#94AECF" text-anchor="end">0</text>
      <text x="58" y="14" class="font-mono" font-size="5" fill="#94AECF">100</text>

      <!-- Needle — pointing to ~87% (approx 252 degrees from start) -->
      <g class="gauge-needle" style="transform-origin: 0px 0px;">
        <line x1="0" y1="0" x2="38" y2="-28" stroke="#FFFFFF" stroke-width="1.5" stroke-linecap="round" />
        <circle cx="0" cy="0" r="3" fill="#FFFFFF" />
      </g>

      <!-- Center percentage text -->
      <text x="0" y="26" class="font-display" font-size="22" font-weight="700" fill="#FFFFFF" text-anchor="middle">87%</text>
    </g>

    <!-- 9 WEEKS NOTICE badge -->
    <rect x="24" y="138" width="102" height="20" rx="3" fill="#0F2A4A" stroke="#2A7AE2" stroke-width="0.75" />
    <text x="75" y="148" class="font-mono" font-size="5.5" fill="#2A7AE2" text-anchor="middle">9 WEEKS NOTICE</text>
    <text x="75" y="156" class="font-mono" font-size="4" fill="#94AECF" text-anchor="middle">Predictive Alert</text>

    <!-- Sub label -->
    <text x="75" y="174" class="font-mono" font-size="5" fill="#94AECF" text-anchor="middle">AVG CELL: 1.215 V/Cell</text>
    <text x="75" y="182" class="font-mono" font-size="5" fill="#34D399" text-anchor="middle">TREND: STABLE</text>
  </g>

  <!-- ============================================================ -->
  <!-- PANEL 3 — SYSTEM STATUS (right)                               -->
  <!-- ============================================================ -->
  <g class="fade-5" transform="translate(387, 52)">
    <!-- Panel background -->
    <rect width="145" height="190" rx="3" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.5" />
    <text x="8" y="14" class="font-mono" font-size="6.5" fill="#94AECF">SYSTEM STATUS</text>
    <line x1="8" y1="18" x2="137" y2="18" stroke="#1A3F6A" stroke-width="0.5" />

    <!-- Header row -->
    <text x="10" y="32" class="font-mono" font-size="5" fill="#1A3F6A">UNIT</text>
    <text x="60" y="32" class="font-mono" font-size="5" fill="#1A3F6A">STS</text>
    <text x="80" y="32" class="font-mono" font-size="5" fill="#1A3F6A">STATE</text>
    <line x1="8" y1="35" x2="137" y2="35" stroke="#1A3F6A" stroke-width="0.3" />

    <!-- INV-01 — Online -->
    <text x="10" y="48" class="font-mono" font-size="6.5" fill="#FFFFFF">INV-01</text>
    <circle cx="66" cy="45.5" r="2.5" fill="#34D399" />
    <text x="80" y="48" class="font-mono" font-size="6" fill="#34D399">Online</text>

    <!-- INV-02 — Online -->
    <text x="10" y="66" class="font-mono" font-size="6.5" fill="#FFFFFF">INV-02</text>
    <circle cx="66" cy="63.5" r="2.5" fill="#34D399" />
    <text x="80" y="66" class="font-mono" font-size="6" fill="#34D399">Online</text>

    <!-- INV-03 — Warning -->
    <text x="10" y="84" class="font-mono" font-size="6.5" fill="#FFFFFF">INV-03</text>
    <circle cx="66" cy="81.5" r="2.5" fill="#FBBF24" class="dot-amber" />
    <text x="80" y="84" class="font-mono" font-size="6" fill="#FBBF24">Warning</text>

    <!-- INV-04 — Online -->
    <text x="10" y="102" class="font-mono" font-size="6.5" fill="#FFFFFF">INV-04</text>
    <circle cx="66" cy="99.5" r="2.5" fill="#34D399" />
    <text x="80" y="102" class="font-mono" font-size="6" fill="#34D399">Online</text>

    <!-- INV-05 — Online -->
    <text x="10" y="120" class="font-mono" font-size="6.5" fill="#FFFFFF">INV-05</text>
    <circle cx="66" cy="117.5" r="2.5" fill="#34D399" />
    <text x="80" y="120" class="font-mono" font-size="6" fill="#34D399">Online</text>

    <!-- Separator -->
    <line x1="8" y1="130" x2="137" y2="130" stroke="#1A3F6A" stroke-width="0.3" />

    <!-- Summary stats -->
    <text x="10" y="144" class="font-mono" font-size="5.5" fill="#94AECF">TOTAL UNITS</text>
    <text x="120" y="144" class="font-mono" font-size="5.5" fill="#FFFFFF" text-anchor="end">5</text>

    <text x="10" y="156" class="font-mono" font-size="5.5" fill="#94AECF">ONLINE</text>
    <text x="120" y="156" class="font-mono" font-size="5.5" fill="#34D399" text-anchor="end">4</text>

    <text x="10" y="168" class="font-mono" font-size="5.5" fill="#94AECF">WARNINGS</text>
    <text x="120" y="168" class="font-mono" font-size="5.5" fill="#FBBF24" text-anchor="end">1</text>

    <text x="10" y="180" class="font-mono" font-size="5.5" fill="#94AECF">ALERTS</text>
    <text x="120" y="180" class="font-mono" font-size="5.5" fill="#FF3B3B" text-anchor="end">0</text>
  </g>

  <!-- ============================================================ -->
  <!-- INVERTER ICONS (below laptop)                                 -->
  <!-- ============================================================ -->
  <g class="fade-5">
    <!-- Connection lines from laptop base to inverter icons -->
    <line x1="200" y1="276" x2="200" y2="310" stroke="#1A3F6A" stroke-width="0.75" stroke-dasharray="3 2" />
    <line x1="300" y1="276" x2="300" y2="310" stroke="#1A3F6A" stroke-width="0.75" stroke-dasharray="3 2" />
    <line x1="400" y1="276" x2="400" y2="310" stroke="#1A3F6A" stroke-width="0.75" stroke-dasharray="3 2" />

    <!-- Inverter 1 -->
    <g transform="translate(185, 310)">
      <rect width="30" height="20" rx="2" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.75" />
      <rect x="4" y="4" width="6" height="3" rx="0.5" fill="#34D399" opacity="0.6" />
      <rect x="4" y="9" width="6" height="3" rx="0.5" fill="#34D399" opacity="0.4" />
      <rect x="12" y="4" width="14" height="2" rx="0.5" fill="#1A3F6A" />
      <rect x="12" y="8" width="10" height="2" rx="0.5" fill="#1A3F6A" />
      <rect x="12" y="12" width="12" height="2" rx="0.5" fill="#1A3F6A" />
      <circle cx="26" cy="16" r="1.5" fill="#34D399" />
    </g>

    <!-- Inverter 2 -->
    <g transform="translate(285, 310)">
      <rect width="30" height="20" rx="2" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.75" />
      <rect x="4" y="4" width="6" height="3" rx="0.5" fill="#34D399" opacity="0.6" />
      <rect x="4" y="9" width="6" height="3" rx="0.5" fill="#34D399" opacity="0.4" />
      <rect x="12" y="4" width="14" height="2" rx="0.5" fill="#1A3F6A" />
      <rect x="12" y="8" width="10" height="2" rx="0.5" fill="#1A3F6A" />
      <rect x="12" y="12" width="12" height="2" rx="0.5" fill="#1A3F6A" />
      <circle cx="26" cy="16" r="1.5" fill="#34D399" />
    </g>

    <!-- Inverter 3 -->
    <g transform="translate(385, 310)">
      <rect width="30" height="20" rx="2" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.75" />
      <rect x="4" y="4" width="6" height="3" rx="0.5" fill="#FBBF24" opacity="0.6" />
      <rect x="4" y="9" width="6" height="3" rx="0.5" fill="#FBBF24" opacity="0.4" />
      <rect x="12" y="4" width="14" height="2" rx="0.5" fill="#1A3F6A" />
      <rect x="12" y="8" width="10" height="2" rx="0.5" fill="#1A3F6A" />
      <rect x="12" y="12" width="12" height="2" rx="0.5" fill="#1A3F6A" />
      <circle cx="26" cy="16" r="1.5" fill="#FBBF24" class="dot-amber" />
    </g>

    <!-- Inverter labels -->
    <text x="200" y="340" class="font-mono" font-size="5" fill="#94AECF" text-anchor="middle">INV-01</text>
    <text x="300" y="340" class="font-mono" font-size="5" fill="#94AECF" text-anchor="middle">INV-02</text>
    <text x="400" y="340" class="font-mono" font-size="5" fill="#94AECF" text-anchor="middle">INV-03</text>

    <!-- DATA FLOW DOTS — streaming from inverters up to laptop -->
    <!-- Inverter 1 data flow -->
