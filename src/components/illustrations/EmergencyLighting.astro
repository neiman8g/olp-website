<svg viewBox="0 0 600 360" width="100%" xmlns="http://www.w3.org/2000/svg">
  <style>
    @keyframes el-power-fail {
      0%, 35%   { opacity: 1; }
      40%, 85%  { opacity: 0; }
      90%, 100% { opacity: 1; }
    }
    @keyframes el-emerg-on {
      0%, 38%   { opacity: 0; }
      42%, 87%  { opacity: 1; }
      90%, 100% { opacity: 0; }
    }
    @keyframes el-flow {
      0%   { offset-distance: 0%; opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { offset-distance: 100%; opacity: 0; }
    }
    @keyframes el-flash {
      0%, 38%   { opacity: 0; }
      40%       { opacity: 1; }
      42%       { opacity: 0; }
      44%       { opacity: 0.8; }
      46%       { opacity: 0; }
      100%      { opacity: 0; }
    }
    .el-normal { animation: el-power-fail 8s ease-in-out infinite; }
    .el-emerg  { animation: el-emerg-on 8s ease-in-out infinite; }
    .el-dot    { animation: el-flow 2s linear infinite; }
    .el-flash  { animation: el-flash 8s ease-in-out infinite; }
  </style>

  <!-- Background -->
  <rect width="600" height="360" fill="#0F2A4A" rx="8"/>

  <!-- ====== LEFT: NORMAL POWER STATE ====== -->
  <text x="150" y="28" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#B8D4F0" letter-spacing="2">NORMAL POWER</text>

  <!-- Building outline -->
  <rect x="40" y="40" width="220" height="250" rx="4" fill="none" stroke="#3D6A9E" stroke-width="1.5"/>

  <!-- Floors -->
  <line x1="40" y1="120" x2="260" y2="120" stroke="#3D6A9E" stroke-width="0.5"/>
  <line x1="40" y1="200" x2="260" y2="200" stroke="#3D6A9E" stroke-width="0.5"/>

  <!-- Floor labels -->
  <text x="30" y="85" text-anchor="end" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">3F</text>
  <text x="30" y="165" text-anchor="end" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">2F</text>
  <text x="30" y="245" text-anchor="end" font-family="DM Sans, sans-serif" font-size="9" fill="#B8D4F0">1F</text>

  <!-- Normal lights (warm white, visible when power is normal) -->
  <g class="el-normal">
    <!-- 3rd floor lights -->
    <rect x="80" y="52" width="30" height="3" rx="1" fill="#E8E0D0"/>
    <circle cx="95" cy="65" r="15" fill="#E8E0D0" opacity="0.12"/>
    <rect x="170" y="52" width="30" height="3" rx="1" fill="#E8E0D0"/>
    <circle cx="185" cy="65" r="15" fill="#E8E0D0" opacity="0.12"/>

    <!-- 2nd floor lights -->
    <rect x="80" y="132" width="30" height="3" rx="1" fill="#E8E0D0"/>
    <circle cx="95" cy="145" r="15" fill="#E8E0D0" opacity="0.12"/>
    <rect x="170" y="132" width="30" height="3" rx="1" fill="#E8E0D0"/>
    <circle cx="185" cy="145" r="15" fill="#E8E0D0" opacity="0.12"/>

    <!-- 1st floor lights -->
    <rect x="80" y="212" width="30" height="3" rx="1" fill="#E8E0D0"/>
    <circle cx="95" cy="225" r="15" fill="#E8E0D0" opacity="0.12"/>
    <rect x="170" y="212" width="30" height="3" rx="1" fill="#E8E0D0"/>
    <circle cx="185" cy="225" r="15" fill="#E8E0D0" opacity="0.12"/>
  </g>

  <!-- Utility power line -->
  <line x1="40" y1="310" x2="150" y2="310" stroke="#34D399" stroke-width="2" class="el-normal"/>
  <text x="50" y="330" font-family="DM Sans, sans-serif" font-size="8" fill="#34D399" class="el-normal">UTILITY OK</text>

  <!-- Power break flash -->
  <text x="150" y="305" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="10" fill="#FF3B3B" font-weight="700" class="el-flash">✕ POWER FAIL</text>

  <!-- Divider -->
  <line x1="300" y1="30" x2="300" y2="340" stroke="#3D6A9E" stroke-width="0.5" stroke-dasharray="4 4"/>

  <!-- ====== RIGHT: EMERGENCY POWER STATE ====== -->
  <text x="450" y="28" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="11" font-weight="700" fill="#2567C2" letter-spacing="2">EMERGENCY POWER</text>

  <!-- Building outline -->
  <rect x="340" y="40" width="220" height="250" rx="4" fill="none" stroke="#3D6A9E" stroke-width="1.5"/>

  <!-- Floors -->
  <line x1="340" y1="120" x2="560" y2="120" stroke="#3D6A9E" stroke-width="0.5"/>
  <line x1="340" y1="200" x2="560" y2="200" stroke="#3D6A9E" stroke-width="0.5"/>

  <!-- Emergency lights — only 1/3 of fixtures are on EM circuit -->
  <g class="el-emerg">
    <!-- 3rd floor: LEFT fixture ON (emergency), RIGHT fixture OFF -->
    <rect x="380" y="52" width="30" height="3" rx="1" fill="#7EB3F5"/>
    <circle cx="395" cy="65" r="18" fill="#2567C2" opacity="0.15"/>
    <circle cx="395" cy="65" r="10" fill="#7EB3F5" opacity="0.2"/>
    <text x="395" y="95" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="6" fill="#7EB3F5">EM</text>
    <!-- Right fixture stays dark -->
    <rect x="470" y="52" width="30" height="3" rx="1" fill="#3D6A9E" opacity="0.3"/>

    <!-- 2nd floor: both fixtures OFF (not on EM circuit) -->
    <rect x="380" y="132" width="30" height="3" rx="1" fill="#3D6A9E" opacity="0.3"/>
    <rect x="470" y="132" width="30" height="3" rx="1" fill="#3D6A9E" opacity="0.3"/>

    <!-- 1st floor: RIGHT fixture ON (emergency near exit), LEFT OFF -->
    <rect x="380" y="212" width="30" height="3" rx="1" fill="#3D6A9E" opacity="0.3"/>
    <rect x="470" y="212" width="30" height="3" rx="1" fill="#7EB3F5"/>
    <circle cx="485" cy="225" r="18" fill="#2567C2" opacity="0.15"/>
    <circle cx="485" cy="225" r="10" fill="#7EB3F5" opacity="0.2"/>
    <text x="485" y="255" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="6" fill="#7EB3F5">EM</text>

    <!-- EXIT sign (always on emergency circuit) -->
    <rect x="420" y="170" width="40" height="16" rx="2" fill="#34D399"/>
    <text x="440" y="182" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="9" font-weight="700" fill="#FFFFFF">EXIT</text>
  </g>

  <!-- OLP Inverter box -->
  <rect x="380" y="298" width="100" height="36" rx="4" fill="#2B5580" stroke="#2567C2" stroke-width="1.5" class="el-emerg"/>
  <text x="430" y="314" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="10" font-weight="700" fill="#FFFFFF" class="el-emerg">OLP INVERTER</text>
  <text x="430" y="327" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#B8D4F0" class="el-emerg">UL 924</text>

  <!-- Battery icon -->
  <rect x="345" y="305" width="28" height="16" rx="2" fill="#2B5580" stroke="#3D6A9E" stroke-width="0.8" class="el-emerg"/>
  <rect x="371" y="310" width="4" height="6" rx="1" fill="#3D6A9E" class="el-emerg"/>
  <rect x="349" y="309" width="6" height="8" rx="1" fill="#34D399" opacity="0.6" class="el-emerg"/>
  <rect x="357" y="309" width="6" height="8" rx="1" fill="#34D399" opacity="0.6" class="el-emerg"/>
  <rect x="365" y="309" width="4" height="8" rx="1" fill="#34D399" opacity="0.4" class="el-emerg"/>

  <!-- Power line from inverter up through building -->
  <line x1="430" y1="298" x2="430" y2="290" stroke="#2567C2" stroke-width="2" class="el-emerg"/>
  <line x1="430" y1="290" x2="450" y2="290" stroke="#2567C2" stroke-width="2" class="el-emerg"/>

  <!-- Flow dots from inverter upward -->
  <circle r="3" fill="#2567C2" class="el-dot el-emerg" style="offset-path: path('M430,298 L430,200 L430,120 L430,50'); animation-delay: 0s;"/>
  <circle r="3" fill="#2567C2" class="el-dot el-emerg" style="offset-path: path('M430,298 L430,200 L430,120 L430,50'); animation-delay: 0.7s;"/>
  <circle r="3" fill="#2567C2" class="el-dot el-emerg" style="offset-path: path('M430,298 L430,200 L430,120 L430,50'); animation-delay: 1.4s;"/>

  <!-- 90 MIN badge -->
  <rect x="490" y="302" width="60" height="22" rx="3" fill="#2B5580" stroke="#2567C2" stroke-width="0.8" class="el-emerg"/>
  <text x="520" y="317" text-anchor="middle" font-family="Barlow Condensed, sans-serif" font-size="10" font-weight="700" fill="#FFFFFF" class="el-emerg">90 MIN</text>

  <!-- Caption -->
  <text x="300" y="354" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="7" fill="#3D6A9E">EMERGENCY LIGHTING · UL 924</text>
</svg>
