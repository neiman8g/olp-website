<svg viewBox="0 0 560 340" width="100%" xmlns="http://www.w3.org/2000/svg">
  <style>
    @keyframes el-fail {
      0%, 35%   { opacity: 1; }
      40%, 85%  { opacity: 0; }
      90%, 100% { opacity: 1; }
    }
    @keyframes el-em-on {
      0%, 38%   { opacity: 0; }
      42%, 87%  { opacity: 1; }
      90%, 100% { opacity: 0; }
    }
    @keyframes el-flash {
      0%, 38%   { opacity: 0; }
      39%       { opacity: 1; }
      41%       { opacity: 0; }
      42%       { opacity: 0.7; }
      44%, 100% { opacity: 0; }
    }
    @keyframes el-dot {
      0%   { offset-distance: 0%; opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { offset-distance: 100%; opacity: 0; }
    }
    .normal { animation: el-fail 8s ease-in-out infinite; }
    .em-on  { animation: el-em-on 8s ease-in-out infinite; }
    .flash  { animation: el-flash 8s ease-in-out infinite; }
    .dot    { animation: el-dot 2s linear infinite; }
  </style>

  <!-- ====== LEFT BUILDING: NORMAL POWER ====== -->
  <text x="130" y="16" text-anchor="middle" font-family="'Inter Tight', 'Inter', sans-serif" font-size="11" font-weight="700" fill="#B8D4F0" letter-spacing="2">NORMAL POWER</text>

  <!-- Building structure -->
  <rect x="20" y="26" width="220" height="240" rx="3" fill="#1A3F6A" stroke="#3D6A9E" stroke-width="1.5"/>
  <!-- Floor lines -->
  <line x1="20" y1="106" x2="240" y2="106" stroke="#3D6A9E" stroke-width="0.8"/>
  <line x1="20" y1="186" x2="240" y2="186" stroke="#3D6A9E" stroke-width="0.8"/>
  <!-- Room divider -->
  <line x1="130" y1="26" x2="130" y2="266" stroke="#3D6A9E" stroke-width="0.5"/>

  <!-- Floor labels -->
  <text x="12" y="70" text-anchor="end" font-family="Inter, sans-serif" font-size="10" fill="#7EB3F5">3F</text>
  <text x="12" y="150" text-anchor="end" font-family="Inter, sans-serif" font-size="10" fill="#7EB3F5">2F</text>
  <text x="12" y="230" text-anchor="end" font-family="Inter, sans-serif" font-size="10" fill="#7EB3F5">1F</text>

  <!-- ALL 6 LIGHTS ON (normal power) — warm amber, clearly visible -->
  <g class="normal">
    <!-- 3F left -->
    <rect x="50" y="38" width="40" height="4" rx="2" fill="#FFD580"/>
    <ellipse cx="70" cy="55" rx="25" ry="15" fill="#FFD580" opacity="0.15"/>
    <circle cx="70" cy="50" r="8" fill="#FFD580" opacity="0.12"/>
    <!-- 3F right -->
    <rect x="160" y="38" width="40" height="4" rx="2" fill="#FFD580"/>
    <ellipse cx="180" cy="55" rx="25" ry="15" fill="#FFD580" opacity="0.15"/>
    <circle cx="180" cy="50" r="8" fill="#FFD580" opacity="0.12"/>
    <!-- 2F left -->
    <rect x="50" y="118" width="40" height="4" rx="2" fill="#FFD580"/>
    <ellipse cx="70" cy="135" rx="25" ry="15" fill="#FFD580" opacity="0.15"/>
    <circle cx="70" cy="130" r="8" fill="#FFD580" opacity="0.12"/>
    <!-- 2F right -->
    <rect x="160" y="118" width="40" height="4" rx="2" fill="#FFD580"/>
    <ellipse cx="180" cy="135" rx="25" ry="15" fill="#FFD580" opacity="0.15"/>
    <circle cx="180" cy="130" r="8" fill="#FFD580" opacity="0.12"/>
    <!-- 1F left -->
    <rect x="50" y="198" width="40" height="4" rx="2" fill="#FFD580"/>
    <ellipse cx="70" cy="215" rx="25" ry="15" fill="#FFD580" opacity="0.15"/>
    <circle cx="70" cy="210" r="8" fill="#FFD580" opacity="0.12"/>
    <!-- 1F right -->
    <rect x="160" y="198" width="40" height="4" rx="2" fill="#FFD580"/>
    <ellipse cx="180" cy="215" rx="25" ry="15" fill="#FFD580" opacity="0.15"/>
    <circle cx="180" cy="210" r="8" fill="#FFD580" opacity="0.12"/>
  </g>

  <!-- Utility power line (green when normal) -->
  <line x1="20" y1="285" x2="130" y2="285" stroke="#34D399" stroke-width="2.5" class="normal"/>
  <circle cx="22" cy="285" r="4" fill="#34D399" class="normal"/>
  <text x="60" y="300" font-family="Inter, sans-serif" font-size="9" fill="#34D399" font-weight="500" class="normal">UTILITY OK</text>

  <!-- Power fail flash -->
  <g class="flash">
    <line x1="120" y1="278" x2="140" y2="292" stroke="#FF3B3B" stroke-width="2"/>
    <line x1="140" y1="278" x2="120" y2="292" stroke="#FF3B3B" stroke-width="2"/>
    <text x="130" y="310" text-anchor="middle" font-family="'Inter Tight', 'Inter', sans-serif" font-size="10" fill="#FF3B3B" font-weight="700">POWER FAIL</text>
  </g>

  <!-- Divider -->
  <line x1="280" y1="10" x2="280" y2="330" stroke="#3D6A9E" stroke-width="0.5" stroke-dasharray="6 4"/>

  <!-- ====== RIGHT BUILDING: EMERGENCY POWER ====== -->
  <text x="410" y="16" text-anchor="middle" font-family="'Inter Tight', 'Inter', sans-serif" font-size="11" font-weight="700" fill="#2567C2" letter-spacing="2">EMERGENCY POWER</text>

  <!-- Building structure -->
  <rect x="300" y="26" width="220" height="240" rx="3" fill="#1A3F6A" stroke="#3D6A9E" stroke-width="1.5"/>
  <!-- Floor lines -->
  <line x1="300" y1="106" x2="520" y2="106" stroke="#3D6A9E" stroke-width="0.8"/>
  <line x1="300" y1="186" x2="520" y2="186" stroke="#3D6A9E" stroke-width="0.8"/>
  <!-- Room divider -->
  <line x1="410" y1="26" x2="410" y2="266" stroke="#3D6A9E" stroke-width="0.5"/>

  <!-- Dark fixtures (all 6 shown as dark outlines — power is out) -->
  <g class="em-on" style="opacity: 0;">
    <!-- Show dark fixture bars where lights are OFF -->
    <rect x="330" y="118" width="40" height="4" rx="2" fill="#3D6A9E" opacity="0.4"/>
    <rect x="440" y="38" width="40" height="4" rx="2" fill="#3D6A9E" opacity="0.4"/>
    <rect x="330" y="198" width="40" height="4" rx="2" fill="#3D6A9E" opacity="0.4"/>
    <rect x="440" y="118" width="40" height="4" rx="2" fill="#3D6A9E" opacity="0.4"/>
  </g>

  <!-- EM LIGHTS ON — only 2 of 6 (1/3 ratio) -->
  <g class="em-on">
    <!-- 3F left — EM fixture ON -->
    <rect x="330" y="38" width="40" height="4" rx="2" fill="#7EB3F5"/>
    <ellipse cx="350" cy="55" rx="28" ry="18" fill="#2567C2" opacity="0.12"/>
    <circle cx="350" cy="50" r="10" fill="#7EB3F5" opacity="0.2"/>
    <text x="350" y="75" text-anchor="middle" font-family="'Inter Tight', 'Inter', sans-serif" font-size="9" fill="#7EB3F5" font-weight="600">EM</text>

    <!-- 1F right — EM fixture ON (near exit) -->
    <rect x="440" y="198" width="40" height="4" rx="2" fill="#7EB3F5"/>
    <ellipse cx="460" cy="215" rx="28" ry="18" fill="#2567C2" opacity="0.12"/>
    <circle cx="460" cy="210" r="10" fill="#7EB3F5" opacity="0.2"/>
    <text x="460" y="235" text-anchor="middle" font-family="'Inter Tight', 'Inter', sans-serif" font-size="9" fill="#7EB3F5" font-weight="600">EM</text>

    <!-- EXIT sign on 2F -->
    <rect x="385" y="140" width="50" height="20" rx="3" fill="#34D399"/>
    <text x="410" y="154" text-anchor="middle" font-family="'Inter Tight', 'Inter', sans-serif" font-size="11" font-weight="700" fill="#FFFFFF" letter-spacing="1">EXIT</text>
  </g>

  <!-- OLP INVERTER -->
  <g class="em-on">
    <rect x="340" y="278" width="110" height="32" rx="4" fill="#2B5580" stroke="#2567C2" stroke-width="1.5"/>
    <text x="395" y="293" text-anchor="middle" font-family="'Inter Tight', 'Inter', sans-serif" font-size="11" font-weight="700" fill="#FFFFFF" letter-spacing="1">OLP INVERTER</text>
    <text x="395" y="305" text-anchor="middle" font-family="Inter, sans-serif" font-size="8" fill="#B8D4F0">UL 924 · Made in LA</text>
  </g>

  <!-- Battery -->
  <g class="em-on">
    <rect x="300" y="284" width="30" height="18" rx="2" fill="#2B5580" stroke="#3D6A9E" stroke-width="0.8"/>
    <rect x="328" y="290" width="4" height="6" rx="1" fill="#3D6A9E"/>
    <rect x="304" y="288" width="7" height="10" rx="1" fill="#34D399" opacity="0.7"/>
    <rect x="313" y="288" width="7" height="10" rx="1" fill="#34D399" opacity="0.5"/>
    <rect x="322" y="288" width="4" height="10" rx="1" fill="#34D399" opacity="0.3"/>
  </g>

  <!-- 90 MIN badge -->
  <g class="em-on">
    <rect x="460" y="280" width="60" height="26" rx="4" fill="#2B5580" stroke="#2567C2" stroke-width="1"/>
    <text x="490" y="297" text-anchor="middle" font-family="'Inter Tight', 'Inter', sans-serif" font-size="12" font-weight="700" fill="#FFFFFF" letter-spacing="1">90 MIN</text>
  </g>

  <!-- Power flow line from inverter up -->
  <line x1="395" y1="278" x2="395" y2="266" stroke="#2567C2" stroke-width="2" class="em-on"/>

  <!-- Flow dots -->
  <circle r="3.5" fill="#2567C2" class="dot em-on" style="offset-path: path('M395,278 L395,186 L395,106 L395,30');"/>
  <circle r="3.5" fill="#2567C2" class="dot em-on" style="offset-path: path('M395,278 L395,186 L395,106 L395,30'); animation-delay: 0.7s;"/>
  <circle r="3.5" fill="#2567C2" class="dot em-on" style="offset-path: path('M395,278 L395,186 L395,106 L395,30'); animation-delay: 1.4s;"/>
</svg>
