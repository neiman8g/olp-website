    <line x1="32" y1="11.5" x2="32" y2="16.5" stroke="#FFFFFF" stroke-width="1.5" />
    <line x1="29.5" y1="14" x2="34.5" y2="14" stroke="#FFFFFF" stroke-width="1.5" />
    <!-- Heart monitor line -->
    <polyline points="16,54 22,54 25,48 28,58 31,50 34,54 40,54 44,54 46,52 48,54" stroke="#34D399" stroke-width="0.75" fill="none" />
    <!-- LED -->
    <circle cx="54" cy="10" r="2" fill="#34D399" class="led led-d1" />
    <!-- Labels -->
    <text x="32" y="70" text-anchor="middle" class="hr-mono" fill="#FFFFFF" font-size="6" font-weight="700">HOSPITALS</text>
    <text x="32" y="80" text-anchor="middle" class="hr-mono" fill="#2A7AE2" font-size="5.5">UL 924</text>
    <!-- Ground symbol -->
    <line x1="32" y1="88" x2="32" y2="92" stroke="#94AECF" stroke-width="0.5" />
    <line x1="26" y1="92" x2="38" y2="92" stroke="#94AECF" stroke-width="0.5" />
    <line x1="28" y1="94" x2="36" y2="94" stroke="#94AECF" stroke-width="0.5" />
    <line x1="30" y1="96" x2="34" y2="96" stroke="#94AECF" stroke-width="0.5" />
