  <text x="230" y="356" text-anchor="middle" class="hr-mono" fill="#94AECF" font-size="5">DISTRIBUTION BUS</text>

  <!-- ============================================ -->
  <!-- BRANCH LINES with BREAKER SYMBOLS            -->
  <!-- ============================================ -->
  <!-- Branch positions: 56, 126, 196, 266, 336, 406 -->

  <!-- Branch 1 -->
