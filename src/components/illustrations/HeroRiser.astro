    <circle cx="175" cy="262" r="2.5" fill="#34D399" class="led led-d2" />
    <circle cx="185" cy="262" r="2.5" fill="#2A7AE2" class="led led-d3" />

    <!-- Location -->
    <text x="230" y="275" text-anchor="middle" class="hr-mono" fill="#94AECF" font-size="5.5" letter-spacing="1.5">LOS ANGELES &middot; CALIFORNIA</text>

    <!-- Input terminal marker -->
    <rect x="224" y="151" width="12" height="6" rx="1" fill="#1A3F6A" stroke="#2A7AE2" stroke-width="0.75" />
    <!-- Output terminal marker -->
    <rect x="224" y="293" width="12" height="6" rx="1" fill="#1A3F6A" stroke="#2A7AE2" stroke-width="0.75" />
  </g>

