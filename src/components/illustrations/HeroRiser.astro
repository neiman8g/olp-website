  <line x1="122" y1="380" x2="130" y2="376" stroke="#FFFFFF" stroke-width="0.75" />
  <line x1="122" y1="384" x2="130" y2="380" stroke="#FFFFFF" stroke-width="0.75" />

  <!-- Branch 3 -->
  <line x1="196" y1="366" x2="196" y2="406" stroke="#2A7AE2" stroke-width="1" />
  <line x1="192" y1="380" x2="200" y2="376" stroke="#FFFFFF" stroke-width="0.75" />
  <line x1="192" y1="384" x2="200" y2="380" stroke="#FFFFFF" stroke-width="0.75" />

  <!-- Branch 4 -->
  <line x1="266" y1="366" x2="266" y2="406" stroke="#2A7AE2" stroke-width="1" />
  <line x1="262" y1="380" x2="270" y2="376" stroke="#FFFFFF" stroke-width="0.75" />
  <line x1="262" y1="384" x2="270" y2="380" stroke="#FFFFFF" stroke-width="0.75" />

  <!-- Branch 5 -->
  <line x1="336" y1="366" x2="336" y2="406" stroke="#2A7AE2" stroke-width="1" />
  <line x1="332" y1="380" x2="340" y2="376" stroke="#FFFFFF" stroke-width="0.75" />
  <line x1="332" y1="384" x2="340" y2="380" stroke="#FFFFFF" stroke-width="0.75" />

  <!-- Branch 6 -->
  <line x1="406" y1="366" x2="406" y2="406" stroke="#2A7AE2" stroke-width="1" />
  <line x1="402" y1="380" x2="410" y2="376" stroke="#FFFFFF" stroke-width="0.75" />
  <line x1="402" y1="384" x2="410" y2="380" stroke="#FFFFFF" stroke-width="0.75" />

  <!-- Flow dots on branches -->
  <circle r="2" fill="#2A7AE2" class="dot-flow-slow" style="offset-path: path('M56,366 L56,406');" />
  <circle r="2" fill="#2A7AE2" class="dot-flow-slow" style="offset-path: path('M126,366 L126,406'); animation-delay: 0.6s;" />
  <circle r="2" fill="#2A7AE2" class="dot-flow-slow" style="offset-path: path('M196,366 L196,406'); animation-delay: 1.2s;" />
  <circle r="2" fill="#2A7AE2" class="dot-flow-slow" style="offset-path: path('M266,366 L266,406'); animation-delay: 1.8s;" />
  <circle r="2" fill="#2A7AE2" class="dot-flow-slow" style="offset-path: path('M336,366 L336,406'); animation-delay: 2.4s;" />
  <circle r="2" fill="#2A7AE2" class="dot-flow-slow" style="offset-path: path('M406,366 L406,406'); animation-delay: 3.0s;" />

  <!-- ============================================ -->
  <!-- BOTTOM: APPLICATION BOXES                    -->
  <!-- ============================================ -->

  <!-- === 1. HOSPITAL === -->
  <g transform="translate(24,406)">
    <!-- Box -->
    <rect x="0" y="0" width="64" height="96" rx="3" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.75" />
    <!-- Cyan accent bar -->
    <rect x="0" y="0" width="64" height="4" rx="3" fill="#2A7AE2" />
