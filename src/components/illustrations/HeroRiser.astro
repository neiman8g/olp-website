  <line x1="52" y1="380" x2="60" y2="376" stroke="#FFFFFF" stroke-width="0.75" />
  <line x1="52" y1="384" x2="60" y2="380" stroke="#FFFFFF" stroke-width="0.75" />

  <!-- Branch 2 -->
