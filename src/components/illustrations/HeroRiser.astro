<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 460 540"
  fill="none"
  role="img"
  aria-label="Online Power hero diagram showing utility power flowing through an OLP inverter-UPS-regulator hub to six application branches including hospitals, elevators, data centers, fire alarm, industrial, and custom OEM"
  class="hero-riser-illustration"
>
  <defs>
    <style>
      /* Fonts inherited from BaseLayout */

      .hr-display { font-family: 'Barlow Condensed', sans-serif; }
      .hr-mono { font-family: 'DM Sans', monospace; }

      /* ---- Hub border pulse (subtle, no glow) ---- */
      @keyframes hubPulse {
        0%, 100% { stroke-opacity: 0.6; }
        50% { stroke-opacity: 1; }
      }
      .hub-border { animation: hubPulse 3s ease-in-out infinite; }

      /* ---- LED blink ---- */
      @keyframes ledBlink {
        0%, 90%, 100% { opacity: 1; }
        95% { opacity: 0.3; }
      }
      .led { animation: ledBlink 2.5s ease-in-out infinite; }
      .led-d1 { animation-delay: 0s; }
      .led-d2 { animation-delay: 0.4s; }
      .led-d3 { animation-delay: 0.8s; }
      .led-d4 { animation-delay: 1.2s; }
      .led-d5 { animation-delay: 1.6s; }
      .led-d6 { animation-delay: 2.0s; }

      /* ---- Power flow dots ---- */
      @keyframes flowDown {
        0%   { offset-distance: 0%;   opacity: 0; }
        5%   { opacity: 1; }
        90%  { opacity: 1; }
        100% { offset-distance: 100%; opacity: 0; }
      }

      .dot-flow {
        offset-rotate: 0deg;
        animation: flowDown 3s linear infinite;
      }
      .dot-flow-slow {
        offset-rotate: 0deg;
        animation: flowDown 4s linear infinite;
      }

      /* ---- Utility failure sequence (12s cycle) ---- */
      @keyframes utilityFail {
        0%, 38%   { stroke: #2A7AE2; opacity: 1; }
        40%       { stroke: #FF3B3B; opacity: 0.5; }
        42%       { stroke: #FF3B3B; opacity: 0.15; }
        44%, 46%  { stroke: #FF3B3B; opacity: 0; }
        48%       { stroke: #FF3B3B; opacity: 0.15; }
        50%       { stroke: #FF3B3B; opacity: 0.5; }
        52%, 78%  { stroke: #FF3B3B; opacity: 0.8; }
        80%       { stroke: #2A7AE2; opacity: 0.5; }
        84%, 100% { stroke: #2A7AE2; opacity: 1; }
      }
      .utility-line { animation: utilityFail 12s ease-in-out infinite; }

      @keyframes hubSurge {
        0%, 38%   { stroke-width: 2; }
        40%, 78%  { stroke-width: 2.5; }
        80%, 100% { stroke-width: 2; }
      }
      .hub-surge { animation: hubSurge 12s ease-in-out infinite; }

      @keyframes utilityLabelFail {
        0%, 38%   { fill: #94AECF; }
        40%, 78%  { fill: #FF3B3B; }
        80%, 100% { fill: #94AECF; }
      }
      .utility-status { animation: utilityLabelFail 12s ease-in-out infinite; }
    </style>

    <!-- No glow filters per design spec -->

    <!-- Paths for power-flow dots -->
    <!-- Utility to hub -->
    <path id="pathUtilToHub" d="M230,58 L230,155" />
    <!-- Hub to bus -->
    <path id="pathHubToBus" d="M230,295 L230,360" />
    <!-- Bus to branches -->
    <path id="pathB1" d="M56,365 L56,400" />
    <path id="pathB2" d="M126,365 L126,400" />
    <path id="pathB3" d="M196,365 L196,400" />
    <path id="pathB4" d="M266,365 L266,400" />
    <path id="pathB5" d="M336,365 L336,400" />
    <path id="pathB6" d="M406,365 L406,400" />
  </defs>

  <!-- ============================================ -->
  <!-- TECHNICAL DRAWING FRAME                      -->
  <!-- ============================================ -->
  <rect x="4" y="4" width="452" height="532" rx="1" stroke="#1A3F6A" stroke-width="0.75" fill="none" />
  <rect x="8" y="8" width="444" height="524" rx="0" stroke="#1A3F6A" stroke-width="0.35" fill="none" />

  <!-- ============================================ -->
  <!-- TOP: UTILITY SOURCE                          -->
  <!-- ============================================ -->
  <!-- Transformer icon -->
  <g transform="translate(230,28)">
    <!-- Pole -->
    <line x1="0" y1="-12" x2="0" y2="8" stroke="#94AECF" stroke-width="1.5" />
    <!-- Cross arm -->
    <line x1="-18" y1="-8" x2="18" y2="-8" stroke="#94AECF" stroke-width="1.5" />
    <!-- Insulators -->
    <circle cx="-18" cy="-8" r="2.5" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.75" />
    <circle cx="18" cy="-8" r="2.5" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.75" />
    <circle cx="0" cy="-8" r="2.5" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.75" />
    <!-- Transformer can -->
    <rect x="-8" y="2" width="16" height="14" rx="2" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.75" />
    <!-- Coil symbol -->
    <path d="M-4,6 Q-4,9 0,9 Q4,9 4,6" stroke="#2A7AE2" stroke-width="0.75" fill="none" />
    <path d="M-4,11 Q-4,14 0,14 Q4,14 4,11" stroke="#2A7AE2" stroke-width="0.75" fill="none" />
  </g>

  <!-- Utility label -->
  <text x="230" y="54" text-anchor="middle" class="hr-mono" fill="#94AECF" font-size="7" letter-spacing="1.5">UTILITY SERVICE</text>
  <text x="230" y="63" text-anchor="middle" class="hr-mono utility-status" fill="#94AECF" font-size="6" letter-spacing="0.5">120 / 208 / 480V</text>

  <!-- Main power line: utility to hub -->
  <line x1="230" y1="68" x2="230" y2="155" class="utility-line" stroke="#2A7AE2" stroke-width="1.5" stroke-dasharray="4,3" />

  <!-- Flow dots: utility to hub -->
  <circle r="3" fill="#2A7AE2" class="dot-flow" style="offset-path: path('M230,68 L230,155');" />
  <circle r="3" fill="#2A7AE2" class="dot-flow" style="offset-path: path('M230,68 L230,155'); animation-delay: 1s;" />
  <circle r="3" fill="#2A7AE2" class="dot-flow" style="offset-path: path('M230,68 L230,155'); animation-delay: 2s;" />

  <!-- ============================================ -->
  <!-- BATTERY BANK (left of hub)                   -->
  <!-- ============================================ -->
  <g transform="translate(88,200)">
    <rect x="0" y="0" width="36" height="22" rx="3" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.75" />
    <!-- Cell dividers -->
    <line x1="9" y1="2" x2="9" y2="20" stroke="#94AECF" stroke-width="0.5" />
    <line x1="18" y1="2" x2="18" y2="20" stroke="#94AECF" stroke-width="0.5" />
    <line x1="27" y1="2" x2="27" y2="20" stroke="#94AECF" stroke-width="0.5" />
    <!-- Terminal nub -->
    <rect x="32" y="8" width="6" height="6" rx="1" fill="#1A3F6A" stroke="#2A7AE2" stroke-width="0.5" />
    <!-- + / - -->
    <text x="4" y="14" class="hr-mono" fill="#34D399" font-size="6">+</text>
    <text x="30" y="14" class="hr-mono" fill="#FF3B3B" font-size="6">-</text>
    <!-- Connection line to hub -->
    <line x1="38" y1="11" x2="52" y2="11" stroke="#2A7AE2" stroke-width="1" stroke-dasharray="2,2" />
    <!-- Label -->
    <text x="18" y="32" text-anchor="middle" class="hr-mono" fill="#94AECF" font-size="5.5">BATTERY</text>
  </g>

  <!-- ============================================ -->
  <!-- CENTER: OLP POWER HUB                        -->
  <!-- ============================================ -->
  <g class="hub-surge">
