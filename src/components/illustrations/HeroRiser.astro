    <!-- Cable -->
    <line x1="32" y1="12" x2="32" y2="30" stroke="#94AECF" stroke-width="0.5" stroke-dasharray="2,1" />
    <!-- Pulley -->
    <circle cx="32" cy="11" r="2.5" fill="none" stroke="#94AECF" stroke-width="0.5" />
    <!-- Floor indicators -->
