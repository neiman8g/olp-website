    <line x1="30" y1="96" x2="34" y2="96" stroke="#94AECF" stroke-width="0.5" />
  </g>

  <!-- === 4. FIRE ALARM === -->
  <g transform="translate(234,406)">
    <rect x="0" y="0" width="64" height="96" rx="3" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.75" />
    <rect x="0" y="0" width="64" height="4" rx="3" fill="#2A7AE2" />
    <!-- Horn/strobe body -->
    <rect x="22" y="18" width="20" height="14" rx="2" fill="#1A3F6A" stroke="#FF3B3B" stroke-width="0.75" />
    <!-- Horn bell -->
