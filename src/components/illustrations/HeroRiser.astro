    <!-- Labels -->
    <text x="32" y="70" text-anchor="middle" class="hr-mono" fill="#FFFFFF" font-size="6" font-weight="700">ELEVATORS</text>
    <text x="32" y="80" text-anchor="middle" class="hr-mono" fill="#2A7AE2" font-size="5.5">UL 924</text>
  </g>

  <!-- === 3. DATA CENTER === -->
  <g transform="translate(164,406)">
    <rect x="0" y="0" width="64" height="96" rx="3" fill="#1A3F6A" stroke="#1A3F6A" stroke-width="0.75" />
    <rect x="0" y="0" width="64" height="4" rx="3" fill="#2A7AE2" />
    <!-- Server rack -->
    <rect x="16" y="12" width="32" height="46" rx="2" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.5" />
    <!-- Rack units -->
    <rect x="19" y="15" width="26" height="8" rx="1" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.3" />
    <rect x="19" y="25" width="26" height="8" rx="1" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.3" />
    <rect x="19" y="35" width="26" height="8" rx="1" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.3" />
