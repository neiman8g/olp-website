    <rect x="30" y="20" width="8" height="6" rx="0.5" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.3" />
    <rect x="18" y="30" width="8" height="6" rx="0.5" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.3" />
    <rect x="30" y="30" width="8" height="6" rx="0.5" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.3" />
