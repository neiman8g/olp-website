    <rect x="148" y="163" width="164" height="124" rx="2" fill="none" stroke="#1A3F6A" stroke-width="0.5" />

    <!-- ONLINE POWER title -->
    <text x="230" y="186" text-anchor="middle" class="hr-display" fill="#FFFFFF" font-size="14" font-weight="700" letter-spacing="2">ONLINE POWER</text>

    <!-- Subtitle -->
    <text x="230" y="200" text-anchor="middle" class="hr-mono" fill="#2A7AE2" font-size="7" letter-spacing="1.2">INVERTER &middot; UPS &middot; REGULATOR</text>

    <!-- Divider line -->
    <line x1="160" y1="208" x2="300" y2="208" stroke="#1A3F6A" stroke-width="0.5" />

    <!-- Certification badges -->
    <g transform="translate(163,215)">
      <!-- UL 924 -->
      <rect x="0" y="0" width="38" height="14" rx="7" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.5" />
      <text x="19" y="10" text-anchor="middle" class="hr-mono" fill="#FFFFFF" font-size="6">UL 924</text>
      <!-- UL 1778 -->
      <rect x="44" y="0" width="42" height="14" rx="7" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.5" />
      <text x="65" y="10" text-anchor="middle" class="hr-mono" fill="#FFFFFF" font-size="6">UL 1778</text>
      <!-- ISO 9001 -->
      <rect x="92" y="0" width="44" height="14" rx="7" fill="#1A3F6A" stroke="#94AECF" stroke-width="0.5" />
      <text x="114" y="10" text-anchor="middle" class="hr-mono" fill="#FFFFFF" font-size="6">ISO 9001</text>
    </g>

    <!-- Power range -->
