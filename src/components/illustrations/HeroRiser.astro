    <circle cx="26" cy="19" r="1" fill="#2A7AE2" class="led led-d3" />
    <circle cx="22" cy="29" r="1" fill="#34D399" class="led led-d2" />
    <circle cx="26" cy="29" r="1" fill="#34D399" class="led led-d4" />
    <circle cx="22" cy="39" r="1" fill="#2A7AE2" class="led led-d1" />
