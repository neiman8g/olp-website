---
/**
 * PowerDistribution.astro
 * Isometric SVG illustration of a Power Distribution Unit (PDU) cabinet
 * with animated power flow, monitoring displays, and branch circuit outputs.
 */
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 600 360"
  fill="none"
  role="img"
  aria-label="Power Distribution Unit illustration showing an isometric PDU cabinet with input power, branch circuit outputs, and monitoring display"
  class="pdu-illustration"
>
  <defs>
    <!-- Fonts -->
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&amp;family=Space+Mono:wght@400;700&amp;display=swap');

      .font-display { font-family: 'Space Grotesk', sans-serif; }
      .font-mono { font-family: 'Space Mono', monospace; }

      /* Power flow animation along input cable */
      @keyframes flowInput {
        0% { offset-distance: 0%; opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { offset-distance: 100%; opacity: 0; }
      }

      /* Power flow along branch outputs */
      @keyframes flowBranch {
        0% { offset-distance: 0%; opacity: 0; }
        15% { opacity: 1; }
        85% { opacity: 1; }
        100% { offset-distance: 100%; opacity: 0; }
      }

      /* Monitor pulse */
      @keyframes monitorPulse {
        0%, 100% { opacity: 0.7; }
        50% { opacity: 1; }
      }

      /* LED blink */
      @keyframes ledBlink {
        0%, 80% { opacity: 1; }
        90% { opacity: 0.4; }
        100% { opacity: 1; }
      }

      /* Bar graph animation */
      @keyframes barGrow {
        0%, 100% { transform: scaleY(1); }
        50% { transform: scaleY(0.75); }
      }
    </style>

    <!-- Glow filter for cyan accent elements -->
    <filter id="cyanGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="3" result="blur" />
      <feFlood flood-color="#00E5FF" flood-opacity="0.6" result="color" />
      <feComposite in="color" in2="blur" operator="in" result="glow" />
      <feMerge>
        <feMergeNode in="glow" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>

    <!-- Subtle glow for LEDs -->
    <filter id="ledGlow" x="-100%" y="-100%" width="300%" height="300%">
      <feGaussianBlur stdDeviation="2" result="blur" />
      <feFlood flood-color="#34D399" flood-opacity="0.5" result="color" />
      <feComposite in="color" in2="blur" operator="in" result="glow" />
      <feMerge>
        <feMergeNode in="glow" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>

    <!-- Monitor screen glow -->
    <filter id="screenGlow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="2" result="blur" />
      <feFlood flood-color="#00E5FF" flood-opacity="0.3" result="color" />
      <feComposite in="color" in2="blur" operator="in" result="glow" />
      <feMerge>
        <feMergeNode in="glow" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>

    <!-- Input cable path -->
    <path id="inputCablePath" d="M 80,40 L 80,80 Q 80,100 100,100 L 220,100 L 220,130" />

    <!-- Branch output paths -->
    <path id="branch1" d="M 370,95  L 430,95  L 470,75" />
    <path id="branch2" d="M 370,125 L 430,125 L 480,115" />
    <path id="branch3" d="M 370,155 L 430,155 L 480,155" />
    <path id="branch4" d="M 370,185 L 430,185 L 480,195" />
    <path id="branch5" d="M 370,215 L 430,215 L 480,235" />
    <path id="branch6" d="M 370,245 L 430,245 L 470,275" />
  </defs>

  <!-- ======================== BACKGROUND ======================== -->
  <rect width="600" height="360" fill="#0A0A0F" rx="8" />

  <!-- Subtle grid overlay -->
  <g opacity="0.04">
    {Array.from({ length: 30 }).map((_, i) => (
      <line x1={i * 20} y1="0" x2={i * 20} y2="360" stroke="#00E5FF" stroke-width="0.5" />
    ))}
    {Array.from({ length: 18 }).map((_, i) => (
      <line x1="0" y1={i * 20} x2="600" y2={i * 20} stroke="#00E5FF" stroke-width="0.5" />
    ))}
  </g>


  <!-- ======================== INPUT CABLE ======================== -->
  <g>
    <!-- Cable line -->
    <path d="M 80,28 L 80,80 Q 80,100 100,100 L 220,100 L 220,130"
          stroke="#00E5FF" stroke-width="4" fill="none" opacity="0.4" stroke-linecap="round" />
    <path d="M 80,28 L 80,80 Q 80,100 100,100 L 220,100 L 220,130"
          stroke="#00E5FF" stroke-width="2" fill="none" opacity="0.8" stroke-linecap="round" />

    <!-- INPUT label -->
    <rect x="52" y="18" width="56" height="18" rx="3" fill="#1C2B3A" stroke="#00E5FF" stroke-width="0.5" />
    <text x="80" y="31" text-anchor="middle" fill="#00E5FF" font-size="9" font-weight="700" class="font-mono">INPUT</text>

    <!-- Voltage badge -->
    <rect x="100" y="75" width="70" height="16" rx="3" fill="#111827" stroke="#2A3A4A" stroke-width="0.5" />
    <text x="135" y="87" text-anchor="middle" fill="#8A9BAE" font-size="8" font-weight="400" class="font-mono">480V 3&#x3A6;</text>

    <!-- Animated flow dots on input cable -->
    <circle r="3" fill="#00E5FF" filter="url(#cyanGlow)">
      <animateMotion dur="2s" repeatCount="indefinite" path="M 80,28 L 80,80 Q 80,100 100,100 L 220,100 L 220,130" />
    </circle>
    <circle r="2.5" fill="#00E5FF" filter="url(#cyanGlow)" opacity="0.7">
      <animateMotion dur="2s" repeatCount="indefinite" begin="0.7s" path="M 80,28 L 80,80 Q 80,100 100,100 L 220,100 L 220,130" />
    </circle>
    <circle r="2" fill="#00E5FF" filter="url(#cyanGlow)" opacity="0.5">
      <animateMotion dur="2s" repeatCount="indefinite" begin="1.3s" path="M 80,28 L 80,80 Q 80,100 100,100 L 220,100 L 220,130" />
    </circle>
  </g>


  <!-- ======================== MAIN CABINET (Isometric) ======================== -->
  <g transform="translate(160, 60)">
    <!-- Cabinet right side panel (3D depth) -->
    <path d="M 200,0 L 240,20 L 240,280 L 200,260 Z" fill="#0D1520" stroke="#1C2B3A" stroke-width="1" />
    <!-- Vertical line details on right panel -->
    <line x1="210" y1="8" x2="210" y2="262" stroke="#1C2B3A" stroke-width="0.5" opacity="0.5" />
    <line x1="220" y1="14" x2="220" y2="268" stroke="#1C2B3A" stroke-width="0.5" opacity="0.3" />
    <line x1="230" y1="18" x2="230" y2="274" stroke="#1C2B3A" stroke-width="0.5" opacity="0.2" />

    <!-- Cabinet top panel (3D depth) -->
    <path d="M 0,0 L 200,0 L 240,20 L 40,20 Z" fill="#141E2A" stroke="#1C2B3A" stroke-width="1" />
    <!-- Grid lines on top -->
    <line x1="40" y1="15" x2="230" y2="15" stroke="#1C2B3A" stroke-width="0.3" opacity="0.4" />
    <!-- Vent slots on top -->
    {[60, 90, 120, 150, 180].map((x) => (
      <rect x={x} y="4" width="16" height="3" rx="1" fill="#0A0A0F" opacity="0.6" />
    ))}

    <!-- Cabinet front panel -->
    <rect x="0" y="0" width="200" height="260" rx="4" fill="#111827" stroke="#1C2B3A" stroke-width="1.5" />

    <!-- Inner frame border -->
    <rect x="6" y="6" width="188" height="248" rx="2" fill="none" stroke="#1C2B3A" stroke-width="0.5" />

    <!-- ---- OLP Logo Badge ---- -->
    <rect x="12" y="12" width="50" height="18" rx="3" fill="#0A0A0F" stroke="#00E5FF" stroke-width="0.8" />
    <text x="37" y="24" text-anchor="middle" fill="#00E5FF" font-size="10" font-weight="700" class="font-display">OLP</text>

    <!-- ---- PDU Label ---- -->
    <text x="100" y="25" text-anchor="middle" fill="#F8FAFC" font-size="13" font-weight="700" class="font-display" letter-spacing="3">PDU</text>

    <!-- ---- MAIN INPUT LUG SECTION (top area) ---- -->
    <rect x="12" y="36" width="176" height="32" rx="2" fill="#0D1520" stroke="#1C2B3A" stroke-width="0.5" />
    <text x="100" y="48" text-anchor="middle" fill="#8A9BAE" font-size="7" class="font-mono">MAIN INPUT LUGS</text>
    <!-- Three phase lug indicators -->
    <g transform="translate(40, 52)">
      <rect x="0" y="0" width="30" height="10" rx="2" fill="#1C2B3A" stroke="#2A3A4A" stroke-width="0.5" />
      <text x="15" y="8" text-anchor="middle" fill="#00E5FF" font-size="6" class="font-mono">L1</text>
    </g>
    <g transform="translate(85, 52)">
      <rect x="0" y="0" width="30" height="10" rx="2" fill="#1C2B3A" stroke="#2A3A4A" stroke-width="0.5" />
      <text x="15" y="8" text-anchor="middle" fill="#00E5FF" font-size="6" class="font-mono">L2</text>
    </g>
    <g transform="translate(130, 52)">
      <rect x="0" y="0" width="30" height="10" rx="2" fill="#1C2B3A" stroke="#2A3A4A" stroke-width="0.5" />
      <text x="15" y="8" text-anchor="middle" fill="#00E5FF" font-size="6" class="font-mono">L3</text>
    </g>

    <!-- ---- CIRCUIT BREAKER SECTION ---- -->
    <rect x="12" y="74" width="176" height="110" rx="2" fill="#0D1520" stroke="#1C2B3A" stroke-width="0.5" />
    <text x="100" y="86" text-anchor="middle" fill="#8A9BAE" font-size="7" class="font-mono">BRANCH CIRCUITS</text>

    <!-- Row 1 of breakers -->
    {[20, 52, 84, 116, 148].map((x, i) => (
      <g transform={`translate(${x}, 92)`}>
        <rect x="0" y="0" width="24" height="14" rx="2" fill="#1C2B3A" stroke="#2A3A4A" stroke-width="0.5" />
        <rect x="3" y="2" width="18" height="4" rx="1" fill={i < 4 ? '#00E5FF' : '#2A3A4A'} opacity={i < 4 ? 0.6 : 0.4} />
        <text x="12" y="13" text-anchor="middle" fill="#8A9BAE" font-size="5" class="font-mono">{`${(i + 1) * 20}A`}</text>
      </g>
    ))}

    <!-- Row 2 of breakers -->
    {[20, 52, 84, 116, 148].map((x, i) => (
      <g transform={`translate(${x}, 112)`}>
        <rect x="0" y="0" width="24" height="14" rx="2" fill="#1C2B3A" stroke="#2A3A4A" stroke-width="0.5" />
        <rect x="3" y="2" width="18" height="4" rx="1" fill={i < 3 ? '#00E5FF' : '#2A3A4A'} opacity={i < 3 ? 0.6 : 0.4} />
        <text x="12" y="13" text-anchor="middle" fill="#8A9BAE" font-size="5" class="font-mono">{`${(i + 6) * 20}A`}</text>
      </g>
    ))}

    <!-- Row 3 of breakers -->
    {[20, 52, 84, 116, 148].map((x, i) => (
      <g transform={`translate(${x}, 132)`}>
        <rect x="0" y="0" width="24" height="14" rx="2" fill="#1C2B3A" stroke="#2A3A4A" stroke-width="0.5" />
        <rect x="3" y="2" width="18" height="4" rx="1" fill={i < 2 ? '#00E5FF' : '#2A3A4A'} opacity={i < 2 ? 0.6 : 0.4} />
        <text x="12" y="13" text-anchor="middle" fill="#8A9BAE" font-size="5" class="font-mono">{`${(i + 11) * 15}A`}</text>
      </g>
    ))}

    <!-- Horizontal divider lines between rows -->
    <line x1="16" y1="110" x2="184" y2="110" stroke="#2A3A4A" stroke-width="0.3" />
    <line x1="16" y1="130" x2="184" y2="130" stroke="#2A3A4A" stroke-width="0.3" />

    <!-- Row labels -->
    <text x="16" y="160" fill="#2A3A4A" font-size="5" class="font-mono">BKR 1-6</text>
    <text x="100" y="170" text-anchor="middle" fill="#2A3A4A" font-size="6" class="font-mono">- - - - - - - - - - - - - - - - -</text>
    <text x="140" y="160" fill="#2A3A4A" font-size="5" class="font-mono">BKR 7-12</text>


    <!-- ---- MONITORING / DISPLAY SECTION ---- -->
    <rect x="12" y="178" width="176" height="72" rx="2" fill="#0D1520" stroke="#1C2B3A" stroke-width="0.5" />

    <!-- Monitor screen -->
    <rect x="18" y="184" width="100" height="58" rx="3" fill="#0A0F18" stroke="#00E5FF" stroke-width="0.6" filter="url(#screenGlow)">
      <animate attributeName="opacity" values="0.85;1;0.85" dur="3s" repeatCount="indefinite" />
    </rect>

    <!-- Screen content: Voltage -->
    <text x="24" y="198" fill="#8A9BAE" font-size="6" class="font-mono">VOLTAGE</text>
    <text x="94" y="198" text-anchor="end" fill="#00E5FF" font-size="11" font-weight="700" class="font-mono">208V</text>

    <!-- Screen content: Current -->
    <text x="24" y="212" fill="#8A9BAE" font-size="6" class="font-mono">CURRENT</text>
    <text x="94" y="212" text-anchor="end" fill="#00E5FF" font-size="11" font-weight="700" class="font-mono">125A</text>

    <!-- Screen content: Bar graph -->
    <text x="24" y="224" fill="#8A9BAE" font-size="6" class="font-mono">LOAD %</text>
    <!-- Bar 1 (Phase A) -->
    <rect x="24" y="228" width="12" height="10" rx="1" fill="#0D1520" />
    <rect x="24" y="231" width="12" height="7" rx="1" fill="#00E5FF" opacity="0.7">
      <animate attributeName="height" values="7;5;7" dur="4s" repeatCount="indefinite" />
      <animate attributeName="y" values="231;233;231" dur="4s" repeatCount="indefinite" />
    </rect>
    <text x="30" y="226" text-anchor="middle" fill="#8A9BAE" font-size="4" class="font-mono">A</text>

    <!-- Bar 2 (Phase B) -->
    <rect x="40" y="228" width="12" height="10" rx="1" fill="#0D1520" />
    <rect x="40" y="230" width="12" height="8" rx="1" fill="#00E5FF" opacity="0.8">
      <animate attributeName="height" values="8;6;8" dur="3.5s" repeatCount="indefinite" begin="0.3s" />
      <animate attributeName="y" values="230;232;230" dur="3.5s" repeatCount="indefinite" begin="0.3s" />
    </rect>
    <text x="46" y="226" text-anchor="middle" fill="#8A9BAE" font-size="4" class="font-mono">B</text>

    <!-- Bar 3 (Phase C) -->
    <rect x="56" y="228" width="12" height="10" rx="1" fill="#0D1520" />
    <rect x="56" y="232" width="12" height="6" rx="1" fill="#00E5FF" opacity="0.6">
      <animate attributeName="height" values="6;4;6" dur="4.5s" repeatCount="indefinite" begin="0.6s" />
      <animate attributeName="y" values="232;234;232" dur="4.5s" repeatCount="indefinite" begin="0.6s" />
    </rect>
    <text x="62" y="226" text-anchor="middle" fill="#8A9BAE" font-size="4" class="font-mono">C</text>

    <!-- SNMP v3 badge (right side of monitor area) -->
    <rect x="126" y="186" width="56" height="16" rx="3" fill="#111827" stroke="#00E5FF" stroke-width="0.5" />
    <text x="154" y="197" text-anchor="middle" fill="#00E5FF" font-size="7" font-weight="700" class="font-mono">SNMP v3</text>

    <!-- Status indicator lights next to SNMP -->
    <circle cx="134" cy="210" r="2.5" fill="#34D399" filter="url(#ledGlow)">
      <animate attributeName="opacity" values="1;0.5;1" dur="2s" repeatCount="indefinite" />
    </circle>
    <text x="142" y="213" fill="#8A9BAE" font-size="5" class="font-mono">NET</text>

    <circle cx="134" cy="222" r="2.5" fill="#34D399" filter="url(#ledGlow)">
      <animate attributeName="opacity" values="1;0.5;1" dur="2.5s" repeatCount="indefinite" begin="0.5s" />
    </circle>
    <text x="142" y="225" fill="#8A9BAE" font-size="5" class="font-mono">COMM</text>

    <circle cx="134" cy="234" r="2.5" fill="#34D399" filter="url(#ledGlow)">
      <animate attributeName="opacity" values="1;0.6;1" dur="3s" repeatCount="indefinite" begin="1s" />
    </circle>
    <text x="142" y="237" fill="#8A9BAE" font-size="5" class="font-mono">ALARM</text>
  </g>


  <!-- ======================== BRANCH OUTPUTS ======================== -->
  <g>
    <!-- Branch output lines and load icons -->

    <!-- Branch 1: Server Rack -->
    <line x1="360" y1="155" x2="400" y2="155" stroke="#1C2B3A" stroke-width="1" />
    <line x1="400" y1="155" x2="430" y2="140" stroke="#1C2B3A" stroke-width="1" />
    <path d="M 400,155 L 430,140 L 490,140" stroke="#00E5FF" stroke-width="1.5" fill="none" opacity="0.5" />
    <!-- Breaker symbol -->
    <line x1="408" y1="149" x2="408" y2="145" stroke="#00E5FF" stroke-width="1" />
    <line x1="412" y1="149" x2="412" y2="145" stroke="#00E5FF" stroke-width="1" />
    <!-- LED -->
    <circle cx="420" cy="140" r="2" fill="#34D399" filter="url(#ledGlow)">
      <animate attributeName="opacity" values="1;0.4;1" dur="2.2s" repeatCount="indefinite" begin="0.1s" />
    </circle>
    <!-- Server rack icon -->
    <g transform="translate(492, 128)">
      <rect x="0" y="0" width="18" height="24" rx="2" fill="#1C2B3A" stroke="#2A3A4A" stroke-width="0.5" />
      <rect x="3" y="3" width="12" height="4" rx="1" fill="#111827" />
      <rect x="3" y="9" width="12" height="4" rx="1" fill="#111827" />
      <rect x="3" y="15" width="12" height="4" rx="1" fill="#111827" />
      <circle cx="13" cy="5" r="1" fill="#34D399" />
      <circle cx="13" cy="11" r="1" fill="#34D399" />
      <circle cx="13" cy="17" r="1" fill="#00E5FF" />
    </g>
    <text x="501" y="160" text-anchor="middle" fill="#8A9BAE" font-size="5" class="font-mono">SERVER</text>
    <!-- Animated dot -->
    <circle r="2" fill="#00E5FF" filter="url(#cyanGlow)">
      <animateMotion dur="1.8s" repeatCount="indefinite" begin="0s" path="M 360,155 L 400,155 L 430,140 L 490,140" />
    </circle>

    <!-- Branch 2: Lighting Panel -->
    <path d="M 360,175 L 400,175 L 490,170" stroke="#00E5FF" stroke-width="1.5" fill="none" opacity="0.5" />
    <!-- Breaker symbol -->
    <line x1="408" y1="178" x2="408" y2="172" stroke="#00E5FF" stroke-width="1" />
    <line x1="412" y1="178" x2="412" y2="172" stroke="#00E5FF" stroke-width="1" />
    <!-- LED -->
    <circle cx="420" cy="173" r="2" fill="#34D399" filter="url(#ledGlow)">
      <animate attributeName="opacity" values="1;0.4;1" dur="2.5s" repeatCount="indefinite" begin="0.4s" />
    </circle>
    <!-- Lighting icon (bulb) -->
    <g transform="translate(493, 160)">
      <circle cx="9" cy="7" r="6" fill="none" stroke="#8A9BAE" stroke-width="1" />
      <line x1="9" y1="1" x2="9" y2="-2" stroke="#8A9BAE" stroke-width="0.8" />
      <line x1="4" y1="3" x2="2" y2="1" stroke="#8A9BAE" stroke-width="0.8" />
      <line x1="14" y1="3" x2="16" y2="1" stroke="#8A9BAE" stroke-width="0.8" />
      <rect x="7" y="13" width="4" height="3" rx="1" fill="#8A9BAE" />
    </g>
    <text x="502" y="184" text-anchor="middle" fill="#8A9BAE" font-size="5" class="font-mono">LIGHTS</text>
    <!-- Animated dot -->
    <circle r="2" fill="#00E5FF" filter="url(#cyanGlow)">
      <animateMotion dur="1.6s" repeatCount="indefinite" begin="0.3s" path="M 360,175 L 400,175 L 490,170" />
    </circle>

    <!-- Branch 3: HVAC -->
    <path d="M 360,200 L 400,200 L 490,200" stroke="#00E5FF" stroke-width="1.5" fill="none" opacity="0.5" />
    <!-- Breaker symbol -->
    <line x1="408" y1="203" x2="408" y2="197" stroke="#00E5FF" stroke-width="1" />
    <line x1="412" y1="203" x2="412" y2="197" stroke="#00E5FF" stroke-width="1" />
    <!-- LED -->
    <circle cx="420" cy="200" r="2" fill="#34D399" filter="url(#ledGlow)">
      <animate attributeName="opacity" values="1;0.4;1" dur="2.8s" repeatCount="indefinite" begin="0.7s" />
    </circle>
    <!-- HVAC icon (fan/snowflake hybrid) -->
    <g transform="translate(493, 190)">
      <rect x="0" y="0" width="18" height="18" rx="2" fill="#1C2B3A" stroke="#2A3A4A" stroke-width="0.5" />
      <circle cx="9" cy="9" r="5" fill="none" stroke="#8A9BAE" stroke-width="0.8" />
      <line x1="9" y1="4" x2="9" y2="14" stroke="#8A9BAE" stroke-width="0.6" />
      <line x1="4" y1="9" x2="14" y2="9" stroke="#8A9BAE" stroke-width="0.6" />
      <line x1="5.5" y1="5.5" x2="12.5" y2="12.5" stroke="#8A9BAE" stroke-width="0.6" />
      <line x1="12.5" y1="5.5" x2="5.5" y2="12.5" stroke="#8A9BAE" stroke-width="0.6" />
    </g>
    <text x="502" y="216" text-anchor="middle" fill="#8A9BAE" font-size="5" class="font-mono">HVAC</text>
    <!-- Animated dot -->
    <circle r="2" fill="#00E5FF" filter="url(#cyanGlow)">
      <animateMotion dur="1.9s" repeatCount="indefinite" begin="0.5s" path="M 360,200 L 400,200 L 490,200" />
    </circle>

    <!-- Branch 4: Medical Equipment -->
    <path d="M 360,225 L 400,225 L 490,230" stroke="#00E5FF" stroke-width="1.5" fill="none" opacity="0.5" />
    <!-- Breaker symbol -->
    <line x1="408" y1="228" x2="408" y2="222" stroke="#00E5FF" stroke-width="1" />
    <line x1="412" y1="228" x2="412" y2="222" stroke="#00E5FF" stroke-width="1" />
    <!-- LED -->
    <circle cx="420" cy="225" r="2" fill="#34D399" filter="url(#ledGlow)">
      <animate attributeName="opacity" values="1;0.4;1" dur="2.3s" repeatCount="indefinite" begin="1s" />
    </circle>
    <!-- Medical icon (cross) -->
    <g transform="translate(493, 220)">
      <rect x="0" y="0" width="18" height="18" rx="2" fill="#1C2B3A" stroke="#2A3A4A" stroke-width="0.5" />
