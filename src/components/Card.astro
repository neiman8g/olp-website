---
interface Props {
  variant?: 'product' | 'feature' | 'testimonial' | 'cta';
  href?: string;
  accent?: boolean;
  dark?: boolean;
  class?: string;
}

const {
  variant = 'feature',
  href,
  accent,
  dark = false,
  class: className = '',
} = Astro.props;

const variantClasses: Record<string, string> = {
  product: dark
    ? 'card-hover-dark bg-navy-mid rounded-lg p-6'
    : 'card-hover bg-white rounded-lg p-6',
  feature: dark
    ? 'card-hover-dark bg-navy-mid rounded-lg p-6'
    : 'card-hover bg-white rounded-lg p-6',
  testimonial: dark
    ? 'bg-navy-mid border border-border-dark rounded-lg p-6'
    : 'bg-white border border-steel-gray rounded-lg p-6',
  cta: dark
    ? 'bg-navy-mid border border-border-dark rounded-lg p-8 md:p-12'
    : 'bg-white border border-steel-gray rounded-lg p-8 md:p-12',
};

const showAccent = accent ?? (variant === 'product');

const baseClasses = [
  variantClasses[variant],
  showAccent ? 'border-t-2 border-t-steel-blue' : '',
  href ? 'group transition-all' : '',
  className,
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={baseClasses}>
    <slot />
  </a>
) : (
  <div class={baseClasses}>
    <slot />
  </div>
)}
