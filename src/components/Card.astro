---
interface Props {
  variant?: 'product' | 'feature' | 'testimonial' | 'cta';
  href?: string;
  accent?: boolean;
  class?: string;
}

const {
  variant = 'feature',
  href,
  accent,
  class: className = '',
} = Astro.props;

const showAccent = accent ?? variant === 'product';

const variantClasses: Record<string, string> = {
  product: 'card-glow bg-steel/30 rounded-xl p-6',
  feature: 'card-glow bg-obsidian rounded-xl p-6',
  testimonial: 'bg-slate/50 border border-steel/30 rounded-xl p-6 md:p-8',
  cta: 'card-glow bg-voltage/5 border-voltage/20 rounded-2xl p-8 md:p-12',
};

const baseClasses = [
  variantClasses[variant],
  showAccent ? 'card-top-accent' : '',
  href ? 'group transition-all' : '',
  className,
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={baseClasses}>
    <slot />
  </a>
) : (
  <div class={baseClasses}>
    <slot />
  </div>
)}
