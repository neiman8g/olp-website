---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';
import SearchModal from '../components/SearchModal.astro';
import SEOHead from '../components/SEOHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  product?: { name: string; description: string; image: string; category: string; };
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const { title, description, canonical, ogImage, product, breadcrumbs } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <SEOHead title={title} description={description} canonical={canonical} ogImage={ogImage} />
  <SchemaOrg type={product ? 'product' : 'organization'} product={product} breadcrumbs={breadcrumbs} />
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-B1MM41FV5G"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-B1MM41FV5G');
  </script>
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1" data-pagefind-body>
    <slot />
  </main>
  <div data-pagefind-ignore>
    <ChatWidget />
    <SearchModal />
    <Footer />
  </div>
</body>
</html>
