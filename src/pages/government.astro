---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="Government & Compliance | BAA & TAA | Online Power"
  description="Online Power products meet Buy American Act and Trade Agreements Act requirements. ISO 9001 certified. Manufactured in Los Angeles. Federal, state, and municipal procurement."
>

  <!-- BREADCRUMB STRIP -->
  <section class="bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
      <nav class="text-[13px] font-display text-slate">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-near-black font-semibold">Government &amp; Compliance</span>
      </nav>
    </div>
  </section>

  <!-- ========== HERO — dark with depth ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute -top-32 -right-32 w-[560px] h-[560px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.3) 0%, rgba(37,103,194,0) 70%); filter: blur(12px);"></div>
    <div class="absolute -bottom-24 -left-24 w-[420px] h-[420px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(126,179,245,0.15) 0%, rgba(126,179,245,0) 70%); filter: blur(10px);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="badge-dark">BAA Compliant</span>
            <span class="badge-dark">TAA Compliant</span>
            <span class="badge-dark">ISO 9001</span>
            <span class="badge-dark">Made in USA</span>
          </div>

          <h1 class="font-display text-4xl md:text-5xl lg:text-[56px] font-extrabold tracking-tight text-white leading-[1.05] mb-5">
            Federal, State, <span class="text-sky-blue">and Municipal.</span>
          </h1>
          <p class="text-lg text-muted-blue leading-relaxed max-w-xl mb-8">
            Online Power equipment meets Buy American Act and Trade Agreements Act requirements. Every unit is designed, engineered, tested, and manufactured at our Los Angeles facility — no offshore assembly, no second-source loopholes.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <Button href="/contact/" size="lg" icon="arrow-right">Request Compliance Docs</Button>
          </div>
          <p class="font-display text-[13px] text-muted-blue">Solicitation-ready documentation in 48 hours</p>
        </div>

        <div class="hidden lg:block lg:col-span-2">
          <div class="relative bg-navy-mid border border-white/5 rounded-xl p-8 shadow-[0_20px_60px_-20px_rgba(0,0,0,0.5)]">
            <div class="absolute inset-0 pointer-events-none opacity-[0.08] rounded-xl overflow-hidden" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 22px 22px;"></div>
            <div class="relative">
              <div class="flex items-center gap-3 mb-4">
                <svg viewBox="0 0 19 10" class="w-10 h-[20px] rounded-[2px] shadow-sm flex-shrink-0" aria-label="US Flag" role="img">
                  <rect width="19" height="10" fill="#B22234"/>
                  <rect y="0.77" width="19" height="0.77" fill="#fff"/>
                  <rect y="2.31" width="19" height="0.77" fill="#fff"/>
                  <rect y="3.85" width="19" height="0.77" fill="#fff"/>
                  <rect y="5.38" width="19" height="0.77" fill="#fff"/>
                  <rect y="6.92" width="19" height="0.77" fill="#fff"/>
                  <rect y="8.46" width="19" height="0.77" fill="#fff"/>
                  <rect width="7.6" height="5.38" fill="#3C3B6E"/>
                </svg>
                <p class="font-display text-[11px] font-semibold uppercase tracking-[0.2em] text-sky-blue">Procurement</p>
              </div>
              <p class="font-display text-white text-[34px] font-extrabold leading-[1.05] tracking-tight">One manufacturer.<br/>One country.<br/>One spec.</p>
              <p class="text-muted-blue text-[14px] mt-5 leading-relaxed">Designed and built under a single ISO 9001 quality system — so every submittal carries the same signed certifications from the same people.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative border-t border-navy-mid" style="z-index: 2;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-navy-mid">
          {[
            { label: 'Buy American Act', value: 'BAA Compliant' },
            { label: 'Trade Agreements Act', value: 'TAA Compliant' },
            { label: 'Quality System', value: 'ISO 9001' },
            { label: 'Country of Origin', value: 'USA · Los Angeles' },
          ].map(s => (
            <div class="py-6 px-4 md:px-6 text-center md:text-left">
              <p class="font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-blue mb-2">{s.label}</p>
              <p class="font-display text-[15px] md:text-[17px] font-bold text-white leading-tight">{s.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 01 · COMPLIANCE CARDS ========== -->
  <section class="py-16 md:py-24 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-10">
        <span class="font-display text-[11px] font-bold tracking-[0.2em] text-steel-blue uppercase inline-flex items-center gap-3"><span class="w-7 h-[1px] bg-steel-blue opacity-60"></span>01 · What This Means</span>
        <h2 class="font-display text-3xl md:text-[40px] font-extrabold tracking-tight text-near-black mt-3 leading-[1.05]">Cleared for <span class="text-steel-blue">Federal Procurement.</span></h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <div class="group relative overflow-hidden bg-white border border-steel-gray rounded-xl p-7 hover:border-steel-blue hover:-translate-y-1 hover:shadow-[0_18px_40px_-12px_rgba(37,103,194,0.28)] transition-all">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0 group-hover:bg-steel-blue transition-colors">
              <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/></svg>
            </div>
            <div>
              <p class="font-display text-[11px] font-semibold uppercase tracking-[0.14em] text-steel-blue mb-1">FAR 52.225-1</p>
              <h3 class="font-display text-2xl font-extrabold tracking-tight text-near-black mb-3">Buy American Act (BAA)</h3>
              <p class="text-[14px] text-slate leading-relaxed">Online Power products can be specified and procured under BAA rules for federal agencies, GSA procurement, and any contract invoking the Buy American Act. Cost of US-manufactured components and manufacturing labor exceeds the statutory threshold.</p>
            </div>
          </div>
        </div>

        <div class="group relative overflow-hidden bg-white border border-steel-gray rounded-xl p-7 hover:border-steel-blue hover:-translate-y-1 hover:shadow-[0_18px_40px_-12px_rgba(37,103,194,0.28)] transition-all">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0 group-hover:bg-steel-blue transition-colors">
              <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="font-display text-[11px] font-semibold uppercase tracking-[0.14em] text-steel-blue mb-1">19 U.S.C. §2501+</p>
              <h3 class="font-display text-2xl font-extrabold tracking-tight text-near-black mb-3">Trade Agreements Act (TAA)</h3>
              <p class="text-[14px] text-slate leading-relaxed">Online Power equipment is manufactured in the United States, a TAA-designated country. Suitable for GSA Schedule contracts, Federal Supply Service, Department of Defense, and other contracts with TAA compliance requirements.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 02 · WHY IT MATTERS ========== -->
  <section class="relative py-16 md:py-24 bg-near-black overflow-hidden border-y border-navy-mid">
    <div class="absolute inset-0 pointer-events-none opacity-[0.05]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] pointer-events-none" style="background: radial-gradient(ellipse, rgba(37,103,194,0.22) 0%, rgba(37,103,194,0) 65%); filter: blur(12px);"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-[3px]" style="background: linear-gradient(90deg, transparent, rgba(126,179,245,0.8), transparent);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <span class="font-display text-[11px] font-bold tracking-[0.2em] text-sky-blue uppercase inline-flex items-center gap-3"><span class="w-7 h-[1px] bg-sky-blue opacity-60"></span>02 · The Advantage</span>
        <h2 class="font-display text-3xl md:text-[44px] font-extrabold tracking-tight text-white mt-3 leading-[1.05]">Built in LA. <span class="text-sky-blue">Signed in LA.</span></h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {[
          { title: 'Full US Manufacturing', body: 'Design, engineering, board assembly, cabinet fabrication, test, and burn-in all happen on our Los Angeles floor. No offshore sub-assembly.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
          { title: 'Single ISO 9001 System', body: 'Every unit — standard or custom OEM — goes through the same ISO-certified quality workflow. One quality record per serial.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
          { title: 'Direct Engineering Support', body: 'No distributor layer. The engineer who signed the UL file can speak to your CO, spec writer, and AHJ directly.', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
        ].map(c => (
          <div class="bg-navy-mid/50 border border-navy-mid rounded-xl p-6 md:p-7 backdrop-blur-sm hover:border-steel-blue transition-colors">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/20 border border-steel-blue/40 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-sky-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={c.icon}/></svg>
            </div>
            <h3 class="font-display text-[20px] font-bold text-white mb-2">{c.title}</h3>
            <p class="text-[14px] text-muted-blue leading-relaxed">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 03 · ACQUISITION VEHICLES ========== -->
  <section class="py-16 md:py-24 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-10">
        <span class="font-display text-[11px] font-bold tracking-[0.2em] text-steel-blue uppercase inline-flex items-center gap-3"><span class="w-7 h-[1px] bg-steel-blue opacity-60"></span>03 · Acquisition Vehicles</span>
        <h2 class="font-display text-3xl md:text-[40px] font-extrabold tracking-tight text-near-black mt-3 leading-[1.05]">Where We've Been <span class="text-steel-blue">Specified.</span></h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { name: 'Federal Agencies', detail: 'DoD, VA, GSA, DOE' },
          { name: 'Municipal', detail: 'City halls, courthouses, transit' },
          { name: 'Healthcare (Gov)', detail: 'VA hospitals, DoD medical' },
          { name: 'Higher Ed', detail: 'State universities, labs' },
          { name: 'Transportation', detail: 'Airports, rail, ports' },
          { name: 'Federal Law Enforcement', detail: 'FBI, DEA, field offices' },
          { name: 'Research Facilities', detail: 'National labs, NIH' },
          { name: 'K-12 Public Schools', detail: 'Emergency lighting compliance' },
        ].map(v => (
          <div class="bg-white border border-steel-gray rounded-lg p-4 hover:border-steel-blue transition-colors">
            <p class="font-display text-[14px] font-bold text-near-black">{v.name}</p>
            <p class="text-[12px] text-slate mt-1">{v.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="relative bg-deep-navy py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-[0.06]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-[3px]" style="background: linear-gradient(90deg, transparent, rgba(37,103,194,0.8), transparent);"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight text-white mb-4 leading-[1.05]">Need Compliance Documentation?</h2>
      <p class="text-base md:text-lg text-muted-blue mb-8 max-w-xl mx-auto">Country-of-origin certificates, ISO 9001 certs, UL listings, BAA / TAA letters — whatever your CO needs. We'll send a complete submittal package within 48 hours.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact/" size="lg" icon="arrow-right">Request Compliance Package</Button>
      </div>
    </div>
  </section>

</BaseLayout>
</content>
</invoke>