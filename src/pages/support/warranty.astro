---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { company } from '../../data/company';
---

<BaseLayout title="Warranty | Online Power" description="Online Power product warranty information and registration.">

  <section class="py-10 md:py-14 bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="eyebrow text-slate mb-6">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a><span class="mx-2 text-slate">/</span><span class="text-steel-blue">Warranty</span>
      </nav>
      <h1 class="font-display text-4xl md:text-[40px] font-bold text-near-black mb-4">Warranty</h1>
      <p class="text-lg text-slate max-w-2xl">All products backed by our manufacturer warranty and factory-direct support.</p>
    </div>
  </section>

  <section class="py-14 md:py-[72px] bg-off-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="text-slate leading-relaxed mb-8">For warranty details, registration, or service requests, contact our support team:</p>
      <div class="card-hover bg-white rounded-xl p-6 space-y-3">
        <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="flex items-center gap-3 text-steel-blue font-display font-semibold text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          {company.phone}
        </a>
        <a href={`mailto:${company.email}`} class="flex items-center gap-3 text-slate hover:text-steel-blue transition-colors text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          {company.email}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
