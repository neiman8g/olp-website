---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { productCategories } from '../../data/navigation';
---

<BaseLayout title="Product Documents | Online Power" description="Download datasheets, technical specs, manuals, and wiring diagrams for all Online Power products.">

  <section class="py-20 md:py-28 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-6">
        <a href="/" class="hover:text-voltage transition-colors">Home</a><span class="mx-2 text-steel">/</span><span class="text-voltage">Documents</span>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-pure mb-4">Product Documents</h1>
      <p class="text-lg text-ash max-w-2xl">Datasheets, technical specs, manuals, and wiring diagrams.</p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {productCategories.map(cat => (
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <h2 class="font-display font-semibold text-pure mb-1">{cat.name}</h2>
            <p class="text-sm text-ash mb-4">{cat.description}</p>
            <a href={`/products/${cat.slug}/`} class="text-sm font-medium text-voltage hover:text-pure transition-colors">View documents &rarr;</a>
          </div>
        ))}
      </div>
      <p class="text-center text-sm text-ash mt-10">Need something specific? <a href="/contact/" class="text-voltage hover:underline">Contact us</a>.</p>
    </div>
  </section>

</BaseLayout>
