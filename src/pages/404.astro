---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | Online Power" description="Page not found.">

  <section class="py-28 md:py-40 text-center">
    <div class="max-w-xl mx-auto px-4">
      <p class="font-display text-7xl font-bold text-voltage mb-4">404</p>
      <h1 class="font-display text-2xl font-bold text-pure mb-3">Page Not Found</h1>
      <p class="text-ash mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary px-6 py-3 rounded-lg text-sm font-semibold">Go Home</a>
        <a href="/products/" class="btn-ghost px-6 py-3 rounded-lg text-sm">Browse Products</a>
      </div>
    </div>
  </section>

</BaseLayout>
