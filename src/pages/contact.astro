---
import BaseLayout from '../layouts/BaseLayout.astro';
import { company } from '../data/company';
---

<BaseLayout
  title="Contact Online Power | Request a Quote | Power Protection Manufacturer"
  description="Contact Online Power for quotes, product information, or technical support. Call (800) 227-8899. US manufacturer of emergency lighting inverters, UPS, and power protection equipment."
>

  <section class="py-20 md:py-28 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-6">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Contact</span>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-pure mb-4">Contact Us</h1>
      <p class="text-lg text-ash max-w-2xl">Request a quote, ask a technical question, or get product information.</p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-5 gap-16">
        <div class="lg:col-span-2">
          <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Direct</p>
          <div class="space-y-4 mb-8">
            <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="flex items-center gap-3 text-ash hover:text-voltage transition-colors">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <span class="font-mono text-sm">{company.phone}</span>
            </a>
            <a href={`mailto:${company.email}`} class="flex items-center gap-3 text-ash hover:text-voltage transition-colors">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <span class="text-sm">{company.email}</span>
            </a>
          </div>
          <p class="text-xs text-steel mb-8">{company.location}</p>

          <div class="card-glow bg-obsidian rounded-xl p-5">
            <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-2">Training</p>
            <p class="text-sm text-ash mb-3">Expert training on any Online Power product.</p>
            <a href="/training/" class="text-sm font-medium text-voltage hover:text-pure transition-colors">Register &rarr;</a>
          </div>
        </div>

        <div class="lg:col-span-3">
          <form id="contact-form" class="bg-obsidian border border-steel/30 rounded-2xl p-6 md:p-8 space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="text" id="c-fname" name="name" required placeholder="First Name *" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/40 focus:border-voltage/50 outline-none transition-colors" />
              <input type="text" id="c-lname" name="lastname" required placeholder="Last Name *" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/40 focus:border-voltage/50 outline-none transition-colors" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="email" id="c-email" name="email" required placeholder="Email *" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/40 focus:border-voltage/50 outline-none transition-colors" />
              <input type="tel" id="c-phone" name="phone" required placeholder="Phone *" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/40 focus:border-voltage/50 outline-none transition-colors" />
            </div>
            <select id="c-subject" name="subject" required class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-ash focus:border-voltage/50 outline-none transition-colors">
              <option value="">Subject *</option>
              <option value="Quote Request">Quote Request</option>
              <option value="Technical Question">Technical Question</option>
              <option value="Custom OEM">Custom OEM Inquiry</option>
              <option value="Service Request">Service Request</option>
              <option value="Other">Other</option>
            </select>
            <textarea id="c-message" name="message" rows="5" required placeholder="Message *" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/40 focus:border-voltage/50 outline-none transition-colors resize-y"></textarea>
            <div class="hidden" aria-hidden="true"><input type="text" name="website" tabindex="-1" autocomplete="off" /></div>
            <button type="submit" id="contact-submit-btn" class="btn-primary px-8 py-3.5 rounded-lg text-sm font-semibold">Send Message</button>
            <div id="contact-success" class="hidden p-4 bg-voltage/10 border border-voltage/30 rounded-lg text-voltage text-sm">Message sent. We'll respond within 1-2 business days.</div>
            <div id="contact-error" class="hidden p-4 bg-red-500/10 border border-red-500/30 rounded-lg text-red-400 text-sm">Something went wrong. Call {company.phone}.</div>
          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  (function() {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js';
    s.onload = function() { emailjs.init('ZpNSMzngBD1uoKBg2'); };
    document.head.appendChild(s);
    var form = document.getElementById('contact-form');
    var btn = document.getElementById('contact-submit-btn');
    form && form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (form.querySelector('[name="website"]').value) return;
      btn.disabled = true; btn.textContent = 'Sending...';
      var p = { name: form.querySelector('#c-fname').value+' '+form.querySelector('#c-lname').value, email: form.querySelector('#c-email').value, phone: form.querySelector('#c-phone').value, subject: form.querySelector('#c-subject').value, message: form.querySelector('#c-message').value };
      emailjs.send('service_wwtue8f','template_tavsq3o',p).then(function(){
        document.getElementById('contact-success').classList.remove('hidden');
        document.getElementById('contact-error').classList.add('hidden');
        form.reset(); btn.disabled=false; btn.textContent='Send Message';
      }).catch(function(){
        document.getElementById('contact-error').classList.remove('hidden');
        btn.disabled=false; btn.textContent='Send Message';
      });
    });
  })();
</script>
