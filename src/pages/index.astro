  <!-- ========== CHAPTER 05 · WHY IT MATTERS (research-backed) ========== -->
  <section id="ch-05" data-chapter="05" data-chapter-title="Why It Matters" class="py-16 md:py-24 bg-off-white journey-seam">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl mb-12 reveal">
        <span class="chapter-num mb-3 inline-flex">05 · Why It Matters</span>
        <h2 class="font-display text-3xl md:text-[44px] font-extrabold tracking-tight text-near-black mt-3 leading-[1.05]">The Code Doesn't Ask <span class="text-steel-blue">Why.</span></h2>
        <p class="text-slate mt-4 text-lg">Every number below comes from a standard, federal lab, or peer-reviewed source. When the grid drops or a panel fails, these are the thresholds that matter — and the citations AHJs read.</p>
      </div>

      <!-- Horizontal scrolling research rail covering every product category -->
      <div class="relative -mx-4 sm:-mx-6">
        <div id="research-rail" class="flex overflow-x-auto snap-x snap-mandatory gap-5 px-4 sm:px-6 pb-5 no-scrollbar scroll-smooth">
          {[
            { cat: 'Power Quality', big: '$44B', unit: '', headline: 'Annual cost of sustained US power interruptions', body: 'Lawrence Berkeley National Laboratory (2018) puts the economic cost of sustained outages at roughly $44 billion per year using peer-reviewed methodology.', src: 'LBNL · LaCommare, Eto et al. (2018)', href: 'https://eta-publications.lbl.gov/sites/default/files/copi_26sept2018.pdf' },
            { cat: 'Data Centers', big: '54', unit: '%', headline: 'of data center outages cost over $100,000', body: "Uptime Institute's 2024 analysis: half of significant outages now cross the six-figure threshold; one in five exceed $1M.", src: 'Uptime Institute · Annual Outage Analysis 2024', href: 'https://uptimeinstitute.com/resources/research-and-reports/annual-outage-analysis-2024' },
            { cat: 'Emergency Lighting', big: '90', unit: ' min', headline: 'Egress illumination required after grid loss', body: 'NFPA 101 §7.9 mandates 1½ hours of emergency illumination along every egress path. Full brightness on minute 89 is the test.', src: 'NFPA 101 · §7.9', href: 'https://www.nfpa.org/news-blogs-and-articles/nfpa-journal/2020/07/01/nfpa-101-july' },
            { cat: 'UL 924 Response', big: '10', unit: ' s', headline: 'Maximum activation time for emergency equipment', body: 'UL 924 requires emergency lighting and power equipment to reach full output within 10 seconds of normal-power loss. NFPA 110 Type 10 matches.', src: 'UL 924 · Emergency Lighting & Power Equipment', href: 'https://www.ul.com/news/updates-ul-924-and-emergency-lighting' },
            { cat: 'Fire Alarm', big: '24', unit: ' hr + 5 min', headline: 'Standby + full-alarm duration required', body: 'NFPA 72 §10.6.7.2: secondary power carries 24 hours of standby plus 5 minutes of full alarm — 15 minutes with voice/MNS evacuation.', src: 'NFPA 72 · §10.6.7', href: 'https://www.nfpa.org/news-blogs-and-articles/nfpa-journal/2021/05/03/nfpa-72-may' },
            { cat: 'Elevator', big: '2', unit: ' hr', headline: 'Continuous evacuation power for safe egress', body: 'ASME A17.1 / IBC require a standby power source capable of operating the elevator and its accessories for safe evacuation during utility failure.', src: 'ASME A17.1 · Elevator Safety Code', href: 'https://www.asme.org/codes-standards/find-codes-standards/a17-1-csa-b44-safety-code-elevators-escalators' },
            { cat: 'Healthcare', big: 'Type 1', unit: '', headline: 'Essential Electrical System for Category 1 care', body: 'NFPA 99 requires a Type 1 EES restoring power within 10 seconds for any space where power loss could cause patient death. UL 60601-1 leakage limits stack on top.', src: 'NFPA 99 · Essential Electrical Systems', href: 'https://www.nfpa.org/news-blogs-and-articles/blogs/2019/09/17/dissecting-the-essential-electrical-system-ees-in-healthcare-facilities' },
            { cat: 'Medical Leakage', big: '100', unit: ' µA', headline: 'Max chassis leakage for medical equipment', body: 'UL 60601-1 caps chassis leakage at 100 µA normal condition and 10 µA at the patient under single-fault condition — thresholds no standard UPS meets.', src: 'UL 60601-1 · Medical Electrical Equipment', href: 'https://www.ul.com/services/ul-60601-1-testing-and-certification' },
            { cat: 'Power Quality · ANSI', big: '±5', unit: '%', headline: 'Utility service voltage tolerance (US)', body: 'ANSI C84.1 specifies ±5% utility service voltage tolerance. Sensitive equipment fails well inside that window — voltage regulation closes the gap.', src: 'ANSI C84.1 · Electric Power Systems & Equipment — Voltage Ratings', href: 'https://webstore.ansi.org/standards/nema/ansinemac842016' },
            { cat: 'Harmonics', big: '5', unit: '% THD', headline: 'Voltage distortion limit at the PCC', body: 'IEEE 519 limits voltage THD at the point of common coupling to 5%. Isolation transformers and harmonic-mitigating PDUs keep non-linear loads inside the window.', src: 'IEEE 519 · Harmonic Control in Electric Power Systems', href: 'https://standards.ieee.org/ieee/519/10677/' },
            { cat: 'Aerospace', big: '400', unit: ' Hz', headline: 'Aircraft & defense electrical systems', body: 'MIL-STD-704 standardizes 400 Hz, 115 VAC three-phase power for US military aircraft. Ground-support gear requires frequency conversion from 60 Hz utility.', src: 'MIL-STD-704 · Aircraft Electric Power Characteristics', href: 'https://quicksearch.dla.mil/qsDocDetails.aspx?ident_number=36080' },
            { cat: 'Sensitive Loads', big: 'IEEE 1100', unit: '', headline: 'Grounding for sensitive electronic equipment', body: 'IEEE 1100 (Emerald Book) recommends isolation with electrostatic shielding for sensitive electronic loads — the spec behind medical imaging and broadcast clean-power requirements.', src: 'IEEE 1100 · Emerald Book', href: 'https://standards.ieee.org/ieee/1100/1811/' },
          ].map((r) => (
            <a href={r.href} target="_blank" rel="noopener" class="snap-start shrink-0 w-[85vw] sm:w-[360px] bg-white border border-steel-gray rounded-xl p-6 md:p-7 hover:border-steel-blue hover:shadow-[0_12px_28px_-8px_rgba(37,103,194,0.18)] hover:-translate-y-0.5 transition-all flex flex-col group">
              <span class="font-display text-[11px] font-semibold uppercase tracking-[0.2em] text-steel-blue">{r.cat}</span>
              <p class="font-display text-[40px] md:text-[48px] font-extrabold tracking-tight text-near-black leading-none mt-3">{r.big}<span class="text-steel-blue">{r.unit}</span></p>
              <p class="text-near-black text-[16px] font-semibold mt-2">{r.headline}</p>
              <p class="text-slate text-[13px] mt-2 leading-relaxed flex-1">{r.body}</p>
              <span class="inline-flex items-center gap-1.5 font-display text-[11px] font-semibold uppercase tracking-[0.12em] text-steel-blue group-hover:text-near-black transition-colors mt-4">
                {r.src}
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </span>
            </a>
          ))}
        </div>

        <!-- Scroll controls (desktop) -->
        <button type="button" data-rail-scroll="research-rail" data-dir="-1" aria-label="Scroll research left" class="hidden md:flex absolute left-2 top-1/2 -translate-y-1/2 z-10 w-11 h-11 rounded-full bg-white border border-steel-gray shadow-md items-center justify-center hover:border-steel-blue hover:bg-steel-blue hover:text-white text-near-black transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
