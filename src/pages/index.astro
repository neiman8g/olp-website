---
import BaseLayout from '../layouts/BaseLayout.astro';
import { company, testimonials } from '../data/company';
---

<BaseLayout
  title="Online Power | Mission-Critical Power Protection | Manufacturer Since 1975"
  description="Online Power manufactures mission-critical power protection equipment. Emergency lighting inverters, UPS systems, fire alarm backup, and custom OEM solutions. UL Listed. ISO 9001. Made in Los Angeles, CA."
>

  <!-- ========== HERO ========== -->
  <section class="min-h-[calc(100vh-4rem)] flex flex-col justify-center relative overflow-hidden">
    <!-- Subtle bg glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-voltage/5 rounded-full blur-[150px] pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-20 md:py-28 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div>
          <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold text-pure leading-[1.05] tracking-tight mb-6">
            Power That<br/>Never Quits.
          </h1>
          <p class="text-lg md:text-xl text-ash max-w-xl leading-relaxed mb-10">
            48 years of mission-critical power protection. UL Listed. ISO 9001. Made in the USA.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-12">
            <a href="/products/" class="btn-primary px-8 py-3.5 rounded-lg text-sm font-semibold text-center inline-flex items-center justify-center gap-2">
              View Products
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
            <a href="/contact/" class="btn-ghost px-8 py-3.5 rounded-lg text-sm text-center inline-flex items-center justify-center">
              Request a Quote
            </a>
          </div>
        </div>

        <!-- Right: Animated SVG Power Flow Diagram -->
        <div class="hidden lg:flex items-center justify-center">
          <svg viewBox="0 0 500 320" width="100%" style="max-width:500px;" xmlns="http://www.w3.org/2000/svg">
            <style>
              @keyframes flowRight {
                0% { offset-distance: 0%; opacity: 0; }
                10% { opacity: 1; }
                90% { opacity: 1; }
                100% { offset-distance: 100%; opacity: 0; }
              }
              @keyframes flowOut1 {
                0% { offset-distance: 0%; opacity: 0; }
                10% { opacity: 1; }
                90% { opacity: 1; }
                100% { offset-distance: 100%; opacity: 0; }
              }
              @keyframes pulseBox {
                0%, 100% { stroke: #00E5FF; stroke-width: 1.5; }
                50% { stroke: #00E5FF; stroke-width: 3; }
              }
              .utility-line { stroke: #1C2B3A; stroke-width: 1.5; fill: none; transition: stroke 0.5s; }
              .output-line { stroke: #1C2B3A; stroke-width: 1.5; fill: none; }
              .active-line { stroke: #00E5FF; }
              .flow-dot {
                r: 3.5; fill: #00E5FF;
                offset-rotate: 0deg;
              }
              .dot-main {
                offset-path: path('M 150 100 L 220 100');
                animation: flowRight 2s linear infinite;
              }
              .dot-out1 {
                offset-path: path('M 360 100 L 420 100');
                animation: flowOut1 2s linear infinite 0.5s;
              }
              .dot-out2 {
                offset-path: path('M 360 100 L 390 100 L 390 180 L 420 180');
                animation: flowOut1 2.5s linear infinite 0.8s;
              }
              .dot-out3 {
                offset-path: path('M 360 100 L 390 100 L 390 260 L 420 260');
                animation: flowOut1 3s linear infinite 1.1s;
              }
              .inverter-box { animation: pulseBox 3s ease-in-out infinite; }
            </style>

            <rect x="20" y="78" width="90" height="44" rx="4" fill="#111827" stroke="#1C2B3A" stroke-width="1"/>
            <text x="65" y="97" text-anchor="middle" font-family="Space Mono, monospace" font-size="9" fill="#8A9BAE">UTILITY</text>
            <text x="65" y="112" text-anchor="middle" font-family="Space Mono, monospace" font-size="8" fill="#5A6A7A">120–480V</text>

            <line x1="110" y1="100" x2="220" y2="100" class="utility-line"/>

            <rect class="inverter-box" x="220" y="68" width="140" height="64" rx="4" fill="#111827" stroke="#00E5FF" stroke-width="1.5"/>
            <text x="290" y="92" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="10" fill="#F8FAFC" font-weight="700">ONLINE POWER</text>
            <text x="290" y="108" text-anchor="middle" font-family="Space Mono, monospace" font-size="8" fill="#00E5FF">INVERTER</text>
            <text x="290" y="122" text-anchor="middle" font-family="Space Mono, monospace" font-size="7" fill="#5A6A7A">27W – 400kW</text>

            <line x1="360" y1="100" x2="420" y2="100" class="output-line active-line"/>
            <line x1="390" y1="100" x2="390" y2="180" class="output-line active-line"/>
            <line x1="390" y1="180" x2="390" y2="260" class="output-line active-line"/>
            <line x1="390" y1="180" x2="420" y2="180" class="output-line active-line"/>
            <line x1="390" y1="260" x2="420" y2="260" class="output-line active-line"/>

            <rect x="420" y="78" width="62" height="44" rx="4" fill="#111827" stroke="#1C2B3A" stroke-width="1"/>
            <text x="451" y="97" text-anchor="middle" font-family="Space Mono, monospace" font-size="7.5" fill="#8A9BAE">EMERGENCY</text>
            <text x="451" y="110" text-anchor="middle" font-family="Space Mono, monospace" font-size="7.5" fill="#8A9BAE">LIGHTING</text>

            <rect x="420" y="158" width="62" height="44" rx="4" fill="#111827" stroke="#1C2B3A" stroke-width="1"/>
            <text x="451" y="177" text-anchor="middle" font-family="Space Mono, monospace" font-size="7.5" fill="#8A9BAE">ELEVATOR</text>
            <text x="451" y="190" text-anchor="middle" font-family="Space Mono, monospace" font-size="7.5" fill="#8A9BAE">BACKUP</text>

            <rect x="420" y="238" width="62" height="44" rx="4" fill="#111827" stroke="#1C2B3A" stroke-width="1"/>
            <text x="451" y="257" text-anchor="middle" font-family="Space Mono, monospace" font-size="7.5" fill="#8A9BAE">FIRE ALARM</text>
            <text x="451" y="270" text-anchor="middle" font-family="Space Mono, monospace" font-size="7.5" fill="#8A9BAE">BACKUP</text>

            <circle class="flow-dot dot-main"/>
            <circle class="flow-dot dot-out1"/>
            <circle class="flow-dot dot-out2"/>
            <circle class="flow-dot dot-out3"/>

            <text x="250" y="290" text-anchor="middle" font-family="Space Mono, monospace" font-size="8" fill="#2A3A4A">// UL 924  ·  NFPA 101  ·  NEC ART. 700  ·  ISO 9001</text>
          </svg>
        </div>
      </div>

      <!-- Stat Bar -->
      <div class="flex flex-wrap items-center gap-3 md:gap-0 md:divide-x md:divide-steel/50 mt-8 lg:mt-12">
        {company.heroStats.map(stat => (
          <span class="font-mono text-xs uppercase tracking-widest text-ash md:px-5 first:md:pl-0">{stat}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== PRODUCTS GRID ========== -->
  <section class="py-20 md:py-28 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">// Product Lines</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Lighting Inverters -->
        <a href="/products/category/emergency-lighting" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-1">Lighting Inverters</h3>
          <p class="text-sm text-ash mb-4">UL924 emergency lighting inverter systems from 0.1kW to 55kW</p>
          <span class="text-sm font-medium text-voltage group-hover:text-pure transition-colors">Learn More &rarr;</span>
        </a>

        <!-- Fire Alarm Backup -->
        <a href="/products/category/fire-alarm-backup" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-1">Fire Alarm Backup</h3>
          <p class="text-sm text-ash mb-4">UL1481 fire alarm notification appliance circuit backup</p>
          <span class="text-sm font-medium text-voltage group-hover:text-pure transition-colors">Learn More &rarr;</span>
        </a>

        <!-- Elevator Backup -->
        <a href="/products/category/elevator-backup" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7l4-4 4 4M8 17l4 4 4-4M3 12h18"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-1">Elevator Backup</h3>
          <p class="text-sm text-ash mb-4">UL924 elevator backup systems for safe evacuation during outages</p>
          <span class="text-sm font-medium text-voltage group-hover:text-pure transition-colors">Learn More &rarr;</span>
        </a>

        <!-- UPS Backup -->
        <a href="/products/category/ups-backup" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-1">UPS Backup</h3>
          <p class="text-sm text-ash mb-4">UL1778 uninterruptible power supply systems for critical loads</p>
          <span class="text-sm font-medium text-voltage group-hover:text-pure transition-colors">Learn More &rarr;</span>
        </a>

        <!-- Medical Grade -->
        <a href="/products/category/medical-grade" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-1">Medical Grade Systems</h3>
          <p class="text-sm text-ash mb-4">Hospital-grade isolation and power protection for critical care</p>
          <span class="text-sm font-medium text-voltage group-hover:text-pure transition-colors">Learn More &rarr;</span>
        </a>

        <!-- Voltage Regulators -->
        <a href="/products/category/voltage-regulators" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-1">Voltage Regulators</h3>
          <p class="text-sm text-ash mb-4">Power conditioning and voltage regulation for sensitive equipment</p>
          <span class="text-sm font-medium text-voltage group-hover:text-pure transition-colors">Learn More &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== PROOF BAR ========== -->
  <section class="py-16 md:py-20 bg-obsidian border-y border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 lg:divide-x lg:divide-steel/30">
        {company.stats.map(stat => (
          <div class="lg:px-8 first:lg:pl-0 last:lg:pr-0 text-center lg:text-left">
            <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-2">{stat.label}</p>
            <p class="font-display text-3xl md:text-4xl font-bold text-pure">{stat.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CUSTOM OEM ========== -->
  <section class="py-20 md:py-28 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Custom Engineering</p>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-pure mb-6 leading-tight">Built to Your Spec.</h2>
          <p class="text-ash leading-relaxed mb-6">
            Our in-house engineering team designs and manufactures custom power protection solutions tailored to your exact requirements. From modified standard products to ground-up OEM designs, we build it in Los Angeles and ship direct.
          </p>
          <p class="text-ash leading-relaxed mb-8">
            With 48 years of manufacturing experience and ISO 9001 quality systems, your custom solution gets the same precision engineering as our standard product lines.
          </p>
          <a href="/contact/" class="btn-primary px-8 py-3.5 rounded-lg text-sm font-semibold inline-flex items-center gap-2">
            Discuss Your Project
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </div>
        <!-- Circuit board trace illustration -->
        <div class="card-glow bg-bg-elevated rounded-2xl p-6 md:p-8 flex items-center justify-center min-h-[300px]">
          <svg viewBox="0 0 400 280" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
            <style>
              @keyframes tracePulse {
                0% { cx: 30; cy: 140; opacity: 0; }
                5% { opacity: 1; }
                25% { cx: 120; cy: 140; }
                30% { cx: 120; cy: 60; }
                50% { cx: 200; cy: 60; }
                55% { cx: 200; cy: 140; }
                75% { cx: 310; cy: 140; }
                80% { cx: 310; cy: 60; }
                95% { cx: 370; cy: 60; opacity: 1; }
                100% { cx: 370; cy: 60; opacity: 0; }
              }
              #trace-dot { animation: tracePulse 3s ease-in-out infinite; }
            </style>

            <!-- Main horizontal bus -->
            <line x1="30" y1="140" x2="370" y2="140" stroke="#1C2B3A" stroke-width="1"/>
            <!-- Top horizontal bus -->
            <line x1="120" y1="60" x2="370" y2="60" stroke="#1C2B3A" stroke-width="1"/>
            <!-- Bottom horizontal bus -->
            <line x1="80" y1="220" x2="320" y2="220" stroke="#1C2B3A" stroke-width="1"/>

            <!-- Vertical connections -->
            <line x1="120" y1="60" x2="120" y2="220" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="200" y1="60" x2="200" y2="220" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="310" y1="60" x2="310" y2="220" stroke="#1C2B3A" stroke-width="1"/>

            <!-- Stub traces -->
            <line x1="30" y1="140" x2="30" y2="100" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="370" y1="60" x2="370" y2="100" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="80" y1="220" x2="80" y2="180" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="320" y1="220" x2="320" y2="180" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="160" y1="60" x2="160" y2="30" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="260" y1="60" x2="260" y2="30" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="160" y1="220" x2="160" y2="250" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="260" y1="220" x2="260" y2="250" stroke="#1C2B3A" stroke-width="1"/>

            <!-- IC Chip 1 (main) -->
            <rect x="148" y="108" width="104" height="64" rx="3" fill="#0D1117" stroke="#00E5FF" stroke-width="1"/>
            <!-- IC pins left -->
            <line x1="148" y1="122" x2="138" y2="122" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="148" y1="140" x2="138" y2="140" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="148" y1="158" x2="138" y2="158" stroke="#1C2B3A" stroke-width="1"/>
            <!-- IC pins right -->
            <line x1="252" y1="122" x2="262" y2="122" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="252" y1="140" x2="262" y2="140" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="252" y1="158" x2="262" y2="158" stroke="#1C2B3A" stroke-width="1"/>
            <!-- IC label -->
            <text x="200" y="137" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="9" font-weight="700" fill="#F8FAFC">ONLINE</text>
            <text x="200" y="152" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="9" font-weight="700" fill="#F8FAFC">POWER</text>
            <!-- Pin 1 dot -->
            <circle cx="155" cy="115" r="1.5" fill="#00E5FF" opacity="0.5"/>

            <!-- IC Chip 2 (small, top right) -->
            <rect x="330" y="85" width="40" height="30" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="330" y1="95" x2="322" y2="95" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="330" y1="105" x2="322" y2="105" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="370" y1="100" x2="370" y2="85" stroke="#1C2B3A" stroke-width="1"/>

            <!-- Resistor 1 (zigzag on top bus) -->
            <path d="M55 140 L60 132 L68 148 L76 132 L84 148 L92 132 L97 140" stroke="#00E5FF" stroke-width="1" opacity="0.5"/>

            <!-- Resistor 2 (bottom) -->
            <path d="M230 220 L235 212 L243 228 L251 212 L259 228 L267 212 L272 220" stroke="#1C2B3A" stroke-width="1"/>

            <!-- Capacitor 1 -->
            <line x1="116" y1="52" x2="116" y2="68" stroke="#00E5FF" stroke-width="1" opacity="0.5"/>
            <line x1="124" y1="52" x2="124" y2="68" stroke="#00E5FF" stroke-width="1" opacity="0.5"/>

            <!-- Capacitor 2 -->
            <line x1="306" y1="132" x2="306" y2="148" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="314" y1="132" x2="314" y2="148" stroke="#1C2B3A" stroke-width="1"/>

            <!-- Diode (triangle + line) -->
            <polygon points="80,176 80,184 88,180" stroke="#1C2B3A" stroke-width="1" fill="none"/>
            <line x1="88" y1="176" x2="88" y2="184" stroke="#1C2B3A" stroke-width="1"/>

            <!-- Junction dots (solder points) -->
            <circle cx="120" cy="140" r="2.5" fill="#00E5FF" opacity="0.3"/>
            <circle cx="200" cy="140" r="2.5" fill="#00E5FF" opacity="0.3"/>
            <circle cx="310" cy="140" r="2.5" fill="#00E5FF" opacity="0.3"/>
            <circle cx="120" cy="60" r="2.5" fill="#00E5FF" opacity="0.3"/>
            <circle cx="200" cy="60" r="2.5" fill="#00E5FF" opacity="0.3"/>
            <circle cx="310" cy="60" r="2.5" fill="#00E5FF" opacity="0.3"/>
            <circle cx="120" cy="220" r="2" fill="#1C2B3A"/>
            <circle cx="200" cy="220" r="2" fill="#1C2B3A"/>
            <circle cx="310" cy="220" r="2" fill="#1C2B3A"/>

            <!-- Via holes -->
            <circle cx="160" cy="30" r="3" stroke="#1C2B3A" stroke-width="1" fill="none"/>
            <circle cx="160" cy="30" r="1" fill="#1C2B3A"/>
            <circle cx="260" cy="30" r="3" stroke="#1C2B3A" stroke-width="1" fill="none"/>
            <circle cx="260" cy="30" r="1" fill="#1C2B3A"/>
            <circle cx="160" cy="250" r="3" stroke="#1C2B3A" stroke-width="1" fill="none"/>
            <circle cx="160" cy="250" r="1" fill="#1C2B3A"/>
            <circle cx="260" cy="250" r="3" stroke="#1C2B3A" stroke-width="1" fill="none"/>
            <circle cx="260" cy="250" r="1" fill="#1C2B3A"/>

            <!-- Traveling pulse dot -->
            <circle id="trace-dot" r="3" fill="#00E5FF" opacity="0">
              <animate attributeName="opacity" values="0;1;1;1;0" dur="3s" repeatCount="indefinite"/>
            </circle>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRAINING SECTION ========== -->
  <section class="py-20 md:py-28 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Expert Training</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-pure mb-4">Learn From the Engineers Who Built It.</h2>
      <p class="text-ash max-w-2xl mb-12">Hands-on product training from our manufacturing engineering team. In-person, virtual, or at your facility.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="card-glow bg-obsidian rounded-xl p-6">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-2">In-Person</h3>
          <p class="text-sm text-ash mb-4">Visit our LA facility. Hands-on with actual equipment.</p>
          <a href="/training/" class="text-sm font-medium text-voltage hover:text-pure transition-colors">Register &rarr;</a>
        </div>
        <div class="card-glow bg-obsidian rounded-xl p-6">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-2">Virtual</h3>
          <p class="text-sm text-ash mb-4">Live sessions with Q&A. Recorded for your team.</p>
          <a href="/training/" class="text-sm font-medium text-voltage hover:text-pure transition-colors">Register &rarr;</a>
        </div>
        <div class="card-glow bg-obsidian rounded-xl p-6">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-2">On-Site</h3>
          <p class="text-sm text-ash mb-4">We come to you. Customized for your installation.</p>
          <a href="/training/" class="text-sm font-medium text-voltage hover:text-pure transition-colors">Register &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <section class="py-20 md:py-28 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">// What Engineers Say</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {testimonials.map(t => (
          <div class="bg-slate/50 border border-steel/30 rounded-xl p-6 md:p-8">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-voltage" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
              ))}
            </div>
            <p class="text-pure/90 leading-relaxed mb-6 text-sm">"{t.quote}"</p>
            <div class="border-t border-steel/30 pt-4">
              <p class="font-display font-semibold text-pure text-sm">{t.author}</p>
              <p class="text-xs text-ash">{t.company}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA BAND ========== -->
  <section class="bg-voltage py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-obsidian mb-4">Ready to Spec Online Power?</h2>
      <p class="text-obsidian/70 mb-8 max-w-xl mx-auto">Get a quote, discuss a custom solution, or register for product training.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="px-8 py-3.5 bg-obsidian text-pure font-semibold rounded-lg hover:bg-slate transition-colors text-sm text-center inline-flex items-center justify-center">
          Request a Quote
        </a>
        <a href="/training/" class="px-8 py-3.5 border-2 border-obsidian/30 text-obsidian font-semibold rounded-lg hover:bg-obsidian/10 transition-colors text-sm text-center inline-flex items-center justify-center">
          Register for Training
        </a>
      </div>
    </div>
  </section>

  <!-- ========== CONTACT FORM ========== -->
  <section class="py-20 md:py-28 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Left: Contact Info -->
        <div class="lg:col-span-2">
          <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Get in Touch</p>
          <h2 class="font-display text-3xl font-bold text-pure mb-6">Contact Us</h2>
          <div class="space-y-4 mb-8">
            <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="flex items-center gap-3 text-ash hover:text-voltage transition-colors">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <span class="font-mono text-sm">{company.phone}</span>
            </a>
            <a href={`mailto:${company.email}`} class="flex items-center gap-3 text-ash hover:text-voltage transition-colors">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <span class="text-sm">{company.email}</span>
            </a>
          </div>
          <p class="text-xs text-steel">{company.location}</p>
        </div>

        <!-- Right: Form -->
        <div class="lg:col-span-3">
          <form id="home-contact-form" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="text" name="name" required placeholder="Name *" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/50 focus:border-voltage/50 focus:ring-1 focus:ring-voltage/30 outline-none transition-colors" />
              <input type="email" name="email" required placeholder="Email *" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/50 focus:border-voltage/50 focus:ring-1 focus:ring-voltage/30 outline-none transition-colors" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="tel" name="phone" placeholder="Phone" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/50 focus:border-voltage/50 focus:ring-1 focus:ring-voltage/30 outline-none transition-colors" />
              <input type="text" name="company" placeholder="Company" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/50 focus:border-voltage/50 focus:ring-1 focus:ring-voltage/30 outline-none transition-colors" />
            </div>
            <select name="product" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-ash focus:border-voltage/50 focus:ring-1 focus:ring-voltage/30 outline-none transition-colors">
              <option value="">Product Interest</option>
              <option value="Lighting Inverters">Lighting Inverters (UL924)</option>
              <option value="Fire Alarm Backup">Fire Alarm Backup (UL1481)</option>
              <option value="Elevator Backup">Elevator Backup (UL924)</option>
              <option value="UPS Systems">UPS Systems (UL1778)</option>
              <option value="Medical Grade">Medical Grade Systems</option>
              <option value="Voltage Regulators">Voltage Regulators</option>
              <option value="Custom OEM">Custom OEM</option>
              <option value="Other">Other</option>
            </select>
            <textarea name="message" rows="4" placeholder="Message" class="w-full px-4 py-3 bg-slate border border-steel/50 rounded-lg text-sm text-pure placeholder:text-ash/50 focus:border-voltage/50 focus:ring-1 focus:ring-voltage/30 outline-none transition-colors resize-y"></textarea>
            <div class="hidden" aria-hidden="true"><input type="text" name="website" tabindex="-1" autocomplete="off" /></div>
            <button type="submit" id="home-submit-btn" class="btn-primary px-8 py-3.5 rounded-lg text-sm font-semibold">
              Submit
            </button>
            <div id="home-success" class="hidden p-4 bg-voltage/10 border border-voltage/30 rounded-lg text-voltage text-sm">Message sent. We'll be in touch within 1-2 business days.</div>
            <div id="home-error" class="hidden p-4 bg-red-500/10 border border-red-500/30 rounded-lg text-red-400 text-sm">Something went wrong. Please call {company.phone}.</div>
          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  (function() {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js';
    s.onload = function() { emailjs.init('ZpNSMzngBD1uoKBg2'); };
    document.head.appendChild(s);

    var form = document.getElementById('home-contact-form');
    var btn = document.getElementById('home-submit-btn');
    form && form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (form.querySelector('[name="website"]').value) return;
      btn.disabled = true; btn.textContent = 'Sending...';
      var p = {};
      new FormData(form).forEach(function(v,k){ p[k] = v; });
      p.subject = 'Website Contact: ' + (p.product || 'General');
      emailjs.send('service_wwtue8f', 'template_tavsq3o', p).then(function() {
        document.getElementById('home-success').classList.remove('hidden');
        document.getElementById('home-error').classList.add('hidden');
        form.reset(); btn.disabled = false; btn.textContent = 'Submit';
      }).catch(function() {
        document.getElementById('home-error').classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Submit';
      });
    });
  })();
</script>
