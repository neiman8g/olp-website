    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center reveal">
      <span class="chapter-num on-dark mb-4 inline-flex">08 · The Next Move</span>
      <h2 class="font-display text-3xl md:text-5xl font-extrabold tracking-tight text-white mt-4 mb-4 leading-[1.05]">Ready to Spec <span class="text-sky-blue">Online Power?</span></h2>
      <p class="text-base md:text-lg text-muted-blue mb-10 max-w-xl mx-auto">Three ways to get moving — request a quote, size a specific system, or train with our engineers.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center flex-wrap">
        <Button href="/contact/" size="lg" icon="arrow-right">Request a Quote</Button>
        <Button href="#sizer" variant="ghost" size="lg">Size Your System</Button>
        <Button href="/training/" variant="ghost" size="lg">Register for Training</Button>
      </div>
    </div>
  </section>

  <!-- ========== CONTACT STRIP — phone/email only ========== -->
  <section class="py-10 md:py-12 bg-deep-navy border-t border-navy-mid">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <p class="eyebrow text-muted-blue mb-2">Direct Line</p>
          <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="font-display text-3xl md:text-4xl font-bold text-white hover:text-steel-blue transition-colors">{company.phone}</a>
          <p class="text-[14px] text-muted-blue mt-1">{company.location}</p>
        </div>
        <div class="text-left md:text-right">
          <p class="eyebrow text-muted-blue mb-2">Email</p>
          <a href={`mailto:${company.email}`} class="font-display text-xl md:text-2xl font-semibold text-white hover:text-steel-blue transition-colors">{company.email}</a>
          <p class="text-[14px] text-muted-blue mt-1">Mon-Fri · 6am-5pm PT</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  // ======= SIZER TOOL =======
  (function(){
    var tabs = document.querySelectorAll('.sizer-tab');
    var panels = document.querySelectorAll('.sizer-panel');
    var emptyEl = document.getElementById('sizer-empty');
    var matchEl = document.getElementById('sizer-match');
    var contactEl = document.getElementById('sizer-contact');
    var matchName = document.getElementById('sizer-match-name');
    var matchRange = document.getElementById('sizer-match-range');
    var matchSpecs = document.getElementById('sizer-match-specs');
    var matchLink = document.getElementById('sizer-match-link');
    var contactReason = document.getElementById('sizer-contact-reason');
    if (!tabs.length) return;
    var activeCat = 'el';

    function showState(which) {
      [emptyEl, matchEl, contactEl].forEach(function(el){ if(el) el.classList.add('hidden'); });
      var target = which === 'match' ? matchEl : which === 'contact' ? contactEl : emptyEl;
      if (target) target.classList.remove('hidden');
    }

    function renderMatch(name, range, specs, slug) {
      showState('match');
      matchName.textContent = name;
      matchRange.textContent = range;
      matchSpecs.innerHTML = specs.map(function(s){
        return '<li class="flex items-start gap-2"><svg class="w-4 h-4 text-sky-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>' + s + '</span></li>';
      }).join('');
      matchLink.setAttribute('href', '/products/' + slug);
    }

    function renderContact(reason) {
      showState('contact');
      contactReason.textContent = reason;
    }

    function sizeEmergencyLighting() {
      var wInp = document.getElementById('el-watts');
      var w = parseFloat(wInp.value) || 0;
      if (w <= 0) { showState('empty'); return; }
      var phase = (document.querySelector('input[name="el-phase"]:checked') || {}).value || '1';
      var seismic = document.getElementById('el-seismic').checked;

      if (w <= 100) {
        renderMatch('Nano Power Wave', '35W – 100W · Lithium Ion · 1Ø', [
          'Input load: ' + w + ' W',
          'Lithium ion battery — long life',
          'LED & fluorescent compatible with dimming',
          '90 min standard · 2 hr per Life Safety Code',
        ], 'nano-wave');
        return;
      }
      if (w <= 490) {
        renderMatch('Micro Power Wave', '200W – 490W · Single Phase', [
          'Input load: ' + w + ' W',
          'Ultra-compact — electronics + batteries in one enclosure',
          'Pure sine wave output',
          '90 min minimum runtime',
        ], 'micro-power-wave');
        return;
      }
      if (w <= 2700) {
        renderMatch('Mini Power Wave', '500W – 2.7kW · Single Phase', [
          'Input load: ' + Math.round(w/10)/100 + ' kW',
          'All-in-one enclosure for tight spaces',
          'Pure sine wave · zero transfer time',
          'Self-test & battery exerciser',
        ], 'mini-power-wave');
        return;
      }
      if (phase === '1' && w <= 17000) {
        renderMatch(seismic ? 'SV Power Wave 1' : 'Power Wave 1', '2.1 – 17 kW · Single Phase' + (seismic ? ' · OSHPD/HCAI' : ''), [
          'Input load: ' + Math.round(w/100)/10 + ' kW',
          'True online double-conversion · zero transfer',
          'TVSS surge suppression (Class C)',
          seismic ? 'Shaker-table tested · OSHPD/HCAI certified' : 'Microprocessor LCD · self-test',
        ], seismic ? 'sv-power-wave-1' : 'power-wave-1');
        return;
      }
      if (phase === '1' && w > 17000) {
        renderContact('Loads above 17 kW exceed single-phase capacity. Switch to three-phase or contact engineering for a custom sizing — we can also parallel single-phase units for some cases.');
        return;
      }
      if (phase === '3' && w <= 50000) {
        renderMatch(seismic ? 'SV Power Wave 3' : 'Power Wave 3', '8 – 50 kW · Three Phase' + (seismic ? ' · OSHPD/HCAI' : ''), [
          'Input load: ' + Math.round(w/100)/10 + ' kW',
          'Three-phase output',
          'Internal maintenance bypass · UL 1489 breakers',
          seismic ? 'Shaker-table tested · OSHPD/HCAI certified' : 'TVSS · microprocessor LCD',
        ], seismic ? 'sv-power-wave-3' : 'power-wave-3');
        return;
      }
      if (phase === '3' && w <= 400000) {
        renderMatch(seismic ? 'SV Power Wave 4' : 'Power Wave 4', '8 – 400 kW · Three Phase' + (seismic ? ' · OSHPD/HCAI' : ''), [
          'Input load: ' + Math.round(w/1000) + ' kW',
          'Field-selectable UPS Double Conversion or Green Mode',
          'Independent phase control · GMS remote monitoring',
          seismic ? 'OSHPD/HCAI seismic preapproval' : 'Internal maintenance bypass',
        ], seismic ? 'sv-power-wave-4' : 'power-wave-4');
        return;
      }
      renderContact('Loads above 400 kW exceed our standard catalog. Our custom-OEM team builds systems up to multi-megawatt with the same UL 924 compliance.');
    }

    function sizeUPS() {
      var kva = parseFloat(document.getElementById('ups-kva').value) || 0;
      if (kva <= 0) { showState('empty'); return; }
      var phase = (document.querySelector('input[name="ups-phase"]:checked') || {}).value || '3';
      if (kva < 10) {
        renderContact('Loads below 10 kVA fall outside our standard online-double-conversion UPS range. For single-equipment protection under 10 kVA we typically recommend our surge-protection Protector series or a custom build.');
        return;
      }
      if (kva > 500) {
        renderContact('Loads above 500 kVA move into custom-OEM territory. We build paralleled systems and dedicated multi-megawatt UPS for hyperscale and utility applications.');
        return;
      }
      if (phase === '1') {
        renderContact('Loads of 10 kVA and above are typically served three-phase. We can build a single-phase custom variant — contact engineering to confirm feasibility.');
        return;
      }
      renderMatch('Host Power UPS', '10 – 500 kVA · Three Phase', [
        'Critical load: ' + Math.round(kva) + ' kVA',
        'True online double-conversion (UL 1778)',
        'Built-in load distribution · 90% efficiency',
        'Generator-compatible · modular assembly',
      ], 'host-power');
    }

    function sizeFireAlarm() {
      var w = parseFloat(document.getElementById('fire-watts').value) || 0;
      if (w <= 0) { showState('empty'); return; }
      var voice = document.getElementById('fire-voice').checked;
      if (w > 15000) {
        renderContact('Panel loads above 15 kW exceed our standard Fire Alarm Backup. For campus-wide or voice/MNS systems beyond that range we build custom UL 1481 solutions.');
        return;
      }
      renderMatch('Fire Alarm Backup', '500W – 15kW · UL 1481', [
        'Panel load: ' + Math.round(w) + ' W',
        '24 hr standby + ' + (voice ? '15 min' : '5 min') + ' full alarm per NFPA 72 §10.6.7',
        'Supervised battery charging',
        'Form-C trouble relay contacts for full monitoring integration',
      ], 'fire-alarm-backup');
    }

    function sizeElevator() {
      var kw = parseFloat(document.getElementById('elev-kw').value) || 0;
      var count = parseInt(document.getElementById('elev-count').value) || 1;
      if (kw <= 0) { showState('empty'); return; }
      var total = kw * count;
      if (total < 24) {
        renderContact('Combined elevator load below 24 kW falls outside our Power Wave Elevate range. Contact engineering — smaller traction systems can sometimes be served by a custom three-phase inverter.');
        return;
      }
      if (total > 240) {
        renderContact('Combined elevator load above 240 kW exceeds standard Elevate capacity. For high-rise bank configurations we build paralleled or custom systems retaining the regen-capable topology.');
        return;
      }
      renderMatch('Power Wave Elevate', '24 – 240 kW · Three Phase', [
        'Combined load: ' + Math.round(total) + ' kW (' + count + ' elevator' + (count > 1 ? 's' : '') + ')',
        '2 hr uninterrupted three-phase for evacuation',
        'Regenerative-capable · no load bank required',
        'Multiple UL 489 output breakers · no ATS required',
      ], 'elevate');
    }

    function recompute() {
      if (activeCat === 'el') sizeEmergencyLighting();
      else if (activeCat === 'ups') sizeUPS();
      else if (activeCat === 'fire') sizeFireAlarm();
      else if (activeCat === 'elev') sizeElevator();
    }

    // Tab switching
    tabs.forEach(function(t){
      t.addEventListener('click', function(){
        var cat = t.getAttribute('data-cat');
        activeCat = cat;
        tabs.forEach(function(tt){
          var isActive = tt === t;
          tt.classList.toggle('active', isActive);
          tt.classList.toggle('text-steel-blue', isActive);
          tt.classList.toggle('border-steel-blue', isActive);
          tt.classList.toggle('text-slate', !isActive);
          tt.classList.toggle('border-transparent', !isActive);
          tt.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        panels.forEach(function(p){
          p.classList.toggle('hidden', p.getAttribute('data-cat') !== cat);
        });
        recompute();
      });
    });

    // Live recompute on any input change inside the sizer
    document.getElementById('sizer').addEventListener('input', recompute);
    document.getElementById('sizer').addEventListener('change', recompute);
  })();

  // ======= HORIZONTAL RAIL SCROLL BUTTONS =======
  (function(){
    document.querySelectorAll('[data-rail-scroll]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var id = btn.getAttribute('data-rail-scroll');
        var dir = parseInt(btn.getAttribute('data-dir') || '1', 10);
        var rail = document.getElementById(id);
        if (!rail) return;
        // Scroll by one card width + gap
        var firstCard = rail.querySelector('.snap-start');
        var step = firstCard ? (firstCard.getBoundingClientRect().width + 20) : rail.clientWidth * 0.8;
        rail.scrollBy({ left: dir * step, behavior: 'smooth' });
      });
    });
  })();
</script>

