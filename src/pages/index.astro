---
import BaseLayout from '../layouts/BaseLayout.astro';
import { company, testimonials } from '../data/company';
---

<BaseLayout
  title="Online Power | Mission-Critical Power Protection | Manufacturer Since 1975"
  description="Online Power manufactures mission-critical power protection equipment. Emergency lighting inverters, UPS systems, fire alarm backup, and custom OEM solutions. UL Listed. ISO 9001. Made in Los Angeles, CA."
>

  <!-- ========== HERO ========== -->
  <section class="min-h-[calc(100vh-4rem)] flex flex-col justify-center relative overflow-hidden">
    <!-- Subtle bg glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-voltage/5 rounded-full blur-[150px] pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-20 md:py-28 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div>
          <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold text-pure leading-[1.05] tracking-tight mb-6">
            Power That<br/>Never Quits.
            <span class="block mt-2 relative" style="min-height: 1.4em;">
              <span class="cycle-word" style="animation-delay: 0s;">For Hospitals.</span>
              <span class="cycle-word" style="animation-delay: 3s;">For Data Centers.</span>
              <span class="cycle-word" style="animation-delay: 6s;">For High-Rise Buildings.</span>
              <span class="cycle-word" style="animation-delay: 9s;">For Government.</span>
              <span class="cycle-word" style="animation-delay: 12s;">For Any Application.</span>
            </span>
          </h1>
          <style>
            .cycle-word {
              display: block;
              position: absolute;
              color: #00E5FF;
              font-size: 0.85em;
              font-family: 'Space Grotesk', sans-serif;
              font-weight: 700;
              opacity: 0;
              animation: cycleText 15s linear infinite;
            }
            @keyframes cycleText {
              0%   { opacity: 0; transform: translateY(6px); }
              5%   { opacity: 1; transform: translateY(0); }
              18%  { opacity: 1; transform: translateY(0); }
              23%  { opacity: 0; transform: translateY(-6px); }
              100% { opacity: 0; }
            }
          </style>
          <p class="text-lg md:text-xl text-ash max-w-xl leading-relaxed mb-10" style="margin-top:1.5rem;">
            The widest range of UL listed power protection from a single manufacturer. Built to order in Los Angeles since 1975.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-12">
            <a href="/products/" class="btn-primary px-8 py-3.5 rounded-lg text-sm font-semibold text-center inline-flex items-center justify-center gap-2">
              View Products
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
            <a href="/contact/" class="btn-ghost px-8 py-3.5 rounded-lg text-sm text-center inline-flex items-center justify-center">
              Request a Quote
            </a>
          </div>
        </div>

        <!-- Right: Emergency Power Riser Diagram -->
        <div class="hidden lg:flex items-center justify-center w-full">
          <svg viewBox="0 0 460 540" width="100%" style="max-width:460px;" xmlns="http://www.w3.org/2000/svg">
            <style>
              @keyframes riserFlow{0%{offset-distance:0%;opacity:0}10%{opacity:1}90%{opacity:1}100%{offset-distance:100%;opacity:0}}
              @keyframes riserPulse{0%,100%{stroke-width:2;opacity:1}50%{stroke-width:3;opacity:0.7}}
              .r-dot{r:4;fill:#00E5FF;}
              .r-d-main{offset-path:path('M 220 40 L 220 130');animation:riserFlow 1.8s linear infinite;}
              .r-d-1{offset-path:path('M 220 230 L 220 265 L 52 265 L 52 290');animation:riserFlow 2s linear infinite 0.3s;}
              .r-d-2{offset-path:path('M 220 230 L 220 265 L 122 265 L 122 290');animation:riserFlow 2s linear infinite 0.6s;}
              .r-d-3{offset-path:path('M 220 230 L 220 265 L 192 265 L 192 290');animation:riserFlow 2s linear infinite 0.9s;}
              .r-d-4{offset-path:path('M 220 230 L 220 265 L 262 265 L 262 290');animation:riserFlow 2s linear infinite 1.2s;}
              .r-d-5{offset-path:path('M 220 230 L 220 265 L 332 265 L 332 290');animation:riserFlow 2s linear infinite 1.5s;}
              .r-d-6{offset-path:path('M 220 230 L 220 265 L 402 265 L 402 290');animation:riserFlow 2s linear infinite 1.8s;}
              .r-inv{animation:riserPulse 3s ease-in-out infinite;}
            </style>
            <!-- Utility -->
            <rect x="170" y="8" width="100" height="32" rx="3" fill="#111827" stroke="#2A3F55" stroke-width="1.5"/>
            <text x="220" y="22" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#A8B8C8">UTILITY SERVICE</text>
            <text x="220" y="34" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#8A9BAE">120 / 208 / 480V</text>
            <line x1="220" y1="40" x2="220" y2="130" stroke="#2A3F55" stroke-width="2"/>
            <line x1="210" y1="80" x2="230" y2="80" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="210" y1="86" x2="230" y2="86" stroke="#2A3F55" stroke-width="1.5"/>
            <text x="238" y="86" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">MAIN DISC</text>
            <!-- Inverter -->
            <rect class="r-inv" x="140" y="130" width="160" height="100" rx="4" fill="#0A1628" stroke="#00E5FF" stroke-width="2"/>
            <rect x="136" y="126" width="168" height="108" rx="6" fill="none" stroke="#00E5FF" stroke-width="0.5" opacity="0.25"/>
            <rect x="148" y="138" width="40" height="14" rx="2" fill="#00E5FF" opacity="0.15"/>
            <text x="168" y="148" text-anchor="middle" font-family="Space Mono,monospace" font-size="6.5" fill="#00E5FF">UL 924</text>
            <rect x="192" y="138" width="40" height="14" rx="2" fill="#00E5FF" opacity="0.15"/>
            <text x="212" y="148" text-anchor="middle" font-family="Space Mono,monospace" font-size="6.5" fill="#00E5FF">UL 1778</text>
            <rect x="236" y="138" width="55" height="14" rx="2" fill="#00E5FF" opacity="0.15"/>
            <text x="263" y="148" text-anchor="middle" font-family="Space Mono,monospace" font-size="6.5" fill="#00E5FF">ISO 9001</text>
            <text x="220" y="170" text-anchor="middle" font-family="Space Grotesk,sans-serif" font-size="13" fill="#F8FAFC" font-weight="700">ONLINE POWER</text>
            <text x="220" y="186" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#00E5FF">INVERTER · UPS · REGULATOR</text>
            <text x="220" y="200" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">27W TO 400kW · BUILT TO ORDER</text>
            <text x="220" y="218" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#3A4A5A">LOS ANGELES · CALIFORNIA</text>
            <!-- Distribution -->
            <line x1="220" y1="230" x2="220" y2="265" stroke="#00E5FF" stroke-width="2" opacity="0.6"/>
            <line x1="40" y1="265" x2="420" y2="265" stroke="#00E5FF" stroke-width="2" opacity="0.5"/>
            <!-- Branch lines -->
            <line x1="52" y1="265" x2="52" y2="290" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="122" y1="265" x2="122" y2="290" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="192" y1="265" x2="192" y2="290" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="262" y1="265" x2="262" y2="290" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="332" y1="265" x2="332" y2="290" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="402" y1="265" x2="402" y2="290" stroke="#2A3F55" stroke-width="1.5"/>
            <!-- Breakers -->
            <line x1="45" y1="278" x2="59" y2="278" stroke="#2A3F55" stroke-width="1.5"/><line x1="45" y1="284" x2="59" y2="284" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="115" y1="278" x2="129" y2="278" stroke="#2A3F55" stroke-width="1.5"/><line x1="115" y1="284" x2="129" y2="284" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="185" y1="278" x2="199" y2="278" stroke="#2A3F55" stroke-width="1.5"/><line x1="185" y1="284" x2="199" y2="284" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="255" y1="278" x2="269" y2="278" stroke="#2A3F55" stroke-width="1.5"/><line x1="255" y1="284" x2="269" y2="284" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="325" y1="278" x2="339" y2="278" stroke="#2A3F55" stroke-width="1.5"/><line x1="325" y1="284" x2="339" y2="284" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="395" y1="278" x2="409" y2="278" stroke="#2A3F55" stroke-width="1.5"/><line x1="395" y1="284" x2="409" y2="284" stroke="#2A3F55" stroke-width="1.5"/>
            <!-- Box 1: Emergency Lighting -->
            <rect x="20" y="290" width="64" height="96" rx="3" fill="#111827" stroke="#2A3F55" stroke-width="1.5"/>
            <rect x="20" y="290" width="64" height="8" rx="3" fill="#00E5FF" opacity="0.2"/>
            <text x="52" y="318" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">EMERG</text>
            <text x="52" y="332" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">LIGHTING</text>
            <text x="52" y="350" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#00E5FF">UL 924</text>
            <text x="52" y="365" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">27W to 400kW</text>
            <text x="52" y="378" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">Pure Sine</text>
            <!-- Box 2: Elevator -->
            <rect x="90" y="290" width="64" height="96" rx="3" fill="#111827" stroke="#2A3F55" stroke-width="1.5"/>
            <rect x="90" y="290" width="64" height="8" rx="3" fill="#00E5FF" opacity="0.2"/>
            <text x="122" y="318" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">ELEVATOR</text>
            <text x="122" y="332" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">BACKUP</text>
            <text x="122" y="350" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#00E5FF">UL 924</text>
            <text x="122" y="365" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">24 to 240kW</text>
            <text x="122" y="378" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">2hr Runtime</text>
            <!-- Box 3: UPS -->
            <rect x="160" y="290" width="64" height="96" rx="3" fill="#111827" stroke="#2A3F55" stroke-width="1.5"/>
            <rect x="160" y="290" width="64" height="8" rx="3" fill="#00E5FF" opacity="0.2"/>
            <text x="192" y="318" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">UPS</text>
            <text x="192" y="332" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">SYSTEMS</text>
            <text x="192" y="350" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#00E5FF">UL 1778</text>
            <text x="192" y="365" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">1 and 3 Phase</text>
            <text x="192" y="378" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">Zero Transfer</text>
            <!-- Box 4: Fire Alarm -->
            <rect x="230" y="290" width="64" height="96" rx="3" fill="#111827" stroke="#2A3F55" stroke-width="1.5"/>
            <rect x="230" y="290" width="64" height="8" rx="3" fill="#00E5FF" opacity="0.2"/>
            <text x="262" y="318" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">FIRE ALARM</text>
            <text x="262" y="332" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">BACKUP</text>
            <text x="262" y="350" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#00E5FF">UL 1481</text>
            <text x="262" y="365" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">24hr Standby</text>
            <text x="262" y="378" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">NFPA 72</text>
            <!-- Box 5: Voltage Reg -->
            <rect x="300" y="290" width="64" height="96" rx="3" fill="#111827" stroke="#2A3F55" stroke-width="1.5"/>
            <rect x="300" y="290" width="64" height="8" rx="3" fill="#00E5FF" opacity="0.2"/>
            <text x="332" y="318" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">VOLTAGE</text>
            <text x="332" y="332" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">REGULATORS</text>
            <text x="332" y="350" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#00E5FF">POWER COND</text>
            <text x="332" y="365" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">±3% Regulation</text>
            <text x="332" y="378" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">99% Efficient</text>
            <!-- Box 6: Custom OEM -->
            <rect x="370" y="290" width="64" height="96" rx="3" fill="#111827" stroke="#00E5FF" stroke-width="1.5" opacity="0.8"/>
            <rect x="370" y="290" width="64" height="8" rx="3" fill="#00E5FF" opacity="0.3"/>
            <text x="402" y="318" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">CUSTOM</text>
            <text x="402" y="332" text-anchor="middle" font-family="Space Mono,monospace" font-size="8.5" fill="#A8B8C8">OEM</text>
            <text x="402" y="350" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#00E5FF">ANY SPEC</text>
            <text x="402" y="365" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">Built to Order</text>
            <text x="402" y="378" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#4A5A6A">ISO 9001</text>
            <!-- Battery bank -->
            <rect x="30" y="148" width="40" height="24" rx="2" fill="#111827" stroke="#2A3F55" stroke-width="1"/>
            <line x1="38" y1="148" x2="38" y2="172" stroke="#2A3F55" stroke-width="1"/>
            <line x1="46" y1="148" x2="46" y2="172" stroke="#2A3F55" stroke-width="1"/>
            <line x1="54" y1="148" x2="54" y2="172" stroke="#2A3F55" stroke-width="1"/>
            <line x1="62" y1="148" x2="62" y2="172" stroke="#2A3F55" stroke-width="1"/>
            <text x="50" y="185" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#4A5A6A">BATTERY</text>
            <line x1="70" y1="160" x2="140" y2="160" stroke="#2A3F55" stroke-width="1" stroke-dasharray="3,2"/>
            <!-- Ground symbols -->
            <line x1="52" y1="386" x2="52" y2="398" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="46" y1="398" x2="58" y2="398" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="48" y1="402" x2="56" y2="402" stroke="#2A3F55" stroke-width="1"/>
            <line x1="192" y1="386" x2="192" y2="398" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="186" y1="398" x2="198" y2="398" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="188" y1="402" x2="196" y2="402" stroke="#2A3F55" stroke-width="1"/>
            <line x1="332" y1="386" x2="332" y2="398" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="326" y1="398" x2="338" y2="398" stroke="#2A3F55" stroke-width="1.5"/>
            <line x1="328" y1="402" x2="336" y2="402" stroke="#2A3F55" stroke-width="1"/>
            <!-- Animated dots -->
            <circle class="r-dot r-d-main"/>
            <circle class="r-dot r-d-1"/>
            <circle class="r-dot r-d-2"/>
            <circle class="r-dot r-d-3"/>
            <circle class="r-dot r-d-4"/>
            <circle class="r-dot r-d-5"/>
            <circle class="r-dot r-d-6"/>
            <!-- Drawing border -->
            <rect x="2" y="2" width="456" height="536" rx="2" fill="none" stroke="#1C2B3A" stroke-width="1"/>
            <rect x="6" y="6" width="448" height="528" rx="1" fill="none" stroke="#1C2B3A" stroke-width="0.5"/>
            <!-- Title block -->
            <rect x="310" y="480" width="146" height="50" fill="#0A0A0F" stroke="#1C2B3A" stroke-width="1"/>
            <line x1="310" y1="492" x2="456" y2="492" stroke="#1C2B3A" stroke-width="0.5"/>
            <line x1="310" y1="504" x2="456" y2="504" stroke="#1C2B3A" stroke-width="0.5"/>
            <text x="383" y="489" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#4A5A6A">ONLINE POWER INC</text>
            <text x="383" y="501" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#4A5A6A">LOS ANGELES · CA</text>
            <text x="383" y="513" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#4A5A6A">EMERGENCY PWR RISER</text>
            <text x="383" y="523" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#4A5A6A">REV A · UL · ISO 9001</text>
          </svg>
        </div>
      </div>

      <!-- Stat Bar -->
      <div class="flex flex-wrap items-center gap-3 md:gap-0 md:divide-x md:divide-steel/50 mt-8 lg:mt-12">
        {company.heroStats.map(stat => (
          <span class="font-mono text-xs uppercase tracking-widest text-ash md:px-5 first:md:pl-0">{stat}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== PRODUCTS GRID ========== -->
  <section class="py-20 md:py-28 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">// Product Lines</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Lighting Inverters -->
        <a href="/products/category/emergency-lighting" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-1">Lighting Inverters</h3>
          <p class="text-sm text-ash mb-4">UL924 emergency lighting inverter systems from 27W to 400kW</p>
          <span class="text-sm font-medium text-voltage group-hover:text-pure transition-colors">Learn More &rarr;</span>
        </a>

        <!-- Fire Alarm Backup -->
        <a href="/products/category/fire-alarm-backup" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-1">Fire Alarm Backup</h3>
          <p class="text-sm text-ash mb-4">UL1481 fire alarm notification appliance circuit backup</p>
          <span class="text-sm font-medium text-voltage group-hover:text-pure transition-colors">Learn More &rarr;</span>
        </a>

        <!-- Elevator Backup -->
        <a href="/products/category/elevator-backup" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7l4-4 4 4M8 17l4 4 4-4M3 12h18"></path></svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-pure mb-1">Elevator Backup</h3>
          <p class="text-sm text-ash mb-4">UL924 elevator backup systems for safe evacuation during outages</p>
          <span class="text-sm font-medium text-voltage group-hover:text-pure transition-colors">Learn More &rarr;</span>
        </a>

        <!-- UPS Backup -->
        <a href="/products/category/ups-backup" class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group transition-all">
          <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
