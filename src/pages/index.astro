<script is:inline>
  (function() {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js';
    s.onload = function() { emailjs.init('ZpNSMzngBD1uoKBg2'); };
    document.head.appendChild(s);

    var form = document.getElementById('home-contact-form');
    var btn = document.getElementById('home-submit-btn');
    form && form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (form.querySelector('[name="website"]').value) return;
      btn.disabled = true; btn.textContent = 'Sending...';
      var p = {};
      new FormData(form).forEach(function(v,k){ p[k] = v; });
      p.subject = 'Website Contact: ' + (p.product || 'General');
      emailjs.send('service_wwtue8f', 'template_tavsq3o', p).then(function() {
        document.getElementById('home-success').classList.remove('hidden');
        document.getElementById('home-error').classList.add('hidden');
        form.reset(); btn.disabled = false; btn.textContent = 'Submit';
      }).catch(function() {
        document.getElementById('home-error').classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Submit';
      });
    });
  })();

</script>
