---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import { company, testimonials } from '../data/company';
import CustomOEM from '../components/illustrations/CustomOEM.astro';
---

<BaseLayout
  title="Online Power | Mission-Critical Power Protection | Manufacturer Since 1975"
  description="Online Power manufactures mission-critical power protection equipment. Emergency lighting inverters, UPS systems, fire alarm backup, and custom OEM solutions. UL Listed. ISO 9001. Made in Los Angeles, CA."
>

  <!-- ========== HERO — video background ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <!-- Video background -->
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover" style="z-index: 0;">
      <source src="/video/hero-video.mp4" type="video/mp4" />
    </video>
    <!-- Depth stack: dark overlay + left-to-right gradient + tech grid -->
    <div class="absolute inset-0 bg-deep-navy/70" style="z-index: 1;"></div>
    <div class="absolute inset-0" style="z-index: 1; background: linear-gradient(90deg, rgba(15,42,74,0.85) 0%, rgba(15,42,74,0.55) 55%, rgba(15,42,74,0.15) 100%);"></div>
    <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="z-index: 1; background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <!-- Steel-blue accent glow bottom-left -->
    <div class="absolute -bottom-24 -left-24 w-[520px] h-[520px] rounded-full pointer-events-none" style="z-index: 1; background: radial-gradient(circle, rgba(37,103,194,0.35) 0%, rgba(37,103,194,0) 70%); filter: blur(8px);"></div>

    <!-- Content -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 md:py-20" style="z-index: 2;">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-sky-blue/30 bg-sky-blue/5 mb-5 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-blue opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-sky-blue"></span>
          </span>
          <span class="font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-blue">Online & Shipping · Built in Los Angeles</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-[76px] font-extrabold tracking-tight text-white leading-[1.02] mb-3">
          Power That<br/>Never Quits.
          <span class="block mt-1 text-sky-blue font-display font-bold text-2xl sm:text-3xl sm:hidden">For Hospitals.</span>
          <span class="hidden sm:block mt-1 relative" style="min-height: 1.2em; margin-bottom: 0;">
            <span class="cycle-word" style="animation-delay: 0s;">For Hospitals.</span>
            <span class="cycle-word" style="animation-delay: 3s;">For Data Centers.</span>
            <span class="cycle-word" style="animation-delay: 6s;">For High-Rise Buildings.</span>
            <span class="cycle-word" style="animation-delay: 9s;">For Government.</span>
          </span>
        </h1>
        <style>
          .cycle-word {
            display: block;
            position: absolute;
            color: #7EB3F5;
            font-size: 0.5em;
            font-family: 'Inter Tight', 'Inter', sans-serif;
            font-weight: 700;
            opacity: 0;
            animation: cycleText 12s linear infinite;
          }
          @keyframes cycleText {
            0%   { opacity: 0; transform: translateY(6px); }
            5%   { opacity: 1; transform: translateY(0); }
            22%  { opacity: 1; transform: translateY(0); }
            27%  { opacity: 0; transform: translateY(-6px); }
            100% { opacity: 0; }
          }
        </style>

        <p class="font-display text-[12px] font-semibold uppercase tracking-[0.14em] text-white/70 mt-6 mb-0">US Manufacturer Since 1975 · Built to Order in Los Angeles</p>
        <p class="text-lg text-white/80 max-w-lg leading-relaxed mb-8" style="margin-top:0.75rem;">
          Emergency lighting, UPS, elevator backup, fire alarm, medical grade, and custom OEM power systems. All UL listed, all built to order in Los Angeles. The widest range from a single US manufacturer since 1975.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="/products/" size="lg" icon="arrow-right">View Products</Button>
          <Button href="/contact/" variant="ghost" size="lg">Request a Quote</Button>
        </div>
      </div>
    </div>

    <!-- Headline Stats: 3 large + compliance row -->
    <div class="relative border-t border-white/10" style="z-index: 2;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-3 divide-x divide-white/10 py-8">
          {[
            { value: '50 YRS', label: 'US Manufacturing' },
            { value: 'ISO 9001', label: 'Quality Certified' },
            { value: 'UL LISTED', label: 'Every Product' },
          ].map((s, i) => (
            <div class={`px-4 md:px-8 ${i === 0 ? 'first:pl-0' : ''} text-center md:text-left`}>
              <p class="font-display text-[32px] md:text-[44px] font-extrabold tracking-tight text-white leading-none mb-2">{s.value}</p>
              <p class="font-display text-[11px] md:text-[12px] font-semibold uppercase tracking-[0.16em] text-white/70">{s.label}</p>
            </div>
          ))}
        </div>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 py-4 border-t border-white/10 font-display text-[11px] font-semibold uppercase tracking-[0.14em] text-white/60">
          <span>BAA Compliant</span>
          <span class="text-white/20">·</span>
          <span>TAA Compliant</span>
          <span class="text-white/20">·</span>
          <span>Built in Los Angeles</span>
          <span class="text-white/20">·</span>
          <span>Founded 1975</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SECTOR TRUST ROW ========== -->
  <section class="bg-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-14">
      <p class="font-display text-[11px] font-semibold uppercase tracking-[0.2em] text-steel-blue text-center mb-6">Trusted in the Environments Where Power Cannot Fail</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { label: 'Hospitals', desc: 'Critical Care · Surgical Suites', icon: 'M9 12h6m-3-3v6m-9 1V5a2 2 0 012-2h14a2 2 0 012 2v11a2 2 0 01-2 2H5a2 2 0 01-2-2z' },
          { label: 'Data Centers', desc: 'Colocation · Hyperscale', icon: 'M4 7a2 2 0 012-2h12a2 2 0 012 2v2H4V7zm0 4h16v2H4v-2zm0 4h16v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2z' },
          { label: 'Government', desc: 'Federal · DoD · Municipal', icon: 'M3 21h18M5 21V10l7-5 7 5v11M9 21V13h6v8' },
          { label: 'High-Rise', desc: 'Commercial · Residential', icon: 'M5 21V5a1 1 0 011-1h5a1 1 0 011 1v16M12 21V9a1 1 0 011-1h5a1 1 0 011 1v12M3 21h18M8 8h1m-1 4h1m-1 4h1m7-4h1m-1 4h1' },
        ].map(s => (
          <div class="group flex flex-col items-center text-center py-5 px-3 border border-steel-gray rounded-lg hover:border-steel-blue hover:shadow-[0_8px_20px_-8px_rgba(37,103,194,0.25)] hover:-translate-y-0.5 transition-all duration-200">
            <div class="w-11 h-11 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-3 group-hover:bg-steel-blue/15 transition-colors">
              <svg class="w-6 h-6 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={s.icon}/></svg>
            </div>
            <p class="font-display text-[16px] font-bold text-near-black">{s.label}</p>
            <p class="text-[12px] text-slate mt-1">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== PRODUCTS GRID ========== -->
  <section class="py-16 md:py-20 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
        <div>
          <p class="eyebrow mb-3">Product Lines</p>
          <h2 class="font-display text-3xl md:text-[44px] font-extrabold tracking-tight text-near-black leading-[1.1]">Every Critical Load. <span class="text-steel-blue">One Manufacturer.</span></h2>
        </div>
        <a href="/products/" class="font-display text-[13px] font-bold uppercase tracking-[0.12em] text-steel-blue hover:text-near-black transition-colors whitespace-nowrap">All Products &rarr;</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Lighting Inverters -->
        <Card variant="product" href="/products/category/emergency-lighting">
          <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-5 group-hover:bg-steel-blue group-hover:text-white transition-colors">
            <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Lighting Inverters</h3>
          <p class="text-base text-slate mb-4">UL924 emergency lighting inverter systems from 35W to 400kW</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- Fire Alarm Backup -->
        <Card variant="product" href="/products/category/fire-alarm-backup">
          <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-5 group-hover:bg-steel-blue group-hover:text-white transition-colors">
            <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Fire Alarm Backup</h3>
          <p class="text-base text-slate mb-4">UL1481 fire alarm notification appliance circuit backup</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- Elevator Backup -->
        <Card variant="product" href="/products/category/elevator-backup">
          <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-5 group-hover:bg-steel-blue group-hover:text-white transition-colors">
            <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7l4-4 4 4M8 17l4 4 4-4M3 12h18"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Elevator Backup</h3>
          <p class="text-base text-slate mb-4">UL924 elevator backup systems for safe evacuation during outages</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- UPS Backup -->
        <Card variant="product" href="/products/category/ups-backup">
          <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-5 group-hover:bg-steel-blue group-hover:text-white transition-colors">
            <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">UPS Backup</h3>
          <p class="text-base text-slate mb-4">UL1778 uninterruptible power supply systems for critical loads</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- Medical Grade -->
        <Card variant="product" href="/products/category/medical-grade">
          <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-5 group-hover:bg-steel-blue group-hover:text-white transition-colors">
            <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Medical Grade Systems</h3>
          <p class="text-base text-slate mb-4">Hospital-grade isolation and power protection for critical care</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- Voltage Regulators -->
        <Card variant="product" href="/products/category/voltage-regulators">
          <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-5 group-hover:bg-steel-blue group-hover:text-white transition-colors">
            <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Voltage Regulators</h3>
          <p class="text-base text-slate mb-4">Power conditioning and voltage regulation for sensitive equipment</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>
      </div>
    </div>
  </section>

  <!-- ========== SPEC REVEAL BAND ========== -->
  <section class="relative overflow-hidden bg-near-black py-16 md:py-24 border-y border-navy-mid">
    <div class="absolute inset-0 pointer-events-none opacity-[0.05]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] pointer-events-none" style="background: radial-gradient(ellipse, rgba(37,103,194,0.25) 0%, rgba(37,103,194,0) 65%); filter: blur(12px);"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-display text-[12px] font-semibold uppercase tracking-[0.2em] text-sky-blue mb-4">Spec at a Glance</p>
      <h2 class="font-display text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-10 max-w-3xl mx-auto leading-[1.1]">One Manufacturer. <span class="text-sky-blue">The Full Range.</span></h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-10">
        {[
          { big: '35W', unit: '\u2013 400kW', label: 'Output Range' },
          { big: '<4', unit: 'ms transfer', label: 'UL 924 Response' },
          { big: '10\u2013500', unit: 'kVA UPS', label: 'UL 1778 Certified' },
          { big: '48+', unit: 'years', label: 'Mission-Critical Builds' },
        ].map(s => (
          <div class="flex flex-col items-center">
            <p class="font-display text-[44px] md:text-[64px] font-extrabold tracking-tight text-white leading-none">{s.big}</p>
            <p class="font-display text-[14px] md:text-[16px] font-semibold text-sky-blue mt-1">{s.unit}</p>
            <p class="font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-white/60 mt-3">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CUSTOM OEM ========== -->
  <section class="py-14 md:py-[72px] bg-deep-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-8 items-center">
        <div>
          <p class="eyebrow text-muted-blue mb-4">Custom Engineering</p>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">Built to Your Spec.</h2>
          <p class="text-base text-muted-blue leading-relaxed mb-6">
            Our in-house engineering team designs and manufactures custom power protection solutions tailored to your exact requirements. From modified standard products to ground-up OEM designs, we build it in Los Angeles and ship direct.
          </p>
          <p class="text-base text-muted-blue leading-relaxed mb-8">
            With 48 years of manufacturing experience and ISO 9001 quality systems, your custom solution gets the same precision engineering as our standard product lines.
          </p>
          <Button href="/contact/" size="lg" icon="arrow-right">Discuss Your Project</Button>
        </div>
        <!-- Custom OEM illustration -->
        <div class="bg-[#2B5580] rounded-lg p-6 overflow-hidden">
          <CustomOEM />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRAINING SECTION ========== -->
  <section class="py-14 md:py-[72px] bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Expert Training</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-near-black mb-4">Learn From the Engineers Who Built It.</h2>
      <p class="text-slate max-w-2xl mb-12">Hands-on product training from our manufacturing engineering team. In-person, virtual, or at your facility.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <Card variant="feature">
          <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-5 group-hover:bg-steel-blue group-hover:text-white transition-colors">
            <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-2">At Our Plant</h3>
          <p class="text-base text-slate mb-4">Factory training at our Los Angeles manufacturing facility. Hands-on with actual equipment.</p>
          <a href="/training/" class="text-[15px] font-medium text-steel-blue hover:text-near-black transition-colors">Register &rarr;</a>
        </Card>
        <Card variant="feature">
          <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-5 group-hover:bg-steel-blue group-hover:text-white transition-colors">
            <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Virtual</h3>
          <p class="text-base text-slate mb-4">Live video sessions with engineering. Recorded for your team.</p>
          <a href="/training/" class="text-[15px] font-medium text-steel-blue hover:text-near-black transition-colors">Register &rarr;</a>
        </Card>
        <Card variant="feature">
          <div class="w-12 h-12 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-5 group-hover:bg-steel-blue group-hover:text-white transition-colors">
            <svg class="w-6 h-6 text-steel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-2">At Your Office</h3>
          <p class="text-base text-slate mb-4">Project-specific training or lunch-and-learn sessions for your team.</p>
          <a href="/training/" class="text-[15px] font-medium text-steel-blue hover:text-near-black transition-colors">Register &rarr;</a>
        </Card>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <section class="py-14 md:py-[72px] bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-near-black mb-8">What Engineers Say</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {testimonials.map(t => (
          <Card variant="testimonial">
            <svg class="w-7 h-7 text-steel-blue/40 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 17h3l2-4V7H5v6h3l-2 4zm8 0h3l2-4V7h-6v6h3l-2 4z"/></svg>
            <p class="text-near-black/90 leading-relaxed mb-6 text-[17px]">{t.quote}</p>
            <div class="border-t border-steel-gray pt-4">
              <p class="font-display font-bold text-near-black text-base">{t.author}</p>
              <p class="text-[14px] text-slate">{t.company}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA BAND ========== -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Ready to Spec Online Power?</h2>
      <p class="text-base text-muted-blue mb-8 max-w-xl mx-auto">Get a quote, discuss a custom solution, or register for product training.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact/" size="lg">Request a Quote</Button>
        <Button href="/training/" variant="ghost" size="lg">Register for Training</Button>
      </div>
    </div>
  </section>

  <!-- ========== CONTACT STRIP — phone/email only ========== -->
  <section class="py-10 md:py-12 bg-deep-navy border-t border-navy-mid">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <p class="eyebrow text-muted-blue mb-2">Direct Line</p>
          <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="font-display text-3xl md:text-4xl font-bold text-white hover:text-steel-blue transition-colors">{company.phone}</a>
          <p class="text-[14px] text-muted-blue mt-1">{company.location}</p>
        </div>
        <div class="text-left md:text-right">
          <p class="eyebrow text-muted-blue mb-2">Email</p>
          <a href={`mailto:${company.email}`} class="font-display text-xl md:text-2xl font-semibold text-white hover:text-steel-blue transition-colors">{company.email}</a>
          <p class="text-[14px] text-muted-blue mt-1">Mon-Fri · 6am-5pm PT</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

