---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import { company, testimonials } from '../data/company';
import CustomOEM from '../components/illustrations/CustomOEM.astro';
---

<BaseLayout
  title="Online Power | Mission-Critical Power Protection | Manufacturer Since 1975"
  description="Online Power manufactures mission-critical power protection equipment. Emergency lighting inverters, UPS systems, fire alarm backup, and custom OEM solutions. UL Listed. ISO 9001. Made in Los Angeles, CA."
>

  <!-- ========== HERO — video background ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <!-- Video background -->
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover" style="z-index: 0;">
      <source src="/video/hero-video.mp4" type="video/mp4" />
    </video>
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-deep-navy/75" style="z-index: 1;"></div>

    <!-- Content -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-20 lg:py-24" style="z-index: 2;">
      <div class="max-w-2xl">
        <h1 class="font-display text-4xl sm:text-5xl lg:text-[60px] font-bold text-white leading-[1.08] mb-3">
          Power That<br/>Never Quits.
          <span class="block mt-1 text-sky-blue font-display font-bold text-2xl sm:text-3xl sm:hidden">For Any Application.</span>
          <span class="hidden sm:block mt-1 relative" style="min-height: 1.2em; margin-bottom: 0;">
            <span class="cycle-word" style="animation-delay: 0s;">For Hospitals.</span>
            <span class="cycle-word" style="animation-delay: 3s;">For Data Centers.</span>
            <span class="cycle-word" style="animation-delay: 6s;">For High-Rise Buildings.</span>
            <span class="cycle-word" style="animation-delay: 9s;">For Government.</span>
            <span class="cycle-word" style="animation-delay: 12s;">For Any Application.</span>
          </span>
        </h1>
        <style>
          .cycle-word {
            display: block;
            position: absolute;
            color: #7EB3F5;
            font-size: 0.5em;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
            opacity: 0;
            animation: cycleText 15s linear infinite;
          }
          @keyframes cycleText {
            0%   { opacity: 0; transform: translateY(6px); }
            5%   { opacity: 1; transform: translateY(0); }
            18%  { opacity: 1; transform: translateY(0); }
            23%  { opacity: 0; transform: translateY(-6px); }
            100% { opacity: 0; }
          }
        </style>

        <p class="font-display text-[14px] font-semibold uppercase tracking-[0.1em] text-white/60 mt-4 mb-1">Trusted by 100+ Fortune 500 Companies</p>
        <p class="text-lg text-white/80 max-w-lg leading-relaxed mb-8" style="margin-top:0.75rem;">
          The widest range of UL listed power protection from a single manufacturer. 35W to 400kW. Built to order in Los Angeles since 1975.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="/products/" size="lg" icon="arrow-right">View Products</Button>
          <Button href="/contact/" variant="ghost" size="lg">Request a Quote</Button>
        </div>
      </div>
    </div>

    <!-- Stat Bar -->
    <div class="relative border-t border-white/10" style="z-index: 2;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex flex-wrap items-center gap-3 md:gap-0 md:divide-x md:divide-white/10 py-4">
          {company.heroStats.map(stat => (
            <span class="font-display text-[13px] uppercase tracking-[0.1em] text-white/50 font-semibold md:px-5 first:md:pl-0">{stat}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRODUCTS GRID ========== -->
  <section class="py-14 md:py-[72px] bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-8">Product Lines</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Lighting Inverters -->
        <Card variant="product" href="/products/category/emergency-lighting">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Lighting Inverters</h3>
          <p class="text-base text-slate mb-4">UL924 emergency lighting inverter systems from 35W to 400kW</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- Fire Alarm Backup -->
        <Card variant="product" href="/products/category/fire-alarm-backup">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Fire Alarm Backup</h3>
          <p class="text-base text-slate mb-4">UL1481 fire alarm notification appliance circuit backup</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- Elevator Backup -->
        <Card variant="product" href="/products/category/elevator-backup">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7l4-4 4 4M8 17l4 4 4-4M3 12h18"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Elevator Backup</h3>
          <p class="text-base text-slate mb-4">UL924 elevator backup systems for safe evacuation during outages</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- UPS Backup -->
        <Card variant="product" href="/products/category/ups-backup">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">UPS Backup</h3>
          <p class="text-base text-slate mb-4">UL1778 uninterruptible power supply systems for critical loads</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- Medical Grade -->
        <Card variant="product" href="/products/category/medical-grade">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Medical Grade Systems</h3>
          <p class="text-base text-slate mb-4">Hospital-grade isolation and power protection for critical care</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>

        <!-- Voltage Regulators -->
        <Card variant="product" href="/products/category/voltage-regulators">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-1">Voltage Regulators</h3>
          <p class="text-base text-slate mb-4">Power conditioning and voltage regulation for sensitive equipment</p>
          <span class="text-[15px] font-medium text-steel-blue group-hover:text-near-black transition-colors">Learn More &rarr;</span>
        </Card>
      </div>
    </div>
  </section>

  <!-- ========== PROOF BAR ========== -->
  <section class="py-16 md:py-20 bg-deep-navy border-y border-navy-mid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 lg:divide-x lg:divide-navy-mid">
        {company.stats.map(stat => (
          <div class="lg:px-8 first:lg:pl-0 last:lg:pr-0 text-center lg:text-left">
            <p class="font-display text-[13px] uppercase tracking-[0.1em] text-steel-blue font-semibold mb-2">{stat.label}</p>
            <p class="font-display text-3xl md:text-4xl font-bold text-white">{stat.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CUSTOM OEM ========== -->
  <section class="py-14 md:py-[72px] bg-deep-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-8 items-center">
        <div>
          <p class="eyebrow text-muted-blue mb-4">Custom Engineering</p>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">Built to Your Spec.</h2>
          <p class="text-base text-muted-blue leading-relaxed mb-6">
            Our in-house engineering team designs and manufactures custom power protection solutions tailored to your exact requirements. From modified standard products to ground-up OEM designs, we build it in Los Angeles and ship direct.
          </p>
          <p class="text-base text-muted-blue leading-relaxed mb-8">
            With 48 years of manufacturing experience and ISO 9001 quality systems, your custom solution gets the same precision engineering as our standard product lines.
          </p>
          <Button href="/contact/" size="lg" icon="arrow-right">Discuss Your Project</Button>
        </div>
        <!-- Custom OEM illustration -->
        <div class="bg-[#2B5580] rounded-lg p-6 overflow-hidden">
          <CustomOEM />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRAINING SECTION ========== -->
  <section class="py-14 md:py-[72px] bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Expert Training</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-near-black mb-4">Learn From the Engineers Who Built It.</h2>
      <p class="text-slate max-w-2xl mb-12">Hands-on product training from our manufacturing engineering team. In-person, virtual, or at your facility.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <Card variant="feature">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-2">In-Person</h3>
          <p class="text-base text-slate mb-4">Visit our LA facility. Hands-on with actual equipment.</p>
          <a href="/training/" class="text-[15px] font-medium text-steel-blue hover:text-near-black transition-colors">Register &rarr;</a>
        </Card>
        <Card variant="feature">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Virtual</h3>
          <p class="text-base text-slate mb-4">Live sessions with Q&A. Recorded for your team.</p>
          <a href="/training/" class="text-[15px] font-medium text-steel-blue hover:text-near-black transition-colors">Register &rarr;</a>
        </Card>
        <Card variant="feature">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <h3 class="font-display text-2xl font-semibold text-near-black mb-2">On-Site</h3>
          <p class="text-base text-slate mb-4">We come to you. Customized for your installation.</p>
          <a href="/training/" class="text-[15px] font-medium text-steel-blue hover:text-near-black transition-colors">Register &rarr;</a>
        </Card>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <section class="py-14 md:py-[72px] bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-8">What Engineers Say</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {testimonials.map(t => (
          <Card variant="testimonial">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-steel-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
              ))}
            </div>
            <p class="text-near-black/90 leading-relaxed mb-6 text-base">"{t.quote}"</p>
            <div class="border-t border-steel-gray pt-4">
              <p class="font-display font-semibold text-near-black text-sm">{t.author}</p>
              <p class="text-xs text-slate">{t.company}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA BAND ========== -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Ready to Spec Online Power?</h2>
      <p class="text-base text-muted-blue mb-8 max-w-xl mx-auto">Get a quote, discuss a custom solution, or register for product training.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact/" size="lg">Request a Quote</Button>
        <Button href="/training/" variant="ghost" size="lg">Register for Training</Button>
      </div>
    </div>
  </section>

  <!-- ========== CONTACT FORM ========== -->
  <section class="py-14 md:py-[72px] bg-deep-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-8">
        <!-- Left: Contact Info -->
        <div class="lg:col-span-2">
          <p class="eyebrow text-muted-blue mb-4">Get in Touch</p>
          <h2 class="font-display text-3xl font-bold text-white mb-6">Contact Us</h2>
          <div class="space-y-4 mb-8">
            <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="flex items-center gap-3 text-muted-blue hover:text-steel-blue transition-colors">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <span class="font-display text-sm">{company.phone}</span>
            </a>
            <a href={`mailto:${company.email}`} class="flex items-center gap-3 text-muted-blue hover:text-steel-blue transition-colors">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <span class="text-sm">{company.email}</span>
            </a>
          </div>
          <p class="text-xs text-muted-blue">{company.location}</p>
        </div>

        <!-- Right: Form -->
        <div class="lg:col-span-3">
          <form id="home-contact-form" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="text" name="name" required placeholder="Name *" class="w-full px-4 py-3 bg-deep-navy border border-navy-mid rounded-lg text-base text-white placeholder:text-muted-blue/50 focus:border-steel-blue/50 focus:ring-1 focus:ring-steel-blue/30 outline-none transition-colors" />
              <input type="email" name="email" required placeholder="Email *" class="w-full px-4 py-3 bg-deep-navy border border-navy-mid rounded-lg text-base text-white placeholder:text-muted-blue/50 focus:border-steel-blue/50 focus:ring-1 focus:ring-steel-blue/30 outline-none transition-colors" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="tel" name="phone" placeholder="Phone" class="w-full px-4 py-3 bg-deep-navy border border-navy-mid rounded-lg text-base text-white placeholder:text-muted-blue/50 focus:border-steel-blue/50 focus:ring-1 focus:ring-steel-blue/30 outline-none transition-colors" />
              <input type="text" name="company" placeholder="Company" class="w-full px-4 py-3 bg-deep-navy border border-navy-mid rounded-lg text-base text-white placeholder:text-muted-blue/50 focus:border-steel-blue/50 focus:ring-1 focus:ring-steel-blue/30 outline-none transition-colors" />
            </div>
            <select name="product" class="w-full px-4 py-3 bg-deep-navy border border-navy-mid rounded-lg text-base text-muted-blue focus:border-steel-blue/50 focus:ring-1 focus:ring-steel-blue/30 outline-none transition-colors">
              <option value="">Product Interest</option>
              <option value="Lighting Inverters">Lighting Inverters (UL924)</option>
              <option value="Elevator Backup">Elevator Backup (UL924)</option>
              <option value="Fire Alarm Backup">Fire Alarm Backup (UL1481)</option>
              <option value="UPS Systems">UPS Systems (UL1778)</option>
              <option value="Medical Grade">Medical Grade Systems</option>
              <option value="Voltage Regulators">Voltage Regulators</option>
              <option value="Power Distribution Units">Power Distribution Units</option>
              <option value="Monitoring and Software">Monitoring and Software</option>
              <option value="Load Control Relays">Load Control Relays</option>
              <option value="Custom OEM Solutions">Custom OEM Solutions</option>
              <option value="Other">Other</option>
            </select>
            <textarea name="message" rows="4" placeholder="Message" class="w-full px-4 py-3 bg-deep-navy border border-navy-mid rounded-lg text-base text-white placeholder:text-muted-blue/50 focus:border-steel-blue/50 focus:ring-1 focus:ring-steel-blue/30 outline-none transition-colors resize-y"></textarea>
            <div class="hidden" aria-hidden="true"><input type="text" name="website" tabindex="-1" autocomplete="off" /></div>
            <Button type="submit" id="home-submit-btn" size="lg">Submit</Button>
            <div id="home-success" class="hidden p-4 bg-steel-blue/10 border border-steel-blue/30 rounded-lg text-steel-blue text-sm">Message sent. We'll be in touch within 1-2 business days.</div>
            <div id="home-error" class="hidden p-4 bg-red-500/10 border border-red-500/30 rounded-lg text-red-400 text-sm">Something went wrong. Please call {company.phone}.</div>
          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  (function() {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js';
    s.onload = function() { emailjs.init('ZpNSMzngBD1uoKBg2'); };
    document.head.appendChild(s);

    var form = document.getElementById('home-contact-form');
    var btn = document.getElementById('home-submit-btn');
    form && form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (form.querySelector('[name="website"]').value) return;
      btn.disabled = true; btn.textContent = 'Sending...';
      var p = {};
      new FormData(form).forEach(function(v,k){ p[k] = v; });
      p.subject = 'Website Contact: ' + (p.product || 'General');
      emailjs.send('service_wwtue8f', 'template_tavsq3o', p).then(function() {
        document.getElementById('home-success').classList.remove('hidden');
        document.getElementById('home-error').classList.add('hidden');
        form.reset(); btn.disabled = false; btn.textContent = 'Submit';
      }).catch(function() {
        document.getElementById('home-error').classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Submit';
      });
    });
  })();

</script>
