---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import { company, testimonials } from '../data/company';
import CustomOEM from '../components/illustrations/CustomOEM.astro';
---

<BaseLayout
  title="Online Power | UL 924 Emergency Lighting Inverters, UPS & Power Protection — US Manufacturer"
  description="Online Power is the US manufacturer of UL 924 emergency lighting inverters (35W–400kW), UL 1778 UPS systems, UL 1481 fire alarm backup, medical-grade (UL 60601-1) power, isolation transformers, and elevator backup. ISO 9001 since 1996. BAA & TAA compliant. Built in Los Angeles since 1975."
>

  <!-- ========== HERO — video background ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <!-- Video background -->
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover" style="z-index: 0;">
      <source src="/video/hero-video.mp4" type="video/mp4" />
    </video>
    <!-- Depth stack: dark overlay + left-to-right gradient + tech grid -->
    <div class="absolute inset-0 bg-deep-navy/70" style="z-index: 1;"></div>
    <div class="absolute inset-0" style="z-index: 1; background: linear-gradient(90deg, rgba(15,42,74,0.85) 0%, rgba(15,42,74,0.55) 55%, rgba(15,42,74,0.15) 100%);"></div>
    <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="z-index: 1; background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <!-- Steel-blue accent glow bottom-left -->
    <div class="absolute -bottom-24 -left-24 w-[520px] h-[520px] rounded-full pointer-events-none" style="z-index: 1; background: radial-gradient(circle, rgba(37,103,194,0.35) 0%, rgba(37,103,194,0) 70%); filter: blur(8px);"></div>

    <!-- Content -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 md:py-20" style="z-index: 2;">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-sky-blue/30 bg-sky-blue/5 mb-5 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-blue opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-sky-blue"></span>
          </span>
          <span class="font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-blue">Online & Shipping · Built in Los Angeles</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-[76px] font-extrabold tracking-tight text-white leading-[1.02] mb-3">
          Power That<br/>Never Quits.
          <span class="block mt-1 text-sky-blue font-display font-bold text-2xl sm:text-3xl sm:hidden">For Hospitals.</span>
          <span class="hidden sm:block mt-1 relative" style="min-height: 1.2em; margin-bottom: 0;">
            <span class="cycle-word" style="animation-delay: 0s;">For Hospitals.</span>
            <span class="cycle-word" style="animation-delay: 3s;">For Data Centers.</span>
            <span class="cycle-word" style="animation-delay: 6s;">For High-Rise Buildings.</span>
            <span class="cycle-word" style="animation-delay: 9s;">For Government.</span>
          </span>
        </h1>
        <style>
          .cycle-word {
            display: block;
            position: absolute;
            color: #7EB3F5;
            font-size: 0.5em;
            font-family: 'Inter Tight', 'Inter', sans-serif;
            font-weight: 700;
            opacity: 0;
            animation: cycleText 12s linear infinite;
          }
          @keyframes cycleText {
            0%   { opacity: 0; transform: translateY(6px); }
            5%   { opacity: 1; transform: translateY(0); }
            22%  { opacity: 1; transform: translateY(0); }
            27%  { opacity: 0; transform: translateY(-6px); }
            100% { opacity: 0; }
          }
        </style>

        <p class="font-display text-[12px] font-semibold uppercase tracking-[0.14em] text-white/70 mt-6 mb-0">US Manufacturer Since 1975 · Built to Order in Los Angeles</p>
        <p class="text-lg text-white/80 max-w-lg leading-relaxed mb-8" style="margin-top:0.75rem;">
          Emergency lighting, UPS, elevator backup, fire alarm, medical grade, and custom OEM power systems. All UL listed, all built to order in Los Angeles. The widest range from a single US manufacturer since 1975.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="/products/" size="lg" icon="arrow-right">View Products</Button>
          <Button href="/contact/" variant="ghost" size="lg">Request a Quote</Button>
        </div>
      </div>
    </div>

    <!-- Headline Stats: stacked on mobile, 3-col on md+ -->
    <div class="relative border-t border-white/10" style="z-index: 2;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 md:divide-x md:divide-white/10 divide-y divide-white/10 md:divide-y-0 py-2 md:py-8">
          <!-- 50 YRS -->
          <div class="flex md:block items-baseline gap-3 py-4 md:py-0 md:px-8 md:first:pl-0 md:text-left">
            <p class="font-display text-[28px] md:text-[44px] font-extrabold tracking-tight text-white leading-none md:mb-2 whitespace-nowrap">50 YRS</p>
            <p class="font-display text-[11px] md:text-[12px] font-semibold uppercase tracking-[0.16em] text-white/70">US Manufacturing</p>
          </div>
          <!-- ISO 9001 -->
          <div class="flex md:block items-baseline gap-3 py-4 md:py-0 md:px-8 md:text-left">
            <p class="font-display text-[28px] md:text-[44px] font-extrabold tracking-tight text-white leading-none md:mb-2 whitespace-nowrap">ISO 9001</p>
            <p class="font-display text-[11px] md:text-[12px] font-semibold uppercase tracking-[0.16em] text-white/70">Quality Certified</p>
          </div>
          <!-- MADE IN USA -->
          <div class="flex md:block items-center md:items-start gap-3 py-4 md:py-0 md:px-8 md:text-left">
            <div class="flex items-center gap-2.5 md:gap-3 md:mb-2">
              <svg viewBox="0 0 19 10" class="w-7 h-[14px] md:w-11 md:h-[23px] rounded-[2px] shadow-sm flex-shrink-0" aria-label="Flag of the United States" role="img">
                <rect width="19" height="10" fill="#B22234"/>
                <rect y="0.77" width="19" height="0.77" fill="#fff"/>
                <rect y="2.31" width="19" height="0.77" fill="#fff"/>
                <rect y="3.85" width="19" height="0.77" fill="#fff"/>
                <rect y="5.38" width="19" height="0.77" fill="#fff"/>
                <rect y="6.92" width="19" height="0.77" fill="#fff"/>
                <rect y="8.46" width="19" height="0.77" fill="#fff"/>
                <rect width="7.6" height="5.38" fill="#3C3B6E"/>
              </svg>
              <p class="font-display text-[22px] md:text-[36px] font-extrabold tracking-tight text-white leading-none whitespace-nowrap">MADE IN USA</p>
            </div>
            <p class="font-display text-[11px] md:text-[12px] font-semibold uppercase tracking-[0.16em] text-white/70 md:mt-0">Built in LA</p>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-x-4 md:gap-x-6 gap-y-2 py-4 border-t border-white/10 font-display text-[10px] md:text-[11px] font-semibold uppercase tracking-[0.12em] md:tracking-[0.14em] text-white/60">
          <span>UL Listed</span>
          <span class="text-white/20">·</span>
          <span>BAA Compliant</span>
          <span class="text-white/20">·</span>
          <span>TAA Compliant</span>
          <span class="text-white/20">·</span>
          <span>Founded 1975</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CHAPTER 01 · SECTOR TRUST ROW ========== -->
  <section id="ch-01" data-chapter="01" data-chapter-title="The Trust" class="bg-white border-b border-steel-gray journey-seam">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16">
      <div class="flex flex-col items-center text-center mb-8 reveal">
        <span class="chapter-num mb-3">01 · The Trust</span>
        <h2 class="font-display text-2xl md:text-3xl font-extrabold tracking-tight text-near-black max-w-2xl leading-tight">Trusted in the Environments<br class="hidden sm:block"/> Where Power <span class="text-steel-blue">Cannot Fail</span></h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { label: 'Hospitals', desc: 'Critical Care · Surgical Suites', icon: 'M9 12h6m-3-3v6m-9 1V5a2 2 0 012-2h14a2 2 0 012 2v11a2 2 0 01-2 2H5a2 2 0 01-2-2z' },
          { label: 'Data Centers', desc: 'Colocation · Hyperscale', icon: 'M4 7a2 2 0 012-2h12a2 2 0 012 2v2H4V7zm0 4h16v2H4v-2zm0 4h16v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2z' },
          { label: 'Government', desc: 'Federal · DoD · Municipal', icon: 'M3 21h18M5 21V10l7-5 7 5v11M9 21V13h6v8' },
          { label: 'High-Rise', desc: 'Commercial · Residential', icon: 'M5 21V5a1 1 0 011-1h5a1 1 0 011 1v16M12 21V9a1 1 0 011-1h5a1 1 0 011 1v12M3 21h18M8 8h1m-1 4h1m-1 4h1m7-4h1m-1 4h1' },
        ].map((s, i) => (
          <div class={`reveal reveal-delay-${i+1} group flex flex-col items-center text-center py-5 px-3 border border-steel-gray rounded-lg hover:border-steel-blue hover:shadow-[0_8px_20px_-8px_rgba(37,103,194,0.25)] hover:-translate-y-0.5 transition-all duration-200`}>
            <div class="w-11 h-11 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-3 group-hover:bg-steel-blue/15 transition-colors">
              <svg class="w-6 h-6 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={s.icon}/></svg>
            </div>
            <p class="font-display text-[16px] font-bold text-near-black">{s.label}</p>
            <p class="text-[12px] text-slate mt-1">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CHAPTER 02 · PRODUCTS GRID ========== -->
  <section id="ch-02" data-chapter="02" data-chapter-title="The Range" class="py-16 md:py-20 bg-off-white journey-seam">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10 reveal">
        <div>
          <span class="chapter-num mb-3 block">02 · The Range</span>
          <h2 class="font-display text-3xl md:text-[44px] font-extrabold tracking-tight text-near-black leading-[1.1] mt-2">Every Critical Load. <span class="text-steel-blue">One Manufacturer.</span></h2>
        </div>
        <a href="/products/" class="font-display text-[13px] font-bold uppercase tracking-[0.12em] text-steel-blue hover:text-near-black transition-colors whitespace-nowrap">All Products &rarr;</a>
      </div>

      <!-- Horizontal scrolling product rail -->
      <div class="relative -mx-4 sm:-mx-6">
        <div id="product-rail" class="flex overflow-x-auto snap-x snap-mandatory gap-5 px-4 sm:px-6 pb-5 no-scrollbar scroll-smooth">
          {[
            { href: '/products/category/emergency-lighting', img: '/images/products/power-wave-1.png', name: 'Emergency Lighting Inverters', range: '35W – 400 kW', tag: 'UL 924', desc: 'Illuminates the path of egress when utility power fails. Engineered to help meet NFPA 101 §7.9 and UL 924 life-safety requirements.' },
            { href: '/products/category/fire-alarm-backup', img: '/images/products/fire-alarm-backup.png', name: 'Fire Alarm Backup', range: '500W – 15 kW', tag: 'UL 1481', desc: '24 hr standby + 5 min alarm (15 for voice evac). Powers the entire FACP — not just NAC circuits.' },
            { href: '/products/category/elevator-backup', img: '/images/products/power-wave-4.png', name: 'Elevator Backup Systems', range: '24 – 240 kW · 3Ø', tag: 'UL 924 + 1778', desc: 'Three-phase evacuation power. Regen-capable. No load bank, no ATS required.' },
            { href: '/products/category/ups-backup', img: '/images/products/host-power.png', name: 'UPS Backup Systems', range: '10 – 500 kVA', tag: 'UL 1778', desc: 'True online double-conversion, IGBT PWM, zero transfer. Generator-compatible.' },
            { href: '/products/category/medical-grade', img: '/images/products/medical-power.png', name: 'Medical Grade Systems', range: '10 – 1,250 kVA', tag: 'UL 60601-1', desc: 'Patient-grade leakage limits, Faraday shields, OSHPD/HCAI seismic preapproval.' },
            { href: '/products/category/isolation-transformers', img: '/images/products/isocare.png', name: 'Isolation Transformers', range: '15 – 500 kVA', tag: 'UL 506', desc: 'Noise & harmonic cancellation up to -152 dB. New derived neutral-ground bond at the output. NEMA 12.' },
            { href: '/products/category/voltage-regulators', img: '/images/products/power-reg.png', name: 'Voltage Regulators', range: '15 – 2,000 kVA', tag: '±3% regulation', desc: 'Electronic tap-switching. Sub-cycle correction. 99% efficient. The quiet class.' },
            { href: '/products/category/power-distribution', img: '/images/products/power-pac.png', name: 'Power Distribution Units', range: '15 – 450 kVA', tag: 'UL 489', desc: 'Custom PDUs and power islands. Built-in regulation, branch monitoring, harmonic-load ready.' },
            { href: '/products/category/frequency-converters', img: '/images/products/frequency-converter.png', name: 'Frequency Converters', range: '10 – 320 kVA', tag: '50 / 60 / 400 Hz', desc: 'True galvanic isolation, ±0.1 Hz accuracy. Defense, aerospace, and global OEM integration.' },
            { href: '/products/category/load-control-relays', img: '/images/products/lcr20.png', name: 'Load Control Relays', range: 'LCR-20', tag: 'UL 924 · IP65', desc: 'Automatic dimmer override for emergency lighting. 0-10V protocol, IP65 rated.' },
          ].map((p) => (
            <a href={p.href} class="snap-start shrink-0 w-[85vw] sm:w-[380px] group relative overflow-hidden bg-white border border-steel-gray rounded-xl flex flex-col transition-all duration-300 hover:border-steel-blue hover:-translate-y-1 hover:shadow-[0_18px_40px_-12px_rgba(37,103,194,0.28)]">
              <div class="relative h-[200px] bg-gradient-to-br from-deep-navy to-near-black overflow-hidden">
                <div class="absolute inset-0 pointer-events-none opacity-[0.12]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 28px 28px;"></div>
                <div class="absolute -top-12 -right-12 w-[260px] h-[260px] pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.4) 0%, rgba(37,103,194,0) 65%); filter: blur(8px);"></div>
                <img src={p.img} alt={`${p.name} — ${p.range}`} loading="lazy" class="relative z-10 w-full h-full object-contain p-6 group-hover:scale-[1.06] transition-transform duration-500" />
                <span class="absolute top-3 left-3 z-20 font-display text-[10px] font-semibold uppercase tracking-[0.14em] text-sky-blue bg-deep-navy/80 backdrop-blur-sm px-2 py-1 rounded border border-white/10">{p.tag}</span>
              </div>
              <div class="flex-1 p-6 flex flex-col">
                <div class="flex items-baseline justify-between gap-3 mb-2">
                  <h3 class="font-display text-xl font-bold tracking-tight text-near-black group-hover:text-steel-blue transition-colors">{p.name}</h3>
                  <span class="font-display text-[12px] font-semibold text-steel-blue whitespace-nowrap">{p.range}</span>
                </div>
                <p class="text-[14px] text-slate leading-relaxed mb-4 flex-1">{p.desc}</p>
                <span class="font-display text-[12px] font-bold uppercase tracking-[0.12em] text-steel-blue group-hover:text-near-black transition-colors inline-flex items-center gap-1.5">
                  Explore
                  <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>

        <!-- Scroll controls (desktop) -->
        <button type="button" data-rail-scroll="product-rail" data-dir="-1" aria-label="Scroll products left" class="hidden md:flex absolute left-2 top-[100px] -translate-y-1/2 z-10 w-11 h-11 rounded-full bg-white border border-steel-gray shadow-md items-center justify-center hover:border-steel-blue hover:bg-steel-blue hover:text-white text-near-black transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button type="button" data-rail-scroll="product-rail" data-dir="1" aria-label="Scroll products right" class="hidden md:flex absolute right-2 top-[100px] -translate-y-1/2 z-10 w-11 h-11 rounded-full bg-white border border-steel-gray shadow-md items-center justify-center hover:border-steel-blue hover:bg-steel-blue hover:text-white text-near-black transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ========== CHAPTER 03 · THE MATCH (sizing tool) ========== -->
  <section id="sizer" data-chapter="03" data-chapter-title="The Match" class="py-16 md:py-24 bg-white border-b border-steel-gray journey-seam">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10 reveal">
        <span class="chapter-num mb-3 inline-flex">03 · The Match</span>
        <h2 class="font-display text-3xl md:text-[44px] font-extrabold tracking-tight text-near-black mt-3 leading-[1.05]">Size Your System <span class="text-steel-blue">in 30 Seconds.</span></h2>
        <p class="text-slate mt-4 max-w-xl mx-auto">Pick the system type, enter your load, see the recommended model. Final specs always confirmed by our engineering team.</p>
      </div>

      <div class="max-w-5xl mx-auto reveal">
        <div class="flex flex-wrap gap-1 border-b border-steel-gray mb-8" role="tablist" aria-label="Select product category">
          <button type="button" class="sizer-tab active flex-1 min-w-[140px] px-4 py-3 font-display text-[13px] font-bold uppercase tracking-[0.08em] text-steel-blue border-b-2 border-steel-blue transition-colors" data-cat="el" role="tab" aria-selected="true">Emergency Lighting</button>
          <button type="button" class="sizer-tab flex-1 min-w-[140px] px-4 py-3 font-display text-[13px] font-bold uppercase tracking-[0.08em] text-slate border-b-2 border-transparent hover:text-near-black transition-colors" data-cat="ups" role="tab" aria-selected="false">UPS</button>
          <button type="button" class="sizer-tab flex-1 min-w-[140px] px-4 py-3 font-display text-[13px] font-bold uppercase tracking-[0.08em] text-slate border-b-2 border-transparent hover:text-near-black transition-colors" data-cat="fire" role="tab" aria-selected="false">Fire Alarm</button>
          <button type="button" class="sizer-tab flex-1 min-w-[140px] px-4 py-3 font-display text-[13px] font-bold uppercase tracking-[0.08em] text-slate border-b-2 border-transparent hover:text-near-black transition-colors" data-cat="elev" role="tab" aria-selected="false">Elevator Backup</button>
        </div>

        <div class="grid lg:grid-cols-2 gap-6 lg:gap-10">
          <div>
            <!-- Emergency Lighting -->
            <div class="sizer-panel" data-cat="el">
              <label class="block mb-5">
                <span class="block font-display text-[12px] font-semibold uppercase tracking-[0.12em] text-slate mb-2">Total Connected Load</span>
                <div class="flex items-center border border-steel-gray rounded-lg bg-off-white focus-within:border-steel-blue transition-colors">
                  <input type="number" id="el-watts" min="0" step="1" placeholder="e.g. 2500" class="flex-1 px-4 py-3 bg-transparent outline-none text-near-black font-display text-lg font-bold" />
                  <span class="px-4 py-3 font-display text-[13px] font-semibold text-slate border-l border-steel-gray">Watts</span>
                </div>
              </label>
              <label class="block mb-5">
                <span class="block font-display text-[12px] font-semibold uppercase tracking-[0.12em] text-slate mb-2">Phase</span>
                <div class="grid grid-cols-2 gap-2">
                  <label class="flex items-center justify-center px-4 py-3 border border-steel-gray rounded-lg bg-off-white cursor-pointer font-display text-sm font-semibold text-near-black has-[:checked]:border-steel-blue has-[:checked]:bg-steel-blue has-[:checked]:text-white transition-colors">
                    <input type="radio" name="el-phase" value="1" checked class="sr-only" />
                    Single Phase (1Ø)
                  </label>
                  <label class="flex items-center justify-center px-4 py-3 border border-steel-gray rounded-lg bg-off-white cursor-pointer font-display text-sm font-semibold text-near-black has-[:checked]:border-steel-blue has-[:checked]:bg-steel-blue has-[:checked]:text-white transition-colors">
                    <input type="radio" name="el-phase" value="3" class="sr-only" />
                    Three Phase (3Ø)
                  </label>
                </div>
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" id="el-seismic" class="w-4 h-4 accent-steel-blue" />
                <span class="font-display text-sm text-near-black">Needs OSHPD/HCAI seismic certification</span>
              </label>
              <p class="text-[12px] text-slate mt-4">Runtime: 90 min per NFPA 101 §7.9 (120 min available). Pure sine wave output.</p>
            </div>

            <!-- UPS -->
            <div class="sizer-panel hidden" data-cat="ups">
              <label class="block mb-5">
                <span class="block font-display text-[12px] font-semibold uppercase tracking-[0.12em] text-slate mb-2">Critical Load</span>
                <div class="flex items-center border border-steel-gray rounded-lg bg-off-white focus-within:border-steel-blue transition-colors">
                  <input type="number" id="ups-kva" min="0" step="1" placeholder="e.g. 50" class="flex-1 px-4 py-3 bg-transparent outline-none text-near-black font-display text-lg font-bold" />
                  <span class="px-4 py-3 font-display text-[13px] font-semibold text-slate border-l border-steel-gray">kVA</span>
                </div>
                <p class="text-[12px] text-slate mt-2">Tip: kW ÷ 0.9 ≈ kVA for most modern loads.</p>
              </label>
              <label class="block mb-5">
                <span class="block font-display text-[12px] font-semibold uppercase tracking-[0.12em] text-slate mb-2">Phase</span>
                <div class="grid grid-cols-2 gap-2">
                  <label class="flex items-center justify-center px-4 py-3 border border-steel-gray rounded-lg bg-off-white cursor-pointer font-display text-sm font-semibold text-near-black has-[:checked]:border-steel-blue has-[:checked]:bg-steel-blue has-[:checked]:text-white transition-colors">
                    <input type="radio" name="ups-phase" value="1" class="sr-only" />
                    Single Phase (1Ø)
                  </label>
                  <label class="flex items-center justify-center px-4 py-3 border border-steel-gray rounded-lg bg-off-white cursor-pointer font-display text-sm font-semibold text-near-black has-[:checked]:border-steel-blue has-[:checked]:bg-steel-blue has-[:checked]:text-white transition-colors">
                    <input type="radio" name="ups-phase" value="3" checked class="sr-only" />
                    Three Phase (3Ø)
                  </label>
                </div>
              </label>
              <p class="text-[12px] text-slate mt-4">True online double-conversion, UL 1778 listed. Generator-compatible.</p>
            </div>

