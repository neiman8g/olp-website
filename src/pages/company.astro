---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { company } from '../data/company';
---

<BaseLayout
  title="About Online Power | US Manufacturer of Power Protection Since 1975"
  description="Online Power is a US-based manufacturer of mission-critical power protection equipment since 1975. ISO 9001 certified since 1996. UL listed. Made in Los Angeles, CA."
>

  <!-- Hero -->
  <section class="py-10 md:py-14 bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="eyebrow text-slate mb-6">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-steel-blue">Company</span>
      </nav>
      <h1 class="font-display text-4xl md:text-[40px] font-bold text-near-black mb-6">About Online Power</h1>
      <p class="text-lg text-slate max-w-2xl">Stay online with Online Power. Manufacturing mission-critical power protection in Los Angeles since 1975.</p>
    </div>
  </section>

  <!-- Company Overview -->
  <section class="py-14 md:py-[72px] bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-8 items-start">
        <div>
          <p class="eyebrow text-steel-blue mb-4">Our Story</p>
          <h2 class="font-display text-3xl font-bold text-near-black mb-6">Built in America. Built to Last.</h2>
          <div class="space-y-4 text-slate leading-relaxed">
            <p>Online Power has been providing critical power protection equipment and backup power supply systems since 1975. We are committed to helping our customers find the right electrical power solution for their specific application.</p>
            <p>We design, engineer, and manufacture every product at our Los Angeles facility — from emergency lighting inverters to custom OEM power solutions. As a manufacturer, we offer what distributors can't: direct engineering support from the people who designed your equipment.</p>
            <p>Our commitment to quality earned us ISO 9001 certification in 1996, and we've maintained it continuously since. Every product is UL listed and tested to meet or exceed NFPA, NEC, and other applicable safety standards.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {company.stats.map(stat => (
            <div class="bg-white border border-steel-gray rounded-xl p-6 text-center">
              <p class="eyebrow text-steel-blue mb-2">{stat.label}</p>
              <p class="font-display text-2xl font-bold text-near-black">{stat.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ISO 9001 -->
  <section class="py-14 md:py-[72px] bg-white" id="iso9001">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-8 items-start">
        <div>
          <p class="eyebrow text-steel-blue mb-4">Quality Assurance</p>
          <h2 class="font-display text-3xl font-bold text-near-black mb-6">ISO 9001 Certified Since 1996</h2>
          <div class="space-y-4 text-slate leading-relaxed">
            <p>Online Power has been ISO 9001 certified since 1996 — continuously maintaining the highest quality management standards for nearly three decades.</p>
            <p>Our quality management system covers every aspect of our operations: design and engineering, manufacturing and assembly, testing and inspection, and customer support. Every product that leaves our facility meets or exceeds the requirements of our ISO 9001 quality system.</p>
          </div>
          <Button href="/pdf/ISO_9001_Certification_11-03-27.pdf" variant="outline" target="_blank" class="mt-6">View ISO 9001 Certificate</Button>
        </div>
        <div class="grid grid-cols-3 gap-4">
          {['ISO 9001:2015', 'UL Listed', 'NFPA Compliant', 'CSA Certified', 'CE Marked', 'OSHPD Approved'].map(cert => (
            <div class="card-hover bg-off-white rounded-xl p-4 text-center">
              <div class="w-8 h-8 rounded-lg bg-steel-blue/10 flex items-center justify-center mx-auto mb-2">
                <svg class="w-4 h-4 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
              </div>
              <p class="text-xs font-medium text-near-black">{cert}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Safety Standards -->
  <section class="py-14 md:py-[72px] bg-off-white" id="safety-standards">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-4">Compliance</p>
      <h2 class="font-display text-3xl font-bold text-near-black mb-10">Safety Standards</h2>
      <p class="text-slate max-w-3xl mb-10">Online Power products are designed and manufactured in accordance with or listed to the following safety standards organizations:</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { org: 'ANSI / IEEE', desc: 'American National Standards Institute / Institute of Electrical and Electronics Engineers' },
          { org: 'NEMA', desc: 'National Electrical Manufacturers Association' },
          { org: 'CSA', desc: 'Canadian Standards Association (Canada)' },
          { org: 'CE / IEC', desc: 'Conformité Européenne / International Electrotechnical Commission (Europe)' },
          { org: 'ETL / UL', desc: 'Intertek / Underwriters Laboratories (USA)' },
          { org: 'FCC', desc: 'Federal Communications Commission (USA)' },
          { org: 'OSHPD / HCAI', desc: 'Office of Statewide Health Planning (California Hospitals)' },
          { org: 'NFPA', desc: 'National Fire Protection Association' },
        ].map(item => (
          <div class="bg-white border border-steel-gray rounded-xl p-5">
            <p class="font-display font-bold text-steel-blue text-sm mb-1">{item.org}</p>
            <p class="text-xs text-slate">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Laboratory Testing -->
  <section class="py-14 md:py-[72px] bg-white" id="lab-testing">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-4">Testing</p>
      <h2 class="font-display text-3xl font-bold text-near-black mb-6">Laboratory Testing</h2>
      <p class="text-slate max-w-3xl mb-10">Online Power maintains comprehensive in-house testing capabilities to ensure every product meets the highest standards of reliability and safety.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {['EMC Testing', 'Humidity & Salt Fog', 'ESD Testing', 'Grounding & Bonding', 'Surge Withstand', 'Rain Intrusion', 'Seismic / Shaker Table', 'Thermal Cycling', 'Load & Performance'].map(test => (
          <div class="flex items-center gap-3 bg-off-white border border-steel-gray rounded-lg p-4">
            <svg class="w-5 h-5 text-steel-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-sm text-near-black">{test}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Careers -->
  <section class="py-14 md:py-[72px] bg-off-white" id="careers">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="eyebrow text-steel-blue mb-4">Careers</p>
        <h2 class="font-display text-3xl font-bold text-near-black mb-6">Join Our Team</h2>
        <p class="text-slate leading-relaxed mb-4">Online Power is an Equal Opportunity Employer offering competitive compensation and benefits. We're always looking for talented engineers, technicians, and manufacturing professionals.</p>
        <p class="text-slate leading-relaxed mb-8">To apply, submit your resume in PDF format to:</p>
        <div class="card-hover bg-white rounded-xl p-6 space-y-3">
          <a href="mailto:hr@onlinepower.com" class="flex items-center gap-3 text-steel-blue font-display font-semibold text-sm hover:text-near-black transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            hr@onlinepower.com
          </a>
          <p class="text-xs text-slate">Fax: (323) 721-3929</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Work With Us</h2>
      <p class="text-muted-blue mb-8">Standard products, custom OEM, or expert training.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/training" class="px-8 py-3.5 bg-steel-blue text-white font-semibold rounded hover:bg-steel-blue/90 transition-colors text-sm">Register for Training</a>
        <a href="/contact" class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded hover:bg-white/10 transition-colors text-sm">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
