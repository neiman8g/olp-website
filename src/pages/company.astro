---
import BaseLayout from '../layouts/BaseLayout.astro';
import { company } from '../data/company';
---

<BaseLayout
  title="About Online Power | US Manufacturer of Power Protection Since 1975"
  description="Online Power is a US-based manufacturer of mission-critical power protection equipment since 1975. ISO 9001 certified. UL listed. Made in Los Angeles, CA."
>

  <section class="py-20 md:py-28 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-6">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Company</span>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-pure mb-6">About Online Power</h1>
      <p class="text-lg text-ash max-w-2xl">Manufacturing mission-critical power protection in Los Angeles since 1975. ISO 9001 certified. Factory-direct.</p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Our Story</p>
          <h2 class="font-display text-3xl font-bold text-pure mb-6">Built in America. Built to Last.</h2>
          <div class="space-y-4 text-ash leading-relaxed">
            <p>Online Power has been at the forefront of critical power protection since 1975. We design, engineer, and manufacture every product at our Los Angeles facility.</p>
            <p>Our ISO 9001 certification — held continuously since 1996 — reflects our commitment to manufacturing excellence. Every product is UL listed and tested to meet or exceed NFPA, NEC, and applicable safety standards.</p>
            <p>As a manufacturer, we offer what distributors can't: direct engineering support, custom modifications, and product training from the team that built your equipment.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {company.stats.map(stat => (
            <div class="bg-obsidian border border-steel/30 rounded-xl p-6 text-center">
              <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-2">{stat.label}</p>
              <p class="font-display text-2xl font-bold text-pure">{stat.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-obsidian" id="certifications">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Standards</p>
      <h2 class="font-display text-3xl font-bold text-pure mb-10">Certifications</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {company.certifications.map(cert => (
          <div class="card-glow bg-slate rounded-xl p-5 text-center">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mx-auto mb-3">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <p class="text-xs font-semibold text-pure">{cert}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-voltage py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-obsidian mb-4">Work With Us</h2>
      <p class="text-obsidian/70 mb-8">Standard products, custom OEM, or expert training — we're here to help.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/training/" class="px-8 py-3.5 bg-obsidian text-pure font-semibold rounded-lg hover:bg-slate transition-colors text-sm">Register for Training</a>
        <a href="/contact/" class="px-8 py-3.5 border-2 border-obsidian/30 text-obsidian font-semibold rounded-lg hover:bg-obsidian/10 transition-colors text-sm">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
