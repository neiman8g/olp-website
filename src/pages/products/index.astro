---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmergencyLighting from '../../components/illustrations/EmergencyLighting.astro';
import ElevatorBackup from '../../components/illustrations/ElevatorBackup.astro';
import UPSSystems from '../../components/illustrations/UPSSystems.astro';
import FireAlarmBackup from '../../components/illustrations/FireAlarmBackup.astro';
import MedicalGrade from '../../components/illustrations/MedicalGrade.astro';
import VoltageRegulators from '../../components/illustrations/VoltageRegulators.astro';
import PowerDistribution from '../../components/illustrations/PowerDistribution.astro';
import Monitoring from '../../components/illustrations/Monitoring.astro';
import LoadControlRelays from '../../components/illustrations/LoadControlRelays.astro';
import CustomOEM from '../../components/illustrations/CustomOEM.astro';
---

<BaseLayout
  title="Power Protection Products | Online Power - Emergency Lighting, UPS, Fire Alarm Backup"
  description="Browse Online Power's full catalog of power protection products. Emergency lighting inverters, UPS systems, fire alarm backup, voltage regulators, medical grade power, and custom OEM solutions. All manufactured in the USA."
>

  <section class="py-20 md:py-28 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-6">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Products</span>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-pure mb-4">Our Products</h1>
      <p class="text-lg text-ash max-w-2xl">Designed, engineered, and manufactured in Los Angeles. Factory-direct quality with expert support.</p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Emergency Lighting Inverters -->
        <a href="/products/category/emergency-lighting" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <EmergencyLighting />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Emergency Lighting Inverters</h2>
            <p class="text-sm text-ash mb-4">UL924 listed emergency lighting inverters from 35W to 400kW</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Elevator Backup -->
        <a href="/products/category/elevator-backup" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <ElevatorBackup />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Elevator Backup</h2>
            <p class="text-sm text-ash mb-4">UL924 elevator backup systems for safe evacuation</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- UPS Systems -->
        <a href="/products/category/ups-backup" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <UPSSystems />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">UPS Systems</h2>
            <p class="text-sm text-ash mb-4">UL1778 uninterruptible power supply systems</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Fire Alarm Backup -->
        <a href="/products/category/fire-alarm-backup" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <FireAlarmBackup />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Fire Alarm Backup</h2>
            <p class="text-sm text-ash mb-4">UL1481 fire alarm notification appliance circuit backup</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Medical Grade -->
        <a href="/products/category/medical-grade" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <MedicalGrade />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Medical Grade</h2>
            <p class="text-sm text-ash mb-4">Hospital-grade isolation and power protection systems</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Voltage Regulators -->
        <a href="/products/category/voltage-regulators" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <VoltageRegulators />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Voltage Regulators</h2>
            <p class="text-sm text-ash mb-4">Power conditioning and voltage regulation systems</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Power Distribution -->
        <a href="/products/category/power-distribution" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <PowerDistribution />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Power Distribution</h2>
            <p class="text-sm text-ash mb-4">Power distribution units and power management</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Monitoring & Software -->
        <a href="/products/category/monitoring" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <Monitoring />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Monitoring & Software</h2>
            <p class="text-sm text-ash mb-4">Remote monitoring and battery advisory systems</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Load Control Relays -->
        <a href="/products/category/load-control-relays" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <LoadControlRelays />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Load Control Relays</h2>
            <p class="text-sm text-ash mb-4">Automatic load control relays for emergency lighting</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Custom OEM -->
        <a href="/products/category/custom-oem" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <CustomOEM />
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Custom OEM</h2>
            <p class="text-sm text-ash mb-4">Custom engineered power solutions for OEM partners</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

      </div>

      <div class="mt-16 card-glow bg-voltage/5 border-voltage/20 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-pure mb-4">Need a Custom Solution?</h2>
        <p class="text-ash max-w-xl mx-auto mb-6">48 years of custom OEM manufacturing experience. We engineer power protection to your exact spec.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact/" class="btn-primary px-8 py-3.5 rounded-lg text-sm font-semibold">Request a Quote</a>
          <a href="/training/" class="btn-ghost px-8 py-3.5 rounded-lg text-sm">Register for Training</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
