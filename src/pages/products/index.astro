              <text x="420" y="75" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#8A9BAE">PATIENT MONITOR</text>
              <line x1="340" y1="70" x2="340" y2="200" stroke="#8A9BAE" stroke-width="1" opacity="0.4"/>
              <circle cx="340" cy="70" r="6" fill="none" stroke="#8A9BAE" stroke-width="0.5" opacity="0.4"/>
              <line x1="334" y1="70" x2="346" y2="70" stroke="#8A9BAE" stroke-width="0.5" opacity="0.4"/>
              <ellipse cx="300" cy="45" rx="30" ry="6" fill="none" stroke="#8A9BAE" stroke-width="0.5" opacity="0.3"/>
              <line x1="300" y1="30" x2="300" y2="39" stroke="#8A9BAE" stroke-width="0.5" opacity="0.3"/>
              <circle cx="100" cy="145" r="18" fill="none" stroke="#00E5FF" stroke-width="1" opacity="0.5"/>
