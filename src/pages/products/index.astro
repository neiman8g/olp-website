---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { productCategories } from '../../data/navigation';
---

<BaseLayout
  title="Power Protection Products | Online Power - Emergency Lighting, UPS, Fire Alarm Backup"
  description="Browse Online Power's full catalog of power protection products. Emergency lighting inverters, UPS systems, fire alarm backup, voltage regulators, medical grade power, and custom OEM solutions. All manufactured in the USA."
>

  <section class="py-20 md:py-28 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-6">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Products</span>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-pure mb-4">Our Products</h1>
      <p class="text-lg text-ash max-w-2xl">Designed, engineered, and manufactured in Los Angeles. Factory-direct quality with expert support.</p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {productCategories.map(cat => (
          <a href={`/products/category/${cat.slug}`} class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
            <div class="h-40 bg-gradient-to-br from-steel/30 to-obsidian flex items-center justify-center">
              <svg class="w-12 h-12 text-voltage/30 group-hover:text-voltage/60 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div class="p-6">
              <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">{cat.name}</h2>
              <p class="text-sm text-ash mb-4">{cat.description}</p>
              <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-16 card-glow bg-voltage/5 border-voltage/20 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-pure mb-4">Need a Custom Solution?</h2>
        <p class="text-ash max-w-xl mx-auto mb-6">48 years of custom OEM manufacturing experience. We engineer power protection to your exact spec.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact/" class="btn-primary px-8 py-3.5 rounded-lg text-sm font-semibold">Request a Quote</a>
          <a href="/training/" class="btn-ghost px-8 py-3.5 rounded-lg text-sm">Register for Training</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
