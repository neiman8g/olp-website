---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import EmergencyLighting from '../../components/illustrations/EmergencyLighting.astro';
import ElevatorBackup from '../../components/illustrations/ElevatorBackup.astro';
import UPSSystems from '../../components/illustrations/UPSSystems.astro';
import FireAlarmBackup from '../../components/illustrations/FireAlarmBackup.astro';
import MedicalGrade from '../../components/illustrations/MedicalGrade.astro';
import VoltageRegulators from '../../components/illustrations/VoltageRegulators.astro';
import PowerDistribution from '../../components/illustrations/PowerDistribution.astro';
import Monitoring from '../../components/illustrations/Monitoring.astro';
import LoadControlRelays from '../../components/illustrations/LoadControlRelays.astro';
import CustomOEM from '../../components/illustrations/CustomOEM.astro';
---

<BaseLayout
  title="Power Protection Products | Online Power - Emergency Lighting, UPS, Fire Alarm Backup"
  description="Browse Online Power's full catalog of power protection products. Emergency lighting inverters, UPS systems, fire alarm backup, voltage regulators, medical grade power, and custom OEM solutions. All manufactured in the USA."
>

  <!-- BREADCRUMB STRIP -->
  <section class="bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
      <nav class="text-[13px] font-display text-slate">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-near-black font-semibold">Products</span>
      </nav>
    </div>
  </section>

  <!-- ========== HERO — dark with depth ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute -top-32 -right-32 w-[560px] h-[560px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.3) 0%, rgba(37,103,194,0) 70%); filter: blur(12px);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="max-w-3xl">
        <p class="font-display text-[12px] font-semibold uppercase tracking-[0.2em] text-sky-blue mb-4">Full Catalog</p>
        <h1 class="font-display text-4xl md:text-5xl lg:text-[56px] font-extrabold tracking-tight text-white leading-[1.05] mb-5">Every Critical Load. <span class="text-sky-blue">One Manufacturer.</span></h1>
        <p class="text-lg text-muted-blue leading-relaxed max-w-xl">Designed, engineered, and manufactured in Los Angeles. Factory-direct quality with expert support. All UL listed. Built to order since 1975.</p>
      </div>
    </div>

    <div class="relative border-t border-navy-mid" style="z-index: 2;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-navy-mid">
          {[
            { label: 'Product Lines', value: '10 Categories' },
            { label: 'Range', value: '35W – 400 kW' },
            { label: 'Certifications', value: 'UL · ISO 9001' },
            { label: 'Manufactured', value: 'Los Angeles, CA' },
          ].map(s => (
            <div class="py-6 px-4 md:px-6 text-center md:text-left">
              <p class="font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-blue mb-2">{s.label}</p>
              <p class="font-display text-[15px] md:text-[17px] font-bold text-white leading-tight">{s.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 md:py-[72px] bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Emergency Lighting Inverters -->
        <a href="/products/category/emergency-lighting" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <EmergencyLighting />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Emergency Lighting Inverters</h2>
            <p class="text-base text-slate mb-4">UL924 listed emergency lighting inverters from 35W to 400kW</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

        <!-- Elevator Backup -->
        <a href="/products/category/elevator-backup" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <ElevatorBackup />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Elevator Backup</h2>
            <p class="text-base text-slate mb-4">UL924 elevator backup systems for safe evacuation</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

        <!-- UPS Systems -->
        <a href="/products/category/ups-backup" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <UPSSystems />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">UPS Systems</h2>
            <p class="text-base text-slate mb-4">UL1778 uninterruptible power supply systems</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

        <!-- Fire Alarm Backup -->
        <a href="/products/category/fire-alarm-backup" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <FireAlarmBackup />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Fire Alarm Backup</h2>
            <p class="text-base text-slate mb-4">UL1481 fire alarm notification appliance circuit backup</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

        <!-- Medical Grade -->
        <a href="/products/category/medical-grade" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <MedicalGrade />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Medical Grade</h2>
            <p class="text-base text-slate mb-4">Hospital-grade isolation and power protection systems</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

        <!-- Voltage Regulators -->
        <a href="/products/category/voltage-regulators" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <VoltageRegulators />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Voltage Regulators</h2>
            <p class="text-base text-slate mb-4">Power conditioning and voltage regulation systems</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

        <!-- Power Distribution -->
        <a href="/products/category/power-distribution" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <PowerDistribution />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Power Distribution</h2>
            <p class="text-base text-slate mb-4">Power distribution units and power management</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

        <!-- Monitoring & Software -->
        <a href="/products/category/monitoring" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <Monitoring />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Monitoring & Software</h2>
            <p class="text-base text-slate mb-4">Remote monitoring and battery advisory systems</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

        <!-- Load Control Relays -->
        <a href="/products/category/load-control-relays" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <LoadControlRelays />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Load Control Relays</h2>
            <p class="text-base text-slate mb-4">Automatic load control relays for emergency lighting</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

        <!-- Custom OEM -->
        <a href="/products/category/custom-oem" class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-deep-navy overflow-hidden" style="pointer-events:none;">
            <CustomOEM />
          </div>
          <div class="p-6">
            <h2 class="font-display text-[20px] font-semibold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Custom OEM</h2>
            <p class="text-base text-slate mb-4">Custom engineered power solutions for OEM partners</p>
            <span class="text-[15px] font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>

      </div>

      <Card variant="cta" class="mt-16 text-center">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-near-black mb-4">Need a Custom Solution?</h2>
        <p class="text-slate max-w-xl mx-auto mb-6">48 years of custom OEM manufacturing experience. We engineer power protection to your exact spec.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/contact/" size="lg">Request a Quote</Button>
          <Button href="/training/" variant="outline" size="lg">Register for Training</Button>
        </div>
      </Card>
    </div>
  </section>

</BaseLayout>
