---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Power Protection Products | Online Power - Emergency Lighting, UPS, Fire Alarm Backup"
  description="Browse Online Power's full catalog of power protection products. Emergency lighting inverters, UPS systems, fire alarm backup, voltage regulators, medical grade power, and custom OEM solutions. All manufactured in the USA."
>

  <section class="py-20 md:py-28 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-6">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Products</span>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-pure mb-4">Our Products</h1>
      <p class="text-lg text-ash max-w-2xl">Designed, engineered, and manufactured in Los Angeles. Factory-direct quality with expert support.</p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Emergency Lighting Inverters -->
        <a href="/products/category/emergency-lighting" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes el-powerFail { 0%,30%{stroke:#00E5FF;} 35%{stroke:#1C2B3A;} 90%{stroke:#1C2B3A;} 95%{stroke:#00E5FF;} }
                @keyframes el-lightsOut { 0%,32%{fill:#111827;} 37%{fill:#0A0A0F;} 90%{fill:#0A0A0F;} 95%{fill:#111827;} }
                @keyframes el-emergOn { 0%,38%{opacity:0;r:0;} 42%{opacity:0.8;r:12;} 88%{opacity:0.8;r:12;} 92%{opacity:0;r:0;} }
                @keyframes el-badge { 0%,40%{opacity:0;} 45%{opacity:1;} 88%{opacity:1;} 92%{opacity:0;} }
                .el-power{animation:el-powerFail 6s ease-in-out infinite;}
                .el-room{animation:el-lightsOut 6s ease-in-out infinite;}
                .el-glow{animation:el-emergOn 6s ease-in-out infinite;}
                .el-badge{animation:el-badge 6s ease-in-out infinite;}
              </style>
              <rect x="120" y="40" width="360" height="240" rx="4" fill="none" stroke="#1C2B3A" stroke-width="1.5"/>
              <line x1="120" y1="120" x2="480" y2="120" stroke="#1C2B3A" stroke-width="0.5"/>
              <line x1="120" y1="200" x2="480" y2="200" stroke="#1C2B3A" stroke-width="0.5"/>
              <line x1="300" y1="40" x2="300" y2="280" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="121" y="41" width="178" height="78" class="el-room" fill="#111827"/>
              <rect x="301" y="41" width="178" height="78" class="el-room" fill="#111827"/>
              <rect x="121" y="121" width="178" height="78" class="el-room" fill="#111827"/>
              <rect x="301" y="121" width="178" height="78" class="el-room" fill="#111827"/>
              <rect x="121" y="201" width="178" height="78" class="el-room" fill="#111827"/>
              <rect x="301" y="201" width="178" height="78" class="el-room" fill="#111827"/>
              <line x1="20" y1="160" x2="120" y2="160" class="el-power" stroke="#00E5FF" stroke-width="2"/>
              <circle cx="210" cy="80" class="el-glow" fill="#00E5FF" opacity="0" r="0"/>
              <circle cx="390" cy="80" class="el-glow" fill="#00E5FF" opacity="0" r="0" style="animation-delay:0.1s;"/>
              <circle cx="210" cy="160" class="el-glow" fill="#00E5FF" opacity="0" r="0" style="animation-delay:0.15s;"/>
              <circle cx="390" cy="160" class="el-glow" fill="#00E5FF" opacity="0" r="0" style="animation-delay:0.2s;"/>
              <circle cx="210" cy="240" class="el-glow" fill="#00E5FF" opacity="0" r="0" style="animation-delay:0.25s;"/>
              <circle cx="390" cy="240" class="el-glow" fill="#00E5FF" opacity="0" r="0" style="animation-delay:0.3s;"/>
              <line x1="200" y1="75" x2="220" y2="75" stroke="#8A9BAE" stroke-width="1" opacity="0.3"/>
              <line x1="380" y1="75" x2="400" y2="75" stroke="#8A9BAE" stroke-width="1" opacity="0.3"/>
              <line x1="200" y1="155" x2="220" y2="155" stroke="#8A9BAE" stroke-width="1" opacity="0.3"/>
              <line x1="380" y1="155" x2="400" y2="155" stroke="#8A9BAE" stroke-width="1" opacity="0.3"/>
              <line x1="200" y1="235" x2="220" y2="235" stroke="#8A9BAE" stroke-width="1" opacity="0.3"/>
              <line x1="380" y1="235" x2="400" y2="235" stroke="#8A9BAE" stroke-width="1" opacity="0.3"/>
              <rect x="480" y="260" width="80" height="24" rx="4" fill="#111827" stroke="#00E5FF" stroke-width="0.5" class="el-badge" opacity="0"/>
              <text x="520" y="276" text-anchor="middle" font-family="Space Mono,monospace" font-size="9" fill="#00E5FF" class="el-badge" opacity="0">90 MIN</text>
              <text x="300" y="300" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#2A3A4A">// EMERGENCY LIGHTING ACTIVATION SEQUENCE</text>
            </svg>
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Emergency Lighting Inverters</h2>
            <p class="text-sm text-ash mb-4">UL924 listed emergency lighting inverters from 27W to 400kW</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Elevator Backup -->
        <a href="/products/category/elevator-backup" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes ev-cabDescent { 0%,35%{transform:translateY(0);} 50%,85%{transform:translateY(120px);} 90%{transform:translateY(120px);} 95%{transform:translateY(0);} }
                @keyframes ev-powerCut { 0%,30%{stroke:#00E5FF;} 35%{stroke:#1C2B3A;} 88%{stroke:#1C2B3A;} 93%{stroke:#00E5FF;} }
                @keyframes ev-backupOn { 0%,36%{fill:#1C2B3A;} 40%{fill:#00E5FF;} 88%{fill:#00E5FF;} 93%{fill:#1C2B3A;} }
                @keyframes ev-doorL { 0%,55%{transform:translateX(0);} 65%,82%{transform:translateX(-18px);} 90%{transform:translateX(0);} }
                @keyframes ev-doorR { 0%,55%{transform:translateX(0);} 65%,82%{transform:translateX(18px);} 90%{transform:translateX(0);} }
                @keyframes ev-text { 0%,65%{opacity:0;} 70%,82%{opacity:1;} 88%{opacity:0;} }
                .ev-cab{animation:ev-cabDescent 8s ease-in-out infinite;}
                .ev-power{animation:ev-powerCut 8s ease-in-out infinite;}
                .ev-backup{animation:ev-backupOn 8s ease-in-out infinite;}
                .ev-doorL{animation:ev-doorL 8s ease-in-out infinite;}
                .ev-doorR{animation:ev-doorR 8s ease-in-out infinite;}
                .ev-safe{animation:ev-text 8s ease-in-out infinite;}
              </style>
              <rect x="220" y="20" width="160" height="280" rx="2" fill="none" stroke="#1C2B3A" stroke-width="1.5"/>
              <line x1="220" y1="76" x2="380" y2="76" stroke="#1C2B3A" stroke-width="0.5" stroke-dasharray="4,4"/>
              <line x1="220" y1="132" x2="380" y2="132" stroke="#1C2B3A" stroke-width="0.5" stroke-dasharray="4,4"/>
              <line x1="220" y1="188" x2="380" y2="188" stroke="#1C2B3A" stroke-width="0.5" stroke-dasharray="4,4"/>
              <line x1="220" y1="244" x2="380" y2="244" stroke="#1C2B3A" stroke-width="0.5" stroke-dasharray="4,4"/>
              <text x="205" y="70" text-anchor="end" font-family="Space Mono,monospace" font-size="8" fill="#8A9BAE">5F</text>
              <text x="205" y="126" text-anchor="end" font-family="Space Mono,monospace" font-size="8" fill="#8A9BAE">4F</text>
              <text x="205" y="182" text-anchor="end" font-family="Space Mono,monospace" font-size="8" fill="#8A9BAE">3F</text>
              <text x="205" y="238" text-anchor="end" font-family="Space Mono,monospace" font-size="8" fill="#8A9BAE">2F</text>
              <text x="205" y="290" text-anchor="end" font-family="Space Mono,monospace" font-size="8" fill="#00E5FF">1F</text>
              <g class="ev-cab">
                <rect x="235" y="100" width="130" height="50" rx="2" fill="#111827" stroke="#8A9BAE" stroke-width="1"/>
                <circle cx="360" cy="110" r="4" class="ev-backup" fill="#1C2B3A"/>
                <rect x="270" y="105" width="28" height="40" rx="1" fill="#1C2B3A" stroke="#8A9BAE" stroke-width="0.5" class="ev-doorL"/>
                <rect x="302" y="105" width="28" height="40" rx="1" fill="#1C2B3A" stroke="#8A9BAE" stroke-width="0.5" class="ev-doorR"/>
              </g>
              <line x1="100" y1="150" x2="220" y2="150" class="ev-power" stroke="#00E5FF" stroke-width="2"/>
              <line x1="300" y1="20" x2="300" y2="100" stroke="#8A9BAE" stroke-width="0.5" opacity="0.3"/>
              <text x="470" y="260" text-anchor="middle" font-family="Space Grotesk,sans-serif" font-size="14" font-weight="700" fill="#00E5FF" class="ev-safe" opacity="0">SAFE</text>
              <text x="470" y="278" text-anchor="middle" font-family="Space Grotesk,sans-serif" font-size="14" font-weight="700" fill="#00E5FF" class="ev-safe" opacity="0">EVACUATION</text>
              <text x="300" y="312" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#2A3A4A">// ELEVATOR EMERGENCY DESCENT SEQUENCE</text>
            </svg>
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Elevator Backup</h2>
            <p class="text-sm text-ash mb-4">UL924 elevator backup systems for safe evacuation</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- UPS Systems -->
        <a href="/products/category/ups-backup" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes ups-utilCut { 0%,25%{stroke:#00E5FF;} 30%{stroke:#1C2B3A;} 85%{stroke:#1C2B3A;} 90%{stroke:#00E5FF;} }
                @keyframes ups-battOn { 0%,28%{stroke:#1C2B3A;fill:none;} 32%{stroke:#00E5FF;fill:#00E5FF10;} 85%{stroke:#00E5FF;fill:#00E5FF10;} 90%{stroke:#1C2B3A;fill:none;} }
                @keyframes ups-led1 { 0%,100%{opacity:0.3;} 50%{opacity:1;} }
                @keyframes ups-text { 0%,32%{opacity:0;} 36%,82%{opacity:1;} 88%{opacity:0;} }
                @keyframes ups-drain { 0%,30%{width:80px;} 85%{width:20px;} 90%{width:80px;} }
                .ups-util{animation:ups-utilCut 7s ease-in-out infinite;}
                .ups-batt{animation:ups-battOn 7s ease-in-out infinite;}
                .ups-led{animation:ups-led1 1s ease-in-out infinite;}
                .ups-txt{animation:ups-text 7s ease-in-out infinite;}
                .ups-bar{animation:ups-drain 7s ease-in-out infinite;}
              </style>
              <line x1="40" y1="120" x2="160" y2="120" class="ups-util" stroke="#00E5FF" stroke-width="2"/>
              <text x="40" y="110" font-family="Space Mono,monospace" font-size="8" fill="#8A9BAE">UTILITY</text>
              <rect x="160" y="80" width="120" height="100" rx="6" class="ups-batt" fill="none" stroke="#1C2B3A" stroke-width="1.5"/>
              <text x="220" y="120" text-anchor="middle" font-family="Space Grotesk,sans-serif" font-size="10" font-weight="700" fill="#F8FAFC">UPS</text>
              <text x="220" y="136" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#8A9BAE">ONLINE POWER</text>
              <rect x="180" y="155" width="80" height="8" rx="2" fill="#00E5FF" opacity="0.3" class="ups-bar"/>
              <rect x="180" y="155" width="80" height="8" rx="2" fill="none" stroke="#1C2B3A" stroke-width="0.5"/>
              <line x1="280" y1="120" x2="380" y2="120" stroke="#00E5FF" stroke-width="2"/>
              <rect x="380" y="40" width="140" height="220" rx="4" fill="#111827" stroke="#1C2B3A" stroke-width="1.5"/>
              <rect x="392" y="55" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="85" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="115" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="145" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="175" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="205" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <circle cx="500" cy="66" r="2" fill="#00E5FF" class="ups-led"/>
              <circle cx="500" cy="96" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:0.2s;"/>
              <circle cx="500" cy="126" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:0.4s;"/>
              <circle cx="500" cy="156" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:0.6s;"/>
              <circle cx="500" cy="186" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:0.8s;"/>
              <circle cx="500" cy="216" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:1.0s;"/>
              <text x="330" y="90" text-anchor="middle" font-family="Space Mono,monospace" font-size="10" fill="#00E5FF" class="ups-txt" opacity="0">&lt;4ms</text>
              <text x="330" y="104" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#8A9BAE" class="ups-txt" opacity="0">TRANSFER</text>
              <text x="300" y="300" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#2A3A4A">// ZERO INTERRUPTION POWER TRANSFER</text>
            </svg>
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">UPS Systems</h2>
            <p class="text-sm text-ash mb-4">UL1778 uninterruptible power supply systems</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Fire Alarm Backup -->
        <a href="/products/category/fire-alarm-backup" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes fa-detect { 0%,25%{r:4;fill:#8A9BAE;} 30%{r:8;fill:#FF3B3B;} 85%{r:4;fill:#FF3B3B;} 90%{r:4;fill:#8A9BAE;} }
                @keyframes fa-pulse { 0%,28%{opacity:0;r:8;} 32%{opacity:0.6;r:20;} 40%{opacity:0;r:30;} 100%{opacity:0;} }
                @keyframes fa-horn { 0%,32%{opacity:0.2;} 35%{opacity:1;} 35.5%{opacity:0.2;} 36%{opacity:1;} 36.5%{opacity:0.2;} 37%{opacity:1;} 85%{opacity:1;} 90%{opacity:0.2;} }
                @keyframes fa-panel { 0%,30%{stroke:#1C2B3A;} 33%{stroke:#00E5FF;} 85%{stroke:#00E5FF;} 90%{stroke:#1C2B3A;} }
                @keyframes fa-backup { 0%,34%{opacity:0;} 38%,85%{opacity:1;} 90%{opacity:0;} }
                .fa-det{animation:fa-detect 7s ease-in-out infinite;}
                .fa-pulse{animation:fa-pulse 7s ease-in-out infinite;}
                .fa-horn{animation:fa-horn 7s ease-in-out infinite;}
                .fa-panel{animation:fa-panel 7s ease-in-out infinite;}
                .fa-bk{animation:fa-backup 7s ease-in-out infinite;}
              </style>
              <rect x="100" y="40" width="400" height="220" rx="4" fill="none" stroke="#1C2B3A" stroke-width="1.5"/>
              <line x1="300" y1="40" x2="300" y2="180" stroke="#1C2B3A" stroke-width="0.5"/>
              <line x1="100" y1="180" x2="500" y2="180" stroke="#1C2B3A" stroke-width="0.5"/>
              <circle cx="160" cy="80" r="4" class="fa-det" fill="#8A9BAE"/>
              <circle cx="440" cy="80" r="4" fill="#8A9BAE" opacity="0.5"/>
              <circle cx="160" cy="220" r="4" fill="#8A9BAE" opacity="0.5"/>
              <circle cx="440" cy="220" r="4" fill="#8A9BAE" opacity="0.5"/>
              <circle cx="160" cy="80" class="fa-pulse" fill="#FF3B3B" opacity="0" r="8"/>
              <path d="M152 72 Q156 68 160 72 Q164 68 168 72" stroke="#8A9BAE" stroke-width="0.5" fill="none" opacity="0.4"/>
              <path d="M152 68 Q156 64 160 68 Q164 64 168 68" stroke="#8A9BAE" stroke-width="0.5" fill="none" opacity="0.3"/>
              <rect x="105" y="100" width="40" height="60" rx="3" class="fa-panel" fill="#111827" stroke="#1C2B3A" stroke-width="1"/>
              <text x="125" y="126" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#8A9BAE">FACP</text>
              <text x="125" y="136" text-anchor="middle" font-family="Space Mono,monospace" font-size="5" fill="#8A9BAE">PANEL</text>
              <rect x="230" y="42" width="12" height="8" rx="1" fill="#FF3B3B" class="fa-horn" opacity="0.2"/>
              <rect x="370" y="42" width="12" height="8" rx="1" fill="#FF3B3B" class="fa-horn" opacity="0.2" style="animation-delay:0.15s;"/>
              <rect x="230" y="252" width="12" height="8" rx="1" fill="#FF3B3B" class="fa-horn" opacity="0.2" style="animation-delay:0.1s;"/>
              <rect x="370" y="252" width="12" height="8" rx="1" fill="#FF3B3B" class="fa-horn" opacity="0.2" style="animation-delay:0.2s;"/>
              <rect x="105" y="170" width="40" height="24" rx="2" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <circle cx="140" cy="182" r="3" fill="#00E5FF" class="fa-bk" opacity="0"/>
              <text x="300" y="300" text-anchor="middle" font-family="Space Mono,monospace" font-size="9" fill="#00E5FF" class="fa-bk" opacity="0">BACKUP ACTIVE</text>
              <text x="300" y="312" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#2A3A4A">// UL1481 FIRE ALARM BACKUP SEQUENCE</text>
            </svg>
          </div>
          <div class="p-6">
            <h2 class="font-display text-lg font-semibold text-pure mb-2 group-hover:text-voltage transition-colors">Fire Alarm Backup</h2>
            <p class="text-sm text-ash mb-4">UL1481 fire alarm notification appliance circuit backup</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>

        <!-- Medical Grade -->
        <a href="/products/category/medical-grade" class="card-glow card-top-accent bg-obsidian rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-[#0A0A0F] overflow-hidden" style="pointer-events:none;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes med-heart { 0%{stroke-dashoffset:200;} 100%{stroke-dashoffset:0;} }
                @keyframes med-badge1 { 0%,20%{opacity:0;} 25%,100%{opacity:1;} }
                @keyframes med-badge2 { 0%,35%{opacity:0;} 40%,100%{opacity:1;} }
                @keyframes med-badge3 { 0%,50%{opacity:0;} 55%,100%{opacity:1;} }
                .med-wave{stroke-dasharray:200;animation:med-heart 2s linear infinite;}
                .med-b1{animation:med-badge1 6s ease-in-out infinite;}
                .med-b2{animation:med-badge2 6s ease-in-out infinite;}
                .med-b3{animation:med-badge3 6s ease-in-out infinite;}
              </style>
              <rect x="140" y="30" width="380" height="230" rx="4" fill="none" stroke="#1C2B3A" stroke-width="1"/>
              <text x="150" y="25" font-family="Space Mono,monospace" font-size="7" fill="#8A9BAE">ISOLATION ROOM</text>
              <rect x="360" y="60" width="120" height="80" rx="4" fill="#111827" stroke="#1C2B3A" stroke-width="1"/>
