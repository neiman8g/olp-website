    ['Lamp Compatibility', 'LED and Fluorescent'],
    ['Dimming', 'Supported'],
    ['Certifications', 'UL 924'],
    ['Warranty', '2 years parts and labor'],
  ],
  'elevate': [
    ['Input Voltage', '120/208/240/277/480 VAC'],
    ['Output Voltage', 'Matches input'],
    ['Power Range', '24kW – 240kW'],
    ['Phases', 'Three Phase'],
    ['Transfer Time', '<4ms'],
    ['Waveform', 'Pure Sine Wave'],
    ['Application', 'Elevator Emergency Backup'],
    ['Battery Type', 'Sealed VRLA'],
    ['Battery Runtime', 'Per code requirements'],
    ['Certifications', 'UL 924, NFPA 101, NEC Article 700'],
    ['Warranty', '2 years parts and labor'],
  ],
  'fire-alarm-backup': [
    ['Input Voltage', '120/240 VAC'],
    ['Output Voltage', '24VDC / 120VAC'],
    ['Range', 'Per system design'],
    ['Transfer Time', '<10ms'],
    ['Battery Type', 'Sealed VRLA'],
    ['Battery Runtime', '24–60 hours'],
    ['Self-Testing', 'Automatic'],
    ['Certifications', 'UL 1481, NFPA 72, NEC Article 760'],
    ['Warranty', '2 years parts and labor'],
  ],
  'lcr20': [
    ['Input Voltage', '120/208/240/277/480 VAC'],
    ['Control Voltage', '120VAC'],
    ['Contact Rating', '30A'],
    ['Poles', 'Single or Multi-pole'],
    ['Dimmer Override', '0-10V DC for full emergency illumination'],
    ['Test Switch', 'Quick-connect IP65 rated'],
    ['Enclosure', 'Aluminum, NEMA 1'],
    ['Certifications', 'UL 924, NFPA 101, NEC Article 700'],
    ['Warranty', '5 years'],
  ],
  'host-power': [
    ['Input Voltage', '208/480 VAC'],
    ['Output Voltage', 'Matches input'],
    ['Power Range', '10kVA – 500kVA'],
