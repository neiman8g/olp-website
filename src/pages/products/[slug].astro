    ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
    ['Enclosure', 'NEMA 1 standard'],
    ['Certifications', 'UL 924, UL 1778, UL 1489, NFPA 101'],
    ['Warranty', '2 years parts and labor'],
  ],
  'power-wave-4': [
    ['Input Voltage', '120/208/240/277/480 VAC'],
    ['Output Voltage', 'Matches input (field selectable)'],
    ['Power Range', '8kW – 400kW'],
    ['Phases', 'Three Phase'],
    ['Transfer Time', '<4ms (Green Mode) / Zero (Double Conversion)'],
    ['Waveform', 'Pure Sine Wave (<3% THD)'],
    ['Efficiency', '>95% at full load'],
    ['Battery Type', 'Sealed VRLA'],
    ['Battery Runtime', '90–120 minutes'],
    ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
    ['Enclosure', 'NEMA 1 standard'],
    ['Certifications', 'UL 924, UL 1778, NFPA 101'],
    ['Warranty', '2 years parts and labor'],
  ],
  'mini-power-wave': [
    ['Input Voltage', '120/208/240/277 VAC'],
    ['Output Voltage', 'Matches input'],
    ['Power Range', '500W – 2.7kW'],
    ['Phases', 'Single Phase'],
    ['Transfer Time', '<4ms'],
    ['Waveform', 'Pure Sine Wave'],
    ['Efficiency', '>92%'],
    ['Battery Type', 'Sealed VRLA (internal)'],
    ['Battery Runtime', '90–120 minutes'],
    ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
    ['Enclosure', 'NEMA 1 all-in-one'],
    ['Certifications', 'UL 924, UL 1778'],
    ['Warranty', '2 years parts and labor'],
  ],
  'micro-power-wave': [
    ['Input Voltage', '120/208/240/277 VAC'],
    ['Output Voltage', 'Matches input'],
    ['Power Range', '200W – 490W'],
    ['Phases', 'Single Phase'],
