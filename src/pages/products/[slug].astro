  'elevate': [
    ['Input Voltage', '120/208/240/277/480 VAC'],
    ['Output Voltage', 'Matches input'],
    ['Power Range', '24kW – 240kW'],
    ['Phases', 'Three Phase'],
    ['Transfer Time', '<4ms'],
    ['Waveform', 'Pure Sine Wave'],
    ['Application', 'Elevator Emergency Backup'],
