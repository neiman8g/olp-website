---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import DocumentGate from '../../components/DocumentGate.astro';
import { products, getProductsByCategory, getCategoryBySlug } from '../../data/products';
import { company } from '../../data/company';
import type { Product } from '../../data/products';
import { getProductImage } from '../../utils/images';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };
const category = getCategoryBySlug(product.category);
const relatedProducts = getProductsByCategory(product.category).filter(p => p.slug !== product.slug).slice(0, 3);

// Pull a power-range callout out of the tagline ("Three Phase, 8 – 50kW" → "8 – 50kW")
function extractPowerSpec(tagline: string): string | null {
  const m = tagline.match(/[\d.]+\s*(W|kW|kVA|VA)?\s*[–-]\s*[\d.]+\s*(W|kW|kVA|VA|Hz)/i);
  return m ? m[0].replace(/\s+/g, ' ').trim() : null;
}
const powerCallout = extractPowerSpec(product.tagline);
const phaseCallout = product.tagline.match(/Three Phase|Single Phase/i)?.[0] || null;

// Per-category scene vocabulary — color, environment label, accent
const sceneByCategory: Record<string, { env: string; tone: string; accent: string }> = {
  'emergency-lighting':    { env: 'Egress corridor',   tone: 'warm',    accent: '#7EB3F5' },
  'elevator-backup':       { env: 'Elevator lobby',    tone: 'cool',    accent: '#7EB3F5' },
  'fire-alarm-backup':     { env: 'Riser closet',      tone: 'amber',   accent: '#FFB86B' },
  'ups-backup':            { env: 'Data center aisle', tone: 'cool',    accent: '#7EB3F5' },
  'medical-grade':         { env: 'Imaging suite',     tone: 'clinical',accent: '#A8E6F0' },
  'voltage-regulators':    { env: 'Plant electrical',  tone: 'cool',    accent: '#7EB3F5' },
  'isolation-transformers':{ env: 'Power room',        tone: 'cool',    accent: '#7EB3F5' },
  'frequency-converters':  { env: 'Test bay',          tone: 'cool',    accent: '#A8E6F0' },
  'power-distribution':    { env: 'Distribution room', tone: 'cool',    accent: '#7EB3F5' },
  'monitoring':            { env: 'NOC / Ops floor',   tone: 'cool',    accent: '#7EB3F5' },
  'load-control-relays':   { env: 'Lighting controls', tone: 'warm',    accent: '#FFD98A' },
  'custom-oem':            { env: 'Engineering bay',   tone: 'cool',    accent: '#7EB3F5' },
};
const scene = sceneByCategory[product.category] || { env: 'On site', tone: 'cool', accent: '#7EB3F5' };
---

<BaseLayout
  title={`${product.name} | ${product.tagline} | Online Power`}
  description={product.description}
  ogImage={product.image}
  product={{ name: product.name, description: product.description, image: product.image, category: product.category }}
  breadcrumbs={[
    { name: 'Home', url: 'https://www.onlinepower.com/' },
    { name: 'Products', url: 'https://www.onlinepower.com/products/' },
    ...(category ? [{ name: category.name, url: `https://www.onlinepower.com/products/category/${category.slug}` }] : []),
    { name: product.name, url: `https://www.onlinepower.com/products/${product.slug}` },
  ]}
>

  <!-- BREADCRUMB STRIP -->
  <section class="bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
      <nav class="text-[13px] font-display text-slate">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-steel-blue transition-colors">Products</a>
        <span class="mx-2">/</span>
        {category && (
          <>
            <a href={`/products/category/${category.slug}`} class="hover:text-steel-blue transition-colors">{category.name}</a>
            <span class="mx-2">/</span>
          </>
        )}
        <span class="text-near-black font-semibold">{product.name}</span>
      </nav>
    </div>
  </section>

  <!-- ========== HERO — dark with depth ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute -top-32 -right-32 w-[560px] h-[560px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.3) 0%, rgba(37,103,194,0) 70%); filter: blur(12px);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="grid lg:grid-cols-11 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-6">
          <div class="flex flex-wrap gap-2 mb-5">
            {product.standards.slice(0, 3).map(std => (
              <span class="badge-dark">{std}</span>
            ))}
            <span class="badge-dark">Made in USA</span>
          </div>
          <h1 class="font-display text-4xl md:text-5xl lg:text-[56px] font-extrabold tracking-tight text-white leading-[1.05] mb-3">{product.name}</h1>
          <p class="font-display font-semibold text-[15px] text-sky-blue uppercase tracking-[0.08em] mb-6">{product.tagline}</p>
          <p class="text-lg text-muted-blue leading-relaxed max-w-xl mb-8">{product.description}</p>
          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <Button href="/contact/" size="lg" icon="arrow-right">Request a Quote</Button>
            <Button href="#documents" variant="ghost" size="lg" icon="arrow-down">Data Sheet</Button>
          </div>
          <p class="font-display text-[13px] text-muted-blue">Responds within 2 business hours</p>
        </div>
        <div class="lg:col-span-5">
          <!-- =============================================== -->
          <!-- PRODUCT SCENE — environmental, on-site context -->
          <!-- =============================================== -->
          <div class="product-stage relative group" style="perspective: 1600px;">

            <!-- Layered ambient backdrop: conic aurora + soft radial glow -->
            <div class="absolute -inset-14 pointer-events-none">
              <div class="absolute inset-0 product-halo opacity-[0.65]" style="background: conic-gradient(from 200deg at 50% 50%, rgba(37,103,194,0) 0deg, rgba(126,179,245,0.40) 80deg, rgba(37,103,194,0.55) 180deg, rgba(126,179,245,0.40) 280deg, rgba(37,103,194,0) 360deg); filter: blur(56px);"></div>
              <div class="absolute inset-0" style="background: radial-gradient(circle at 50% 42%, rgba(126,179,245,0.40) 0%, transparent 55%); filter: blur(32px);"></div>
            </div>

            <!-- LEFT floating chip (desktop only) -->
            {powerCallout && (
              <div class="hidden lg:block absolute -left-5 top-[28%] z-30 pointer-events-none product-chip-left">
                <div class="px-3.5 py-2 rounded-lg bg-deep-navy/85 backdrop-blur-md border border-sky-blue/30 shadow-[0_20px_40px_-12px_rgba(37,103,194,0.6)]">
                  <p class="text-[9px] uppercase tracking-[0.14em] text-sky-blue font-display font-bold mb-0.5">Output</p>
                  <p class="text-[13px] font-display font-bold text-white whitespace-nowrap leading-none">{powerCallout}</p>
                </div>
                <!-- Connector dash + dot pointing toward product -->
                <div class="absolute top-1/2 left-full w-8 h-px bg-gradient-to-r from-sky-blue/60 to-transparent"></div>
                <div class="absolute top-1/2 left-[calc(100%+8px)] w-1.5 h-1.5 -translate-y-1/2 rounded-full bg-sky-blue shadow-[0_0_8px_rgba(126,179,245,0.8)]"></div>
              </div>
            )}

            <!-- RIGHT floating chip (desktop only) -->
            <div class="hidden lg:block absolute -right-5 bottom-[26%] z-30 pointer-events-none product-chip-right">
              <div class="px-3.5 py-2 rounded-lg bg-deep-navy/85 backdrop-blur-md border border-sky-blue/30 shadow-[0_20px_40px_-12px_rgba(37,103,194,0.6)]">
                <p class="text-[9px] uppercase tracking-[0.14em] text-sky-blue font-display font-bold mb-0.5">{phaseCallout ? 'Phase' : 'Origin'}</p>
                <p class="text-[13px] font-display font-bold text-white whitespace-nowrap leading-none">{phaseCallout || 'Made in USA'}</p>
              </div>
              <div class="absolute top-1/2 right-full w-8 h-px bg-gradient-to-l from-sky-blue/60 to-transparent"></div>
              <div class="absolute top-1/2 right-[calc(100%+8px)] w-1.5 h-1.5 -translate-y-1/2 rounded-full bg-sky-blue shadow-[0_0_8px_rgba(126,179,245,0.8)]"></div>
            </div>

            <!-- TILTING SCENE — 3D perspective transform on mousemove -->
            <div class="product-tilt relative rounded-2xl p-px bg-gradient-to-br from-steel-blue/60 via-sky-blue/30 to-navy-mid/70 transition-transform duration-300 ease-out" style="transform-style: preserve-3d; will-change: transform;">
              <div class="relative rounded-[15px] overflow-hidden border border-white/[0.08] shadow-[0_40px_80px_-20px_rgba(0,0,0,0.75)]" style="background: linear-gradient(180deg, #050d1c 0%, #0a1f3a 40%, #061427 100%); transform-style: preserve-3d;">

                <!-- ENVIRONMENT LAYER 1: Distant rack wall (deep perspective) -->
                <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
                  <!-- Far wall: repeated rectangle "rack" silhouettes -->
                  <div class="absolute inset-x-0 top-[8%] h-[55%]" style="background-image: repeating-linear-gradient(90deg, rgba(126,179,245,0.04) 0px, rgba(126,179,245,0.04) 14px, rgba(255,255,255,0.012) 14px, rgba(255,255,255,0.012) 70px, rgba(126,179,245,0.04) 70px, rgba(126,179,245,0.04) 84px, transparent 84px, transparent 110px); background-size: 110px 100%; opacity: 0.5; mask-image: radial-gradient(ellipse 90% 70% at 50% 40%, black 40%, transparent 85%); -webkit-mask-image: radial-gradient(ellipse 90% 70% at 50% 40%, black 40%, transparent 85%);"></div>

                  <!-- Server-room vanishing-point lines — left wall -->
                  <div class="absolute left-0 top-0 bottom-0 w-1/2" style="background: linear-gradient(105deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 18%, transparent 22%, transparent 100%);"></div>
                  <!-- Right wall -->
                  <div class="absolute right-0 top-0 bottom-0 w-1/2" style="background: linear-gradient(255deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 18%, transparent 22%, transparent 100%);"></div>
                </div>

                <!-- ENVIRONMENT LAYER 2: Ceiling spotlights (volumetric cones) -->
                <div class="absolute inset-x-0 top-0 h-[60%] pointer-events-none scene-lighting" aria-hidden="true">
                  <!-- Center spotlight cone (key light) -->
                  <div class="absolute left-1/2 -translate-x-1/2 top-0 w-[80%] h-full" style={`background: radial-gradient(ellipse 50% 80% at 50% 0%, ${scene.accent}40 0%, ${scene.accent}18 30%, transparent 65%);`}></div>
                  <!-- Side spot 1 (fill light L) -->
                  <div class="absolute left-[10%] top-0 w-[40%] h-[70%]" style={`background: radial-gradient(ellipse 60% 70% at 30% 0%, ${scene.accent}1F 0%, transparent 55%);`}></div>
                  <!-- Side spot 2 (fill light R) -->
                  <div class="absolute right-[10%] top-0 w-[40%] h-[70%]" style={`background: radial-gradient(ellipse 60% 70% at 70% 0%, ${scene.accent}1F 0%, transparent 55%);`}></div>
                </div>

                <!-- ENVIRONMENT LAYER 3: 3D perspective floor -->
                <div class="absolute inset-x-0 bottom-0 h-[40%] pointer-events-none overflow-hidden" aria-hidden="true">
                  <div class="absolute inset-0" style="transform: perspective(800px) rotateX(62deg); transform-origin: bottom; background-image: linear-gradient(rgba(126,179,245,0.10) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,0.10) 1px, transparent 1px); background-size: 38px 38px; mask-image: linear-gradient(180deg, transparent 0%, black 40%, black 100%); -webkit-mask-image: linear-gradient(180deg, transparent 0%, black 40%, black 100%);"></div>
                  <!-- Floor color wash -->
                  <div class="absolute inset-0" style={`background: linear-gradient(180deg, transparent 0%, rgba(5,13,28,0.4) 50%, rgba(5,13,28,0.85) 100%);`}></div>
                  <!-- Floor accent reflection from spotlight -->
                  <div class="absolute inset-x-1/4 bottom-0 h-full" style={`background: radial-gradient(ellipse 60% 30% at 50% 0%, ${scene.accent}20 0%, transparent 70%);`}></div>
                </div>

                <!-- ENVIRONMENT LAYER 4: Atmospheric haze / depth fog -->
                <div class="absolute inset-x-0 top-1/3 h-2/3 pointer-events-none" aria-hidden="true" style={`background: linear-gradient(180deg, transparent 0%, rgba(5,13,28,0.25) 50%, rgba(5,13,28,0.6) 100%); mix-blend-mode: multiply;`}></div>

                <!-- ENVIRONMENT LAYER 5: Animated scanning beam -->
                <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
                  <div class="absolute -inset-y-8 w-[35%] product-scan" style={`background: linear-gradient(110deg, transparent 30%, ${scene.accent}1A 50%, transparent 70%); filter: blur(3px);`}></div>
                </div>

                <!-- Scene label — environment tag (top-left) -->
                <div class="absolute top-4 left-4 z-20 pointer-events-none">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-black/40 backdrop-blur-md border border-white/10 text-[10px] font-display font-bold uppercase tracking-[0.12em] text-white/90">
                    <span class="w-1.5 h-1.5 rounded-full animate-pulse" style={`background-color: ${scene.accent}; box-shadow: 0 0 6px ${scene.accent};`}></span>
                    {scene.env}
                  </span>
                </div>

                <!-- Standards chip (top-right) -->
                {product.standards[0] && (
                  <div class="absolute top-4 right-4 z-20 pointer-events-none">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-black/40 backdrop-blur-md border border-white/10 text-[10px] font-display font-bold uppercase tracking-[0.1em] text-white/90">
                      {product.standards[0]}
                    </span>
                  </div>
                )}

                <!-- Top edge hairline -->
                <div class="absolute top-0 inset-x-12 h-px bg-gradient-to-r from-transparent via-white/30 to-transparent pointer-events-none"></div>

                <!-- ============================================ -->
                <!-- PRODUCT + REFLECTION inside the scene -->
                <!-- ============================================ -->
                <div class="relative flex flex-col items-center justify-end px-6 sm:px-10 pt-10 sm:pt-16 pb-6 min-h-[460px] sm:min-h-[560px]">
                  <!-- Volumetric light cone TIGHTLY behind product (warmer near, cooler far) -->
                  <div class="absolute left-1/2 top-[12%] -translate-x-1/2 w-[70%] h-[75%] pointer-events-none" style={`background: radial-gradient(ellipse 50% 65% at 50% 30%, ${scene.accent}28 0%, ${scene.accent}10 40%, transparent 70%); filter: blur(8px);`} aria-hidden="true"></div>

                  <!-- Main product (floating, key-lit) -->
                  <div class="relative z-10 product-float w-full">
                    {typeof getProductImage(product.image) === 'string' ? (
                      <img
                        src={product.image}
                        alt={`${product.name} by Online Power, shown in a ${scene.env.toLowerCase()} environment`}
                        class="w-full h-auto object-contain max-h-[440px] mx-auto drop-shadow-[0_40px_60px_rgba(0,0,0,0.7)] group-hover:scale-[1.04] transition-transform duration-500 ease-out"
                        loading="eager"
                      />
                    ) : (
                      <Image
                        src={getProductImage(product.image) as ImageMetadata}
                        alt={`${product.name} by Online Power, shown in a ${scene.env.toLowerCase()} environment`}
                        class="w-full h-auto object-contain max-h-[440px] mx-auto drop-shadow-[0_40px_60px_rgba(0,0,0,0.7)] group-hover:scale-[1.04] transition-transform duration-500 ease-out"
                        loading="eager"
                        format="webp"
                        quality={92}
                        widths={[480, 720, 960]}
                        sizes="(max-width: 768px) 100vw, 45vw"
                      />
                    )}

                    <!-- Reflection on the polished floor — flipped image, masked, color-graded -->
                    <div class="absolute left-0 right-0 top-full h-[55%] overflow-hidden pointer-events-none" aria-hidden="true" style="mask-image: linear-gradient(180deg, rgba(0,0,0,0.36) 0%, rgba(0,0,0,0.08) 35%, transparent 70%); -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.36) 0%, rgba(0,0,0,0.08) 35%, transparent 70%); transform: scaleY(-1); transform-origin: top; filter: blur(0.6px);">
                      {typeof getProductImage(product.image) === 'string' ? (
                        <img src={product.image} alt="" class="w-full h-auto object-contain max-h-[440px] mx-auto" loading="lazy" />
                      ) : (
                        <Image src={getProductImage(product.image) as ImageMetadata} alt="" class="w-full h-auto object-contain max-h-[440px] mx-auto" loading="lazy" format="webp" quality={70} widths={[300, 480]} sizes="45vw" />
                      )}
                    </div>
                  </div>

                  <!-- Hard-edged ground shadow directly beneath product -->
                  <div class="absolute bottom-5 left-1/2 -translate-x-1/2 w-3/5 h-3 rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.35) 50%, transparent 75%); filter: blur(6px);"></div>
                  <!-- Soft outer shadow ring -->
                  <div class="absolute bottom-3 left-1/2 -translate-x-1/2 w-3/4 h-8 rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(0,0,0,0.4) 0%, transparent 75%); filter: blur(12px);"></div>
                </div>

                <!-- Bottom vignette -->
                <div class="absolute bottom-0 inset-x-0 h-1/4 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, rgba(5,13,28,0.5) 60%, rgba(5,13,28,0.95) 100%);"></div>

              </div>
            </div>
          </div>

          <!-- Certification chips bar -->
          <div class="flex items-center justify-center flex-wrap gap-2 mt-6">
            {product.standards.slice(0, 4).map(std => (
              <span class="badge-dark text-[11px]">{std}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Documents — moved above Overview per single-page flow -->
  <section id="documents" class="py-10 md:py-14 bg-off-white scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-4">Documents &amp; Downloads</p>
      <h2 class="font-display text-3xl font-extrabold tracking-tight text-near-black mb-3 leading-[1.1]">Data sheets, specs, drawings.</h2>
      <p class="text-[15px] text-slate max-w-2xl mb-8">Every specification — voltage, runtime, dimensions, wiring — lives in the data sheet. Instant download on most; submittal and CAD packages delivered after a brief registration.</p>
      <DocumentGate productSlug={product.slug} />
    </div>
  </section>

  <!-- Use Cases — where it gets specified -->
  {product.useCases && product.useCases.length > 0 && (
    <section class="py-10 md:py-14 bg-white border-t border-steel-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <p class="eyebrow text-steel-blue mb-4">Use Cases</p>
        <h2 class="font-display text-3xl font-extrabold tracking-tight text-near-black mb-6 leading-[1.1]">Where it gets specified.</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-3">
          {product.useCases.map(useCase => (
            <div class="flex items-start gap-3 bg-off-white border border-steel-gray rounded-lg p-4">
              <svg class="w-5 h-5 text-steel-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
              <span class="text-sm text-near-black leading-snug">{useCase}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Advantages — why this product -->
  {product.advantages && product.advantages.length > 0 && (
    <section class="py-10 md:py-14 bg-off-white border-t border-steel-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <p class="eyebrow text-steel-blue mb-4">Advantages</p>
        <h2 class="font-display text-3xl font-extrabold tracking-tight text-near-black mb-3 leading-[1.1]">Why {product.name}.</h2>
        <p class="text-[15px] text-slate max-w-2xl mb-8">The design choices that make the difference on a real jobsite — in code review, in commissioning, and in the years after it is installed.</p>
        <div class="grid md:grid-cols-2 gap-5">
          {product.advantages.map(adv => (
            <div class="bg-white border border-steel-gray rounded-xl p-6 hover:border-steel-blue/50 transition-colors">
              <div class="flex items-start gap-3 mb-2">
                <div class="w-8 h-8 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h3 class="font-display text-lg font-bold text-near-black leading-snug">{adv.title}</h3>
              </div>
              <p class="text-[15px] text-slate leading-relaxed pl-11">{adv.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <section class="py-10 md:py-14 bg-deep-navy">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <p class="eyebrow text-steel-blue mb-8">Related Products</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedProducts.map(rp => (
            <a href={`/products/${rp.slug}`} class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
              <div class="h-[180px] bg-off-white flex items-center justify-center p-4">
                {typeof getProductImage(rp.image) === 'string' ? (
                  <img src={rp.image} alt={`${rp.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" />
                ) : (
                  <Image src={getProductImage(rp.image) as ImageMetadata} alt={`${rp.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
                )}
              </div>
              <div class="p-6">
                <h3 class="font-display text-2xl font-semibold text-near-black mb-1 group-hover:text-steel-blue transition-colors">{rp.name}</h3>
                <p class="font-display text-sm text-slate mb-3">{rp.tagline}</p>
                <p class="text-base text-slate mb-4 line-clamp-2">{rp.description}</p>
                <span class="text-[15px] font-medium text-steel-blue">View Product &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-white mb-4">Need Help With {product.name}?</h2>
      <p class="text-muted-blue mb-6">Register for training, request a quote, or call our engineering team.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/training/" class="px-8 py-3.5 bg-steel-blue text-white font-semibold rounded hover:bg-steel-blue/90 transition-colors text-sm">Register for Training</a>
        <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded hover:bg-white/10 transition-colors text-sm font-display font-semibold">{company.phone}</a>
      </div>
    </div>
  </section>

  <!-- Mobile Sticky CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-deep-navy/95 backdrop-blur border-t border-steel-gray p-3 z-40 lg:hidden" id="product-mobile-cta" style="display:none;padding-bottom:max(12px, env(safe-area-inset-bottom));">
    <Button href="/contact/" size="lg" icon="bolt" fullWidth>Request a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
  // Mobile sticky CTA - show after scrolling 300px
  var cta = document.getElementById('product-mobile-cta');
  if (cta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      cta.style.display = window.scrollY > 300 ? '' : 'none';
    });
  }

  // 3D mouse-tracked tilt on the product stage (skipped if reduced motion)
  (function () {
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var stage = document.querySelector('.product-stage');
    if (!stage || window.innerWidth < 1024) return;
    var tilt = stage.querySelector('.product-tilt');
    if (!tilt) return;
    var raf = 0;
    stage.addEventListener('mousemove', function (e) {
      if (raf) return;
      raf = requestAnimationFrame(function () {
        var r = stage.getBoundingClientRect();
        var x = (e.clientX - r.left) / r.width - 0.5;
        var y = (e.clientY - r.top) / r.height - 0.5;
        tilt.style.transform = 'rotateY(' + (x * 7).toFixed(2) + 'deg) rotateX(' + (-y * 7).toFixed(2) + 'deg)';
        raf = 0;
      });
    });
    stage.addEventListener('mouseleave', function () {
      tilt.style.transform = '';
    });
  })();
</script>
