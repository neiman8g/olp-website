---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocumentGate from '../../components/DocumentGate.astro';
import { products, getProductsByCategory, getCategoryBySlug } from '../../data/products';
import { company } from '../../data/company';
import type { Product } from '../../data/products';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };
const category = getCategoryBySlug(product.category);
const relatedProducts = getProductsByCategory(product.category).filter(p => p.slug !== product.slug).slice(0, 3);

// Spec tables per product (Issue 4)
const specTables: Record<string, [string, string][]> = {
