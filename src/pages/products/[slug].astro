---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocumentGate from '../../components/DocumentGate.astro';
import { products, getProductsByCategory, getCategoryBySlug } from '../../data/products';
import { company } from '../../data/company';
import type { Product } from '../../data/products';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };
const category = getCategoryBySlug(product.category);
const relatedProducts = getProductsByCategory(product.category).filter(p => p.slug !== product.slug).slice(0, 3);
---

<BaseLayout
  title={`${product.name} | ${product.tagline} | Online Power`}
  description={product.description}
>

  <!-- Breadcrumb + Hero -->
  <section class="py-16 md:py-24 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-6">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-voltage transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        {category && (
          <>
            <a href={`/products/category/${category.slug}`} class="hover:text-voltage transition-colors">{category.name}</a>
            <span class="mx-2 text-steel">/</span>
          </>
        )}
        <span class="text-voltage">{product.name}</span>
      </nav>

      <div class="grid lg:grid-cols-11 gap-8 lg:gap-12 items-start">
        <!-- Left: 55% -->
        <div class="lg:col-span-6">
          <div class="flex flex-wrap gap-2 mb-4">
            {product.standards.slice(0, 3).map(std => (
              <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">{std}</span>
            ))}
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">Made in USA</span>
          </div>
          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-pure leading-tight mb-2">{product.name}</h1>
          <p class="font-mono text-sm text-voltage mb-6">{product.tagline}</p>
          <p class="text-lg text-ash leading-relaxed mb-8">{product.description}</p>
          <div class="flex flex-wrap gap-3 mb-4">
            <a href="/contact/" class="btn-primary px-6 py-3.5 rounded-lg text-sm font-semibold inline-flex items-center gap-2">
              Request a Quote
            </a>
            <a href="/training/" class="btn-ghost px-6 py-3.5 rounded-lg text-sm inline-flex items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              Get Training
            </a>
          </div>
          <p class="font-mono text-xs text-ash">// Responds within 2 business hours</p>
        </div>
        <!-- Right: 45% -->
        <div class="lg:col-span-5">
          <div class="bg-bg-elevated border border-voltage/20 rounded-xl p-6 flex items-center justify-center min-h-[320px]">
            <img src={product.image} alt={`${product.name} by Online Power`} class="w-full h-auto object-contain max-h-[420px] mx-auto hover:scale-[1.03] transition-transform duration-300" loading="eager" />
          </div>
          <div class="flex items-center justify-center gap-3 mt-4">
            {product.standards.slice(0, 4).map(std => (
              <span class="px-2.5 py-1 bg-slate border border-steel/30 rounded text-[10px] font-mono text-ash">{std}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features + Standards -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Features -->
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Key Features</p>
          <div class="space-y-3">
            {product.features.map(feature => (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-voltage flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-pure">{feature}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Standards + Docs -->
        <div>
          {product.standards.length > 0 && (
            <div class="mb-10">
              <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Standards & Certifications</p>
              <div class="flex flex-wrap gap-2">
                {product.standards.map(std => (
                  <span class="px-3 py-1.5 bg-obsidian border border-steel/50 rounded text-sm text-pure font-mono">{std}</span>
                ))}
              </div>
            </div>
          )}

          {product.docs.length > 0 && (
            <div>
              <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Documents</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {product.docs.map(doc => (
                  <a href={doc.url} target="_blank" rel="noopener" class="card-glow flex items-center gap-3 bg-obsidian rounded-lg p-4 group">
                    <svg class="w-5 h-5 text-voltage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span class="text-sm text-ash group-hover:text-voltage transition-colors">{doc.label}</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Documents (Email-Gated) -->
  <section class="py-16 md:py-24 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <DocumentGate productSlug={product.slug} />
    </div>
  </section>

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <section class="py-16 md:py-24 bg-obsidian">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">// Related Products</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedProducts.map(rp => (
            <a href={`/products/${rp.slug}`} class="card-glow card-top-accent bg-steel/30 rounded-xl p-6 group">
              <h3 class="font-display text-lg font-semibold text-pure mb-1 group-hover:text-voltage transition-colors">{rp.name}</h3>
              <p class="font-mono text-xs text-ash mb-3">{rp.tagline}</p>
              <p class="text-sm text-ash mb-4 line-clamp-2">{rp.description}</p>
              <span class="text-sm font-medium text-voltage">View Product &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-voltage py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-obsidian mb-4">Need Help With {product.name}?</h2>
      <p class="text-obsidian/70 mb-6">Register for training, request a quote, or call our engineering team.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/training/" class="px-8 py-3.5 bg-obsidian text-pure font-semibold rounded-lg hover:bg-slate transition-colors text-sm">Register for Training</a>
        <a href={`tel:${company.phone.replace(/[^0-9]/g, '')}`} class="px-8 py-3.5 border-2 border-obsidian/30 text-obsidian font-semibold rounded-lg hover:bg-obsidian/10 transition-colors text-sm font-mono">{company.phone}</a>
      </div>
    </div>
  </section>

</BaseLayout>
