---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';

const category = getCategoryBySlug('ups-backup')!;
const categoryProducts = getProductsByCategory('ups-backup');

const specs = [
  ['Input Voltage', '208/480 VAC Single and Three Phase'],
  ['Output Voltage', 'Matches input (field selectable)'],
  ['Frequency', '60 Hz'],
  ['Topology', 'Online double conversion (IGBT PWM)'],
  ['Output Waveform', 'Pure sine wave, less than 3% THD, ±2% voltage regulation'],
  ['Power Range', '10kVA to 500kVA'],
  ['Phase', 'Single Phase and Three Phase (3Ø)'],
  ['Static Bypass', 'Under 4ms automatic transfer'],
  ['Maintenance Bypass', 'External wrap-around, make-before-break'],
  ['Efficiency', 'Greater than 94% at full load, up to 99% in ECO mode'],
  ['Generator Compatible', 'Yes'],
  ['Battery Type', 'Sealed VRLA'],
  ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
  ['Enclosure', 'Modular assembly'],
  ['Certifications', 'UL 1778, ISO 9001, UL 924 dual listed models available'],
  ['Warranty', '2 years parts and labor'],
];

const applications = [
  { name: 'Data Centers', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Industrial', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
  { name: 'Broadcast', icon: 'M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 010-7.072m-2.828 9.9a9 9 0 010-12.728' },
  { name: 'Telecom', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z' },
];
---

<BaseLayout
  title="UPS Backup Systems | UL 1778 | 10 to 500kVA | Online Power"
  description="Online double conversion UPS systems from 10kVA to 500kVA. UL 1778 listed with zero transfer time. Single and three phase. Built to order in Los Angeles."
>

  <!-- HERO -->
  <section class="py-16 md:py-24 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-8">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-voltage transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">UPS Backup</span>
      </nav>

      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">UL 1778</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">UL 924</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">Made in USA</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-pure leading-tight mb-5">UPS Backup Systems</h1>
          <p class="text-lg text-ash leading-relaxed mb-8">
            Every power anomaly including sags, surges, spikes, brownouts, frequency variations, harmonic distortion, and complete blackouts costs U.S. businesses over $150 billion annually. Online Power's UL 1778 listed UPS systems use true online double-conversion topology with IGBT PWM and digital signal processing to eliminate all nine common power problems with zero transfer time. Unlike off-the-shelf UPS products that force you into fixed configurations, Online Power engineers each system to your exact load, voltage, runtime, and bypass requirements. From single-phase protection for a telecom closet to three-phase systems supporting data center redundancy. Built to order in Los Angeles.
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {[
              { label: 'Topology', value: 'Online Double Conv.' },
              { label: 'Transfer', value: 'Zero (no gap)' },
              { label: 'Configurations', value: '1Ø and 3Ø' },
              { label: 'Certifications', value: 'UL 1778 · UL 924' },
            ].map(s => (
              <div class="bg-slate border border-steel/30 rounded-lg p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-widest text-ash mb-1">{s.label}</p>
                <p class="font-display text-sm font-bold text-pure">{s.value}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <a href="/contact" class="btn-primary px-6 py-3.5 rounded-lg text-sm font-semibold inline-flex items-center justify-center gap-2">Tell Us Your Critical Load for a Custom UPS Specification in 48 Hours</a>
            <button class="btn-ghost px-6 py-3.5 rounded-lg text-sm inline-flex items-center justify-center gap-2 doc-download-btn" data-url="/pdf/hostpower_DS.pdf" data-name="UPS Backup Spec Sheet" data-product="UPS Backup Systems">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"></path></svg>
              Download Spec Sheet
            </button>
          </div>
          <p class="font-mono text-xs text-ash">// Responds within 2 business hours</p>
        </div>

        <div class="lg:col-span-2">
          <div style="background:#0A0A0F;border-radius:12px;overflow:hidden;width:100%;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes ups-utilCut { 0%,25%{stroke:#00E5FF;} 30%{stroke:#1C2B3A;} 85%{stroke:#1C2B3A;} 90%{stroke:#00E5FF;} }
                @keyframes ups-battOn { 0%,28%{stroke:#1C2B3A;fill:none;} 32%{stroke:#00E5FF;fill:#00E5FF10;} 85%{stroke:#00E5FF;fill:#00E5FF10;} 90%{stroke:#1C2B3A;fill:none;} }
                @keyframes ups-led1 { 0%,100%{opacity:0.3;} 50%{opacity:1;} }
                @keyframes ups-text { 0%,32%{opacity:0;} 36%,82%{opacity:1;} 88%{opacity:0;} }
                @keyframes ups-drain { 0%,30%{width:80px;} 85%{width:20px;} 90%{width:80px;} }
                .ups-util{animation:ups-utilCut 7s ease-in-out infinite;}
                .ups-batt{animation:ups-battOn 7s ease-in-out infinite;}
                .ups-led{animation:ups-led1 1s ease-in-out infinite;}
                .ups-txt{animation:ups-text 7s ease-in-out infinite;}
                .ups-bar{animation:ups-drain 7s ease-in-out infinite;}
              </style>
              <line x1="40" y1="120" x2="160" y2="120" class="ups-util" stroke="#00E5FF" stroke-width="2"/>
              <text x="40" y="110" font-family="Space Mono,monospace" font-size="8" fill="#8A9BAE">UTILITY</text>
              <rect x="160" y="80" width="120" height="100" rx="6" class="ups-batt" fill="none" stroke="#1C2B3A" stroke-width="1.5"/>
              <text x="220" y="120" text-anchor="middle" font-family="Space Grotesk,sans-serif" font-size="10" font-weight="700" fill="#F8FAFC">UPS</text>
              <text x="220" y="136" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#8A9BAE">ONLINE POWER</text>
              <rect x="180" y="155" width="80" height="8" rx="2" fill="#00E5FF" opacity="0.3" class="ups-bar"/>
              <rect x="180" y="155" width="80" height="8" rx="2" fill="none" stroke="#1C2B3A" stroke-width="0.5"/>
              <line x1="280" y1="120" x2="380" y2="120" stroke="#00E5FF" stroke-width="2"/>
              <rect x="380" y="40" width="140" height="220" rx="4" fill="#111827" stroke="#1C2B3A" stroke-width="1.5"/>
              <rect x="392" y="55" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="85" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="115" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="145" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="175" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="392" y="205" width="116" height="22" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5"/>
              <circle cx="500" cy="66" r="2" fill="#00E5FF" class="ups-led"/>
              <circle cx="500" cy="96" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:0.2s;"/>
              <circle cx="500" cy="126" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:0.4s;"/>
              <circle cx="500" cy="156" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:0.6s;"/>
              <circle cx="500" cy="186" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:0.8s;"/>
              <circle cx="500" cy="216" r="2" fill="#00E5FF" class="ups-led" style="animation-delay:1.0s;"/>
              <text x="330" y="90" text-anchor="middle" font-family="Space Mono,monospace" font-size="10" fill="#00E5FF" class="ups-txt" opacity="0">&lt;4ms</text>
              <text x="330" y="104" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#8A9BAE" class="ups-txt" opacity="0">TRANSFER</text>
              <text x="300" y="300" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#2A3A4A">// ZERO INTERRUPTION POWER TRANSFER</text>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex gap-1 border-b border-steel/30 mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-voltage border-voltage' : 'text-ash border-transparent hover:text-pure'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Zero transfer time eliminates the most dangerous milliseconds</h3>
            <p class="text-sm text-ash leading-relaxed">Line-interactive UPS systems have a 4 to 10 millisecond transfer gap. Standby units gap for 5 to 12 milliseconds. For sensitive PLCs, process controllers, and medical instruments, those milliseconds cause shutdowns, data corruption, and production loss. Online double conversion means your load never sees the switch because there is no switch.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Engineered to your load, not the nearest catalog size</h3>
            <p class="text-sm text-ash leading-relaxed">Off-the-shelf UPS vendors offer fixed kVA increments that force oversizing or undersizing. Online Power builds to your exact specification including voltage, frequency, runtime, bypass configuration, enclosure type, and monitoring integration. No compromises and no wasted capacity.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Internal static bypass plus external maintenance bypass</h3>
            <p class="text-sm text-ash leading-relaxed">The internal static bypass activates automatically in under 4 milliseconds during a fault condition. The external wrap-around maintenance bypass uses make-before-break switching for zero-downtime UPS service, completely isolating the unit for repair without interrupting your critical load. Both should always be specified.</p>
          </div>
        </div>

        <!-- Technical Callout -->
        <div class="bg-bg-elevated border-l-2 border-voltage p-6 mb-10" style="border-radius: 0 12px 12px 0;">
          <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-3">// What your spec sheet won't tell you</p>
          <p class="text-sm text-ash leading-relaxed">UL 1778 and UL 924 certify fundamentally different things. UL 1778 certifies power continuity and quality for UPS equipment. UL 924 certifies emergency life-safety lighting compliance including 90 minute runtime, 10 second activation, and tamperproof design. A UPS with only UL 1778 listing does not satisfy NEC Article 700 emergency system requirements and your AHJ will reject it for emergency lighting applications. Online Power offers dual-listed UL 924 and UL 1778 models that satisfy both standards with a single unit. Also, demand actual efficiency curves at 25 percent, 50 percent, 75 percent, and 100 percent load from any vendor, not just the peak number. A UPS running at 30 percent load for most of its life at 85 percent efficiency costs far more in electricity than one maintaining 94 percent across all load points.</p>
        </div>

        <!-- Codes & Standards -->
        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Codes &amp; Standards</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-16">
          {[
            { code: 'UL 1778', desc: 'Uninterruptible Power Supply Equipment' },
            { code: 'UL 924', desc: 'Emergency Lighting Equipment (dual listed)' },
            { code: 'NEC Article 645', desc: 'Information Technology Equipment' },
            { code: 'NEC Article 700', desc: 'Emergency Systems' },
            { code: 'NEC Article 701', desc: 'Legally Required Standby' },
            { code: 'TIA 942', desc: 'Data Center Infrastructure Standard' },
          ].map(item => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4">
              <p class="font-display font-bold text-voltage text-sm">{item.code}</p>
              <p class="text-xs text-ash mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-6">// Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-voltage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-pure">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure font-medium mb-1">Critical Load Protection</p>
          <p class="text-sm text-ash">Designed for servers, networking equipment, broadcast systems, and other critical loads requiring uninterrupted power. Contact our engineering team for load analysis.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-obsidian border border-steel/30 rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-obsidian' : 'bg-slate/30'} ${i < specs.length - 1 ? 'border-b border-steel/20' : ''}`}>
              <span class="text-sm text-ash font-medium">{label}</span>
              <span class="text-sm text-pure font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure">Need a custom specification? <a href="/contact" class="text-voltage hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-mono text-xs text-ash mb-6">// All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="host-power" />
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS -->
  <section class="py-16 md:py-24 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">// {categoryProducts.length} Models Available</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="card-glow card-top-accent bg-steel/30 rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-bg-elevated flex items-center justify-center p-4">
              <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-pure mb-1 group-hover:text-voltage transition-colors">{p.name}</h3>
            <p class="font-mono text-xs text-voltage mb-3">{p.tagline}</p>
            <p class="text-sm text-ash mb-4 line-clamp-2">{p.description}</p>
            <span class="text-sm font-medium text-voltage">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-obsidian border border-steel/30 rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-voltage" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-pure text-lg leading-relaxed mb-6 italic">"Our Amazon customer needed an inverter on-site sooner than the standard lead time. Online Power was able to adhere to the customer's needs, expediting their order and delivering their product 2 weeks before their scheduled ship date. You can always count on Online Power."</p>
        <div class="border-t border-steel/30 pt-4">
          <p class="font-display font-semibold text-pure">Brittany Bromley</p>
          <p class="text-sm text-ash">Purchasing, Dominion Electric Supply Co.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-voltage py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-obsidian mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-obsidian text-pure font-semibold rounded-lg hover:bg-slate transition-colors text-sm">Tell Us Your Critical Load for a Custom UPS Specification in 48 Hours</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-obsidian/30 text-obsidian font-semibold rounded-lg hover:bg-obsidian/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-obsidian/95 backdrop-blur border-t border-steel/30 p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <a href="/contact" class="btn-primary w-full py-3.5 rounded-lg text-sm font-semibold flex items-center justify-center gap-2">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      Request a Quote
    </a>
  </div>

</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-voltage', 'border-voltage');
        b.classList.add('text-ash', 'border-transparent');
      });
      btn.classList.remove('text-ash', 'border-transparent');
      btn.classList.add('text-voltage', 'border-voltage');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
