---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import { Image } from 'astro:assets';
import { getProductImage } from '../../../utils/images';
import UPSSystems from '../../../components/illustrations/UPSSystems.astro';

const category = getCategoryBySlug('ups-backup')!;
const categoryProducts = getProductsByCategory('ups-backup');

const specs = [
  ['Input Voltage', '208/480 VAC Single and Three Phase'],
  ['Output Voltage', 'Matches input (field selectable)'],
  ['Frequency', '60 Hz'],
  ['Topology', 'Online double conversion (IGBT PWM)'],
  ['Output Waveform', 'Pure sine wave, less than 3% THD, ±2% voltage regulation'],
  ['Power Range', '10kVA to 500kVA'],
  ['Phase', 'Single Phase and Three Phase (3Ø)'],
  ['Static Bypass', 'Under 4ms automatic transfer'],
  ['Maintenance Bypass', 'External wrap-around, make-before-break'],
  ['Efficiency', 'Greater than 94% at full load, up to 99% in ECO mode'],
  ['Generator Compatible', 'Yes'],
  ['Battery Type', 'Sealed VRLA'],
  ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
  ['Enclosure', 'Modular assembly'],
  ['Certifications', 'UL 1778, ISO 9001, UL 924 dual listed models available'],
  ['Warranty', '1 year parts · 2nd year optional with PM plan'],
];

const applications = [
  { name: 'Data Centers', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Industrial', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
  { name: 'Broadcast', icon: 'M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 010-7.072m-2.828 9.9a9 9 0 010-12.728' },
  { name: 'Telecom', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z' },
];

const faq = [
  { question: 'What is an online double-conversion UPS?', answer: 'An online double-conversion UPS continuously converts incoming AC to DC, then back to AC. Your critical load always runs on the UPS inverter — when utility power fails, there is no transfer time because the inverter never stops running. This is the topology required by UL 1778 and specified in data centers, hospitals, and broadcast facilities.' },
  { question: 'What does UL 1778 certify?', answer: 'UL 1778 is the US safety standard for uninterruptible power supply equipment. It covers electrical safety, battery handling, and continuity of power. Online Power\'s Host Power UPS is UL 1778 listed across the full 10–500 kVA range, with dual-listed UL 924 models available for applications that also need emergency-lighting compliance.' },
  { question: 'Can a UPS also serve as emergency lighting backup?', answer: 'Yes — if it carries both UL 1778 and UL 924 listings. Most catalog UPS products are UL 1778 only and will be rejected by an AHJ for emergency lighting applications. Online Power offers dual-listed models so a single unit covers both NEC Article 700 emergency systems and critical load protection.' },
  { question: 'How is Online Power UPS different from catalog vendors?', answer: 'Catalog UPS vendors force you into fixed kVA increments, generic runtime curves, and standard bypass configurations. Online Power engineers each system to your exact load, voltage, runtime, and bypass requirements. No oversizing, no undersizing, and the engineer who designed your system answers the phone.' },
  { question: 'Is Online Power UPS compatible with generators?', answer: 'Yes. Host Power UPS is fully generator-compatible with input filtering that accepts the voltage and frequency swings common on standby generator power. Input filter specifications available in the datasheet.' },
];
---

<BaseLayout
  title="UL 1778 UPS Backup Systems | 10–500 kVA Online Double-Conversion | Online Power"
  description="Online Power UL 1778 UPS systems from 10 kVA to 500 kVA. True online double-conversion with IGBT PWM and DSP, zero transfer time, generator-compatible. Dual UL 924 listed models available. Built to order in Los Angeles."
  faq={faq}
>

  <!-- BREADCRUMB STRIP -->
  <section class="bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
      <nav class="text-[13px] font-display text-slate">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-steel-blue transition-colors">Products</a>
        <span class="mx-2">/</span>
        <span class="text-near-black font-semibold">UPS Backup</span>
      </nav>
    </div>
  </section>

  <!-- ========== HERO — dark with depth ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute -top-32 -right-32 w-[560px] h-[560px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.3) 0%, rgba(37,103,194,0) 70%); filter: blur(12px);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="badge-dark">UL 1778</span>
            <span class="badge-dark">UL 924</span>
            <span class="badge-dark">Made in USA</span>
          </div>

          <h1 class="font-display text-4xl md:text-5xl lg:text-[56px] font-extrabold tracking-tight text-white leading-[1.05] mb-5">UPS Backup Systems</h1>
          <p class="text-lg text-muted-blue leading-relaxed max-w-xl mb-8">
            Lawrence Berkeley Lab puts the cost of US power interruptions at roughly $44B annually. Our UL 1778 UPS uses true online double-conversion with IGBT PWM and DSP — zero transfer, nine power problems eliminated. Engineered to your exact load, voltage, runtime, and bypass requirements. Built to order in Los Angeles.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <Button href="/contact" size="lg" icon="arrow-right">Tell Us Your Load</Button>
          </div>
          <p class="font-display text-[13px] text-muted-blue">Responds within 2 business hours</p>
        </div>

        <div class="hidden lg:block lg:col-span-2">
          <UPSSystems />
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative border-t border-navy-mid" style="z-index: 2;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-navy-mid">
          {[
            { label: 'Topology', value: 'Online Double Conv.' },
            { label: 'Transfer', value: 'Zero (no gap)' },
            { label: 'Configurations', value: '1Ø and 3Ø' },
            { label: 'Certifications', value: 'UL 1778 · UL 924' },
          ].map(s => (
            <div class="py-6 px-4 md:px-6 text-center md:text-left">
              <p class="font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-blue mb-2">{s.label}</p>
              <p class="font-display text-[15px] md:text-[17px] font-bold text-white leading-tight">{s.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS — models first per emergency-lighting pattern -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-8">{categoryProducts.length} Models Available</p>
      <div class="flex overflow-x-auto snap-x snap-mandatory gap-5 -mx-4 px-4 pb-4 no-scrollbar sm:grid sm:grid-cols-2 lg:grid-cols-3 sm:overflow-visible sm:mx-0 sm:px-0 sm:pb-0">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="snap-start shrink-0 w-[82vw] sm:w-auto sm:shrink card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-off-white flex items-center justify-center p-4">
              {typeof getProductImage(p.image) === 'string' ? (
                <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
              ) : (
                <Image src={getProductImage(p.image) as ImageMetadata} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
              )}
            </div>
            <div class="p-6">
              <h3 class="font-display text-2xl font-semibold text-near-black mb-1 group-hover:text-steel-blue transition-colors">{p.name}</h3>
              <p class="font-display font-semibold text-xs text-steel-blue mb-3">{p.tagline}</p>
              <p class="text-base text-slate mb-4 line-clamp-2">{p.description}</p>
              <span class="text-[15px] font-medium text-steel-blue">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

    <!-- OVERVIEW -->
  <section class="py-10 md:py-14 bg-white border-t border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Overview</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Zero transfer time eliminates the most dangerous milliseconds</h3>
            <p class="text-base text-slate leading-relaxed">Line-interactive UPS systems have a 4 to 10 millisecond transfer gap. Standby units gap for 5 to 12 milliseconds. For sensitive PLCs, process controllers, and medical instruments, those milliseconds cause shutdowns, data corruption, and production loss. Online double conversion means your load never sees the switch because there is no switch.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Engineered to your load, not the nearest catalog size</h3>
            <p class="text-base text-slate leading-relaxed">Off-the-shelf UPS vendors offer fixed kVA increments that force oversizing or undersizing. Online Power builds to your exact specification including voltage, frequency, runtime, bypass configuration, enclosure type, and monitoring integration. No compromises and no wasted capacity.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Internal static bypass plus external maintenance bypass</h3>
            <p class="text-base text-slate leading-relaxed">The internal static bypass activates automatically in under 4 milliseconds during a fault condition. The external wrap-around maintenance bypass uses make-before-break switching for zero-downtime UPS service, completely isolating the unit for repair without interrupting your critical load. Both should always be specified.</p>
          </div>
        </div>

        <!-- Technical Callout -->
        <div class="bg-off-white border-l-2 border-steel-blue p-6 mb-10" style="border-radius: 0 12px 12px 0;">
          <p class="eyebrow text-steel-blue mb-3">What your spec sheet won't tell you</p>
          <p class="text-base text-slate leading-relaxed">UL 1778 and UL 924 certify fundamentally different things. UL 1778 certifies power continuity and quality for UPS equipment. UL 924 certifies emergency life-safety lighting compliance including 90 minute runtime, 10 second activation, and tamperproof design. A UPS with only UL 1778 listing does not satisfy NEC Article 700 emergency system requirements and your AHJ will reject it for emergency lighting applications. Online Power offers dual-listed UL 924 and UL 1778 models that satisfy both standards with a single unit. Also, demand actual efficiency curves at 25 percent, 50 percent, 75 percent, and 100 percent load from any vendor, not just the peak number. A UPS running at 30 percent load for most of its life at 85 percent efficiency costs far more in electricity than one maintaining 94 percent across all load points.</p>
        </div>

        <!-- Codes & Standards -->
        <p class="eyebrow text-steel-blue mb-4">Codes &amp; Standards</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-16">
          {[
            { code: 'UL 1778', desc: 'Uninterruptible Power Supply Equipment' },
            { code: 'UL 924', desc: 'Emergency Lighting Equipment (dual listed)' },
            { code: 'NEC Article 645', desc: 'Information Technology Equipment' },
            { code: 'NEC Article 700', desc: 'Emergency Systems' },
            { code: 'NEC Article 701', desc: 'Legally Required Standby' },
            { code: 'TIA 942', desc: 'Data Center Infrastructure Standard' },
          ].map(item => (
            <div class="bg-white border border-steel-gray rounded-lg p-4">
              <p class="font-display font-bold text-steel-blue text-sm">{item.code}</p>
              <p class="text-xs text-slate mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <p class="eyebrow text-steel-blue mb-6">Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-white border border-steel-gray rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-steel-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-near-black">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black font-medium mb-1">Critical Load Protection</p>
          <p class="text-base text-slate">Designed for servers, networking equipment, broadcast systems, and other critical loads requiring uninterrupted power. Contact our engineering team for load analysis.</p>
        </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-white border border-steel-gray rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-steel-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-near-black text-lg leading-relaxed mb-6 italic">"Our Amazon customer needed an inverter on-site sooner than the standard lead time. Online Power was able to adhere to the customer's needs, expediting their order and delivering their product 2 weeks before their scheduled ship date. You can always count on Online Power."</p>
        <div class="border-t border-steel-gray pt-4">
          <p class="font-display font-semibold text-near-black">Brittany Bromley</p>
          <p class="text-base text-slate">Purchasing, Dominion Electric Supply Co.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="py-10 md:py-14 bg-off-white border-t border-steel-gray">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Common Questions</p>
      <h2 class="font-display text-3xl font-extrabold tracking-tight text-near-black mb-8 leading-[1.1]">UPS Backup FAQ</h2>
      <div class="space-y-3">
        {faq.map(item => (
          <details class="group bg-white border border-steel-gray rounded-xl overflow-hidden hover:border-steel-blue transition-colors">
            <summary class="flex items-start gap-4 p-5 cursor-pointer">
              <span class="font-display text-[15px] font-semibold text-near-black flex-1 group-hover:text-steel-blue transition-colors">{item.question}</span>
              <svg class="w-4 h-4 text-slate group-open:rotate-180 group-open:text-steel-blue transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </summary>
            <div class="px-5 pb-5 text-[15px] text-slate leading-relaxed">{item.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== RELATED CATEGORIES ========== -->
  <section class="py-10 md:py-14 bg-white border-t border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Related Product Lines</p>
      <h2 class="font-display text-2xl md:text-3xl font-extrabold tracking-tight text-near-black mb-8 leading-[1.1]">Explore More from Online Power</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {[
          { href: '/products/category/medical-grade', name: 'Medical Grade Systems', desc: 'UL 60601-1 patient-grade leakage + OSHPD seismic for hospitals.' },
          { href: '/products/category/isolation-transformers', name: 'Isolation Transformers', desc: 'ISO-Care clean-power transformer, -152 dB noise attenuation.' },
          { href: '/products/category/voltage-regulators', name: 'Voltage Regulators', desc: '±3% tap-switching regulation, 99% efficient. Power conditioning.' },
        ].map(c => (
          <a href={c.href} class="group bg-white border border-steel-gray rounded-xl p-6 hover:border-steel-blue hover:shadow-[0_12px_28px_-10px_rgba(37,103,194,0.25)] hover:-translate-y-0.5 transition-all">
            <h3 class="font-display text-xl font-bold text-near-black group-hover:text-steel-blue transition-colors mb-2">{c.name}</h3>
            <p class="text-[14px] text-slate mb-4">{c.desc}</p>
            <span class="font-display text-[12px] font-bold uppercase tracking-[0.12em] text-steel-blue group-hover:text-near-black inline-flex items-center gap-1.5 transition-colors">
              Explore
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-steel-blue text-white font-semibold rounded hover:bg-steel-blue/90 transition-colors text-sm">Tell Us Your Critical Load for a Custom UPS Specification in 48 Hours</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded hover:bg-white/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-deep-navy/95 backdrop-blur border-t border-steel-gray p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <Button href="/contact" size="lg" icon="bolt" fullWidth>Request a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
      btn.classList.remove('text-slate', 'border-transparent');
      btn.classList.add('text-steel-blue', 'border-steel-blue');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
