---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';

const category = getCategoryBySlug('monitoring')!;
const categoryProducts = getProductsByCategory('monitoring');

const specs = [
  ['Monitoring', '24/7 real-time system oversight'],
  ['Access', 'Remote web-based interface'],
  ['Display', 'Touch screen (BAS)'],
  ['Connection', 'Wired and wireless options'],
  ['Notifications', 'Real-time email/SMS alerts'],
  ['Battery Monitoring', 'Voltage, impedance, temperature'],
  ['String Current', 'Continuous monitoring'],
  ['Ohmic Testing', 'Scheduled impedance testing'],
  ['Data Logging', 'Historical trend analysis'],
  ['Compatibility', 'All Online Power systems'],
  ['Protocol', 'SNMP, Modbus, BACnet'],
  ['Warranty', '2 years parts and labor'],
];

const applications = [
  { name: 'Data Centers', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'High-Rise Office', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
  { name: 'Industrial', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { name: 'Telecom', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z' },
];
---

<BaseLayout
  title="Monitoring & Software | GMS | Battery Advisor | Online Power"
  description="Global Monitoring System and Battery Advisor System for comprehensive power system oversight. Real-time alerts, remote access, and battery health tracking."
>

  <!-- HERO -->
  <section class="py-16 md:py-24 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-8">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-voltage transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Monitoring & Software</span>
      </nav>

      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">Remote Access</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">24/7 Monitoring</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">Made in USA</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-pure leading-tight mb-5">Monitoring & Software</h1>
          <p class="text-lg text-ash leading-relaxed mb-8">
            Global Monitoring System and Battery Advisor System for comprehensive power system oversight. Real-time alerts and battery health tracking.
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {[
              { label: 'Monitoring', value: '24/7' },
              { label: 'Access', value: 'Remote' },
              { label: 'Display', value: 'Touch Screen' },
              { label: 'Connection', value: 'Wired/Wireless' },
            ].map(s => (
              <div class="bg-slate border border-steel/30 rounded-lg p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-widest text-ash mb-1">{s.label}</p>
                <p class="font-display text-sm font-bold text-pure">{s.value}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <a href="/contact" class="btn-primary px-6 py-3.5 rounded-lg text-sm font-semibold inline-flex items-center justify-center gap-2">Request a Quote</a>
            <button class="btn-ghost px-6 py-3.5 rounded-lg text-sm inline-flex items-center justify-center gap-2 doc-download-btn" data-url="/pdf/gms_DS.pdf" data-name="GMS - Spec Sheet" data-product="Monitoring & Software">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"></path></svg>
              Download Spec Sheet
            </button>
          </div>
          <p class="font-mono text-xs text-ash">// Responds within 2 business hours</p>
        </div>

        <div class="lg:col-span-2">
          <div style="background:#0A0A0F;border-radius:12px;overflow:hidden;width:100%;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes mon-needle { 0%,100%{transform:rotate(-20deg);} 50%{transform:rotate(20deg);} }
                @keyframes mon-blink { 0%,100%{opacity:0.4;} 50%{opacity:1;} }
                @keyframes mon-alert { 0%,40%{fill:#F59E0B;} 50%{fill:#00E5FF;} 100%{fill:#00E5FF;} }
                .mon-ndl{transform-origin:300px 160px;animation:mon-needle 6s ease-in-out infinite;}
                .mon-blink{animation:mon-blink 2s ease-in-out infinite;}
                .mon-alert{animation:mon-alert 5s ease-in-out infinite;}
              </style>
              <!-- Dashboard frame -->
              <rect x="20" y="15" width="560" height="280" rx="6" fill="#111827" stroke="#1C2B3A" stroke-width="1"/>
              <!-- Title bar -->
              <rect x="20" y="15" width="560" height="28" rx="6" fill="#0D1117"/>
              <text x="300" y="34" text-anchor="middle" font-family="Space Mono,monospace" font-size="9" fill="#00E5FF">GLOBAL MONITORING SYSTEM</text>
              <!-- Left panel: floor plan -->
              <rect x="35" y="55" width="170" height="160" rx="4" fill="#0A0A0F" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="45" y="65" width="150" height="140" rx="2" fill="none" stroke="#1C2B3A" stroke-width="0.3"/>
              <line x1="120" y1="65" x2="120" y2="205" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="45" y1="135" x2="195" y2="135" stroke="#1C2B3A" stroke-width="0.2"/>
              <!-- Inverter dots -->
              <circle cx="75" cy="95" r="4" fill="#00E5FF" class="mon-blink"/>
              <circle cx="150" cy="95" r="4" fill="#00E5FF" class="mon-blink" style="animation-delay:0.3s;"/>
              <circle cx="75" cy="165" r="4" fill="#00E5FF" class="mon-blink" style="animation-delay:0.6s;"/>
              <circle cx="150" cy="165" r="4" fill="#00E5FF" class="mon-blink" style="animation-delay:0.9s;"/>
              <circle cx="100" cy="130" r="4" fill="#00E5FF" class="mon-blink" style="animation-delay:1.2s;"/>
              <circle cx="170" cy="130" r="4" fill="#00E5FF" class="mon-blink" style="animation-delay:1.5s;"/>
              <text x="120" y="225" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#8A9BAE">SITE MAP</text>
              <!-- Center: gauge -->
              <circle cx="300" cy="145" r="70" fill="#0A0A0F" stroke="#1C2B3A" stroke-width="1"/>
              <circle cx="300" cy="145" r="65" fill="none" stroke="#00E5FF" stroke-width="3" stroke-dasharray="307 102" opacity="0.3"/>
              <line x1="300" y1="145" x2="300" y2="90" stroke="#00E5FF" stroke-width="1.5" class="mon-ndl"/>
              <text x="300" y="155" text-anchor="middle" font-family="Space Grotesk,sans-serif" font-size="22" font-weight="700" fill="#F8FAFC">87%</text>
              <text x="300" y="172" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#8A9BAE">BATTERY HEALTH</text>
              <!-- Right panel: status list -->
              <rect x="395" y="55" width="170" height="160" rx="4" fill="#0A0A0F" stroke="#1C2B3A" stroke-width="0.5"/>
              <text x="405" y="72" font-family="Space Mono,monospace" font-size="7" fill="#8A9BAE">STATUS</text>
              <!-- Status items -->
              <circle cx="415" cy="90" r="3" fill="#00E5FF" class="mon-blink"/>
              <text x="428" y="93" font-family="Space Mono,monospace" font-size="7" fill="#F8FAFC">INV-01 Normal</text>
              <circle cx="415" cy="110" r="3" fill="#00E5FF" class="mon-blink" style="animation-delay:0.2s;"/>
              <text x="428" y="113" font-family="Space Mono,monospace" font-size="7" fill="#F8FAFC">INV-02 Normal</text>
              <circle cx="415" cy="130" r="3" class="mon-alert"/>
              <text x="428" y="133" font-family="Space Mono,monospace" font-size="7" fill="#F8FAFC">INV-03 Maint</text>
              <circle cx="415" cy="150" r="3" fill="#00E5FF" class="mon-blink" style="animation-delay:0.4s;"/>
              <text x="428" y="153" font-family="Space Mono,monospace" font-size="7" fill="#F8FAFC">INV-04 Normal</text>
              <circle cx="415" cy="170" r="3" fill="#00E5FF" class="mon-blink" style="animation-delay:0.6s;"/>
              <text x="428" y="173" font-family="Space Mono,monospace" font-size="7" fill="#F8FAFC">INV-05 Normal</text>
              <circle cx="415" cy="190" r="3" fill="#00E5FF" class="mon-blink" style="animation-delay:0.8s;"/>
              <text x="428" y="193" font-family="Space Mono,monospace" font-size="7" fill="#F8FAFC">INV-06 Normal</text>
              <!-- Label -->
              <text x="300" y="300" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#2A3A4A">// REAL-TIME SYSTEM MONITORING DASHBOARD</text>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex gap-1 border-b border-steel/30 mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-voltage border-voltage' : 'text-ash border-transparent hover:text-pure'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-16">
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Global Monitoring System</h3>
            <p class="text-sm text-ash">24/7 remote monitoring and notification for all power protection equipment. Real-time visibility into system performance from anywhere.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Battery Advisor System</h3>
            <p class="text-sm text-ash">Comprehensive battery health tracking with voltage, impedance, temperature, and string current monitoring. Wired or wireless deployment.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Proactive Alerts</h3>
            <p class="text-sm text-ash">Real-time email and SMS notifications for system events, battery degradation, and maintenance scheduling. Prevent failures before they happen.</p>
          </div>
        </div>

        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-6">// Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-voltage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-pure">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure font-medium mb-1">BMS Integration</p>
          <p class="text-sm text-ash">Supports SNMP, Modbus, and BACnet protocols for seamless integration with building management systems. Contact our engineering team for integration specifications.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-obsidian border border-steel/30 rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-obsidian' : 'bg-slate/30'} ${i < specs.length - 1 ? 'border-b border-steel/20' : ''}`}>
              <span class="text-sm text-ash font-medium">{label}</span>
              <span class="text-sm text-pure font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure">Need a custom specification? <a href="/contact" class="text-voltage hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-mono text-xs text-ash mb-6">// All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="gms" />
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS -->
  <section class="py-16 md:py-24 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">// {categoryProducts.length} Models Available</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="card-glow card-top-accent bg-steel/30 rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-bg-elevated flex items-center justify-center p-4">
              <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-pure mb-1 group-hover:text-voltage transition-colors">{p.name}</h3>
            <p class="font-mono text-xs text-voltage mb-3">{p.tagline}</p>
            <p class="text-sm text-ash mb-4 line-clamp-2">{p.description}</p>
            <span class="text-sm font-medium text-voltage">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-obsidian border border-steel/30 rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-voltage" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-pure text-lg leading-relaxed mb-6 italic">"The GMS monitoring system gives us complete visibility into our power infrastructure across multiple sites. The proactive alerts have saved us from several potential failures."</p>
        <div class="border-t border-steel/30 pt-4">
          <p class="font-display font-semibold text-pure">Lisa Chang</p>
          <p class="text-sm text-ash">Facilities Operations Director</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-voltage py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-obsidian mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-obsidian text-pure font-semibold rounded-lg hover:bg-slate transition-colors text-sm">Request a Quote</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-obsidian/30 text-obsidian font-semibold rounded-lg hover:bg-obsidian/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-obsidian/95 backdrop-blur border-t border-steel/30 p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <a href="/contact" class="btn-primary w-full py-3.5 rounded-lg text-sm font-semibold flex items-center justify-center gap-2">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      Request a Quote
    </a>
  </div>

</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-voltage', 'border-voltage');
        b.classList.add('text-ash', 'border-transparent');
      });
      btn.classList.remove('text-ash', 'border-transparent');
      btn.classList.add('text-voltage', 'border-voltage');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
