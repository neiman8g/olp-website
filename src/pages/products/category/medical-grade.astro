---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import MedicalGrade from '../../../components/illustrations/MedicalGrade.astro';

const category = getCategoryBySlug('medical-grade')!;
const categoryProducts = getProductsByCategory('medical-grade');

const specs = [
  ['Input Voltage', '208/480 VAC Three Phase'],
  ['Output Voltage', 'Matches input'],
  ['Frequency', '60 Hz'],
  ['Power Range', '10kVA to 1,250kVA'],
  ['Phase', 'Three Phase (3Ø)'],
  ['Voltage Regulation', '±1% (sub-cycle stabilization)'],
  ['Topology', 'Independent Phase Control'],
  ['Leakage Current', 'Under 100µA (Type B) · Under 10µA (Type CF cardiac)'],
  ['Isolation', '4,000 VAC input to output, Faraday shielded'],
  ['Seismic', 'OSHPD/HCAI preapproved, SDS 3.0G'],
  ['Harmonic Reduction', '12 pulse topology'],
  ['Redundancy', 'Seamless redundant power paths'],
  ['Serviceability', 'Front access only, service without shutdown'],
  ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
  ['Certifications', 'UL 60601-1, NFPA 99, NEC 517'],
  ['Warranty', '2 years parts and labor'],
];

const applications = [
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Surgical Centers', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  { name: 'Imaging Centers', icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z' },
  { name: 'Research Labs', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  { name: 'Clinics', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { name: 'Pharmaceutical', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
];
---

<BaseLayout
  title="Medical Grade Power Systems | UL 60601-1 | 10 to 1250kVA | Online Power"
  description="UL 60601-1 certified medical grade power conditioners and UPS. Under 100µA leakage current. OSHPD/HCAI seismic preapproved. 10kVA to 1,250kVA. Built in Los Angeles."
>

  <!-- HERO -->
  <section class="py-16 md:py-24 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-8">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-voltage transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Medical Grade Systems</span>
      </nav>

      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">UL 60601-1</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">OSHPD/HCAI</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">Made in USA</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-pure leading-tight mb-5">Medical Grade Systems</h1>
          <p class="text-lg text-ash leading-relaxed mb-8">
            In a patient care vicinity, ordinary power protection can be lethal. UL 60601-1 limits leakage current to 100 microamps under normal conditions and 10 microamps at the patient. Thresholds no standard UPS comes close to meeting. APC publicly states their products are not classified as medical grade devices. Online Power's medical grade systems are engineered from the ground up with built-in isolation transformers, Faraday shields, hospital grade connectors, and ultra-low leakage current design validated to UL 60601-1 Third Edition. With OSHPD/HCAI seismic preapproval for California hospital construction and NFPA 99 compliance for wet procedure locations, these systems protect everything from bedside patient monitors to MRI scanners worth $3,000,000 or more.
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {[
              { label: 'Leakage', value: 'Under 100µA · 10µA CF' },
              { label: 'Isolation', value: '4,000 VAC' },
              { label: 'Range', value: '10 to 1,250kVA' },
              { label: 'Certifications', value: 'UL 60601-1 · NFPA 99' },
            ].map(s => (
              <div class="bg-slate border border-steel/30 rounded-lg p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-widest text-ash mb-1">{s.label}</p>
                <p class="font-display text-sm font-bold text-pure">{s.value}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <a href="/contact" class="btn-primary px-6 py-3.5 rounded-lg text-sm font-semibold inline-flex items-center justify-center gap-2">Request an OSHPD Compliant Submittal Package</a>
          </div>
          <p class="font-mono text-xs text-ash">// Responds within 2 business hours</p>
        </div>

        <div class="lg:col-span-2">
          <MedicalGrade />
        </div>
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex gap-1 border-b border-steel/30 mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-voltage border-voltage' : 'text-ash border-transparent hover:text-pure'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">True medical grade, not a standard UPS with a green plug</h3>
            <p class="text-sm text-ash leading-relaxed">UL 60601-1 compliance requires engineered isolation transformers with Faraday shields, verified leakage current at every output, medical EMC testing, and risk management documentation per IEC 14971. Online Power builds all of this in because bolting a hospital grade plug onto a commercial UPS does not make it safe for patient vicinity use.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Protects the imaging equipment that protects your patients</h3>
            <p class="text-sm text-ash leading-relaxed">CT scanners, MRIs, and linear accelerators represent capital investments from $500,000 to $3,000,000 that demand voltage stability within 1 to 3 percent. The Phase Stabilizer independently corrects each phase with sub-cycle response time, eliminating image artifacts, scan interruptions, and the chronic voltage stress that shortens equipment life.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">OSHPD/HCAI seismic preapproval eliminates your biggest permitting delay</h3>
            <p class="text-sm text-ash leading-relaxed">Without OSHPD OSP preapproval, every power system in a California acute care hospital project requires individual seismic certification adding weeks to permitting and tens of thousands in testing costs. Online Power's seismic rated systems are shake-table tested and preapproved, streamlining your OSHPD 1 project from day one.</p>
          </div>
        </div>

        <!-- Technical Callout -->
        <div class="bg-bg-elevated border-l-2 border-voltage p-6 mb-10" style="border-radius: 0 12px 12px 0;">
          <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-3">// What your spec sheet won't tell you</p>
          <p class="text-sm text-ash leading-relaxed">NEC 517.16 prohibits isolated ground receptacles within the patient care vicinity defined as 6 feet around and 7.5 feet above the patient bed. This surprises many engineers. Instead NEC 517.13 requires redundant equipment grounding using two separate paths: metallic raceway plus an insulated copper equipment grounding conductor, with equipotential grounding buses of normal and essential panels connected by at least 6 AWG insulated copper. Line Isolation Monitors in wet procedure locations alarm at 5 milliamps total hazard current but do not interrupt power. This is by design because tripping a circuit during open heart surgery is more dangerous than the leakage current itself. Only 45 percent of California hospitals are currently on track for the 2030 SB 1953 seismic compliance deadline, creating urgent demand for OSHPD preapproved power equipment.</p>
        </div>

        <!-- Codes & Standards -->
        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Codes &amp; Standards</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-16">
          {[
            { code: 'UL 60601-1', desc: 'Medical Electrical Equipment' },
            { code: 'NFPA 99', desc: 'Healthcare Facilities Code' },
            { code: 'NEC Article 517', desc: 'Healthcare Facilities' },
            { code: 'OSHPD/HCAI', desc: 'California Hospital Seismic' },
            { code: 'IEC 14971', desc: 'Medical Device Risk Management' },
            { code: 'NFPA 110', desc: 'Emergency Power Systems' },
          ].map(item => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4">
              <p class="font-display font-bold text-voltage text-sm">{item.code}</p>
              <p class="text-xs text-ash mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-6">// Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-voltage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-pure">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure font-medium mb-1">Medical Equipment Compatibility</p>
          <p class="text-sm text-ash">Designed for MRI, CT, PET, and other imaging systems, as well as surgical and critical care equipment. Contact our engineering team for equipment compatibility verification.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-obsidian border border-steel/30 rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-obsidian' : 'bg-slate/30'} ${i < specs.length - 1 ? 'border-b border-steel/20' : ''}`}>
              <span class="text-sm text-ash font-medium">{label}</span>
              <span class="text-sm text-pure font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure">Need a custom specification? <a href="/contact" class="text-voltage hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-mono text-xs text-ash mb-6">// All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="medical-power" />
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS -->
  <section class="py-16 md:py-24 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">// {categoryProducts.length} Models Available</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="card-glow card-top-accent bg-steel/30 rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-bg-elevated flex items-center justify-center p-4">
              <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-pure mb-1 group-hover:text-voltage transition-colors">{p.name}</h3>
            <p class="font-mono text-xs text-voltage mb-3">{p.tagline}</p>
            <p class="text-sm text-ash mb-4 line-clamp-2">{p.description}</p>
            <span class="text-sm font-medium text-voltage">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-obsidian border border-steel/30 rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-voltage" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-pure text-lg leading-relaxed mb-6 italic">"Online Power's commitment to working closely with my engineers on a design build project in South Florida allowed me the confidence and assurance that I will be getting nothing but the best whenever I have an emergency lighting inverter requirement."</p>
        <div class="border-t border-steel/30 pt-4">
          <p class="font-display font-semibold text-pure">Roberto Kachakil</p>
          <p class="text-sm text-ash">PMP, P.Eng · Credo Consulting Engineers LLC</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-voltage py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-obsidian mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-obsidian text-pure font-semibold rounded-lg hover:bg-slate transition-colors text-sm">Request an OSHPD Compliant Submittal Package</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-obsidian/30 text-obsidian font-semibold rounded-lg hover:bg-obsidian/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-obsidian/95 backdrop-blur border-t border-steel/30 p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <a href="/contact" class="btn-primary w-full py-3.5 rounded-lg text-sm font-semibold flex items-center justify-center gap-2">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      Request a Quote
    </a>
  </div>

</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-voltage', 'border-voltage');
        b.classList.add('text-ash', 'border-transparent');
      });
      btn.classList.remove('text-ash', 'border-transparent');
      btn.classList.add('text-voltage', 'border-voltage');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
