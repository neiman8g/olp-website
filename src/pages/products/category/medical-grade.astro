---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import { Image } from 'astro:assets';
import { getProductImage } from '../../../utils/images';
import MedicalGrade from '../../../components/illustrations/MedicalGrade.astro';

const category = getCategoryBySlug('medical-grade')!;
const categoryProducts = getProductsByCategory('medical-grade');

const specs = [
  ['Input Voltage', '208/480 VAC Three Phase'],
  ['Output Voltage', 'Matches input'],
  ['Frequency', '60 Hz'],
  ['Power Range', '10kVA to 1,250kVA'],
  ['Phase', 'Three Phase (3Ø)'],
  ['Voltage Regulation', '±1% (sub-cycle stabilization)'],
  ['Topology', 'Independent Phase Control'],
  ['Leakage Current', 'Under 100µA (Type B) · Under 10µA (Type CF cardiac)'],
  ['Isolation', '4,000 VAC input to output, Faraday shielded'],
  ['Seismic', 'OSHPD/HCAI preapproved, SDS 3.0G'],
  ['Harmonic Reduction', '12 pulse topology'],
  ['Redundancy', 'Seamless redundant power paths'],
  ['Serviceability', 'Front access only, service without shutdown'],
  ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
  ['Certifications', 'UL 60601-1, NFPA 99, NEC 517'],
  ['Warranty', '1 year parts · 2nd year optional with PM plan'],
];

const applications = [
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Surgical Centers', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  { name: 'Imaging Centers', icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z' },
  { name: 'Research Labs', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  { name: 'Clinics', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { name: 'Pharmaceutical', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
];

const faq = [
  { question: 'What is UL 60601-1 and why does it matter?', answer: 'UL 60601-1 is the US safety standard for medical electrical equipment. It caps chassis leakage current at 100 µA under normal conditions and 10 µA at the patient (Type CF cardiac) under single-fault conditions. Standard UPS products cannot meet these thresholds — they leak hundreds to thousands of microamps, which in a patient-care vicinity can be lethal.' },
  { question: 'Is OSHPD / HCAI certification required for California hospitals?', answer: 'Yes. California hospital construction requires OSHPD (now HCAI) seismic preapproval for essential electrical equipment. Online Power\'s Medical Power and Phase Stabilizer carry OSHPD/HCAI preapproval with SDS 3.0G seismic rating — shaker-table tested and ready for California AHJ submittal.' },
  { question: 'What is NFPA 99 Type 1 Essential Electrical System?', answer: 'NFPA 99 classifies healthcare facilities by risk. Category 1 patient-care spaces — where power loss could cause patient death — require a Type 1 Essential Electrical System that restores power within 10 seconds of utility failure. Medical Power meets this requirement with dual-input redundancy and sub-cycle voltage stabilization.' },
  { question: 'Can Medical Power protect MRI scanners and imaging equipment?', answer: 'Yes. Medical Power delivers ±1% sub-cycle voltage stabilization with Faraday-shielded isolation and independent phase control — the specification required by major MRI, CT, and imaging OEMs to protect sensors calibrated to sub-millivolt tolerances.' },
  { question: 'What is the difference between medical-grade UPS and standard UPS?', answer: 'Medical-grade UPS combines UL 60601-1 leakage compliance, isolation transformer with Faraday shield, hospital-grade power connectors, serviceable-without-shutdown dual input paths, and OSHPD/HCAI seismic certification. Standard UPS does not meet any of these requirements and cannot be installed in a patient-care vicinity under NEC Article 517.' },
];
---

<BaseLayout
  title="UL 60601-1 Medical Grade Power Systems | 10–1,250 kVA | Online Power"
  description="UL 60601-1 certified medical-grade power conditioners and UPS. <100 µA normal / <10 µA Type CF leakage. OSHPD/HCAI seismic preapproved. 10 to 1,250 kVA. NFPA 99 Type 1 EES compatible. Built in Los Angeles."
  faq={faq}
>

  <!-- BREADCRUMB STRIP -->
  <section class="bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
      <nav class="text-[13px] font-display text-slate">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-steel-blue transition-colors">Products</a>
        <span class="mx-2">/</span>
        <span class="text-near-black font-semibold">Medical Grade Systems</span>
      </nav>
    </div>
  </section>

  <!-- ========== HERO — dark with depth ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute -top-32 -right-32 w-[560px] h-[560px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.3) 0%, rgba(37,103,194,0) 70%); filter: blur(12px);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="badge-dark">UL 60601-1</span>
            <span class="badge-dark">OSHPD/HCAI</span>
            <span class="badge-dark">Made in USA</span>
          </div>

          <h1 class="font-display text-4xl md:text-5xl lg:text-[56px] font-extrabold tracking-tight text-white leading-[1.05] mb-5">Medical Grade Systems</h1>
          <p class="text-lg text-muted-blue leading-relaxed max-w-xl mb-8">
            UL 60601-1 caps leakage at 100µA normal, 10µA at the patient — thresholds no standard UPS meets. Built from the ground up with isolation transformers, Faraday shields, hospital-grade connectors, and OSHPD/HCAI seismic preapproval. Protecting patient monitors to $3M MRI scanners.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <Button href="/contact" size="lg" icon="arrow-right">Request OSHPD Submittal</Button>
          </div>
          <p class="font-display text-[13px] text-muted-blue">Responds within 2 business hours</p>
        </div>

        <div class="hidden lg:block lg:col-span-2">
          <MedicalGrade />
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative border-t border-navy-mid" style="z-index: 2;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-navy-mid">
          {[
            { label: 'Leakage', value: '<100µA · 10µA CF' },
            { label: 'Isolation', value: '4,000 VAC' },
            { label: 'Range', value: '10 to 1,250 kVA' },
            { label: 'Certifications', value: 'UL 60601-1 · NFPA 99' },
          ].map(s => (
            <div class="py-6 px-4 md:px-6 text-center md:text-left">
              <p class="font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-blue mb-2">{s.label}</p>
              <p class="font-display text-[15px] md:text-[17px] font-bold text-white leading-tight">{s.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS — models first per emergency-lighting pattern -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-8">{categoryProducts.length} Models Available</p>
      <div class="flex overflow-x-auto snap-x snap-mandatory gap-5 -mx-4 px-4 pb-4 no-scrollbar sm:grid sm:grid-cols-2 lg:grid-cols-3 sm:overflow-visible sm:mx-0 sm:px-0 sm:pb-0">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="snap-start shrink-0 w-[82vw] sm:w-auto sm:shrink card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-off-white flex items-center justify-center p-4">
              {typeof getProductImage(p.image) === 'string' ? (
                <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
              ) : (
                <Image src={getProductImage(p.image) as ImageMetadata} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
              )}
            </div>
            <div class="p-6">
              <h3 class="font-display text-2xl font-semibold text-near-black mb-1 group-hover:text-steel-blue transition-colors">{p.name}</h3>
              <p class="font-display font-semibold text-xs text-steel-blue mb-3">{p.tagline}</p>
              <p class="text-base text-slate mb-4 line-clamp-2">{p.description}</p>
              <span class="text-[15px] font-medium text-steel-blue">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

    <!-- OVERVIEW -->
  <section class="py-10 md:py-14 bg-white border-t border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Overview</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">True medical grade, not a standard UPS with a green plug</h3>
            <p class="text-base text-slate leading-relaxed">UL 60601-1 compliance requires engineered isolation transformers with Faraday shields, verified leakage current at every output, medical EMC testing, and risk management documentation per IEC 14971. Online Power builds all of this in because bolting a hospital grade plug onto a commercial UPS does not make it safe for patient vicinity use.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Protects the imaging equipment that protects your patients</h3>
            <p class="text-base text-slate leading-relaxed">CT scanners, MRIs, and linear accelerators represent capital investments from $500,000 to $3,000,000 that demand voltage stability within 1 to 3 percent. The Phase Stabilizer independently corrects each phase with sub-cycle response time, eliminating image artifacts, scan interruptions, and the chronic voltage stress that shortens equipment life.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">OSHPD/HCAI seismic preapproval eliminates your biggest permitting delay</h3>
            <p class="text-base text-slate leading-relaxed">Without OSHPD OSP preapproval, every power system in a California acute care hospital project requires individual seismic certification adding weeks to permitting and tens of thousands in testing costs. Online Power's seismic rated systems are shake-table tested and preapproved, streamlining your OSHPD 1 project from day one.</p>
          </div>
        </div>

        <!-- Technical Callout -->
        <div class="bg-off-white border-l-2 border-steel-blue p-6 mb-10" style="border-radius: 0 12px 12px 0;">
          <p class="eyebrow text-steel-blue mb-3">What your spec sheet won't tell you</p>
          <p class="text-base text-slate leading-relaxed">NEC 517.16 prohibits isolated ground receptacles within the patient care vicinity defined as 6 feet around and 7.5 feet above the patient bed. This surprises many engineers. Instead NEC 517.13 requires redundant equipment grounding using two separate paths: metallic raceway plus an insulated copper equipment grounding conductor, with equipotential grounding buses of normal and essential panels connected by at least 6 AWG insulated copper. Line Isolation Monitors in wet procedure locations alarm at 5 milliamps total hazard current but do not interrupt power. This is by design because tripping a circuit during open heart surgery is more dangerous than the leakage current itself. Only 45 percent of California hospitals are currently on track for the 2030 SB 1953 seismic compliance deadline, creating urgent demand for OSHPD preapproved power equipment.</p>
        </div>

        <!-- Codes & Standards -->
        <p class="eyebrow text-steel-blue mb-4">Codes &amp; Standards</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-16">
          {[
            { code: 'UL 60601-1', desc: 'Medical Electrical Equipment' },
            { code: 'NFPA 99', desc: 'Healthcare Facilities Code' },
            { code: 'NEC Article 517', desc: 'Healthcare Facilities' },
            { code: 'OSHPD/HCAI', desc: 'California Hospital Seismic' },
            { code: 'IEC 14971', desc: 'Medical Device Risk Management' },
            { code: 'NFPA 110', desc: 'Emergency Power Systems' },
          ].map(item => (
            <div class="bg-white border border-steel-gray rounded-lg p-4">
              <p class="font-display font-bold text-steel-blue text-sm">{item.code}</p>
              <p class="text-xs text-slate mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <p class="eyebrow text-steel-blue mb-6">Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-white border border-steel-gray rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-steel-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-near-black">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black font-medium mb-1">Medical Equipment Compatibility</p>
          <p class="text-base text-slate">Designed for MRI, CT, PET, and other imaging systems, as well as surgical and critical care equipment. Contact our engineering team for equipment compatibility verification.</p>
        </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-white border border-steel-gray rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-steel-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-near-black text-lg leading-relaxed mb-6 italic">"Online Power's commitment to working closely with my engineers on a design build project in South Florida allowed me the confidence and assurance that I will be getting nothing but the best whenever I have an emergency lighting inverter requirement."</p>
        <div class="border-t border-steel-gray pt-4">
          <p class="font-display font-semibold text-near-black">Roberto Kachakil</p>
          <p class="text-base text-slate">PMP, P.Eng · Credo Consulting Engineers LLC</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="py-10 md:py-14 bg-off-white border-t border-steel-gray">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Common Questions</p>
      <h2 class="font-display text-3xl font-extrabold tracking-tight text-near-black mb-8 leading-[1.1]">Medical Grade FAQ</h2>
      <div class="space-y-3">
        {faq.map(item => (
          <details class="group bg-white border border-steel-gray rounded-xl overflow-hidden hover:border-steel-blue transition-colors">
            <summary class="flex items-start gap-4 p-5 cursor-pointer">
              <span class="font-display text-[15px] font-semibold text-near-black flex-1 group-hover:text-steel-blue transition-colors">{item.question}</span>
              <svg class="w-4 h-4 text-slate group-open:rotate-180 group-open:text-steel-blue transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </summary>
            <div class="px-5 pb-5 text-[15px] text-slate leading-relaxed">{item.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== RELATED CATEGORIES ========== -->
  <section class="py-10 md:py-14 bg-white border-t border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Related Product Lines</p>
      <h2 class="font-display text-2xl md:text-3xl font-extrabold tracking-tight text-near-black mb-8 leading-[1.1]">Explore More from Online Power</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {[
          { href: '/products/category/ups-backup', name: 'UPS Backup Systems', desc: 'UL 1778 online double-conversion for non-patient critical loads.' },
          { href: '/products/category/isolation-transformers', name: 'Isolation Transformers', desc: 'Noise & harmonic cancellation for medical imaging and research labs.' },
          { href: '/products/category/emergency-lighting', name: 'Emergency Lighting Inverters', desc: 'OSHPD/HCAI seismic certified SV Power Wave series for hospitals.' },
        ].map(c => (
          <a href={c.href} class="group bg-white border border-steel-gray rounded-xl p-6 hover:border-steel-blue hover:shadow-[0_12px_28px_-10px_rgba(37,103,194,0.25)] hover:-translate-y-0.5 transition-all">
            <h3 class="font-display text-xl font-bold text-near-black group-hover:text-steel-blue transition-colors mb-2">{c.name}</h3>
            <p class="text-[14px] text-slate mb-4">{c.desc}</p>
            <span class="font-display text-[12px] font-bold uppercase tracking-[0.12em] text-steel-blue group-hover:text-near-black inline-flex items-center gap-1.5 transition-colors">
              Explore
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-steel-blue text-white font-semibold rounded hover:bg-steel-blue/90 transition-colors text-sm">Request an OSHPD Compliant Submittal Package</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded hover:bg-white/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-deep-navy/95 backdrop-blur border-t border-steel-gray p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <Button href="/contact" size="lg" icon="bolt" fullWidth>Request a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
      btn.classList.remove('text-slate', 'border-transparent');
      btn.classList.add('text-steel-blue', 'border-steel-blue');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
