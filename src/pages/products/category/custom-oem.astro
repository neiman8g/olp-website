---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';

const category = getCategoryBySlug('custom-oem')!;
const categoryProducts = getProductsByCategory('custom-oem');

const specs = [
  ['Experience', '48 years of custom engineering'],
  ['Certification', 'ISO 9001 quality management'],
  ['Location', 'Los Angeles, California'],
  ['Type', 'Built to specification'],
  ['Frequency Conversion', '50/60/400 Hz'],
  ['Voltage Modification', 'AC & DC, any voltage'],
  ['Global Input', 'Multi-voltage for worldwide use'],
  ['Noise Isolation', 'Application-specific filtering'],
  ['Distribution', 'Integrated monitoring optional'],
  ['Battery Backup', 'Optional UPS integration'],
  ['Certifications', 'Application-specific (UL, CE, etc.)'],
  ['Warranty', 'Project-specific terms'],
];

const applications = [
  { name: 'Military & Defense', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
  { name: 'Aerospace', icon: 'M12 19l9 2-9-18-9 18 9-2zm0 0v-8' },
  { name: 'Industrial', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { name: 'Maritime', icon: 'M3 17l6-6 4 4 8-8M14 7h7m0 0v7' },
  { name: 'Broadcast', icon: 'M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 010-7.072m-2.828 9.9a9 9 0 010-12.728' },
  { name: 'Research Labs', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  { name: 'Oil & Gas', icon: 'M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z' },
  { name: 'OEM Partners', icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
];
---

<BaseLayout
  title="Custom OEM Power Solutions | 48 Years Experience | Online Power"
  description="Custom power supply units engineered to your specification. Frequency conversion, voltage modification, and complete power systems. 48 years experience. Built in Los Angeles."
>

  <!-- HERO -->
  <section class="py-16 md:py-24 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-8">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-voltage transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Custom OEM</span>
      </nav>

      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">ISO 9001</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">48 Years</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">Made in USA</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-pure leading-tight mb-5">Custom OEM Solutions</h1>
          <p class="text-lg text-ash leading-relaxed mb-8">
            Custom power supply units engineered to your specification. Frequency conversion, voltage modification, and complete power systems. Built in Los Angeles.
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {[
              { label: 'Experience', value: '48 Years' },
              { label: 'Certified', value: 'ISO 9001' },
              { label: 'Location', value: 'Los Angeles' },
              { label: 'Type', value: 'Built to Spec' },
            ].map(s => (
              <div class="bg-slate border border-steel/30 rounded-lg p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-widest text-ash mb-1">{s.label}</p>
                <p class="font-display text-sm font-bold text-pure">{s.value}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <a href="/contact" class="btn-primary px-6 py-3.5 rounded-lg text-sm font-semibold inline-flex items-center justify-center gap-2">Request a Quote</a>
            <button class="btn-ghost px-6 py-3.5 rounded-lg text-sm inline-flex items-center justify-center gap-2 doc-download-btn" data-url="/pdf/fc_DS.pdf" data-name="Frequency Converter - Spec Sheet" data-product="Custom OEM Solutions">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"></path></svg>
              Download Spec Sheet
            </button>
          </div>
          <p class="font-mono text-xs text-ash">// Responds within 2 business hours</p>
        </div>

        <div class="lg:col-span-2">
          <div style="background:#0D1520;border-radius:12px;overflow:hidden;width:100%;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes oem-draw { 0%{stroke-dashoffset:1000;} 80%{stroke-dashoffset:0;} 100%{stroke-dashoffset:0;} }
                @keyframes oem-fade { 0%,70%{opacity:0;} 80%{opacity:1;} }
                .oem-line{stroke-dasharray:1000;animation:oem-draw 4s ease-out forwards;}
                .oem-fade{animation:oem-fade 4s ease-out forwards;}
              </style>
              <!-- Grid -->
              <line x1="0" y1="40" x2="600" y2="40" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="0" y1="80" x2="600" y2="80" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="0" y1="120" x2="600" y2="120" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="0" y1="160" x2="600" y2="160" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="0" y1="200" x2="600" y2="200" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="0" y1="240" x2="600" y2="240" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="60" y1="0" x2="60" y2="320" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="120" y1="0" x2="120" y2="320" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="180" y1="0" x2="180" y2="320" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="240" y1="0" x2="240" y2="320" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="300" y1="0" x2="300" y2="320" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="360" y1="0" x2="360" y2="320" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="420" y1="0" x2="420" y2="320" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="480" y1="0" x2="480" y2="320" stroke="#1C2B3A" stroke-width="0.2"/>
              <line x1="540" y1="0" x2="540" y2="320" stroke="#1C2B3A" stroke-width="0.2"/>
              <!-- Enclosure outline (drawn progressively) -->
              <rect x="100" y="50" width="300" height="180" rx="4" fill="none" stroke="#00E5FF" stroke-width="1" class="oem-line"/>
              <!-- Internal components -->
              <rect x="130" y="80" width="80" height="50" rx="2" fill="none" stroke="#00E5FF" stroke-width="0.5" class="oem-line" style="animation-delay:0.5s;"/>
              <rect x="230" y="80" width="60" height="50" rx="2" fill="none" stroke="#00E5FF" stroke-width="0.5" class="oem-line" style="animation-delay:0.8s;"/>
              <rect x="310" y="80" width="60" height="120" rx="2" fill="none" stroke="#00E5FF" stroke-width="0.5" class="oem-line" style="animation-delay:1s;"/>
              <rect x="130" y="150" width="80" height="60" rx="2" fill="none" stroke="#00E5FF" stroke-width="0.5" class="oem-line" style="animation-delay:1.3s;"/>
              <!-- Dimension lines -->
              <line x1="100" y1="250" x2="400" y2="250" stroke="#8A9BAE" stroke-width="0.5" class="oem-line" style="animation-delay:1.5s;"/>
              <line x1="100" y1="245" x2="100" y2="255" stroke="#8A9BAE" stroke-width="0.5" class="oem-line" style="animation-delay:1.5s;"/>
              <line x1="400" y1="245" x2="400" y2="255" stroke="#8A9BAE" stroke-width="0.5" class="oem-line" style="animation-delay:1.5s;"/>
              <line x1="420" y1="50" x2="420" y2="230" stroke="#8A9BAE" stroke-width="0.5" class="oem-line" style="animation-delay:1.8s;"/>
              <line x1="415" y1="50" x2="425" y2="50" stroke="#8A9BAE" stroke-width="0.5" class="oem-line" style="animation-delay:1.8s;"/>
              <line x1="415" y1="230" x2="425" y2="230" stroke="#8A9BAE" stroke-width="0.5" class="oem-line" style="animation-delay:1.8s;"/>
              <!-- Callout lines -->
              <line x1="170" y1="80" x2="170" y2="30" stroke="#8A9BAE" stroke-width="0.3" class="oem-line" style="animation-delay:2s;"/>
              <text x="170" y="26" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#8A9BAE" class="oem-fade">TRANSFORMER</text>
              <line x1="260" y1="80" x2="260" y2="40" stroke="#8A9BAE" stroke-width="0.3" class="oem-line" style="animation-delay:2.2s;"/>
              <text x="260" y="36" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#8A9BAE" class="oem-fade">REGULATOR</text>
              <line x1="340" y1="205" x2="340" y2="270" stroke="#8A9BAE" stroke-width="0.3" class="oem-line" style="animation-delay:2.4s;"/>
              <text x="340" y="280" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#8A9BAE" class="oem-fade">DISTRIBUTION</text>
              <!-- Title block -->
              <rect x="440" y="230" width="150" height="80" rx="2" fill="#0D1117" stroke="#1C2B3A" stroke-width="0.5" class="oem-fade" opacity="0"/>
              <line x1="440" y1="250" x2="590" y2="250" stroke="#1C2B3A" stroke-width="0.3" class="oem-fade" opacity="0"/>
              <line x1="440" y1="270" x2="590" y2="270" stroke="#1C2B3A" stroke-width="0.3" class="oem-fade" opacity="0"/>
              <text x="515" y="245" text-anchor="middle" font-family="Space Grotesk,sans-serif" font-size="8" font-weight="700" fill="#F8FAFC" class="oem-fade" opacity="0">CUSTOM OEM SOLUTION</text>
              <text x="515" y="264" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#8A9BAE" class="oem-fade" opacity="0">DESIGNED IN LOS ANGELES</text>
              <text x="515" y="284" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#8A9BAE" class="oem-fade" opacity="0">REV A</text>
              <text x="515" y="302" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#00E5FF" class="oem-fade" opacity="0">ONLINE POWER, INC.</text>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex gap-1 border-b border-steel/30 mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-voltage border-voltage' : 'text-ash border-transparent hover:text-pure'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-16">
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Engineered to Spec</h3>
            <p class="text-sm text-ash">48 years of custom power engineering. Every unit designed and built to your exact requirements with full engineering support throughout the process.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Frequency Conversion</h3>
            <p class="text-sm text-ash">Industrial frequency converters with true galvanic isolation and ±0.1Hz accuracy. 50/60/400Hz conversion with DSP and IGBT technology.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Global Compatibility</h3>
            <p class="text-sm text-ash">Multi-voltage input systems for worldwide deployment. AC/DC voltage conversion, noise isolation, and plug-and-play system integration.</p>
          </div>
        </div>

        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-6">// Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-voltage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-pure">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure font-medium mb-1">Start Your Custom Project</p>
          <p class="text-sm text-ash">From initial concept to final delivery, our engineering team works with you at every stage. Contact us with your requirements and we will provide a detailed proposal and timeline.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-obsidian border border-steel/30 rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-obsidian' : 'bg-slate/30'} ${i < specs.length - 1 ? 'border-b border-steel/20' : ''}`}>
              <span class="text-sm text-ash font-medium">{label}</span>
              <span class="text-sm text-pure font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure">Need a custom specification? <a href="/contact" class="text-voltage hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-mono text-xs text-ash mb-6">// All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="frequency-converter" />
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS -->
  <section class="py-16 md:py-24 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">// {categoryProducts.length} Models Available</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="card-glow card-top-accent bg-steel/30 rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-bg-elevated flex items-center justify-center p-4">
              <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-pure mb-1 group-hover:text-voltage transition-colors">{p.name}</h3>
            <p class="font-mono text-xs text-voltage mb-3">{p.tagline}</p>
            <p class="text-sm text-ash mb-4 line-clamp-2">{p.description}</p>
            <span class="text-sm font-medium text-voltage">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-obsidian border border-steel/30 rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-voltage" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-pure text-lg leading-relaxed mb-6 italic">"Online Power designed a custom frequency converter that met our exact specifications. Their 48 years of experience shows in every detail of the engineering."</p>
        <div class="border-t border-steel/30 pt-4">
          <p class="font-display font-semibold text-pure">Tom Nakamura</p>
          <p class="text-sm text-ash">Defense Systems Integrator</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-voltage py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-obsidian mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-obsidian text-pure font-semibold rounded-lg hover:bg-slate transition-colors text-sm">Request a Quote</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-obsidian/30 text-obsidian font-semibold rounded-lg hover:bg-obsidian/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-obsidian/95 backdrop-blur border-t border-steel/30 p-3 z-40 lg:hidden" id="mobile-sticky-cta" style="display:none;">
    <a href="/contact" class="btn-primary w-full py-3.5 rounded-lg text-sm font-semibold flex items-center justify-center gap-2">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      Request a Quote
    </a>
  </div>

</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-voltage', 'border-voltage');
        b.classList.add('text-ash', 'border-transparent');
      });
      btn.classList.remove('text-ash', 'border-transparent');
      btn.classList.add('text-voltage', 'border-voltage');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
