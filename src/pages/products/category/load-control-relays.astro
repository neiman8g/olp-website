---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import { Image } from 'astro:assets';
import { getProductImage } from '../../../utils/images';
import LoadControlRelays from '../../../components/illustrations/LoadControlRelays.astro';

const category = getCategoryBySlug('load-control-relays')!;
const categoryProducts = getProductsByCategory('load-control-relays');

const specs = [
  ['Standard', 'UL 924, UL 1778, NFPA 101'],
  ['Override', '0-10V dimmer override'],
  ['Rating', 'IP65 rated connections'],
  ['Test Switch', 'Quick-connect IP65 rated'],
  ['Housing', 'Aluminum case'],
  ['Mounting', 'Surface mount'],
  ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
  ['Compatibility', 'LED and fluorescent fixtures'],
  ['Dimming Protocol', '0-10V'],
  ['Emergency Mode', 'Full brightness override'],
  ['Certifications', 'UL 924, UL 1778, NFPA 101'],
  ['Warranty', '5 years parts and labor'],
];

const applications = [
  { name: 'High-Rise Office', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Schools & Universities', icon: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z' },
  { name: 'Hotels', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { name: 'Retail', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
];
---

<BaseLayout
  title="Load Control Relays | UL924 | IP65 | Online Power"
  description="UL924 automatic load control relays for emergency lighting dimmer override. 0-10V override, IP65 rated, 5-year warranty. Built in Los Angeles."
>

  <!-- HERO -->
  <section class="py-16 md:py-24 bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="eyebrow text-slate mb-8">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-steel-blue transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-steel-blue">Load Control Relays</span>
      </nav>

      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="badge-light">UL 924</span>
            <span class="badge-light">IP65</span>
            <span class="badge-light">Made in USA</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-near-black leading-tight mb-5">Load Control Relays</h1>
          <p class="text-lg text-slate leading-relaxed mb-8">
            UL924 automatic load control relays for emergency lighting dimmer override. IP65 rated. 5-year warranty.
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {[
              { label: 'Standard', value: 'UL924' },
              { label: 'Override', value: '0-10V' },
              { label: 'Rating', value: 'IP65' },
              { label: 'Warranty', value: '5 Years' },
            ].map(s => (
              <div class="bg-off-white border border-steel-gray rounded-lg p-3 text-center">
                <p class="font-display text-[9px] font-semibold uppercase tracking-[0.1em] text-slate mb-1">{s.label}</p>
                <p class="font-display text-sm font-bold text-near-black">{s.value}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <Button href="/contact" size="lg">Request a Quote</Button>
          </div>
          <p class="font-display text-xs text-slate">Responds within 2 business hours</p>
        </div>

        <div class="hidden lg:block lg:col-span-2">
          <LoadControlRelays />
        </div>
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="py-16 md:py-24 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex gap-1 border-b border-steel-gray mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-steel-blue border-steel-blue' : 'text-slate border-transparent hover:text-near-black'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-16">
          <div class="card-glow bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-near-black mb-2">Automatic Dimmer Override</h3>
            <p class="text-sm text-slate">Automatically overrides 0-10V dimming controls during emergency conditions to bring lighting to full brightness for safe evacuation.</p>
          </div>
          <div class="card-glow bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-near-black mb-2">IP65 Rated</h3>
            <p class="text-sm text-slate">IP65 rated quick-connect test switch in durable aluminum housing. Built for reliable operation in demanding commercial environments.</p>
          </div>
          <div class="card-glow bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-near-black mb-2">5-Year Warranty</h3>
            <p class="text-sm text-slate">Industry-leading 5-year warranty demonstrates our confidence in the LCR20's reliability and long-term performance.</p>
          </div>
        </div>

        <p class="eyebrow text-steel-blue mb-6">Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-white border border-steel-gray rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-steel-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-near-black">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black font-medium mb-1">Dimming System Compatibility</p>
          <p class="text-sm text-slate">Compatible with all 0-10V dimming systems including Lutron, Leviton, and Wattstopper. Contact our engineering team for dimming system compatibility verification.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-white border border-steel-gray rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-white' : 'bg-off-white'} ${i < specs.length - 1 ? 'border-b border-steel-gray' : ''}`}>
              <span class="text-sm text-slate font-medium">{label}</span>
              <span class="text-sm text-near-black font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black">Need a custom specification? <a href="/contact" class="text-steel-blue hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-display text-xs text-slate mb-6">All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="lcr20" />
      </div>
    </div>
  </section>

  <!-- KEY FEATURES -->
  <section class="py-16 md:py-24 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-6">Key Features</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {['UL924 Listed', '0-10V Dimmer Override', 'IP65 Rated Connections', 'Quick-Connect Test Switch', 'Aluminum Case', '5-Year Warranty'].map(feature => (
          <div class="flex items-start gap-3 bg-off-white border border-steel-gray rounded-lg p-4">
            <svg class="w-5 h-5 text-steel-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-sm text-near-black">{feature}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DOCUMENTS -->
  <section class="py-16 md:py-24 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <DocumentGate productSlug="lcr20" />
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <section class="py-16 md:py-24 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-8">Related Products</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <a href="/products/category/emergency-lighting" class="card-glow card-top-accent bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-off-white flex items-center justify-center p-4">
            {typeof getProductImage('/images/products/power-wave-1.png') === 'string' ? (
              <img src="/images/products/power-wave-1.png" alt="Emergency Lighting by Online Power" class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" />
            ) : (
              <Image src={getProductImage('/images/products/power-wave-1.png') as ImageMetadata} alt="Emergency Lighting by Online Power" class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
            )}
          </div>
          <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-near-black mb-1 group-hover:text-steel-blue transition-colors">Emergency Lighting Inverters</h3>
            <p class="text-sm text-slate mb-4">UL924 emergency lighting inverters from 35W to 400kW</p>
            <span class="text-sm font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>
        <a href="/products/category/elevator-backup" class="card-glow card-top-accent bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-off-white flex items-center justify-center p-4">
            {typeof getProductImage('/images/products/elevate.png') === 'string' ? (
              <img src="/images/products/elevate.png" alt="Elevator Backup by Online Power" class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" />
            ) : (
              <Image src={getProductImage('/images/products/elevate.png') as ImageMetadata} alt="Elevator Backup by Online Power" class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
            )}
          </div>
          <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-near-black mb-1 group-hover:text-steel-blue transition-colors">Elevator Backup Systems</h3>
            <p class="text-sm text-slate mb-4">UL924 elevator backup for safe evacuation</p>
            <span class="text-sm font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>
        <a href="/products/category/voltage-regulators" class="card-glow card-top-accent bg-white rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-off-white flex items-center justify-center p-4">
            {typeof getProductImage('/images/products/voltage-regulators.png') === 'string' ? (
              <img src="/images/products/voltage-regulators.png" alt="Voltage Regulators by Online Power" class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" />
            ) : (
              <Image src={getProductImage('/images/products/voltage-regulators.png') as ImageMetadata} alt="Voltage Regulators by Online Power" class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
            )}
          </div>
          <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-near-black mb-1 group-hover:text-steel-blue transition-colors">Voltage Regulators</h3>
            <p class="text-sm text-slate mb-4">Power conditioning and voltage regulation systems</p>
            <span class="text-sm font-medium text-steel-blue">View Products &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-steel-blue text-white font-semibold rounded-lg hover:bg-steel-blue/90 transition-colors text-sm">Request a Quote</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-deep-navy/95 backdrop-blur border-t border-steel-gray p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <Button href="/contact" size="lg" icon="bolt" fullWidth>Request a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-steel-blue', 'border-steel-blue');
        b.classList.add('text-slate', 'border-transparent');
      });
      btn.classList.remove('text-slate', 'border-transparent');
      btn.classList.add('text-steel-blue', 'border-steel-blue');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
