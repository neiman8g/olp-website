---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';

const category = getCategoryBySlug('fire-alarm-backup')!;
const categoryProducts = getProductsByCategory('fire-alarm-backup');

const specs = [
  ['Input Voltage', '120/208/240/277/480 VAC'],
  ['Output Voltage', 'Matches input'],
  ['Frequency', '60 Hz'],
  ['Power Range', 'Scaled to NAC circuit requirements'],
  ['Transfer Time', 'Zero (online double conversion)'],
  ['Efficiency', '>92% at full load'],
  ['Battery Type', 'Sealed VRLA'],
  ['Battery Runtime', '24 hours standby + 5-minute alarm per NFPA 72 §10.6.7.2 · 15-minute alarm for voice evacuation systems'],
  ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
  ['Enclosure', 'NEMA 1 standard'],
  ['Certifications', 'UL 1481, NFPA 72'],
  ['Warranty', '2 years parts and labor'],
];

const applications = [
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Schools & Universities', icon: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z' },
  { name: 'High-Rise Office', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
  { name: 'Hotels', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { name: 'Retail', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
  { name: 'Industrial', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { name: 'Data Centers', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
];
---

<BaseLayout
  title="Fire Alarm Backup Systems | UL1481 | NFPA 72 | Online Power"
  description="UL1481 fire alarm notification appliance circuit backup systems. Continuous power for life safety compliance. NFPA 72 compliant. Built in Los Angeles. ISO 9001."
>

  <!-- HERO -->
  <section class="py-16 md:py-24 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-8">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-voltage transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Fire Alarm Backup</span>
      </nav>

      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <!-- Left: Content -->
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">UL 1481</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">NFPA 72</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">Made in USA</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-pure leading-tight mb-5">Fire Alarm Backup Systems</h1>
          <p class="text-lg text-ash leading-relaxed mb-8">
            When a fire alarm panel loses utility power, NFPA 72 demands 24 hours of standby plus 5 minutes of full alarm, and 15 minutes if you have voice evacuation. Internal panel batteries max out at 55Ah, which means any large building, high-rise, or voice evacuation system needs external backup power. Online Power's UL 1481 listed Fire Alarm Backup powers the entire fire alarm control panel with zero transfer time, not just individual NAC circuits like commodity extenders. From 500W to 15kW, it scales from a single panel to campus-wide systems, with supervised battery charging and Form-C trouble relay contacts for full monitoring integration.
          </p>

          <!-- Key Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {[
              { label: 'Standby', value: '24hr Standby · 5min Alarm' },
              { label: 'Standard', value: 'NFPA 72 §10.6.7.2' },
              { label: 'Transfer', value: 'Zero (online)' },
              { label: 'Certifications', value: 'UL 1481 · NFPA 72' },
            ].map(s => (
              <div class="bg-slate border border-steel/30 rounded-lg p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-widest text-ash mb-1">{s.label}</p>
                <p class="font-display text-sm font-bold text-pure">{s.value}</p>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <a href="/contact" class="btn-primary px-6 py-3.5 rounded-lg text-sm font-semibold inline-flex items-center justify-center gap-2">Send Us Your Panel Load Calculation · We Will Size and Submit in 48 Hours</a>
            <button class="btn-ghost px-6 py-3.5 rounded-lg text-sm inline-flex items-center justify-center gap-2 doc-download-btn" data-url="/pdf/fab_DS.pdf" data-name="Fire Alarm Backup - Spec Sheet" data-product="Fire Alarm Backup Systems">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"></path></svg>
              Download Spec Sheet
            </button>
          </div>
          <p class="font-mono text-xs text-ash">// Responds within 2 business hours</p>
        </div>

        <!-- Right: Animated SVG -->
        <div class="lg:col-span-2">
          <div style="background:#0A0A0F;border-radius:12px;overflow:hidden;width:100%;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes fa-detect { 0%,25%{r:4;fill:#8A9BAE;} 30%{r:8;fill:#FF3B3B;} 85%{r:4;fill:#FF3B3B;} 90%{r:4;fill:#8A9BAE;} }
                @keyframes fa-pulse { 0%,28%{opacity:0;r:8;} 32%{opacity:0.6;r:20;} 40%{opacity:0;r:30;} 100%{opacity:0;} }
                @keyframes fa-horn { 0%,32%{opacity:0.2;} 35%{opacity:1;} 35.5%{opacity:0.2;} 36%{opacity:1;} 36.5%{opacity:0.2;} 37%{opacity:1;} 85%{opacity:1;} 90%{opacity:0.2;} }
                @keyframes fa-panel { 0%,30%{stroke:#1C2B3A;} 33%{stroke:#00E5FF;} 85%{stroke:#00E5FF;} 90%{stroke:#1C2B3A;} }
                @keyframes fa-backup { 0%,34%{opacity:0;} 38%,85%{opacity:1;} 90%{opacity:0;} }
                .fa-det{animation:fa-detect 7s ease-in-out infinite;}
                .fa-pulse{animation:fa-pulse 7s ease-in-out infinite;}
                .fa-horn{animation:fa-horn 7s ease-in-out infinite;}
                .fa-panel{animation:fa-panel 7s ease-in-out infinite;}
                .fa-bk{animation:fa-backup 7s ease-in-out infinite;}
              </style>
              <!-- Floor plan -->
              <rect x="100" y="40" width="400" height="220" rx="4" fill="none" stroke="#1C2B3A" stroke-width="1.5"/>
              <!-- Room dividers -->
              <line x1="300" y1="40" x2="300" y2="180" stroke="#1C2B3A" stroke-width="0.5"/>
              <line x1="100" y1="180" x2="500" y2="180" stroke="#1C2B3A" stroke-width="0.5"/>
              <!-- Detectors -->
              <circle cx="160" cy="80" r="4" class="fa-det" fill="#8A9BAE"/>
              <circle cx="440" cy="80" r="4" fill="#8A9BAE" opacity="0.5"/>
              <circle cx="160" cy="220" r="4" fill="#8A9BAE" opacity="0.5"/>
              <circle cx="440" cy="220" r="4" fill="#8A9BAE" opacity="0.5"/>
              <!-- Red pulse from activated detector -->
              <circle cx="160" cy="80" class="fa-pulse" fill="#FF3B3B" opacity="0" r="8"/>
              <!-- Smoke waves on detector -->
              <path d="M152 72 Q156 68 160 72 Q164 68 168 72" stroke="#8A9BAE" stroke-width="0.5" fill="none" opacity="0.4"/>
              <path d="M152 68 Q156 64 160 68 Q164 64 168 68" stroke="#8A9BAE" stroke-width="0.5" fill="none" opacity="0.3"/>
              <!-- Panel -->
              <rect x="105" y="100" width="40" height="60" rx="3" class="fa-panel" fill="#111827" stroke="#1C2B3A" stroke-width="1"/>
              <text x="125" y="126" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#8A9BAE">FACP</text>
              <text x="125" y="136" text-anchor="middle" font-family="Space Mono,monospace" font-size="5" fill="#8A9BAE">PANEL</text>
              <!-- Horn/strobes -->
              <rect x="230" y="42" width="12" height="8" rx="1" fill="#FF3B3B" class="fa-horn" opacity="0.2"/>
              <rect x="370" y="42" width="12" height="8" rx="1" fill="#FF3B3B" class="fa-horn" opacity="0.2" style="animation-delay:0.15s;"/>
              <rect x="230" y="252" width="12" height="8" rx="1" fill="#FF3B3B" class="fa-horn" opacity="0.2" style="animation-delay:0.1s;"/>
              <rect x="370" y="252" width="12" height="8" rx="1" fill="#FF3B3B" class="fa-horn" opacity="0.2" style="animation-delay:0.2s;"/>
              <!-- Backup unit -->
              <rect x="105" y="170" width="40" height="24" rx="2" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <circle cx="140" cy="182" r="3" fill="#00E5FF" class="fa-bk" opacity="0"/>
              <!-- Backup text -->
              <text x="300" y="300" text-anchor="middle" font-family="Space Mono,monospace" font-size="9" fill="#00E5FF" class="fa-bk" opacity="0">BACKUP ACTIVE</text>
              <!-- Label -->
              <text x="300" y="312" text-anchor="middle" font-family="Space Mono,monospace" font-size="7" fill="#2A3A4A">// UL1481 FIRE ALARM BACKUP SEQUENCE</text>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <!-- Tab Buttons -->
      <div class="flex gap-1 border-b border-steel/30 mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-voltage border-voltage' : 'text-ash border-transparent hover:text-pure'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <!-- Benefit Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Back up the entire panel, not just the NAC circuits</h3>
            <p class="text-sm text-ash leading-relaxed">NAC power extenders only add notification circuit capacity. Online Power's Fire Alarm Backup provides AC power to the FACP itself, backing up every function: addressable loops, signaling line circuits, NAC outputs, communications, and supervisory circuits. One UPS. Complete protection.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Zero transfer means zero panel reset</h3>
            <p class="text-sm text-ash leading-relaxed">Standard battery switchover can cause a momentary power interruption that resets the fire alarm control panel, losing alarm history, zone status, and potentially triggering false trouble signals to the monitoring station. True online double conversion eliminates this risk entirely.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">VRLA batteries with 10-year design life</h3>
            <p class="text-sm text-ash leading-relaxed">Panel-internal batteries typically last 3-5 years and require semi-annual testing under NFPA 72 §14.4. Online Power's premium VRLA batteries deliver 10-year expected life with 250+ discharge cycles. The integrated supervised charger meets NFPA 72's 48-hour full-recharge requirement per §10.6.10.3.2 and monitors for low voltage, charger failure, and ground faults.</p>
          </div>
        </div>

        <!-- Technical Callout -->
        <div class="bg-bg-elevated border-l-2 border-voltage p-6 mb-10" style="border-radius: 0 12px 12px 0;">
          <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-3">// What your spec sheet won't tell you</p>
          <p class="text-sm text-ash leading-relaxed">NFPA 72 §10.6.7.2 requires a 20% safety margin in all battery calculations. The formula is: Battery Capacity (Ah) = [(Standby Current × 24h) + (Alarm Current × 0.0833h)] × 1.20. Most specifiers run this math against panel-internal batteries and find they are undersized on day one. The bigger trap: NFPA 72 §10.6.10.3.2 requires batteries to recharge fully within 48 hours after complete discharge. Many fire alarm panels have chargers sized for their maximum internal battery, not for an oversized external battery bank. An external UPS with its own properly sized charger solves both problems. Also note: effective January 2024 under NFPA 72 2022 edition, all rechargeable batteries used as secondary fire alarm power must be listed per UL 1989 or UL 2054.</p>
        </div>

        <!-- Custom Alarm Mode Options -->
        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Custom Alarm Mode Options</p>
        <p class="text-sm text-ash leading-relaxed mb-6">Every building has different fire alarm loads, panel configurations, and code requirements. Online Power engineers each Fire Alarm Backup system to your exact specification. Tell us your panel make and model, your NAC circuit load in amps, your standby current draw, and your jurisdiction and we will size the system, calculate the battery capacity with the NFPA 72 required 20% safety margin, and provide a complete submittal package.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-16">
          <div class="bg-bg-elevated card-top-accent rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="font-display text-base font-semibold text-pure mb-2">Extended Runtime</h3>
            <p class="text-sm text-ash leading-relaxed">Standard NFPA 72 requires 24 hours standby plus 5 minutes alarm. Online Power configures extended runtime batteries for jurisdictions requiring 60 hours, 72 hours, or beyond standard minimums. Ideal for remote facilities, critical government buildings, and projects with stringent AHJ requirements.</p>
          </div>
          <div class="bg-bg-elevated card-top-accent rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 010-7.072m-2.828 9.9a9 9 0 010-12.728"></path></svg>
            </div>
            <h3 class="font-display text-base font-semibold text-pure mb-2">Voice Evacuation Systems</h3>
            <p class="text-sm text-ash leading-relaxed">Buildings with voice evacuation require 15 minutes of full alarm runtime instead of the standard 5 minutes per NFPA 72. Online Power sizes battery capacity to meet the higher drain of amplifiers, speakers, and mass notification equipment across large floor plates and campus environments.</p>
          </div>
          <div class="bg-bg-elevated card-top-accent rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <h3 class="font-display text-base font-semibold text-pure mb-2">High Rise and Campus Systems</h3>
            <p class="text-sm text-ash leading-relaxed">Large buildings with multiple fire alarm control panels and remote power supplies require coordinated backup across the entire system. Online Power designs multi-unit configurations that maintain NFPA 72 compliance for each panel independently while providing centralized monitoring through a single GMS interface.</p>
          </div>
          <div class="bg-bg-elevated card-top-accent rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-display text-base font-semibold text-pure mb-2">Generator Coordination</h3>
            <p class="text-sm text-ash leading-relaxed">For buildings with standby generators, Online Power configures the Fire Alarm Backup to bridge the gap between utility failure and generator transfer with zero interruption, then seamlessly hand off to generator power for extended outages without panel reset or false alarm signals.</p>
          </div>
        </div>

        <!-- Codes & Standards -->
        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">// Codes &amp; Standards</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-16">
          {[
            { code: 'UL 1481', desc: 'Power Supplies for Fire Alarm Systems' },
            { code: 'NFPA 72 §10.6.7.2', desc: 'Standby and Alarm Runtime' },
            { code: 'NFPA 72 §10.6.10.3.2', desc: '48-Hour Recharge Requirement' },
            { code: 'NEC Article 760', desc: 'Fire Alarm Systems' },
            { code: 'NEC Article 700', desc: 'Emergency Systems' },
            { code: 'UL 864', desc: 'Fire Alarm Control Units' },
          ].map(item => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4">
              <p class="font-display font-bold text-voltage text-sm">{item.code}</p>
              <p class="text-xs text-ash mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <!-- Applications -->
        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-6">// Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-voltage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-pure">{app.name}</span>
            </div>
          ))}
        </div>

        <!-- Compatibility -->
        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure font-medium mb-1">Fire Alarm Panel Compatibility</p>
          <p class="text-sm text-ash">Compatible with all major fire alarm control panels including Notifier, Simplex, Edwards, and Honeywell. Contact our engineering team for panel compatibility verification.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-obsidian border border-steel/30 rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-obsidian' : 'bg-slate/30'} ${i < specs.length - 1 ? 'border-b border-steel/20' : ''}`}>
              <span class="text-sm text-ash font-medium">{label}</span>
              <span class="text-sm text-pure font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure">Need a custom specification? <a href="/contact" class="text-voltage hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-mono text-xs text-ash mb-6">// All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="fire-alarm-backup" />
      </div>
    </div>
  </section>

  <!-- KEY FEATURES -->
  <section class="py-16 md:py-24 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-6">// Key Features</p>
