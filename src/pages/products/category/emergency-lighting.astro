---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import { Image } from 'astro:assets';
import { getProductImage } from '../../../utils/images';
import EmergencyLighting from '../../../components/illustrations/EmergencyLighting.astro';

const category = getCategoryBySlug('emergency-lighting')!;
const categoryProducts = getProductsByCategory('emergency-lighting');

const specs = [
  ['Input Voltage', '120/208/240/277/480 VAC'],
  ['Output Voltage', 'Matches input (field selectable)'],
  ['Frequency', '60 Hz'],
  ['Waveform', 'Pure Sine Wave (<3% THD)'],
  ['Power Range', '35W to 400kW'],
  ['Transfer Time', '<4ms (HID compatible available)'],
  ['Efficiency', '>95% at full load'],
  ['Battery Type', 'Sealed VRLA / Lithium-Ion (optional)'],
  ['Battery Runtime', '90 minutes standard · 120-minute option available per NFPA 101 §7.9.2.1'],
  ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
  ['Seismic Rating', 'OSHPD/HCAI SDS 3.0G'],
  ['Enclosure', 'NEMA 1 standard, NEMA 3R optional'],
  ['Certifications', 'UL 924, NFPA 101, NEC Article 700, OSHPD/HCAI, ISO 9001'],
  ['Warranty', '2 years parts and labor'],
];
---

<BaseLayout
  title="Emergency Lighting Inverters | UL924 | 35W–400kW | Online Power"
  description="Centralized emergency lighting inverters from 35W to 400kW. UL924 listed, pure sine wave output, <4ms transfer time. Single and three phase. Built in Los Angeles. ISO 9001."
>

  <!-- ========== HERO — clean, no boxes ========== -->
  <section class="py-10 md:py-14 bg-deep-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-display text-[12px] uppercase tracking-[0.1em] text-muted-blue mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2 opacity-40">/</span>
        <a href="/products" class="hover:text-white transition-colors">Products</a>
        <span class="mx-2 opacity-40">/</span>
        <span class="text-white">Emergency Lighting Inverters</span>
      </nav>

      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="badge-dark">UL 924</span>
            <span class="badge-dark">UL 1778</span>
            <span class="badge-dark">OSHPD / HCAI</span>
            <span class="badge-dark">Made in USA</span>
          </div>

          <h1 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight mb-4">Emergency Lighting Inverters</h1>

          <p class="text-lg text-muted-blue leading-relaxed mb-6 max-w-xl">
            The widest range of UL 924 listed emergency lighting inverters from a single manufacturer. 35W to 400kW. Pure sine wave. Zero transfer time. Built to order in Los Angeles since 1975.
          </p>

          <!-- Key specs as inline text, not boxes -->
          <div class="flex flex-wrap gap-x-6 gap-y-2 mb-8 text-[14px]">
            <span class="text-white font-display font-semibold">35W–400kW</span>
            <span class="text-muted-blue">·</span>
            <span class="text-white font-display font-semibold">90–120 min runtime</span>
            <span class="text-muted-blue">·</span>
            <span class="text-white font-display font-semibold">Zero transfer</span>
            <span class="text-muted-blue">·</span>
            <span class="text-white font-display font-semibold">Single & 3-phase</span>
          </div>

          <div class="flex flex-wrap gap-3">
            <Button href="/contact" size="lg">Size My Inverter</Button>
            <Button href="#documents" variant="ghost" size="lg" icon="arrow-down">Data Sheets</Button>
          </div>
        </div>

        <div class="hidden lg:block">
          <EmergencyLighting />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRODUCTS — front and center with phase filter ========== -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
          <h2 class="font-display text-2xl md:text-3xl font-bold text-near-black">{categoryProducts.length} Models Available</h2>
          <p class="text-base text-slate mt-1">Single phase and three phase configurations</p>
        </div>
        <!-- Phase filter -->
        <div class="flex gap-1 bg-white border border-steel-gray rounded-lg p-1" id="phase-filter">
          <button class="phase-btn px-4 py-2 text-[13px] font-display font-semibold uppercase tracking-wide rounded transition-colors bg-steel-blue text-white" data-phase="all">All</button>
          <button class="phase-btn px-4 py-2 text-[13px] font-display font-semibold uppercase tracking-wide rounded transition-colors text-slate hover:text-near-black" data-phase="single">Single Phase</button>
          <button class="phase-btn px-4 py-2 text-[13px] font-display font-semibold uppercase tracking-wide rounded transition-colors text-slate hover:text-near-black" data-phase="three">Three Phase</button>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="product-grid">
        {categoryProducts.map(p => {
          const isThreePhase = /three|3.phase|3Ø/i.test(p.tagline + ' ' + p.name);
          const isSinglePhase = /single|1.phase/i.test(p.tagline + ' ' + p.name);
          const phase = isThreePhase ? 'three' : isSinglePhase ? 'single' : 'all';
          return (
            <a href={`/products/${p.slug}`} class="product-card bg-white border border-steel-gray rounded-lg overflow-hidden group hover:border-steel-blue transition-colors" data-phase={phase}>
              <div class="h-[200px] bg-off-white flex items-center justify-center p-4">
                {typeof getProductImage(p.image) === 'string' ? (
                  <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
                ) : (
                  <Image src={getProductImage(p.image) as ImageMetadata} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
                )}
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl font-bold text-near-black mb-1 group-hover:text-steel-blue transition-colors">{p.name}</h3>
                <p class="font-display text-[13px] font-semibold text-steel-blue mb-2">{p.tagline}</p>
                <p class="text-[15px] text-slate line-clamp-2 mb-3">{p.description}</p>
                <span class="font-display text-[14px] font-semibold text-steel-blue uppercase tracking-wide">View Details →</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ========== WHY CENTRALIZED — clean editorial, no card boxes ========== -->
  <section class="py-10 md:py-14 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Why Centralized Emergency Lighting</p>

      <div class="space-y-10">
        <div class="flex gap-5 items-start">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold text-near-black mb-2">Full brightness for the full 90 minutes</h3>
            <p class="text-base text-slate leading-relaxed">Distributed battery packs dim as they discharge, often dropping below the 0.6 fc minimum NFPA 101 requires at the 90-minute mark. Online Power inverters maintain full rated output from first second to last.</p>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold text-near-black mb-2">Pure sine wave — every LED driver, every time</h3>
            <p class="text-base text-slate leading-relaxed">Modified sine wave inverters cause LED flickering, buzzing, and premature driver failure. Online Power's pure sine wave output with less than 3% THD is identical to utility power.</p>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold text-near-black mb-2">One system replaces hundreds of battery packs</h3>
            <p class="text-base text-slate leading-relaxed">Centralized batteries last 10-15 years versus 3-5 for distributed packs. One annual 90-minute test replaces hundreds of individual fixture tests — cutting maintenance labor by up to 90%.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SPECIFICATIONS — clean table ========== -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-6">Specifications</p>
      <div class="border border-steel-gray rounded-lg overflow-hidden">
        {specs.map(([label, value], i) => (
          <div class={`flex items-center justify-between px-5 py-3.5 ${i % 2 === 0 ? 'bg-white' : 'bg-off-white'} ${i < specs.length - 1 ? 'border-b border-steel-gray' : ''}`}>
            <span class="text-base text-slate">{label}</span>
            <span class="text-[15px] text-near-black font-medium text-right ml-4">{value}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== DOCUMENTS — prominent, not hidden in tab ========== -->
  <section id="documents" class="py-10 md:py-14 bg-white scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <DocumentGate productSlug="power-wave-1" />
    </div>
  </section>

  <!-- ========== COMPLIANCE — simple list, not cards ========== -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-6">Codes & Standards</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-3">
        {[
          'UL 924 — Emergency Lighting Equipment',
          'UL 1778 — Uninterruptible Power Supply',
          'NEC Article 700 — Emergency Systems',
          'NFPA 101 §7.9 — Life Safety Code',
          'NFPA 110 — Emergency Power Systems',
          'OSHPD/HCAI — California Hospital Seismic',
        ].map(item => (
          <p class="text-[15px] text-slate py-1 border-b border-steel-gray/50">{item}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIAL — clean quote ========== -->
  <section class="py-10 md:py-14 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <svg class="w-8 h-8 text-steel-blue/30 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/></svg>
      <p class="text-xl text-near-black leading-relaxed mb-6 italic">"Online Power has been our go-to for emergency lighting inverters. Their engineering team is responsive and the products are absolutely rock solid."</p>
      <p class="font-display font-bold text-near-black">Alex Jenkins</p>
      <p class="text-base text-slate">Green MEP Engineering</p>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Ready to Spec Emergency Lighting?</h2>
      <p class="text-base text-muted-blue mb-8 max-w-xl mx-auto">Get a 24-hour load calculation, discuss your project, or request product training.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact" size="lg">Size My Inverter</Button>
        <Button href="/training" variant="ghost" size="lg">Register for Training</Button>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-deep-navy/95 backdrop-blur border-t border-navy-mid p-3 z-40 lg:hidden" id="mobile-sticky-cta" style="display:none;padding-bottom:max(12px, env(safe-area-inset-bottom));">
    <Button href="/contact" size="lg" icon="bolt" fullWidth>Request a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
  // Phase filter
  document.querySelectorAll('.phase-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var phase = btn.getAttribute('data-phase');

      // Update active button style
      document.querySelectorAll('.phase-btn').forEach(function(b) {
        b.classList.remove('bg-steel-blue', 'text-white');
        b.classList.add('text-slate');
      });
      btn.classList.remove('text-slate');
      btn.classList.add('bg-steel-blue', 'text-white');

      // Filter cards
      document.querySelectorAll('.product-card').forEach(function(card) {
        var cardPhase = card.getAttribute('data-phase');
        if (phase === 'all' || cardPhase === phase || cardPhase === 'all') {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  // Mobile sticky CTA
  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
