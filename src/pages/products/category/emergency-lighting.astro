---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import { Image } from 'astro:assets';
import { getProductImage } from '../../../utils/images';
import EmergencyLighting from '../../../components/illustrations/EmergencyLighting.astro';

const category = getCategoryBySlug('emergency-lighting')!;
const categoryProducts = getProductsByCategory('emergency-lighting');

const specs = [
  ['Input Voltage', '120/208/240/277/480 VAC'],
  ['Output Voltage', 'Matches input (field selectable)'],
  ['Frequency', '60 Hz'],
  ['Waveform', 'Pure Sine Wave (<3% THD)'],
  ['Power Range', '35W to 400kW'],
  ['Transfer Time', '<4ms (HID compatible available)'],
  ['Efficiency', '>95% at full load'],
  ['Battery Type', 'Sealed VRLA / Lithium-Ion (optional)'],
  ['Battery Runtime', '90 minutes standard · 120-minute option available per NFPA 101 §7.9.2.1'],
  ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
  ['Seismic Rating', 'OSHPD/HCAI SDS 3.0G'],
  ['Enclosure', 'NEMA 1 standard, NEMA 3R optional'],
  ['Certifications', 'UL 924, NFPA 101, NEC Article 700, OSHPD/HCAI, ISO 9001'],
  ['Warranty', '2 years parts and labor'],
];

const applications = [
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Schools & Universities', icon: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z' },
  { name: 'High-Rise Office', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { name: 'Data Centers', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
  { name: 'Hotels', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { name: 'Retail', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
  { name: 'Industrial', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
];
---

<BaseLayout
  title="Emergency Lighting Inverters | UL924 | 35W–400kW | Online Power"
  description="Centralized emergency lighting inverters from 35W to 400kW. UL924 listed, pure sine wave output, <4ms transfer time. Single and three phase. Built in Los Angeles. ISO 9001."
>

  <!-- HERO -->
  <section class="py-10 md:py-14 bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="eyebrow text-slate mb-8">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-steel-blue transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-steel-blue">Emergency Lighting Inverters</span>
      </nav>

      <div class="grid lg:grid-cols-5 gap-6 lg:gap-12 items-start">
        <!-- Left: Content -->
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="badge-light">UL 924</span>
            <span class="badge-light">OSHPD / HCAI</span>
            <span class="badge-light">Made in USA</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-near-black leading-tight mb-5">Emergency Lighting Inverters</h1>
          <p class="text-base text-slate leading-relaxed mb-8">
            When the lights go out, your emergency lighting system determines whether occupants reach the exit safely. Online Power's UL 924 inverters deliver pure sine wave output from 35W to 400kW — the widest range in the industry — maintaining full illumination for the entire 90-minute code-required duration. Built to order in Los Angeles since 1975, with OSHPD/HCAI seismic models for California's most demanding hospital projects.
          </p>

          <!-- Key Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {[
              { label: 'Range', value: '35W–400kW' },
              { label: 'Runtime', value: '90–120 min' },
              { label: 'Transfer', value: 'Zero (online)' },
              { label: 'Certifications', value: 'UL 924 · UL 1778' },
            ].map(s => (
              <div class="bg-off-white border border-steel-gray rounded-lg p-3 text-center">
                <p class="font-display text-[13px] font-semibold uppercase tracking-[0.1em] text-slate mb-1">{s.label}</p>
                <p class="font-display text-base font-bold text-near-black">{s.value}</p>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <Button href="/contact" size="lg">Size My Inverter — 24-Hour Load Calculation</Button>
          </div>
          <p class="font-display text-[13px] text-slate">Responds within 2 business hours</p>
        </div>

        <!-- Right: Product Image + Trust -->
        <div class="hidden lg:block lg:col-span-2">
          <EmergencyLighting />
        </div>
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="pt-6 md:pt-8 pb-10 md:pb-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <!-- Tab Buttons -->
      <div class="flex gap-1 border-b border-steel-gray mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-steel-blue border-steel-blue' : 'text-slate border-transparent hover:text-near-black'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <!-- Benefit Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Full brightness for the full 90 minutes</h3>
            <p class="text-base text-slate leading-relaxed">Distributed battery packs dim as they discharge, often dropping below the 0.6 fc minimum NFPA 101 requires at the 90-minute mark. Online Power inverters maintain full rated output from first second to last, ensuring egress paths stay code-compliant through the entire emergency.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Pure sine wave output — every LED driver, every time</h3>
            <p class="text-base text-slate leading-relaxed">Modified sine wave inverters cause LED flickering, buzzing, and premature driver failure. Online Power's pure sine wave output with less than 3% THD is identical to utility power, ensuring compatibility with every dimmable LED driver, 0-10V control, and architectural fixture.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">One system replaces hundreds of battery packs</h3>
            <p class="text-base text-slate leading-relaxed">Centralized inverter batteries last 10-15 years in a controlled environment versus 3-5 years for distributed packs. One annual 90-minute test replaces hundreds of individual fixture tests — cutting maintenance labor by up to 90% and eliminating thousands in recurring battery costs.</p>
          </div>
        </div>

        <!-- Technical Callout -->
        <div class="bg-off-white border-l-2 border-steel-blue p-6 mb-10" style="border-radius: 0 12px 12px 0;">
          <p class="eyebrow text-steel-blue mb-3">What your spec sheet won't tell you</p>
          <p class="text-base text-slate leading-relaxed">NEC Article 700.10(B) requires emergency wiring to be kept completely independent of all other wiring — separate raceways, boxes, cabinets, and panels. This is the most frequently red-tagged requirement in emergency lighting installations. NFPA 101 §7.9.2.1.3 also caps the maximum-to-minimum illumination uniformity ratio at 40:1 — a requirement that distributed battery packs routinely fail because output drops unevenly as batteries age. A centralized inverter with proper circuit design solves both at the design stage, not during punch list.</p>
        </div>

        <!-- Codes & Standards -->
        <p class="eyebrow text-steel-blue mb-4">Codes &amp; Standards</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-16">
          {[
            { code: 'UL 924', desc: 'Emergency Lighting Equipment' },
            { code: 'UL 1778', desc: 'Uninterruptible Power Supply' },
            { code: 'NEC Article 700', desc: 'Emergency Systems' },
            { code: 'NFPA 101 §7.9', desc: 'Life Safety Code' },
            { code: 'NFPA 110', desc: 'Emergency Power Systems' },
            { code: 'OSHPD/HCAI', desc: 'California Hospital Seismic' },
          ].map(item => (
            <div class="bg-white border border-steel-gray rounded-lg p-4">
              <p class="font-display font-bold text-steel-blue text-sm">{item.code}</p>
              <p class="text-xs text-slate mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <!-- Applications -->
        <p class="eyebrow text-steel-blue mb-6">Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-white border border-steel-gray rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-steel-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-near-black">{app.name}</span>
            </div>
          ))}
        </div>

        <!-- Compatibility -->
        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black font-medium mb-1">LED Driver Compatibility</p>
          <p class="text-base text-slate">Compatible with all major LED driver manufacturers including Lutron, Osram, GE Current, and Philips Advance. Contact our engineering team for driver compatibility verification.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-white border border-steel-gray rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-white' : 'bg-off-white'} ${i < specs.length - 1 ? 'border-b border-steel-gray' : ''}`}>
              <span class="text-base text-slate font-medium">{label}</span>
              <span class="text-sm text-near-black font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black">Need a custom specification? <a href="/contact" class="text-steel-blue hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-display text-[13px] text-slate mb-6">All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="power-wave-1" />
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-8">{categoryProducts.length} Models Available</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-off-white flex items-center justify-center p-4">
              {typeof getProductImage(p.image) === 'string' ? (
                <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
              ) : (
                <Image src={getProductImage(p.image) as ImageMetadata} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
              )}
            </div>
            <div class="p-6">
            <h3 class="font-display text-2xl font-semibold text-near-black mb-1 group-hover:text-steel-blue transition-colors">{p.name}</h3>
            <p class="font-display font-semibold text-xs text-steel-blue mb-3">{p.tagline}</p>
            <p class="text-base text-slate mb-4 line-clamp-2">{p.description}</p>
            <span class="text-[15px] font-medium text-steel-blue">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-white border border-steel-gray rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-steel-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-near-black text-lg leading-relaxed mb-6 italic">"Online Power has been our go-to for emergency lighting inverters. Their engineering team is responsive and the products are absolutely rock solid."</p>
        <div class="border-t border-steel-gray pt-4">
          <p class="font-display font-semibold text-near-black">Alex Jenkins</p>
          <p class="text-base text-slate">Green MEP Engineering</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-steel-blue text-white font-semibold rounded hover:bg-steel-blue/90 transition-colors text-sm">Size My Inverter — 24-Hour Load Calculation</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded hover:bg-white/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-deep-navy/95 backdrop-blur border-t border-steel-gray p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <Button href="/contact" size="lg" icon="bolt" fullWidth>Request a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-steel-blue', 'border-steel-blue');
        b.classList.add('text-slate', 'border-transparent');
      });
      btn.classList.remove('text-slate', 'border-transparent');
      btn.classList.add('text-steel-blue', 'border-steel-blue');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  // Mobile sticky CTA — show after scrolling 400px
  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
