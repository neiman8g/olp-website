---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import { Image } from 'astro:assets';
import { getProductImage } from '../../../utils/images';
import ElevatorBackup from '../../../components/illustrations/ElevatorBackup.astro';

const category = getCategoryBySlug('elevator-backup')!;
const categoryProducts = getProductsByCategory('elevator-backup');
const product = categoryProducts[0]; // Only one product: Power Wave Elevate
---

<BaseLayout
  title="Elevator Backup Systems | UL924 | 24–240kW | Online Power"
  description="Three phase elevator emergency backup from 24kW to 240kW. UL924 and UL1778 listed. Safe building evacuation during power outages. Built in Los Angeles. ISO 9001."
>

  <!-- ========== HERO ========== -->
  <section class="bg-deep-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-12 items-center">
        <div>
          <p class="font-display text-[13px] font-bold uppercase tracking-[0.12em] text-steel-blue mb-2">UL 924 · UL 1778 · Three Phase · Made in USA</p>

          <h1 class="font-display text-4xl md:text-5xl lg:text-[54px] font-bold text-white leading-[1.1] mb-5">
            Elevator Backup<br/>Systems
          </h1>

          <p class="text-lg text-muted-blue leading-relaxed mb-8 max-w-lg">
            2 hours of uninterrupted three-phase power for safe building evacuation. Traction and regenerative elevators from 24kW to 240kW. No load bank. No ATS switch. Multiple output breakers for separate lighting and elevator loads.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            <Button href="/contact" size="lg">Size My Unit</Button>
            <Button href="#documents" variant="ghost" size="lg" icon="arrow-down">Documents</Button>
          </div>

          <div class="inline-flex items-center gap-4 bg-[#1A3F6A] rounded-lg px-5 py-3">
            <p class="font-display text-[11px] font-semibold uppercase tracking-[0.1em] text-steel-blue">Range</p>
            <p class="font-display text-2xl md:text-3xl font-bold text-white leading-none">24 – 240kW</p>
            <p class="text-[14px] text-muted-blue">3-Phase · Online & Fast Transfer</p>
          </div>
        </div>

        <div class="hidden lg:block">
          <ElevatorBackup />
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="border-t border-navy-mid">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-navy-mid">
          {[
            { label: 'Topology', value: 'Online UPS & Fast Transfer Standby' },
            { label: 'Load Bank', value: 'Not Required' },
            { label: 'ATS Switch', value: 'Not Required' },
            { label: 'Output', value: 'Multiple UL489 Breakers' },
          ].map(s => (
            <div class="py-6 px-4 md:px-6 text-center md:text-left">
              <p class="font-display text-[13px] font-semibold uppercase tracking-[0.1em] text-steel-blue mb-1">{s.label}</p>
              <p class="font-display text-lg md:text-xl font-bold text-white">{s.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== THE PRODUCT — since there's only one ========== -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <!-- Product photo -->
        <div class="bg-white border border-steel-gray rounded-lg p-8 flex items-center justify-center min-h-[300px]">
          {typeof getProductImage(product.image) === 'string' ? (
            <img src={product.image} alt={`${product.name} by Online Power`} class="max-h-[350px] w-auto object-contain" loading="lazy" />
          ) : (
            <Image src={getProductImage(product.image) as ImageMetadata} alt={`${product.name} by Online Power`} class="max-h-[350px] w-auto object-contain" loading="lazy" format="webp" quality={85} widths={[400, 600]} sizes="(max-width: 768px) 100vw, 50vw" />
          )}
        </div>

        <!-- Product info -->
        <div>
          <p class="eyebrow mb-3">Power Wave Elevate</p>
          <h2 class="font-display text-3xl font-bold text-near-black mb-3">{product.name}</h2>
          <p class="font-display text-base font-semibold text-steel-blue mb-4">{product.tagline}</p>
          <p class="text-base text-slate leading-relaxed mb-6">{product.description}</p>

          <div class="flex flex-wrap gap-2 mb-6">
            {product.standards.map(std => (
              <span class="badge-light">{std}</span>
            ))}
          </div>

          <div class="flex flex-wrap gap-3">
            <Button href="/contact" size="lg">Request a Quote</Button>
            <Button href="/training" variant="outline" size="lg">Schedule Training</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY THIS PRODUCT ========== -->
  <section class="py-10 md:py-14 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-4">Why the Power Wave Elevate</p>

      <div class="space-y-10">
        <div class="flex gap-5 items-start">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold text-near-black mb-2">No load bank. No ATS switch.</h3>
            <p class="text-base text-slate leading-relaxed">The Power Wave Elevate handles regenerative energy natively — no external load bank needed. And because it provides both online and fast transfer modes, there's no automatic transfer switch to install, maintain, or fail.</p>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold text-near-black mb-2">Multiple output breakers for code compliance</h3>
            <p class="text-base text-slate leading-relaxed">Separate lighting and elevator loads on independent output breakers from a single unit. Satisfies NEC Article 700 wiring independence requirements without separate panels or additional equipment.</p>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold text-near-black mb-2">Online and fast transfer — both included</h3>
            <p class="text-base text-slate leading-relaxed">The unit ships with both online (zero transfer) and fast transfer modes. Online for continuous power quality. Fast transfer for efficiency. Switch between modes based on your application requirements.</p>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center flex-shrink-0 mt-1">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold text-near-black mb-2">Replace the generator you can't fit</h3>
            <p class="text-base text-slate leading-relaxed">Zero emissions, silent operation, installs indoors. Ideal for urban high-rises, mixed-use buildings, and retrofits where generator installation is physically or economically impractical.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== VIDEO ========== -->
  <section class="py-10 md:py-14 bg-deep-navy">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <p class="font-display text-[13px] font-bold uppercase tracking-[0.12em] text-steel-blue mb-4 text-center">See It In Action</p>
      <h2 class="font-display text-2xl md:text-3xl font-bold text-white mb-8 text-center">Power Wave Elevate</h2>
      <div class="rounded-lg overflow-hidden border border-navy-mid">
        <video controls preload="metadata" class="w-full" poster="">
          <source src="/video/OLP-Elevate.mp4" type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </div>
    </div>
  </section>

  <!-- ========== DOCUMENTS ========== -->
  <section id="documents" class="py-10 md:py-14 bg-off-white scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <DocumentGate productSlug="elevate" />
    </div>
  </section>

  <!-- ========== RESOURCES ========== -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-8">Resources & Training</p>
      <div class="grid md:grid-cols-3 gap-5">
        <a href="/training/" class="bg-white border border-steel-gray rounded-lg p-6 group hover:border-steel-blue transition-colors">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-bold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Product Training</h3>
          <p class="text-[15px] text-slate mb-3">At our plant, virtual, or at your office. Hands-on with our engineering team.</p>
          <span class="font-display text-[14px] font-semibold text-steel-blue uppercase tracking-wide">Register →</span>
        </a>

        <div class="bg-white border border-steel-gray rounded-lg p-6">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-bold text-near-black mb-2">Code Requirements</h3>
          <ul class="text-[15px] text-slate space-y-1.5">
            <li>ASME A17.1 — Elevator Safety Code</li>
            <li>IBC §2702.2.2 — Standby Power</li>
            <li>IBC §3007.8 — Fire Service Access</li>
            <li>NEC Article 700 — Emergency Systems</li>
            <li>California Title 24 — 2-Hour Runtime</li>
          </ul>
        </div>

        <a href="/contact/" class="bg-white border border-steel-gray rounded-lg p-6 group hover:border-steel-blue transition-colors">
          <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          </div>
          <h3 class="font-display text-lg font-bold text-near-black mb-2 group-hover:text-steel-blue transition-colors">Engineering Support</h3>
          <p class="text-[15px] text-slate mb-3">Tell us your elevator HP and building requirements. Same-day quote.</p>
          <span class="font-display text-[14px] font-semibold text-steel-blue uppercase tracking-wide">Contact Engineering →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIAL ========== -->
  <section class="py-10 md:py-14 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <svg class="w-8 h-8 text-steel-blue/30 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/></svg>
      <p class="text-xl text-near-black leading-relaxed mb-6 italic">"Online Power and their staff couple technical ability with speed, taking the complicated and turning it into the digestible. Our reputation is strong because of our partnership with them."</p>
      <p class="font-display font-bold text-near-black">Joe Gangl</p>
      <p class="text-base text-slate">Quotation Specialist, JTH Lighting Alliance</p>
    </div>
  </section>

  <!-- ========== RELATED PRODUCTS ========== -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow mb-8">Related Products</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <a href="/products/category/emergency-lighting" class="bg-white border border-steel-gray rounded-lg overflow-hidden group hover:border-steel-blue transition-colors">
          <div class="h-[180px] bg-off-white flex items-center justify-center p-4">
            {typeof getProductImage('/images/products/power-wave-1.png') === 'string' ? (
              <img src="/images/products/power-wave-1.png" alt="Emergency Lighting Inverters" class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-200" loading="lazy" />
            ) : (
              <Image src={getProductImage('/images/products/power-wave-1.png') as ImageMetadata} alt="Emergency Lighting Inverters" class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-200" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="33vw" />
            )}
          </div>
          <div class="p-5">
            <h3 class="font-display text-xl font-bold text-near-black mb-1 group-hover:text-steel-blue transition-colors">Emergency Lighting</h3>
            <p class="text-[15px] text-slate mb-3">UL924 inverters from 35W to 400kW</p>
            <span class="font-display text-[14px] font-semibold text-steel-blue uppercase tracking-wide">View Products →</span>
          </div>
        </a>
        <a href="/products/category/ups-backup" class="bg-white border border-steel-gray rounded-lg overflow-hidden group hover:border-steel-blue transition-colors">
          <div class="h-[180px] bg-off-white flex items-center justify-center p-4">
            {typeof getProductImage('/images/products/host-power.png') === 'string' ? (
              <img src="/images/products/host-power.png" alt="UPS Backup Systems" class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-200" loading="lazy" />
            ) : (
              <Image src={getProductImage('/images/products/host-power.png') as ImageMetadata} alt="UPS Backup Systems" class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-200" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="33vw" />
            )}
          </div>
          <div class="p-5">
            <h3 class="font-display text-xl font-bold text-near-black mb-1 group-hover:text-steel-blue transition-colors">UPS Backup</h3>
            <p class="text-[15px] text-slate mb-3">UL1778 uninterruptible power supply</p>
            <span class="font-display text-[14px] font-semibold text-steel-blue uppercase tracking-wide">View Products →</span>
          </div>
        </a>
        <a href="/products/category/custom-oem" class="bg-white border border-steel-gray rounded-lg overflow-hidden group hover:border-steel-blue transition-colors">
          <div class="h-[180px] bg-off-white flex items-center justify-center p-4">
            {typeof getProductImage('/images/products/custom-oem.png') === 'string' ? (
              <img src="/images/products/custom-oem.png" alt="Custom OEM Solutions" class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-200" loading="lazy" />
            ) : (
              <Image src={getProductImage('/images/products/custom-oem.png') as ImageMetadata} alt="Custom OEM Solutions" class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-200" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="33vw" />
            )}
          </div>
          <div class="p-5">
            <h3 class="font-display text-xl font-bold text-near-black mb-1 group-hover:text-steel-blue transition-colors">Custom OEM</h3>
            <p class="text-[15px] text-slate mb-3">Custom engineered power solutions</p>
            <span class="font-display text-[14px] font-semibold text-steel-blue uppercase tracking-wide">View Products →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Ready to Spec Elevator Backup?</h2>
      <p class="text-base text-muted-blue mb-8 max-w-xl mx-auto">Tell us your elevator HP and building requirements for a same-day quote.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact" size="lg">Get a Quote</Button>
        <Button href="/training" variant="ghost" size="lg">Register for Training</Button>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-deep-navy/95 backdrop-blur border-t border-navy-mid p-3 z-40 lg:hidden" id="mobile-sticky-cta" style="display:none;padding-bottom:max(12px, env(safe-area-inset-bottom));">
    <Button href="/contact" size="lg" icon="bolt" fullWidth>Get a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
