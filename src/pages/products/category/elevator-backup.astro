---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import ElevatorBackup from '../../../components/illustrations/ElevatorBackup.astro';

const category = getCategoryBySlug('elevator-backup')!;
const categoryProducts = getProductsByCategory('elevator-backup');

const specs = [
  ['Input Voltage', '208/480 VAC Three Phase'],
  ['Output Voltage', 'Matches input'],
  ['Frequency', '60 Hz'],
  ['Waveform', 'Pure Sine Wave (<3% THD)'],
  ['Power Range', '24kW to 240kW'],
  ['Phase', 'Three Phase (3Ø)'],
  ['Transfer Time', 'Zero (online double conversion)'],
  ['Efficiency', '>92% at full load'],
  ['Battery Type', 'Sealed VRLA'],
  ['Battery Runtime', '2 hours minimum — California Title 24, IBC §2702.1.6'],
  ['Operating Temp', '32°F to 104°F (0°C to 40°C)'],
  ['Enclosure', 'NEMA 1 standard'],
  ['Certifications', 'UL 924, UL 1778'],
  ['Warranty', '2 years parts and labor'],
];

const applications = [
  { name: 'High-Rise Office', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Hotels', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
  { name: 'Mixed-Use', icon: 'M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z' },
  { name: 'Retail', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
];
---

<BaseLayout
  title="Elevator Backup Systems | UL924 | 24–240kW | Online Power"
  description="Three phase elevator emergency backup from 24kW to 240kW. UL924 and UL1778 listed. Safe building evacuation during power outages. Built in Los Angeles. ISO 9001."
>

  <!-- HERO -->
  <section class="py-16 md:py-24 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-8">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-voltage transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Elevator Backup</span>
      </nav>

      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <!-- Left: Content -->
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">UL 924</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">UL 1778</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">Made in USA</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-pure leading-tight mb-5">Elevator Backup Systems</h1>
          <p class="text-lg text-ash leading-relaxed mb-8">
            A power outage in a high-rise doesn't just stop elevators — it traps occupants, strands people with disabilities, and disables fire service access. The Power Wave Elevate provides 2 hours of uninterrupted three-phase power for hydraulic, traction, and regenerative elevators from 24kW to 240kW. Dual-listed to UL 924 and UL 1778, it satisfies both life-safety and power quality requirements with a single unit. Zero transfer time means the elevator never stalls and passengers never know the utility failed.
          </p>

          <!-- Key Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {[
              { label: 'Runtime', value: '2 Hours' },
              { label: 'Range', value: '24–240kW 3Ø' },
              { label: 'Transfer', value: 'Zero (online)' },
              { label: 'Certifications', value: 'UL 924 · UL 1778' },
            ].map(s => (
              <div class="bg-slate border border-steel/30 rounded-lg p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-widest text-ash mb-1">{s.label}</p>
                <p class="font-display text-sm font-bold text-pure">{s.value}</p>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <Button href="/contact" size="lg">Tell Us Your Elevator HP — Same-Day Quote</Button>
          </div>
          <p class="font-mono text-xs text-ash">Responds within 2 business hours</p>
        </div>

        <!-- Right: Animated SVG -->
        <div class="hidden lg:block lg:col-span-2">
          <ElevatorBackup />
        </div>
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <!-- Tab Buttons -->
      <div class="flex gap-1 border-b border-steel/30 mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-voltage border-voltage' : 'text-ash border-transparent hover:text-pure'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <!-- Benefit Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Regenerative-ready — no resistor bank required</h3>
            <p class="text-sm text-ash leading-relaxed">Modern traction elevators generate power during descent that can damage standard UPS systems. The Power Wave Elevate redirects regenerative energy to the building grid during normal operation or to battery charging during an outage — eliminating the expensive, heat-generating resistor banks competitors require.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">One unit. Two certifications. Every code satisfied.</h3>
            <p class="text-sm text-ash leading-relaxed">Dual UL 924 and UL 1778 listing means a single Power Wave Elevate satisfies NEC Article 700 emergency systems, Article 701 legally required standby, IBC Section 3007.8 fire service access, and IBC Section 1009.4.1 accessible means of egress. One product, one submittal, one AHJ approval.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Replace the generator you can't fit</h3>
            <p class="text-sm text-ash leading-relaxed">Diesel generators require fuel storage, exhaust systems, emissions permits, and monthly maintenance. The Power Wave Elevate installs indoors with zero emissions and silent operation — ideal for urban high-rises, mixed-use buildings, and retrofits where generator installation is physically or economically impractical.</p>
          </div>
        </div>

        <!-- Technical Callout -->
        <div class="bg-bg-elevated border-l-2 border-voltage p-6 mb-10" style="border-radius: 0 12px 12px 0;">
          <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-3">What your spec sheet won't tell you</p>
          <p class="text-sm text-ash leading-relaxed">IBC Section 3003.1 requires automatic power transfer within 60 seconds for elevator recall — but that 60-second gap means passengers experience complete darkness and a stationary cab. A zero-transfer-time online UPS eliminates this entirely. Also critical: California Building Code Section 2702.1.6 requires a full 2-hour runtime — more stringent than the base IBC. And for regenerative traction elevators, now standard in most new mid-rise construction, standard UPS topology cannot absorb the energy generated during descent. The Power Wave Elevate's bidirectional converter handles regenerative loads natively, while competitors either require separate resistor banks or exclude regenerative elevators from their specs entirely.</p>
        </div>

        <!-- Codes & Standards -->
        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-4">Codes &amp; Standards</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-16">
          {[
            { code: 'ASME A17.1', desc: 'Safety Code for Elevators' },
            { code: 'IBC §2702.2.2', desc: 'Standby Power for Elevators' },
            { code: 'IBC §1009.4.1', desc: 'Accessible Means of Egress' },
            { code: 'IBC §3007.8', desc: 'Fire Service Access Elevators' },
            { code: 'NEC Article 700', desc: 'Emergency Systems' },
            { code: 'California Title 24', desc: '2-Hour Runtime Required' },
          ].map(item => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4">
              <p class="font-display font-bold text-voltage text-sm">{item.code}</p>
              <p class="text-xs text-ash mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <!-- Applications -->
        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-6">Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-voltage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-pure">{app.name}</span>
            </div>
          ))}
        </div>

        <!-- Compatibility -->
        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure font-medium mb-1">Elevator Motor Compatibility</p>
          <p class="text-sm text-ash">Compatible with all major elevator manufacturers including Otis, KONE, Schindler, and ThyssenKrupp. Contact our engineering team for motor compatibility verification.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-obsidian border border-steel/30 rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-obsidian' : 'bg-slate/30'} ${i < specs.length - 1 ? 'border-b border-steel/20' : ''}`}>
              <span class="text-sm text-ash font-medium">{label}</span>
              <span class="text-sm text-pure font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure">Need a custom specification? <a href="/contact" class="text-voltage hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-mono text-xs text-ash mb-6">All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="elevate" />
      </div>
    </div>
  </section>

  <!-- KEY FEATURES -->
  <section class="py-16 md:py-24 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-6">Key Features</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {['Elevator-Specific Design', 'Three Phase Output', 'UL924 & UL1778 Listed', 'Safe Evacuation Power', 'Building Code Compliant'].map(feature => (
          <div class="flex items-start gap-3 bg-slate border border-steel/20 rounded-lg p-4">
            <svg class="w-5 h-5 text-voltage flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-sm text-pure">{feature}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DOCUMENTS -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <DocumentGate productSlug="elevate" />
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-obsidian border border-steel/30 rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-voltage" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-pure text-lg leading-relaxed mb-6 italic">"Online Power and their staff couple technical ability with speed, taking the complicated and turning it into the digestible. I've lost track of the number of times they have saved a job or offered the assurance a customer needed at the eleventh hour. Our reputation is strong because of our partnership with them."</p>
        <div class="border-t border-steel/30 pt-4">
          <p class="font-display font-semibold text-pure">Joe Gangl</p>
          <p class="text-sm text-ash">Quotation Specialist, JTH Lighting Alliance</p>
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <section class="py-16 md:py-24 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">Related Products</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <a href="/products/category/emergency-lighting" class="card-glow card-top-accent bg-steel/30 rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-bg-elevated flex items-center justify-center p-4">
            <img src="/images/products/power-wave-1.png" alt="Emergency Lighting Inverters by Online Power" class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-pure mb-1 group-hover:text-voltage transition-colors">Emergency Lighting Inverters</h3>
            <p class="text-sm text-ash mb-4">UL924 emergency lighting inverters from 35W to 400kW</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>
        <a href="/products/category/ups-backup" class="card-glow card-top-accent bg-steel/30 rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-bg-elevated flex items-center justify-center p-4">
            <img src="/images/products/host-power.png" alt="UPS Backup by Online Power" class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-pure mb-1 group-hover:text-voltage transition-colors">UPS Backup Systems</h3>
            <p class="text-sm text-ash mb-4">UL1778 uninterruptible power supply systems</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>
        <a href="/products/category/custom-oem" class="card-glow card-top-accent bg-steel/30 rounded-xl overflow-hidden group">
          <div class="h-[180px] bg-bg-elevated flex items-center justify-center p-4">
            <img src="/images/products/custom-oem.png" alt="Custom OEM by Online Power" class="max-h-full w-auto object-contain group-hover:scale-[1.04] transition-transform duration-200" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-pure mb-1 group-hover:text-voltage transition-colors">Custom OEM Solutions</h3>
            <p class="text-sm text-ash mb-4">Custom engineered power solutions for OEM partners</p>
            <span class="text-sm font-medium text-voltage">View Products &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-voltage py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-obsidian mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-obsidian text-pure font-semibold rounded-lg hover:bg-slate transition-colors text-sm">Tell Us Your Elevator HP — Same-Day Quote</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-obsidian/30 text-obsidian font-semibold rounded-lg hover:bg-obsidian/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-obsidian/95 backdrop-blur border-t border-steel/30 p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <Button href="/contact" size="lg" icon="bolt" fullWidth>Request a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-voltage', 'border-voltage');
        b.classList.add('text-ash', 'border-transparent');
      });
      btn.classList.remove('text-ash', 'border-transparent');
      btn.classList.add('text-voltage', 'border-voltage');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  // Mobile sticky CTA — show after scrolling 400px
  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
