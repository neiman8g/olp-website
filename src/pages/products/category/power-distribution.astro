---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';

const category = getCategoryBySlug('power-distribution')!;
const categoryProducts = getProductsByCategory('power-distribution');

const specs = [
  ['Input Voltage', '120/208/240/480 VAC'],
  ['Output Voltage', 'Configurable per application'],
  ['Frequency', '60 Hz'],
  ['Power Range', '15kVA to 450kVA'],
  ['Phase', 'Single and Three Phase'],
  ['Efficiency', '>96% at full load'],
  ['Regulation', 'Built-in (Power Pac models)'],
  ['Monitoring', 'System monitoring panel'],
  ['Distribution', 'Remote panel board matching'],
  ['Construction', 'Swivel caster & leveling feet'],
  ['Certifications', 'UL 50, UL 67, UL 489, NFPA, NEMA'],
  ['Warranty', '2 years parts and labor'],
];

const applications = [
  { name: 'Data Centers', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
  { name: 'Broadcast & Events', icon: 'M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 010-7.072m-2.828 9.9a9 9 0 010-12.728' },
  { name: 'Industrial', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { name: 'Construction', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
];
---

<BaseLayout
  title="Power Distribution Units | 15–450kVA | Online Power"
  description="Customizable power distribution solutions for permanent and temporary installations. Modular designs with monitoring. 15–450kVA. UL Listed. Built in Los Angeles."
>

  <!-- HERO -->
  <section class="py-16 md:py-24 border-b border-steel/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="font-mono text-xs uppercase tracking-widest text-ash mb-8">
        <a href="/" class="hover:text-voltage transition-colors">Home</a>
        <span class="mx-2 text-steel">/</span>
        <a href="/products" class="hover:text-voltage transition-colors">Products</a>
        <span class="mx-2 text-steel">/</span>
        <span class="text-voltage">Power Distribution</span>
      </nav>

      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">UL Listed</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">NEMA</span>
            <span class="px-3 py-1 border border-voltage/40 rounded-full text-xs font-mono uppercase tracking-wider text-voltage">Made in USA</span>
          </div>

          <h1 class="font-display text-3xl md:text-4xl lg:text-[42px] font-bold text-pure leading-tight mb-5">Power Distribution Units</h1>
          <p class="text-lg text-ash leading-relaxed mb-8">
            Customizable power distribution solutions for permanent and temporary installations. Modular designs with monitoring. Built in Los Angeles.
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {[
              { label: 'Range', value: '15–450kVA' },
              { label: 'Efficiency', value: '>96%' },
              { label: 'Config', value: 'Modular' },
              { label: 'Certified', value: 'UL Listed' },
            ].map(s => (
              <div class="bg-slate border border-steel/30 rounded-lg p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-widest text-ash mb-1">{s.label}</p>
                <p class="font-display text-sm font-bold text-pure">{s.value}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <a href="/contact" class="btn-primary px-6 py-3.5 rounded-lg text-sm font-semibold inline-flex items-center justify-center gap-2">Request a Quote</a>
            <button class="btn-ghost px-6 py-3.5 rounded-lg text-sm inline-flex items-center justify-center gap-2 doc-download-btn" data-url="/pdf/powerpac_DS.pdf" data-name="Power Distribution - Spec Sheet" data-product="Power Distribution Units">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"></path></svg>
              Download Spec Sheet
            </button>
          </div>
          <p class="font-mono text-xs text-ash">// Responds within 2 business hours</p>
        </div>

        <div class="lg:col-span-2">
          <div style="background:#0A0A0F;border-radius:12px;overflow:hidden;width:100%;">
            <svg viewBox="0 0 600 320" width="100%" xmlns="http://www.w3.org/2000/svg">
              <style>
                @keyframes pd-flow { 0%{offset-distance:0%;opacity:0;} 10%{opacity:1;} 90%{opacity:1;} 100%{offset-distance:100%;opacity:0;} }
                @keyframes pd-read { 0%{opacity:1;} 49%{opacity:1;} 50%{opacity:0;} 100%{opacity:0;} }
                @keyframes pd-read2 { 0%{opacity:0;} 50%{opacity:0;} 51%{opacity:1;} 100%{opacity:1;} }
                .pd-dot{r:2.5;fill:#00E5FF;offset-rotate:0deg;animation:pd-flow 2s linear infinite;}
                .pd-r1{animation:pd-read 4s step-end infinite;}
                .pd-r2{animation:pd-read2 4s step-end infinite;}
              </style>
              <!-- PDU -->
              <rect x="40" y="60" width="60" height="200" rx="4" fill="#111827" stroke="#00E5FF" stroke-width="1"/>
              <text x="70" y="155" text-anchor="middle" font-family="Space Grotesk,sans-serif" font-size="11" font-weight="700" fill="#F8FAFC" transform="rotate(-90 70 155)">PDU</text>
              <!-- Power input -->
              <line x1="20" y1="160" x2="40" y2="160" stroke="#00E5FF" stroke-width="2"/>
              <!-- Branch lines to racks -->
              <line x1="100" y1="80" x2="180" y2="80" stroke="#1C2B3A" stroke-width="1"/>
              <line x1="100" y1="120" x2="180" y2="120" stroke="#1C2B3A" stroke-width="1"/>
              <line x1="100" y1="160" x2="180" y2="160" stroke="#1C2B3A" stroke-width="1"/>
              <line x1="100" y1="200" x2="180" y2="200" stroke="#1C2B3A" stroke-width="1"/>
              <line x1="100" y1="240" x2="180" y2="240" stroke="#1C2B3A" stroke-width="1"/>
              <!-- Second row branches -->
              <line x1="320" y1="80" x2="400" y2="80" stroke="#1C2B3A" stroke-width="1"/>
              <line x1="320" y1="120" x2="400" y2="120" stroke="#1C2B3A" stroke-width="1"/>
              <line x1="320" y1="160" x2="400" y2="160" stroke="#1C2B3A" stroke-width="1"/>
              <!-- Racks row 1 -->
              <rect x="180" y="65" width="140" height="30" rx="3" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="180" y="105" width="140" height="30" rx="3" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="180" y="145" width="140" height="30" rx="3" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="180" y="185" width="140" height="30" rx="3" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="180" y="225" width="140" height="30" rx="3" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <!-- Racks row 2 -->
              <rect x="400" y="65" width="140" height="30" rx="3" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="400" y="105" width="140" height="30" rx="3" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <rect x="400" y="145" width="140" height="30" rx="3" fill="#111827" stroke="#1C2B3A" stroke-width="0.5"/>
              <!-- Power indicators -->
              <circle cx="310" cy="80" r="2" fill="#00E5FF" opacity="0.6"/>
              <circle cx="310" cy="120" r="2" fill="#00E5FF" opacity="0.6"/>
              <circle cx="310" cy="160" r="2" fill="#00E5FF" opacity="0.6"/>
              <circle cx="310" cy="200" r="2" fill="#00E5FF" opacity="0.6"/>
              <circle cx="310" cy="240" r="2" fill="#00E5FF" opacity="0.6"/>
              <circle cx="530" cy="80" r="2" fill="#00E5FF" opacity="0.6"/>
              <circle cx="530" cy="120" r="2" fill="#00E5FF" opacity="0.6"/>
              <circle cx="530" cy="160" r="2" fill="#00E5FF" opacity="0.6"/>
              <!-- Monitor readout -->
              <rect x="45" y="65" width="50" height="30" rx="2" fill="#0D1117"/>
              <text x="70" y="78" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#00E5FF" class="pd-r1">12.4A</text>
              <text x="70" y="88" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#8A9BAE" class="pd-r1">208V</text>
              <text x="70" y="78" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#00E5FF" class="pd-r2">2.4kW</text>
              <text x="70" y="88" text-anchor="middle" font-family="Space Mono,monospace" font-size="6" fill="#8A9BAE" class="pd-r2">CKT-3</text>
              <!-- Badge -->
              <text x="450" y="220" font-family="Space Mono,monospace" font-size="8" fill="#00E5FF">REMOTE MONITORING</text>
              <text x="300" y="300" text-anchor="middle" font-family="Space Mono,monospace" font-size="8" fill="#2A3A4A">// POWER DISTRIBUTION ARCHITECTURE</text>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex gap-1 border-b border-steel/30 mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-voltage border-voltage' : 'text-ash border-transparent hover:text-pure'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-16">
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Modular Design</h3>
            <p class="text-sm text-ash">Configurable power distribution with neutral and ground bus, tiered conduit landing brackets. Supports single and three-phase applications.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Built-in Monitoring</h3>
            <p class="text-sm text-ash">System monitoring panel provides real-time visibility into power distribution, load levels, and system health for proactive maintenance.</p>
          </div>
          <div class="card-glow bg-obsidian rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-voltage/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-voltage" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35"></path></svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-pure mb-2">Permanent & Temporary</h3>
            <p class="text-sm text-ash">Versatile solutions for permanent installations and temporary event setups. Swivel casters and leveling feet for easy deployment.</p>
          </div>
        </div>

        <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-6">// Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-obsidian border border-steel/30 rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-voltage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-pure">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure font-medium mb-1">Custom Configuration</p>
          <p class="text-sm text-ash">Every power distribution unit is built to your specific requirements. Contact our engineering team for custom panel board configurations and load analysis.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-obsidian border border-steel/30 rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-obsidian' : 'bg-slate/30'} ${i < specs.length - 1 ? 'border-b border-steel/20' : ''}`}>
              <span class="text-sm text-ash font-medium">{label}</span>
              <span class="text-sm text-pure font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-obsidian border-l-2 border-voltage rounded-r-xl p-6">
          <p class="text-sm text-pure">Need a custom specification? <a href="/contact" class="text-voltage hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-mono text-xs text-ash mb-6">// All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="power-pac" />
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS -->
  <section class="py-16 md:py-24 bg-obsidian">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-voltage mb-8">// {categoryProducts.length} Models Available</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="card-glow card-top-accent bg-steel/30 rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-bg-elevated flex items-center justify-center p-4">
              <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-6">
            <h3 class="font-display text-lg font-semibold text-pure mb-1 group-hover:text-voltage transition-colors">{p.name}</h3>
            <p class="font-mono text-xs text-voltage mb-3">{p.tagline}</p>
            <p class="text-sm text-ash mb-4 line-clamp-2">{p.description}</p>
            <span class="text-sm font-medium text-voltage">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-16 md:py-24 bg-slate">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-obsidian border border-steel/30 rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-voltage" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-pure text-lg leading-relaxed mb-6 italic">"The Power Pac units have simplified our distribution setup tremendously. The built-in regulation and monitoring give us complete confidence in our power delivery."</p>
        <div class="border-t border-steel/30 pt-4">
          <p class="font-display font-semibold text-pure">Kevin Park</p>
          <p class="text-sm text-ash">Event Production Manager</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-voltage py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-obsidian mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-obsidian text-pure font-semibold rounded-lg hover:bg-slate transition-colors text-sm">Request a Quote</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-obsidian/30 text-obsidian font-semibold rounded-lg hover:bg-obsidian/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-obsidian/95 backdrop-blur border-t border-steel/30 p-3 z-40 lg:hidden" id="mobile-sticky-cta" style="display:none;">
    <a href="/contact" class="btn-primary w-full py-3.5 rounded-lg text-sm font-semibold flex items-center justify-center gap-2">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      Request a Quote
    </a>
  </div>

</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-voltage', 'border-voltage');
        b.classList.add('text-ash', 'border-transparent');
      });
      btn.classList.remove('text-ash', 'border-transparent');
      btn.classList.add('text-voltage', 'border-voltage');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
