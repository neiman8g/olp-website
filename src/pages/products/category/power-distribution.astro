---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import { Image } from 'astro:assets';
import { getProductImage } from '../../../utils/images';
import PowerDistribution from '../../../components/illustrations/PowerDistribution.astro';

const category = getCategoryBySlug('power-distribution')!;
const categoryProducts = getProductsByCategory('power-distribution');

const specs = [
  ['Configurations', 'Rack-mount, floor-standing, wall-mount, custom enclosure'],
  ['Input Voltage', 'Any voltage, custom configured'],
  ['Outlet Types', 'NEMA, IEC, MIL-spec, hospital grade, bus bar, custom'],
  ['Monitoring', 'SNMP v3, Modbus RTU/TCP, BACnet/IP, web interface'],
  ['Measurement Accuracy', 'Plus or minus 1% (ISO/IEC 62053-21 compliant)'],
  ['Communication', 'Ethernet, RS-485, custom protocols'],
  ['Power Range', '15kVA to 450kVA'],
  ['Medical Capability', 'UL 60601-1 for OEM applications'],
  ['Efficiency', 'Greater than 96% at full load'],
  ['Manufacturing', 'Build to order, ISO 9001, Los Angeles CA'],
  ['Certifications', 'UL Listed, NEMA, ISO 9001'],
  ['Warranty', '2 years parts and labor'],
];

const applications = [
  { name: 'Data Centers', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
  { name: 'Broadcast & Events', icon: 'M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 010-7.072m-2.828 9.9a9 9 0 010-12.728' },
  { name: 'Industrial', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { name: 'Construction', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
];
---

<BaseLayout
  title="Power Distribution Units | 15–450kVA | Online Power"
  description="Customizable power distribution solutions for permanent and temporary installations. Modular designs with monitoring. 15–450kVA. UL Listed. Built in Los Angeles."
>

  <!-- BREADCRUMB STRIP -->
  <section class="bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
      <nav class="text-[13px] font-display text-slate">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-steel-blue transition-colors">Products</a>
        <span class="mx-2">/</span>
        <span class="text-near-black font-semibold">Power Distribution</span>
      </nav>
    </div>
  </section>

  <!-- ========== HERO — dark with depth ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute -top-32 -right-32 w-[560px] h-[560px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.3) 0%, rgba(37,103,194,0) 70%); filter: blur(12px);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="badge-dark">UL Listed</span>
            <span class="badge-dark">NEMA</span>
            <span class="badge-dark">Made in USA</span>
          </div>

          <h1 class="font-display text-4xl md:text-5xl lg:text-[56px] font-extrabold tracking-tight text-white leading-[1.05] mb-5">Power Distribution Units</h1>
          <p class="text-lg text-muted-blue leading-relaxed max-w-xl mb-8">
            When off-the-shelf PDUs don't fit your voltage, enclosure, or monitoring requirements, we build to your spec. Custom PDUs integrating voltage regulation, isolation, and branch-circuit monitoring — rack, floor, or wall — with the outlet configs, breakers, and protocols your application demands.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <Button href="/contact" size="lg" icon="arrow-right">Send One-Line Diagram</Button>
          </div>
          <p class="font-display text-[13px] text-muted-blue">Responds within 2 business hours</p>
        </div>

        <div class="hidden lg:block lg:col-span-2">
          <PowerDistribution />
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative border-t border-navy-mid" style="z-index: 2;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-navy-mid">
          {[
            { label: 'Configurations', value: 'Rack · Floor · Wall · Custom' },
            { label: 'Monitoring', value: 'SNMP v3 · Modbus · BACnet' },
            { label: 'Accuracy', value: '±1% power measurement' },
            { label: 'Manufacturing', value: 'Build to order · ISO 9001' },
          ].map(s => (
            <div class="py-6 px-4 md:px-6 text-center md:text-left">
              <p class="font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-blue mb-2">{s.label}</p>
              <p class="font-display text-[15px] md:text-[17px] font-bold text-white leading-tight">{s.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS — models first per emergency-lighting pattern -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-8">{categoryProducts.length} Models Available</p>
      <div class="flex overflow-x-auto snap-x snap-mandatory gap-5 -mx-4 px-4 pb-4 no-scrollbar sm:grid sm:grid-cols-2 lg:grid-cols-3 sm:overflow-visible sm:mx-0 sm:px-0 sm:pb-0">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="snap-start shrink-0 w-[82vw] sm:w-auto sm:shrink card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-off-white flex items-center justify-center p-4">
              {typeof getProductImage(p.image) === 'string' ? (
                <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
              ) : (
                <Image src={getProductImage(p.image) as ImageMetadata} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
              )}
            </div>
            <div class="p-6">
              <h3 class="font-display text-2xl font-semibold text-near-black mb-1 group-hover:text-steel-blue transition-colors">{p.name}</h3>
              <p class="font-display font-semibold text-xs text-steel-blue mb-3">{p.tagline}</p>
              <p class="text-base text-slate mb-4 line-clamp-2">{p.description}</p>
              <span class="text-[15px] font-medium text-steel-blue">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="pt-4 md:pt-6 pb-10 md:pb-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex gap-1 border-b border-steel-gray mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-steel-blue border-steel-blue' : 'text-slate border-transparent hover:text-near-black'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Regulation, isolation, and distribution in one chassis</h3>
            <p class="text-base text-slate">Standard PDUs just distribute power. Online Power integrates voltage regulation, isolation transformers, and power distribution into single units giving you fewer boxes, less complexity, and a single point of accountability for your entire power chain.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Custom outlet configurations for any application</h3>
            <p class="text-base text-slate">NEMA 5-15, NEMA 5-20, NEMA L6-30, IEC C13, IEC C19, bus bars, MIL-spec connectors, and hospital grade receptacles configured exactly as your equipment requires. No adapter cables, no outlet conversion, and no compromises on connection integrity.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Branch circuit monitoring at plus or minus 1 percent accuracy</h3>
            <p class="text-base text-slate">Track voltage, current, power factor, and kWh at the individual circuit level for capacity planning, phase balancing, tenant billing, and PUE reporting. Remote visibility via SNMP, Modbus, or web interface means your facility team sees real-time load data from anywhere.</p>
          </div>
        </div>

        <!-- Technical Callout -->
        <div class="bg-off-white border-l-2 border-steel-blue p-6 mb-10" style="border-radius: 0 12px 12px 0;">
          <p class="eyebrow text-steel-blue mb-3">What your spec sheet won't tell you</p>
          <p class="text-base text-slate leading-relaxed">AI and HPC workloads are pushing data center rack densities to 30 to 60 kilowatts per cabinet, far beyond the 5 to 8 kilowatts that standard rack PDUs support. Floor-standing PDUs feeding multiple racks through sub panels are increasingly necessary but catalog PDU vendors do not offer the custom configurations these high density deployments require. For medical OEM applications, the PDU embedded in an imaging system must meet UL 60601-1 medical grade requirements including leakage current, isolation, and EMC specifications that no standard data center PDU carries. For colocation billing, monitoring grade accuracy of plus or minus 2 to 3 percent is not adequate for tenant billing. You need plus or minus 1 percent or better conforming to ISO/IEC 62053-21. Verify your PDU vendor's measurement accuracy specification because many quote accuracy at full load but degrade significantly at the 20 to 40 percent load points where most circuits actually operate.</p>
        </div>

        <!-- Codes & Standards -->
        <p class="eyebrow text-steel-blue mb-4">Codes &amp; Standards</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-16">
          {[
            { code: 'UL 891', desc: 'Switchboards' },
            { code: 'UL 60601-1', desc: 'Medical Electrical Equipment (OEM PDUs)' },
            { code: 'NEMA PB-2', desc: 'Deadfront Distribution Switchboards' },
            { code: 'TIA-942', desc: 'Data Center Infrastructure Standard' },
            { code: 'NEC Article 645', desc: 'Information Technology Equipment' },
            { code: 'ISO/IEC 62053-21', desc: 'Power Measurement Accuracy' },
          ].map(item => (
            <div class="bg-white border border-steel-gray rounded-lg p-4">
              <p class="font-display font-bold text-steel-blue text-sm">{item.code}</p>
              <p class="text-xs text-slate mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <p class="eyebrow text-steel-blue mb-6">Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-white border border-steel-gray rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-steel-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-near-black">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black font-medium mb-1">Custom Configuration</p>
          <p class="text-base text-slate">Every power distribution unit is built to your specific requirements. Contact our engineering team for custom panel board configurations and load analysis.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-white border border-steel-gray rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-white' : 'bg-off-white'} ${i < specs.length - 1 ? 'border-b border-steel-gray' : ''}`}>
              <span class="text-base text-slate font-medium">{label}</span>
              <span class="text-sm text-near-black font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black">Need a custom specification? <a href="/contact" class="text-steel-blue hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-display text-[13px] text-slate mb-6">All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="power-pac" />
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-white border border-steel-gray rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-steel-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-near-black text-lg leading-relaxed mb-6 italic">"In these uncertain times dealing with COVID-19, the US Government needed to build warehouses to help fight this tragedy. Time was critical so we turned to Online Power to provide 16 emergency lighting inverters. Online Power was able to build and ship all 16 units in 10 days. Great job Online Power."</p>
        <div class="border-t border-steel-gray pt-4">
          <p class="font-display font-semibold text-near-black">Ready Electric Company</p>
          <p class="text-base text-slate">Electrical Contractor, Eckart Supply</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-steel-blue text-white font-semibold rounded hover:bg-steel-blue/90 transition-colors text-sm">Send Us Your One Line Diagram for a Custom PDU Design in 48 Hours</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded hover:bg-white/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-deep-navy/95 backdrop-blur border-t border-steel-gray p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <Button href="/contact" size="lg" icon="bolt" fullWidth>Request a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-steel-blue', 'border-steel-blue');
        b.classList.add('text-slate', 'border-transparent');
      });
      btn.classList.remove('text-slate', 'border-transparent');
      btn.classList.add('text-steel-blue', 'border-steel-blue');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
