---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import DocumentGate from '../../../components/DocumentGate.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../../data/products';
import { company } from '../../../data/company';
import { Image } from 'astro:assets';
import { getProductImage } from '../../../utils/images';
import VoltageRegulators from '../../../components/illustrations/VoltageRegulators.astro';

const category = getCategoryBySlug('voltage-regulators')!;
const categoryProducts = getProductsByCategory('voltage-regulators');

const specs = [
  ['Input Voltage', '120/208/240/480 VAC'],
  ['Output Voltage', 'Regulated (field selectable)'],
  ['Input Tolerance', 'Plus 10% to minus 26%'],
  ['Technology', 'Electronic tap-switching, no moving parts'],
  ['Correction Speed', 'Under 8 milliseconds (sub-cycle)'],
  ['Output Regulation', 'Plus or minus 3% standard, plus or minus 1% available'],
  ['Efficiency', 'Up to 99% at all load levels'],
  ['Output THD', 'Under 1%'],
  ['Cooling', 'Convection cooled, no fans required'],
  ['Maintenance', 'Zero maintenance required'],
  ['Noise Attenuation', 'Up to 152 dB common mode'],
  ['Isolation (ISO-Care)', '4,000 VAC galvanic isolation, new neutral ground bond'],
  ['Power Range', '3kVA to 2,000kVA'],
  ['Transformer', 'Dual shielded isolation'],
  ['Certifications', 'UL Listed, UL 60601-1 (ISO-Care), NFPA, NEMA, ISO 9001'],
  ['Warranty', '2 years parts and labor'],
];

const applications = [
  { name: 'Data Centers', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
  { name: 'Broadcast', icon: 'M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 010-7.072m-2.828 9.9a9 9 0 010-12.728' },
  { name: 'Industrial', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { name: 'Hospitals', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { name: 'Telecom', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z' },
  { name: 'Government', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
  { name: 'Research Labs', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  { name: 'Manufacturing', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
];
---

<BaseLayout
  title="Voltage Regulators and Power Conditioning | 3 to 2,000kVA | Online Power"
  description="Electronic tap-switching voltage regulators from 3kVA to 2,000kVA. Plus or minus 3% regulation, 99% efficiency, sub-cycle correction. ISO-Care isolation transformers. Built in Los Angeles."
>

  <!-- BREADCRUMB STRIP -->
  <section class="bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
      <nav class="text-[13px] font-display text-slate">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-steel-blue transition-colors">Products</a>
        <span class="mx-2">/</span>
        <span class="text-near-black font-semibold">Voltage Regulators</span>
      </nav>
    </div>
  </section>

  <!-- ========== HERO — dark with depth ========== -->
  <section class="relative overflow-hidden bg-deep-navy">
    <div class="absolute inset-0 pointer-events-none opacity-[0.08]" style="background-image: linear-gradient(rgba(126,179,245,.7) 1px, transparent 1px), linear-gradient(90deg, rgba(126,179,245,.7) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute -top-32 -right-32 w-[560px] h-[560px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(37,103,194,0.3) 0%, rgba(37,103,194,0) 70%); filter: blur(12px);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-3">
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="badge-dark">UL Listed</span>
            <span class="badge-dark">ISO 9001</span>
            <span class="badge-dark">Made in USA</span>
          </div>

          <h1 class="font-display text-4xl md:text-5xl lg:text-[56px] font-extrabold tracking-tight text-white leading-[1.05] mb-5">Voltage Regulators &<br/>Power Conditioning</h1>
          <p class="text-lg text-muted-blue leading-relaxed max-w-xl mb-8">
            Voltage sags and power-quality events drive sustained US interruption costs into the tens of billions annually (LBNL 2018). Our electronic tap-switching regulators deliver ±3% regulation at sub-cycle speed and 99% efficiency — faster than mechanical, more efficient than ferroresonant, quieter than both. ISO-Care integrates isolation and regulation in one chassis, exactly as medical imaging OEMs spec.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <Button href="/contact" size="lg" icon="arrow-right">Describe Your Voltage Problem</Button>
          </div>
          <p class="font-display text-[13px] text-muted-blue">Responds within 2 business hours</p>
        </div>

        <div class="hidden lg:block lg:col-span-2">
          <VoltageRegulators />
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative border-t border-navy-mid" style="z-index: 2;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-navy-mid">
          {[
            { label: 'Regulation', value: '±3% (±1% avail.)' },
            { label: 'Efficiency', value: 'Up to 99%' },
            { label: 'THD', value: 'Under 1%' },
            { label: 'Technology', value: 'Tap switching' },
          ].map(s => (
            <div class="py-6 px-4 md:px-6 text-center md:text-left">
              <p class="font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-blue mb-2">{s.label}</p>
              <p class="font-display text-[15px] md:text-[17px] font-bold text-white leading-tight">{s.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCT MODELS — models first per emergency-lighting pattern -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="eyebrow text-steel-blue mb-8">{categoryProducts.length} Models Available</p>
      <div class="flex overflow-x-auto snap-x snap-mandatory gap-5 -mx-4 px-4 pb-4 no-scrollbar sm:grid sm:grid-cols-2 lg:grid-cols-3 sm:overflow-visible sm:mx-0 sm:px-0 sm:pb-0">
        {categoryProducts.map(p => (
          <a href={`/products/${p.slug}`} class="snap-start shrink-0 w-[82vw] sm:w-auto sm:shrink card-hover border-t-2 border-t-steel-blue bg-white rounded-xl overflow-hidden group">
            <div class="h-[200px] bg-off-white flex items-center justify-center p-4">
              {typeof getProductImage(p.image) === 'string' ? (
                <img src={p.image} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" />
              ) : (
                <Image src={getProductImage(p.image) as ImageMetadata} alt={`${p.name} by Online Power`} class="max-h-full w-auto object-contain group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" format="webp" quality={80} widths={[200, 400]} sizes="(max-width: 640px) 100vw, 33vw" />
              )}
            </div>
            <div class="p-6">
              <h3 class="font-display text-2xl font-semibold text-near-black mb-1 group-hover:text-steel-blue transition-colors">{p.name}</h3>
              <p class="font-display font-semibold text-xs text-steel-blue mb-3">{p.tagline}</p>
              <p class="text-base text-slate mb-4 line-clamp-2">{p.description}</p>
              <span class="text-[15px] font-medium text-steel-blue">View Details &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TAB SECTION -->
  <section class="pt-4 md:pt-6 pb-10 md:pb-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex gap-1 border-b border-steel-gray mb-10">
        {['Overview', 'Specifications', 'Documents'].map((tab, i) => (
          <button class={`tab-btn px-5 py-3 text-sm font-medium transition-colors border-b-2 ${i === 0 ? 'text-steel-blue border-steel-blue' : 'text-slate border-transparent hover:text-near-black'}`} data-tab={tab.toLowerCase()}>
            {tab}
          </button>
        ))}
      </div>

      <!-- OVERVIEW TAB -->
      <div class="tab-content" data-tab="overview">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">99 percent efficient because your old ferroresonant wastes 25 percent as heat</h3>
            <p class="text-base text-slate leading-relaxed">Ferroresonant transformers drop to 50 percent efficiency at light loads, generate significant heat requiring additional cooling, and must be oversized 2 to 2.5 times the connected load. Online Power's tap-switching technology maintains 99 percent efficiency at all load levels, runs convection cooled with no fans, and requires zero maintenance with no brushes, no contacts, and no moving parts.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">Sub-cycle correction speed protects what mechanical regulators cannot</h3>
            <p class="text-base text-slate leading-relaxed">Servo motor regulators take seconds to correct voltage deviations, an eternity for a CNC spindle or CT scanner mid scan. Online Power's electronic tap switching corrects in less than 8 milliseconds, keeping voltage within the CBEMA/ITIC safe operating envelope where equipment operates without malfunction.</p>
          </div>
          <div class="card-hover bg-white rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-steel-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-steel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="font-display text-2xl font-semibold text-near-black mb-2">ISO-Care: isolation and regulation in one unit</h3>
            <p class="text-base text-slate leading-relaxed">Medical imaging OEMs like GE Healthcare specify dedicated isolated power separated from elevators and HVAC. The ISO-Care delivers galvanic isolation with a new neutral ground bond, voltage regulation, noise attenuation, and transient suppression in a single integrated chassis, replacing two separate boxes with one engineered solution.</p>
          </div>
        </div>

        <!-- Technical Callout -->
        <div class="bg-off-white border-l-2 border-steel-blue p-6 mb-10" style="border-radius: 0 12px 12px 0;">
          <p class="eyebrow text-steel-blue mb-3">What your spec sheet won't tell you</p>
          <p class="text-base text-slate leading-relaxed">The CBEMA/ITIC curve shows that standard IT equipment tolerates steady state voltage within plus or minus 10 percent. But medical imaging equipment, semiconductor tools, and precision instruments often require plus or minus 1 to 3 percent. A 5 percent sag lasting 10 cycles can cause MRI image artifacts, CNC position errors, or semiconductor wafer scrap worth hundreds of thousands of dollars. When evaluating voltage regulators, demand the efficiency curve at 25 percent, 50 percent, 75 percent, and 100 percent load. Ferroresonant units that claim 95 percent efficiency at full load can drop to 50 percent at light loads, which is where most regulated systems operate 80 percent of the time. Online Power's tap-switching regulators are not affected by load power factor, a critical distinction because ferroresonant transformers distort their output under reactive or nonlinear loads. For three phase applications, insist on independent phase regulation. A single regulator on a three phase system cannot correct phase specific voltage issues caused by unbalanced loads.</p>
        </div>

        <!-- Codes & Standards -->
        <p class="eyebrow text-steel-blue mb-4">Codes &amp; Standards</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-16">
          {[
            { code: 'CBEMA/ITIC Curve', desc: 'Voltage Tolerance Envelope' },
            { code: 'SEMI F47', desc: 'Semiconductor Equipment Voltage Sag Immunity' },
            { code: 'UL 1950', desc: 'Information Technology Equipment Safety' },
            { code: 'UL 60601-1', desc: 'Medical Electrical Equipment (ISO-Care)' },
            { code: 'IEEE 1159', desc: 'Power Quality Monitoring' },
            { code: 'NFPA 70', desc: 'National Electrical Code' },
          ].map(item => (
            <div class="bg-white border border-steel-gray rounded-lg p-4">
              <p class="font-display font-bold text-steel-blue text-sm">{item.code}</p>
              <p class="text-xs text-slate mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <p class="eyebrow text-steel-blue mb-6">Where It Gets Specified</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-16">
          {applications.map(app => (
            <div class="bg-white border border-steel-gray rounded-lg p-4 flex items-center gap-3">
              <svg class="w-5 h-5 text-steel-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.icon}></path></svg>
              <span class="text-sm text-near-black">{app.name}</span>
            </div>
          ))}
        </div>

        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black font-medium mb-1">Complete Product Line</p>
          <p class="text-base text-slate">Includes Power Reg voltage regulators, Constant Power isolation systems, and ISO-Care isolation transformers. Contact our engineering team for application specific recommendations.</p>
        </div>
      </div>

      <!-- SPECIFICATIONS TAB -->
      <div class="tab-content hidden" data-tab="specifications">
        <div class="bg-white border border-steel-gray rounded-xl overflow-hidden mb-8">
          {specs.map(([label, value], i) => (
            <div class={`flex items-center justify-between px-6 py-4 ${i % 2 === 0 ? 'bg-white' : 'bg-off-white'} ${i < specs.length - 1 ? 'border-b border-steel-gray' : ''}`}>
              <span class="text-base text-slate font-medium">{label}</span>
              <span class="text-sm text-near-black font-medium text-right">{value}</span>
            </div>
          ))}
        </div>
        <div class="bg-off-white border-l-2 border-steel-blue rounded-r-xl p-6">
          <p class="text-sm text-near-black">Need a custom specification? <a href="/contact" class="text-steel-blue hover:underline">Our engineering team will work with you &rarr;</a></p>
        </div>
      </div>

      <!-- DOCUMENTS TAB -->
      <div class="tab-content hidden" data-tab="documents">
        <p class="font-display text-[13px] text-slate mb-6">All documents available for immediate download after a quick registration.</p>
        <DocumentGate productSlug="power-reg" />
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-white border border-steel-gray rounded-2xl p-8 md:p-10">
        <div class="flex gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-steel-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          ))}
        </div>
        <p class="text-near-black text-lg leading-relaxed mb-6 italic">"When we needed clarification on sizing of breakers inside their inverters, Online Power's expert engineering department was extremely helpful in clarifying the exact need for our application. Thank you Online Power."</p>
        <div class="border-t border-steel-gray pt-4">
          <p class="font-display font-semibold text-near-black">Alex Feizbakhsh</p>
          <p class="text-base text-slate">PE · RCI Builders</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Ready to Spec This Product?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-steel-blue text-white font-semibold rounded hover:bg-steel-blue/90 transition-colors text-sm">Describe Your Voltage Problem for a Power Quality Analysis</a>
        <a href="/training" class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded hover:bg-white/10 transition-colors text-sm">Register for Training</a>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY CTA -->
  <div class="fixed bottom-0 left-0 right-0 bg-deep-navy/95 backdrop-blur border-t border-steel-gray p-3 z-40 lg:hidden" style="padding-bottom:max(12px, env(safe-area-inset-bottom));" id="mobile-sticky-cta" style="display:none;">
    <Button href="/contact" size="lg" icon="bolt" fullWidth>Request a Quote</Button>
  </div>

</BaseLayout>

<script is:inline>
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('text-steel-blue', 'border-steel-blue');
        b.classList.add('text-slate', 'border-transparent');
      });
      btn.classList.remove('text-slate', 'border-transparent');
      btn.classList.add('text-steel-blue', 'border-steel-blue');
      document.querySelectorAll('.tab-content').forEach(function(c) {
        c.classList.add('hidden');
      });
      document.querySelector('.tab-content[data-tab="' + tab + '"]').classList.remove('hidden');
    });
  });

  var stickyCta = document.getElementById('mobile-sticky-cta');
  if (stickyCta && window.innerWidth < 1024) {
    window.addEventListener('scroll', function() {
      stickyCta.style.display = window.scrollY > 400 ? '' : 'none';
    });
  }
</script>
