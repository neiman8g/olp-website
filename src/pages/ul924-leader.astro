---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
---

<BaseLayout
  title="The Industry Standard in UL 924 Lighting Inverters | Online Power"
  description="Online Power manufactures the widest range of UL 924 listed emergency lighting inverters — 35W to 400kW. Zero transfer time, pure sine wave, OSHPD/HCAI seismic. Built in Los Angeles since 1975."
>

  <section class="py-10 md:py-14 bg-off-white border-b border-steel-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="eyebrow text-slate mb-6">
        <a href="/" class="hover:text-steel-blue transition-colors">Home</a>
        <span class="mx-2 text-steel-gray">/</span>
        <a href="/products/" class="hover:text-steel-blue transition-colors">Products</a>
        <span class="mx-2 text-steel-gray">/</span>
        <span class="text-steel-blue">Why Online Power for UL 924</span>
      </nav>
      <h1 class="font-display text-4xl md:text-[40px] font-bold text-near-black mb-4">The Industry Standard in UL 924 Lighting Inverters</h1>
      <p class="text-base text-slate max-w-3xl leading-relaxed">Online Power manufactures the widest range of UL 924 listed emergency lighting inverters from a single manufacturer — 35W to 400kW. Built to order in Los Angeles since 1975 with zero transfer time, pure sine wave output, and OSHPD/HCAI seismic certification for California's most demanding projects.</p>
    </div>
  </section>

  <section class="py-10 md:py-14 bg-deep-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 lg:divide-x lg:divide-navy-mid">
        <div class="lg:px-8 first:lg:pl-0 last:lg:pr-0 text-center lg:text-left">
          <p class="font-display text-[13px] uppercase tracking-[0.1em] text-steel-blue font-semibold mb-2">Range</p>
          <p class="font-display text-3xl md:text-4xl font-bold text-white">35W–400kW</p>
        </div>
        <div class="lg:px-8 first:lg:pl-0 last:lg:pr-0 text-center lg:text-left">
          <p class="font-display text-[13px] uppercase tracking-[0.1em] text-steel-blue font-semibold mb-2">Founded</p>
          <p class="font-display text-3xl md:text-4xl font-bold text-white">Since 1975</p>
        </div>
        <div class="lg:px-8 first:lg:pl-0 last:lg:pr-0 text-center lg:text-left">
          <p class="font-display text-[13px] uppercase tracking-[0.1em] text-steel-blue font-semibold mb-2">Certified</p>
          <p class="font-display text-3xl md:text-4xl font-bold text-white">UL 924</p>
        </div>
        <div class="lg:px-8 first:lg:pl-0 last:lg:pr-0 text-center lg:text-left">
          <p class="font-display text-[13px] uppercase tracking-[0.1em] text-steel-blue font-semibold mb-2">Seismic</p>
          <p class="font-display text-3xl md:text-4xl font-bold text-white">OSHPD / HCAI</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-10 md:py-14 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-3 gap-5">
        <Card variant="feature">
          <h3 class="font-display text-2xl font-semibold text-near-black mb-3">Widest Range Available</h3>
          <p class="text-base text-slate leading-relaxed">From small 35W systems to large-scale 400kW installations, no other single manufacturer covers this range under one UL 924 listing.</p>
        </Card>
        <Card variant="feature">
          <h3 class="font-display text-2xl font-semibold text-near-black mb-3">Zero Transfer Time</h3>
          <p class="text-base text-slate leading-relaxed">Online UPS topology means the inverter is always on line. No transfer switching. No flicker. Full illumination maintained for the entire 90-minute code-required duration.</p>
        </Card>
        <Card variant="feature">
          <h3 class="font-display text-2xl font-semibold text-near-black mb-3">Built for California</h3>
          <p class="text-base text-slate leading-relaxed">OSHPD and HCAI seismic certification for hospital and healthcare projects. The most demanding compliance requirements in the country, met as standard.</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="bg-deep-navy py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-white mb-6">Ready to Specify UL 924?</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/products/category/emergency-lighting" size="lg">View Emergency Lighting Inverters</Button>
        <Button href="/contact/" variant="ghost" size="lg">Request a Quote</Button>
      </div>
    </div>
  </section>

</BaseLayout>
